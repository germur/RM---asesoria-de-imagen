---
import MainLayout from "@/layouts/MainLayout.astro";
import {
    CheckCircle2,
    XCircle,
    BookOpen,
    ChevronDown,
    Award,
    Users,
    Clock,
    Shield,
    Star,
} from "lucide-react";
import HotmartButton from "@/components/HotmartButton.astro";

const { frontmatter } = Astro.props;
const {
    title,
    subtitle,
    price,
    originalPrice,
    description,
    promise,
    modules,
    benefits,
    forWho,
    notForWho,
    image,
    buyLink,
    instructor,
    instructorBio,
    instructorCredentials,
    testimonial,
    faq,
    tag,
    studentCount,
} = frontmatter;

const courseSchema = {
    "@context": "https://schema.org",
    "@type": "Course",
    name: title,
    description: description,
    provider: {
        "@type": "Organization",
        name: "Roger Murillo Academy",
        sameAs: "https://rogermurillo.co",
    },
    offers: {
        "@type": "Offer",
        price: price.replace(/[^0-9]/g, ""),
        priceCurrency: "USD",
        url: buyLink || "#",
        availability: "https://schema.org/InStock",
    },
    hasCourseInstance: {
        "@type": "CourseInstance",
        courseMode: "Online",
        instructor: {
            "@type": "Person",
            name: instructor,
        },
    },
};
---

<MainLayout
    title={`${title} | Roger Murillo Academy`}
    description={description}
    schema={JSON.stringify(courseSchema)}
>
    <!-- STICKY CTA MÓVIL -->
    <div class="fixed bottom-0 left-0 w-full bg-white border-t border-neutral-200 p-4 z-50 md:hidden flex justify-between items-center shadow-[0_-5px_20px_rgba(0,0,0,0.12)]">
        <div>
            <span class="text-xs text-neutral-400 block uppercase tracking-widest">Precio total</span>
            <span class="font-bold text-brand-black text-xl">{price}</span>
        </div>
        <a
            href={`${buyLink}?src=mobile_sticky`}
            target="_blank"
            rel="noopener"
            class="bg-brand-primary text-white px-6 py-3 font-bold uppercase text-xs tracking-widest rounded-sm"
        >
            Inscribirme Ahora
        </a>
    </div>

    <!-- 1. HERO — full-bleed editorial -->
    <section class="relative min-h-[90vh] flex flex-col justify-end bg-brand-black text-white overflow-hidden">
        <!-- Background: course image -->
        <div class="absolute inset-0">
            <img
                src={image}
                alt={title}
                class="w-full h-full object-cover object-center"
            />
            <!-- Gradient overlays for text readability -->
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/70 to-black/10"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/30 to-transparent"></div>
        </div>

        <!-- Content anchored to bottom-left -->
        <div class="container mx-auto px-6 max-w-6xl relative z-10 pb-16 pt-48 md:pb-24">
            <div class="max-w-2xl">
                <!-- Badge + students -->
                <div class="flex flex-wrap items-center gap-3 mb-6">
                    <span class="inline-block py-1 px-3 border border-brand-primary/50 text-brand-primary text-xs font-bold uppercase tracking-[0.3em] bg-brand-primary/10">
                        {tag || "Curso Online"}
                    </span>
                    {studentCount && (
                        <span class="text-neutral-400 text-xs flex items-center gap-1.5">
                            <Users className="w-3 h-3" /> {studentCount} estudiantes
                        </span>
                    )}
                </div>

                <!-- Title -->
                <h1 class="font-serif text-6xl md:text-8xl text-white mb-4 leading-none">{title}</h1>

                <!-- Subtitle -->
                <p class="text-lg md:text-xl text-neutral-300 font-light mb-5 leading-relaxed">{subtitle}</p>

                <!-- Promise -->
                {promise && (
                    <p class="text-sm text-brand-primary border-l-2 border-brand-primary pl-4 mb-10 italic">
                        "{promise}"
                    </p>
                )}

                <!-- Price + CTA — always visible -->
                <div class="flex flex-wrap items-center gap-6">
                    <div class="flex items-baseline gap-3">
                        <span class="text-3xl font-serif text-white">{price}</span>
                        {originalPrice && (
                            <span class="text-sm text-neutral-500 line-through">{originalPrice}</span>
                        )}
                    </div>
                    <div class="flex flex-col gap-2">
                        <HotmartButton link={buyLink} label="Inscribirme Ahora" />
                        <p class="text-xs text-neutral-400 flex items-center gap-1">
                            <Shield className="w-3 h-3" /> Acceso inmediato · Pago seguro
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 2. PROMESA / TRANSFORMACIÓN -->
    <section class="py-20 bg-white border-b border-neutral-100">
        <div class="container mx-auto px-6 max-w-4xl text-center">
            <p class="text-xs font-bold uppercase tracking-[0.3em] text-brand-primary mb-4">Lo que vas a lograr</p>
            <h2 class="font-serif text-3xl md:text-4xl text-brand-black mb-8 leading-snug">
                {description}
            </h2>
            <div class="grid md:grid-cols-3 gap-6 mt-12">
                {benefits.map((benefit: { icon: string; title: string; text: string }) => (
                    <div class="p-6 bg-brand-gray rounded-sm text-left group hover:bg-brand-black hover:text-white transition-all duration-300">
                        <div class="text-2xl mb-3">{benefit.icon}</div>
                        <h3 class="font-bold text-sm uppercase tracking-wider mb-2 group-hover:text-brand-primary transition-colors">{benefit.title}</h3>
                        <p class="text-neutral-500 text-sm leading-relaxed group-hover:text-neutral-300 transition-colors">{benefit.text}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- 3. PARA QUIÉN ES / NO ES -->
    <section class="py-20 bg-brand-gray">
        <div class="container mx-auto px-6 max-w-5xl">
            <div class="grid md:grid-cols-2 gap-12">
                <!-- Para quién SÍ -->
                <div>
                    <p class="text-xs font-bold uppercase tracking-[0.3em] text-brand-primary mb-4">Este curso es para ti si...</p>
                    <ul class="space-y-4">
                        {forWho?.map((item: string) => (
                            <li class="flex items-start gap-3">
                                <CheckCircle2 className="w-5 h-5 text-brand-primary shrink-0 mt-0.5" />
                                <p class="text-neutral-700 text-sm leading-relaxed">{item}</p>
                            </li>
                        ))}
                    </ul>
                </div>
                <!-- Para quién NO -->
                <div>
                    <p class="text-xs font-bold uppercase tracking-[0.3em] text-neutral-400 mb-4">No es para ti si...</p>
                    <ul class="space-y-4">
                        {notForWho?.map((item: string) => (
                            <li class="flex items-start gap-3">
                                <XCircle className="w-5 h-5 text-neutral-300 shrink-0 mt-0.5" />
                                <p class="text-neutral-400 text-sm leading-relaxed">{item}</p>
                            </li>
                        ))}
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- 4. MÓDULOS DEL CURSO -->
    <section class="py-20 bg-white">
        <div class="container mx-auto px-6 max-w-4xl">
            <div class="flex flex-col lg:flex-row gap-16">
                <!-- Módulos -->
                <div class="w-full lg:w-2/3">
                    <p class="text-xs font-bold uppercase tracking-[0.3em] text-brand-primary mb-2">Programa completo</p>
                    <h2 class="font-serif text-3xl text-brand-black mb-10">Qué aprenderás módulo a módulo</h2>
                    <div class="space-y-3">
                        {modules.map((mod: { title: string; lessons: string[] }, index: number) => (
                            <details class="group bg-brand-gray rounded-sm overflow-hidden border border-transparent hover:border-neutral-200 transition-all">
                                <summary class="flex items-center gap-4 p-5 cursor-pointer list-none select-none">
                                    <span class="text-brand-primary font-serif text-lg font-bold opacity-60 shrink-0 w-8">
                                        {String(index + 1).padStart(2, '0')}
                                    </span>
                                    <span class="font-bold text-brand-black text-sm flex-1">{mod.title}</span>
                                    <ChevronDown className="w-4 h-4 text-neutral-400 group-open:rotate-180 transition-transform shrink-0" />
                                </summary>
                                <div class="px-5 pb-5 pt-0 ml-12">
                                    <ul class="space-y-2">
                                        {mod.lessons.map((lesson: string) => (
                                            <li class="flex items-start gap-2 text-sm text-neutral-500">
                                                <BookOpen className="w-3.5 h-3.5 text-neutral-300 shrink-0 mt-0.5" />
                                                {lesson}
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                            </details>
                        ))}
                    </div>
                </div>

                <!-- Sidebar de compra sticky -->
                <div class="w-full lg:w-1/3">
                    <div class="sticky top-28 bg-brand-black text-white p-8 rounded-sm shadow-2xl">
                        <p class="text-xs font-bold uppercase tracking-widest text-brand-primary mb-4">Tu inscripción incluye</p>
                        <ul class="space-y-3 mb-8 text-sm text-gray-300">
                            <li class="flex items-center gap-2"><CheckCircle2 className="w-4 h-4 text-brand-primary shrink-0" /> Acceso de por vida al contenido</li>
                            <li class="flex items-center gap-2"><CheckCircle2 className="w-4 h-4 text-brand-primary shrink-0" /> Material descargable por módulo</li>
                            <li class="flex items-center gap-2"><CheckCircle2 className="w-4 h-4 text-brand-primary shrink-0" /> Certificado de finalización</li>
                            <li class="flex items-center gap-2"><CheckCircle2 className="w-4 h-4 text-brand-primary shrink-0" /> Acceso inmediato tras la compra</li>
                            <li class="flex items-center gap-2"><CheckCircle2 className="w-4 h-4 text-brand-primary shrink-0" /> Actualizaciones futuras incluidas</li>
                        </ul>
                        <div class="text-center mb-6 border-t border-white/10 pt-6">
                            <div class="flex items-baseline justify-center gap-2 mb-1">
                                <span class="text-3xl font-serif text-white">{price}</span>
                                {originalPrice && (
                                    <span class="text-xs text-neutral-500 line-through">{originalPrice}</span>
                                )}
                            </div>
                            <p class="text-xs text-neutral-300">Pago único · Sin suscripción</p>
                        </div>
                        <HotmartButton link={buyLink} label="Inscribirme Ahora" />
                        <p class="text-xs text-neutral-300 text-center mt-4 flex items-center justify-center gap-1">
                            <Shield className="w-3 h-3" /> Compra segura vía Hotmart
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 5. INSTRUCTOR -->
    <section class="py-20 bg-brand-black text-white">
        <div class="container mx-auto px-6 max-w-4xl">
            <div class="flex flex-col md:flex-row gap-12 items-center">
                <div class="w-full md:w-1/3 shrink-0">
                    <img
                        src={instructor?.includes("Adriana") ? "/images/adriana-portrait-bw.jpg" : "/images/roger-portrait-bw.jpg"}
                        alt={instructor}
                        class="w-full aspect-square object-cover object-top rounded-sm grayscale contrast-110"
                    />
                </div>
                <div class="w-full md:w-2/3">
                    <p class="text-xs font-bold uppercase tracking-[0.3em] text-brand-primary mb-3">Tu instructor</p>
                    <h2 class="font-serif text-3xl mb-2">{instructor}</h2>
                    <div class="flex flex-wrap gap-2 mb-6">
                        {instructorCredentials?.map((cred: string) => (
                            <span class="text-xs border border-white/20 text-neutral-300 px-3 py-1 rounded-sm flex items-center gap-1">
                                <Award className="w-3 h-3 text-brand-primary" /> {cred}
                            </span>
                        ))}
                    </div>
                    {instructorBio?.map((paragraph: string) => (
                        <p class="text-neutral-300 text-sm leading-relaxed mb-4 font-light">{paragraph}</p>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- 6. TESTIMONIO -->
    {testimonial && (
        <section class="py-20 bg-brand-gray">
            <div class="container mx-auto px-6 max-w-3xl text-center">
                <div class="flex justify-center gap-1 mb-6">
                    {[1,2,3,4,5].map(() => (
                        <Star className="w-5 h-5 fill-brand-primary text-brand-primary" />
                    ))}
                </div>
                <blockquote class="font-serif text-2xl md:text-3xl text-brand-black leading-relaxed mb-8 italic">
                    "{testimonial.quote}"
                </blockquote>
                <div class="flex items-center justify-center gap-3">
                    <div class="w-10 h-10 bg-brand-primary/20 rounded-full flex items-center justify-center text-brand-primary font-bold text-sm">
                        {testimonial.name.charAt(0)}
                    </div>
                    <div class="text-left">
                        <p class="font-bold text-brand-black text-sm">{testimonial.name}</p>
                        <p class="text-neutral-400 text-xs">{testimonial.role}</p>
                    </div>
                </div>
            </div>
        </section>
    )}

    <!-- 7. FAQ -->
    {faq && faq.length > 0 && (
        <section class="py-20 bg-white">
            <div class="container mx-auto px-6 max-w-3xl">
                <p class="text-xs font-bold uppercase tracking-[0.3em] text-brand-primary mb-2 text-center">Preguntas frecuentes</p>
                <h2 class="font-serif text-3xl text-brand-black mb-10 text-center">Resolvemos tus dudas</h2>
                <div class="space-y-3">
                    {faq.map((item: { q: string; a: string }) => (
                        <details class="group border-b border-neutral-100 pb-3">
                            <summary class="flex justify-between items-start gap-4 cursor-pointer list-none py-3 select-none">
                                <span class="font-bold text-brand-black text-sm leading-relaxed">{item.q}</span>
                                <ChevronDown className="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform shrink-0 mt-0.5" />
                            </summary>
                            <p class="text-neutral-500 text-sm leading-relaxed pb-3 font-light">{item.a}</p>
                        </details>
                    ))}
                </div>
            </div>
        </section>
    )}

    <!-- 8. CTA FINAL -->
    <section class="py-24 bg-brand-black text-white text-center">
        <div class="container mx-auto px-6 max-w-2xl">
            <p class="text-xs font-bold uppercase tracking-[0.3em] text-brand-primary mb-4">Empieza hoy</p>
            <h2 class="font-serif text-4xl md:text-5xl mb-6 leading-tight">
                Tu imagen es tu activo más poderoso.
            </h2>
            <p class="text-neutral-300 font-light mb-10 text-lg">
                Las oportunidades no esperan. Cada día que proyectas la imagen equivocada es un costo invisible que pagas sin darte cuenta.
            </p>
            <div class="flex flex-col items-center gap-4 max-w-xs mx-auto">
                <div class="flex items-baseline gap-2 mb-2">
                    <span class="text-3xl font-serif">{price}</span>
                    {originalPrice && (
                        <span class="text-sm text-neutral-500 line-through">{originalPrice}</span>
                    )}
                </div>
                <HotmartButton link={buyLink} label="Quiero Transformar mi Imagen" />
                <p class="text-xs text-neutral-300 flex items-center gap-1">
                    <Clock className="w-3 h-3" /> Acceso inmediato · Pago único
                </p>
            </div>
        </div>
    </section>
</MainLayout>
