---

<header
    class="sticky top-0 z-50 w-full border-b border-white/10 bg-luxury-black/80 backdrop-blur-md"
>
    <div
        class="container mx-auto flex h-16 items-center justify-between px-4 sm:px-8"
    >
        <a
            href="/"
            class="text-2xl font-serif font-bold text-luxury-gold tracking-wide"
        >
            Roger Murillo
        </a>

        <nav class="hidden md:flex items-center gap-8">
            <a
                href="/servicios"
                class="text-sm font-medium text-luxury-sand/80 hover:text-luxury-gold transition-colors"
            >
                Servicios
            </a>
            <a
                href="/herramientas"
                class="text-sm font-medium text-luxury-sand/80 hover:text-luxury-gold transition-colors"
            >
                Herramientas
            </a>
            <a
                href="/blog"
                class="text-sm font-medium text-luxury-sand/80 hover:text-luxury-gold transition-colors"
            >
                Blog
            </a>
            <a
                href="/contacto"
                class="px-4 py-2 bg-luxury-gold text-luxury-black font-semibold text-sm rounded-sm hover:bg-white transition-colors"
            >
                Agendar
            </a>
        </nav>

        <!-- Mobile Menu Button (Placeholder) -->
        <button class="md:hidden text-luxury-gold">
            <span class="sr-only">Menu</span>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><line x1="4" x2="20" y1="12" y2="12"></line><line
                    x1="4"
                    x2="20"
                    y1="6"
                    y2="6"></line><line x1="4" x2="20" y1="18" y2="18"
                ></line></svg
            >
        </button>
    </div>
</header>
