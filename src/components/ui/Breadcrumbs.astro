---
import { CaretRight, House } from "@phosphor-icons/react";

const { pathname } = Astro.url;
const segments = pathname.split("/").filter(Boolean);

// Mapa de nombres legibles para rutas
const routeNames: Record<string, string> = {
    herramientas: "Diagnóstico",
    servicios: "Servicios",
    academia: "Academia",
    contacto: "Contacto",
    libro: "Libro",
    "test-colorimetria": "Test de Color",
};

// No mostrar breadcrumbs en home (la raíz no lleva breadcrumb)
if (pathname === "/") return null;

const { theme = 'dark' } = Astro.props;
const isDark = theme === 'dark';

const textClass = isDark ? "text-gray-300" : "text-gray-500";
const hoverClass = isDark ? "hover:text-white" : "hover:text-brand-primary";
const activeClass = isDark ? "text-white" : "text-brand-primary";
---

<nav aria-label="Breadcrumb" class="absolute top-20 left-0 w-full z-40">
    <div class="container mx-auto px-6 py-4">
    <ol
        class={`flex items-center space-x-2 text-xs uppercase tracking-widest font-medium ${textClass}`}
    >
        <li>
            <a
                href="/"
                class={`${hoverClass} transition-colors flex items-center gap-1`}
            >
                <House weight="bold" size={14} />
                <span class="sr-only">Inicio</span>
            </a>
        </li>

        {
            segments.map((segment, index) => {
                const isLast = index === segments.length - 1;
                const href = `/${segments.slice(0, index + 1).join("/")}`;
                const name = routeNames[segment] || segment.replace(/-/g, " ");

                return (
                    <>
                        <li class="opacity-50">
                            <CaretRight size={12} weight="bold" />
                        </li>
                        <li>
                            {isLast ? (
                                <span
                                    class={`${activeClass} font-bold`}
                                    aria-current="page"
                                >
                                    {name}
                                </span>
                            ) : (
                                <a
                                    href={href}
                                    class={`${hoverClass} transition-colors`}
                                >
                                    {name}
                                </a>
                            )}
                        </li>
                    </>
                );
            })
        }
    </ol>
    </div>
</nav>
