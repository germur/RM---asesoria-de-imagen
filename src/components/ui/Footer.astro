---
const servicios = [
    { n: "01", label: "Consultoría Integral",  href: "/servicios/asesoria-integral-imagen",   tag: "Flagship" },
    { n: "02", label: "Color & Salud Capilar", href: "/servicios/color-salud-capilar",        tag: "Técnico" },
    { n: "03", label: "Visagismo & Corte",     href: "/servicios/visagismo-corte",            tag: "Arquitectura" },
    { n: "04", label: "Peluquería de Autor",   href: "/servicios/peluqueria",                 tag: "★ Estrella", star: true },
    { n: "05", label: "Imagen Ejecutiva",      href: "/servicios/imagen-ejecutiva-autoridad", tag: "C-Suite" },
];
---

<footer class="bg-[#0a0a0a] text-white relative overflow-hidden">

    <!-- Marquee superior -->
    <div class="border-y border-white/10 py-5 overflow-hidden">
        <div class="marquee-track text-[10px] tracking-[0.4em] uppercase text-white/40">
            <span class="flex items-center gap-16">
                <span>A puerta cerrada</span><span class="text-brand-primary">&bull;</span>
                <span>Bogotá · Colina Campestre</span><span class="text-brand-primary">&bull;</span>
                <span>Consultoría privada 1 a 1</span><span class="text-brand-primary">&bull;</span>
                <span>Máx. 4 cupos / mes</span><span class="text-brand-primary">&bull;</span>
                <span>Desde 2009</span><span class="text-brand-primary">&bull;</span>
            </span>
            <span class="flex items-center gap-16" aria-hidden="true">
                <span>A puerta cerrada</span><span class="text-brand-primary">&bull;</span>
                <span>Bogotá · Colina Campestre</span><span class="text-brand-primary">&bull;</span>
                <span>Consultoría privada 1 a 1</span><span class="text-brand-primary">&bull;</span>
                <span>Máx. 4 cupos / mes</span><span class="text-brand-primary">&bull;</span>
                <span>Desde 2009</span><span class="text-brand-primary">&bull;</span>
            </span>
        </div>
    </div>

    <div class="container mx-auto px-6 max-w-[1400px]">

        <!-- Editorial block -->
        <div class="pt-24 md:pt-32 pb-20 grid md:grid-cols-12 gap-12 md:gap-16 items-end border-b border-white/10">
            <div class="md:col-span-8">
                <p class="text-[10px] tracking-[0.42em] uppercase text-neutral-500 mb-10">
                    Roger Murillo · Adriana Garzón · Bogotá
                </p>
                <h2 class="giant-word text-[20vw] md:text-[13vw] lg:text-[10.5rem] text-white">
                    Imagen<br/>
                    <span class="text-neutral-600">que</span> <span class="italic">comunica</span><br/>
                    <span class="text-brand-primary">poder.</span>
                </h2>
            </div>
            <div class="md:col-span-4 md:pb-6">
                <p class="text-sm text-neutral-500 font-light leading-relaxed mb-8 max-w-xs">
                    Consultoría privada 1 a 1. Agenda limitada — máximo 4 cupos al mes.
                </p>
                <a href="/contacto"
                   class="inline-flex items-center gap-3 bg-brand-primary text-white px-9 py-4 text-[11px] tracking-[0.22em] uppercase hover:bg-white hover:text-[#0a0a0a] transition-colors duration-500">
                    Reservar consulta
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                        <path d="M5 12h14M13 6l6 6-6 6"/>
                    </svg>
                </a>
            </div>
        </div>

        <!-- Servicios + Ficha -->
        <div class="grid md:grid-cols-12 gap-16 py-20 border-b border-white/10">

            <!-- Lista editorial de servicios -->
            <div class="md:col-span-7">
                <div class="flex items-baseline justify-between mb-8">
                    <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-500">Servicios</p>
                    <a href="/servicios" class="text-[10px] tracking-[0.3em] uppercase text-neutral-500 hover:text-white transition-colors">
                        Ver todos →
                    </a>
                </div>
                <div>
                    {servicios.map((s) => (
                        <a href={s.href} class="footer-service">
                            <span class="flex items-baseline gap-5">
                                <span class="font-serif italic text-xs text-neutral-600">{s.n}</span>
                                <span class="font-serif text-2xl md:text-3xl text-white">{s.label}</span>
                            </span>
                            <span class={`text-[10px] tracking-[0.3em] uppercase ${s.star ? "text-brand-primary" : "text-neutral-500"}`}>
                                {s.tag}
                            </span>
                        </a>
                    ))}
                </div>
            </div>

            <!-- Ficha estudio -->
            <div class="md:col-span-5 grid grid-cols-2 gap-y-10 gap-x-8 content-start md:pt-8">
                <div class="col-span-2">
                    <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-500 mb-4">Ubicación</p>
                    <p class="font-serif text-xl leading-snug text-white">Cra. 62 #161-15</p>
                    <p class="text-sm text-neutral-500 mt-1">Colina Campestre · Bogotá</p>
                    <a href="https://maps.google.com/?q=Cra+62+161-15+Bogota"
                       target="_blank" rel="noopener"
                       class="inline-flex items-center gap-2 mt-4 text-[10px] tracking-[0.3em] uppercase text-neutral-400 hover:text-white transition-colors">
                        Abrir en Maps →
                    </a>
                </div>
                <div>
                    <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-500 mb-3">Horario</p>
                    <p class="text-sm text-neutral-300 leading-relaxed">
                        Lun — Sáb<br/><span class="text-white">09:00 — 19:00</span>
                    </p>
                    <p class="text-sm text-neutral-600 mt-1">Dom / fest: cerrado</p>
                </div>
                <div>
                    <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-500 mb-3">Contacto</p>
                    <a href="https://wa.me/573214189010" class="footer-link !text-neutral-300 hover:!text-white">+57 321 418 9010</a>
                    <a href="mailto:contacto@rogermurillo.co" class="footer-link block mt-1">contacto@rogermurillo.co</a>
                </div>
                <div class="col-span-2 pt-6 border-t border-white/10">
                    <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-500 mb-4">Academia &amp; Tools</p>
                    <div class="grid grid-cols-2 gap-x-6">
                        <a href="/academia"                              class="footer-link">Cursos</a>
                        <a href="/libro"                                 class="footer-link">Libro oficial</a>
                        <a href="/herramientas/test-colorimetria-online" class="footer-link">Test Colorimetría</a>
                        <a href="/herramientas/calculadora-rostro"       class="footer-link">Calculadora rostro</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom bar -->
        <div class="py-8 flex flex-col md:flex-row items-center justify-between gap-4">
            <span class="text-[10px] tracking-[0.3em] uppercase text-neutral-600">
                &copy; {new Date().getFullYear()} Roger Murillo &amp; Adriana Garzón · Bogotá
            </span>
            <div class="flex items-center gap-4 text-[10px] tracking-[0.3em] uppercase text-neutral-500">
                <a href="/legales/privacidad" class="hover:text-white transition-colors">Privacidad</a>
                <span class="text-neutral-700">/</span>
                <a href="/legales/terminos"   class="hover:text-white transition-colors">Términos</a>
                <span class="text-neutral-700">/</span>
                <a href="/sitemap-index.xml"  class="hover:text-white transition-colors">Sitemap</a>
            </div>
            <a href="https://www.instagram.com/rogermurilloai/" target="_blank" rel="noopener"
               class="inline-flex items-center gap-2.5 group">
                <span class="w-8 h-8 border border-white/20 group-hover:border-brand-primary flex items-center justify-center transition-colors">
                    <svg class="w-3.5 h-3.5 text-white/60 group-hover:text-brand-primary transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                    </svg>
                </span>
                <span class="text-[10px] tracking-[0.3em] uppercase text-white/50 group-hover:text-white transition-colors">@rogermurilloai</span>
            </a>
        </div>
    </div>
</footer>

<style>
    .footer-link {
        font-size: 0.875rem;
        color: rgb(163, 163, 163);
        font-weight: 300;
        padding: 4px 0;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: color .25s, padding-left .3s;
    }
    .footer-link::before {
        content: "";
        width: 0;
        height: 1px;
        background: #C41230;
        transition: width .4s;
    }
    .footer-link:hover { color: white; }
    .footer-link:hover::before { width: 14px; }

    .footer-service {
        border-top: 1px solid rgba(255,255,255,.08);
        padding: 14px 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: padding-left .4s;
        position: relative;
    }
    .footer-service::before {
        content: "";
        position: absolute;
        left: 0; bottom: 0;
        width: 0; height: 1px;
        background: #C41230;
        transition: width .5s cubic-bezier(.7,0,.3,1);
    }
    .footer-service:hover { padding-left: 14px; }
    .footer-service:hover::before { width: 100%; }
    .footer-service:last-child { border-bottom: 1px solid rgba(255,255,255,.08); }

    .marquee-track {
        display: flex;
        gap: 4rem;
        white-space: nowrap;
        animation: rm-marquee 50s linear infinite;
    }
    @keyframes rm-marquee { to { transform: translateX(-50%); } }

    .giant-word {
        font-family: 'Playfair Display', serif;
        font-weight: 400;
        line-height: 0.82;
        letter-spacing: -0.02em;
    }
</style>
