<div
    id="cookie-banner"
    class="fixed bottom-0 left-0 w-full bg-black text-white p-6 z-50 transform translate-y-full transition-transform duration-700 shadow-[0_-10px_40px_rgba(0,0,0,0.2)] flex flex-col md:flex-row items-center justify-center md:justify-between gap-6 border-t border-white/10"
>
    <div class="max-w-3xl text-center md:text-left">
        <p class="text-sm font-light text-gray-300 leading-relaxed">
            <span class="text-yellow-600 font-bold mr-2"
                >🍪 Privacidad & Lujo.</span
            >
            Usamos cookies para mejorar tu experiencia y analizar nuestra estrategia
            de imagen. Al continuar, aceptas nuestra <a
                href="/legales/privacidad"
                class="underline decoration-yellow-600 hover:text-yellow-600 transition-colors"
                >política de privacidad</a
            >.
        </p>
    </div>

    <div class="flex gap-4 shrink-0">
        <button
            id="accept-cookies"
            class="bg-yellow-600 text-black px-8 py-3 text-xs uppercase tracking-widest font-bold hover:bg-white hover:text-black transition-colors rounded-sm shadow-lg"
        >
            Aceptar
        </button>
    </div>
</div>

<script>
    // Lógica de "Vibecoding": Sin plugins pesados, puro JS nativo
    const banner = document.getElementById("cookie-banner");
    const acceptBtn = document.getElementById("accept-cookies");

    // Solo mostrar si no ha aceptado antes
    if (!localStorage.getItem("cookiesAccepted")) {
        // Retraso de 2.5s para no agobiar al usuario apenas entra (UX Premium)
        setTimeout(() => {
            banner?.classList.remove("translate-y-full");
        }, 2500);
    }

    acceptBtn?.addEventListener("click", () => {
        localStorage.setItem("cookiesAccepted", "true");
        banner?.classList.add("translate-y-full");

        // Aquí se podrían disparar los eventos de consentimiento de GA4/Meta si fuera necesario
        // window.gtag('consent', 'update', { ... });
    });
</script>
