---
import { ChevronDown } from "lucide-react";

const navItems = [
    { 
        label: "Servicios", 
        href: "/servicios", 
        type: "dropdown",
        items: [
            { label: "Consultoría Integral", href: "/servicios/asesoria-integral-imagen" },
            { label: "Color & Salud", href: "/servicios/color-salud-capilar" },
            { label: "Visagismo & Corte", href: "/servicios/visagismo-corte" },
            { label: "Imagen Ejecutiva", href: "/servicios/imagen-ejecutiva-autoridad" },
        ]
    },
    { 
        label: "La Firma", 
        href: "/nosotros",
        type: "simple"
    },
    { 
        label: "Academia", 
        href: "/academia",
        type: "mega",
        columns: [
            {
                title: "Formación Online",
                items: [
                    { label: "Ver Todo", href: "/academia" },
                    { label: "Curso Descúbrete", href: "/academia/curso-descubrete" },
                    { label: "Curso Diseñate", href: "/academia/crea-tu-iconologia" },
                    { label: "Curso Conquista", href: "/academia/disena-tu-voz" },
                    { label: "Curso Destaca", href: "/academia/el-correcto-uso-del-color" },
                ]
            },
            {
                title: "Recursos",
                items: [
                     { label: "Libro: Revoluciona tu Imagen", href: "/libro" },
                     { label: "Herramientas Gratuitas", href: "/herramientas" }
                ]
            }
        ],
        featured: {
            image: "/images/book-lifestyle.jpg",
            title: "El Manual Fundacional",
            subtitle: "Tu guía definitiva de estilo.",
            href: "/libro"
        }
    },
    { 
        label: "Herramientas", 
        href: "/herramientas",
        type: "simple"
    },
];
---

<header
    id="main-header"
    class="fixed w-full top-0 z-50 transition-all duration-500 bg-transparent border-b border-transparent group/header hover:bg-white hover:text-brand-black"
>
    <div class="container mx-auto px-6 h-16 md:h-20 flex items-center justify-between">
        <a href="/" class="block group relative z-50">
            <img
                src="/logo_rmai.webp"
                alt="Roger Murillo Asesoría de Imagen"
                class="h-8 md:h-14 w-auto object-contain brightness-0 invert group-[.scrolled]/header:invert-0 group-hover/header:invert-0 transition-all duration-500"
            />
        </a>

        <!-- DESKTOP NAVIGATION -->
        <nav class="hidden md:flex items-center gap-10">
            {
                navItems.map((item) => (
                    <div class="relative group h-20 flex items-center">
                        <a
                            href={item.href}
                            class="text-xs font-bold uppercase tracking-widest py-2 relative text-white group-[.scrolled]/header:text-brand-black group-hover/header:text-brand-black hover:text-brand-primary transition-colors duration-500 flex items-center gap-1"
                        >
                            {item.label}
                            {item.type !== 'simple' && <ChevronDown className="w-3 h-3 group-hover:rotate-180 transition-transform duration-300" />}
                            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-brand-primary transition-all duration-300 group-hover:w-full" />
                        </a>

                        {/* MEGA MENU: ACADEMIA */}
                        {item.type === 'mega' && (
                            <div class="absolute top-full left-1/2 -translate-x-1/2 w-[800px] bg-white border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-4 group-hover:translate-y-0 shadow-2xl rounded-sm overflow-hidden p-8 grid grid-cols-12 gap-8">
                                
                                <!-- Columns -->
                                <div class="col-span-8 grid grid-cols-2 gap-8 border-r border-gray-100 pr-8">
                                    {item.columns?.map(col => (
                                        <div>
                                            <h4 class="font-serif text-lg text-brand-black mb-4">{col.title}</h4>
                                            <ul class="space-y-3">
                                                {col.items?.map(subItem => (
                                                    <li>
                                                        <a href={subItem.href} class="text-sm text-slate-600 hover:text-brand-primary transition-colors block py-0.5">
                                                            {subItem.label}
                                                        </a>
                                                    </li>
                                                ))}
                                            </ul>
                                        </div>
                                    ))}
                                </div>

                                <!-- Featured -->
                                <div class="col-span-4 flex flex-col justify-between h-full">
                                    <h4 class="font-xs font-bold uppercase tracking-widest text-brand-primary mb-4">Destacado</h4>
                                    {item.featured && (
                                    <a href={item.featured.href} class="block group/featured overflow-hidden rounded-sm relative aspect-[3/4] bg-brand-gray flex items-center justify-center">
                                        <div class="absolute inset-0 bg-brand-primary/0 group-hover/featured:bg-brand-primary/10 transition-colors z-10"></div>
                                        <img src="/images/book-cover-3d.png" alt={item.featured.title} class="w-2/3 h-auto object-contain drop-shadow-2xl transition-transform duration-700 group-hover/featured:scale-110 relative z-0" />
                                        <div class="absolute bottom-0 left-0 w-full p-4 z-20 bg-white/90 backdrop-blur-sm border-t border-gray-100">
                                            <p class="font-serif text-lg leading-tight mb-0.5 text-brand-black">{item.featured.title}</p>
                                            <p class="text-[10px] uppercase tracking-wider text-gray-500">{item.featured.subtitle}</p>
                                        </div>
                                    </a>
                                    )}
                                </div>

                            </div>
                        )}

                        {/* SIMPLE DROPDOWN: SERVICIOS */}
                        {item.type === 'dropdown' && (
                           <div class="absolute top-full left-1/2 -translate-x-1/2 w-56 bg-white border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-4 group-hover:translate-y-0 py-2 shadow-2xl rounded-sm">
                                {item.items?.map(subItem => (
                                    <a
                                        href={subItem.href}
                                        class="block px-6 py-3 hover:bg-brand-gray text-xs uppercase tracking-widest text-brand-black hover:text-brand-primary transition-colors text-left"
                                    >
                                        {subItem.label}
                                    </a>
                                ))}
                            </div> 
                        )}

                    </div>
                ))
            }
        </nav>

        <div class="flex items-center gap-4 relative z-50">
            <a
                href="/contacto"
                class="hidden md:block bg-brand-primary text-white px-6 py-3 text-xs font-bold uppercase tracking-widest hover:bg-white hover:text-brand-black border border-transparent hover:border-brand-black transition-colors shadow-lg shadow-brand-primary/20 rounded-sm"
            >
                Agendar Cita
            </a>

            <button
                id="mobile-menu-btn"
                class="md:hidden text-white group-[.scrolled]/header:text-brand-black group-hover/header:text-brand-black focus:outline-none p-2 transition-colors duration-500"
                aria-label="Abrir menú"
            >
                <svg
                    class="w-8 h-8"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </div>

    <!-- MOBILE MENU (Sliding Overlay) -->
    <div
        id="mobile-menu"
        class="fixed inset-0 bg-brand-black/95 backdrop-blur-xl z-40 transform translate-x-full transition-transform duration-500 md:hidden flex flex-col h-screen"
    >
        <div class="p-6 flex justify-between items-center h-16 border-b border-white/10">
             <span class="text-white font-serif text-lg">Menu</span>
            <button
                id="close-menu-btn"
                class="text-white hover:text-brand-primary transition-colors flex items-center justify-center w-8 h-8"
                >
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        
        <div class="flex-1 px-8 py-8 flex flex-col gap-6 overflow-y-auto">
            {
                navItems.map((item) => (
                    item.type === 'simple' ? (
                        <a
                            href={item.href}
                            class="text-2xl font-serif text-white hover:text-brand-primary transition-colors py-2 border-b border-white/10"
                        >
                            {item.label}
                        </a>
                    ) : (
                        <div class="border-b border-white/10 pb-4">
                            <button class="mobile-accordion-btn text-2xl font-serif text-white hover:text-brand-primary transition-colors w-full flex justify-between items-center py-2">
                                {item.label}
                                <ChevronDown className="w-5 h-5 transition-transform duration-300" />
                            </button>
                            <div class="mobile-accordion-content hidden pl-4 pt-4 space-y-4">
                                {item.type === 'dropdown' ? (
                                    item.items?.map(subItem => (
                                         <a href={subItem.href} class="block text-sm text-gray-400 uppercase tracking-widest hover:text-white">
                                            {subItem.label}
                                         </a>
                                    ))
                                ) : ( // Mega Menu Mobile
                                    <>
                                        {item.columns?.map(col => (
                                            <div class="mb-4">
                                                <p class="text-xs font-bold text-brand-primary uppercase mb-3 border-l-2 border-brand-primary pl-2">{col.title}</p>
                                                <div class="space-y-3">
                                                {col.items?.map(subItem => (
                                                    <a href={subItem.href} class="block text-sm text-gray-400 hover:text-white">
                                                        {subItem.label}
                                                    </a>
                                                ))}
                                                </div>
                                            </div>
                                        ))}
                                    </>
                                )}
                            </div>
                        </div>
                    )
                ))
            }

            <a
                href="/contacto"
                class="text-brand-primary text-xl font-bold uppercase tracking-widest mt-8 border border-brand-primary px-8 py-4 hover:bg-brand-primary hover:text-white transition-colors text-center shrink-0"
            >
                Agendar Cita
            </a>
            
             <!-- Extra padding for bottom scrol -->
             <div class="h-20 shrink-0"></div>
        </div>
    </div>
</header>

<script>
    const header = document.getElementById("main-header");
    const menuBtn = document.getElementById("mobile-menu-btn");
    const closeBtn = document.getElementById("close-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const accordionBtns = document.querySelectorAll('.mobile-accordion-btn');

    // SCROLL EFFECT
    const handleScroll = () => {
        if (header) {
            if (window.scrollY > 20) { // Changed to 20px for faster trigger on mobile
                header.classList.add(
                    "scrolled",
                    "bg-white/95",
                    "backdrop-blur-md",
                    "shadow-sm",
                    "border-gray-100",
                );
                header.classList.remove("bg-transparent", "border-transparent");
            } else {
                header.classList.remove(
                    "scrolled",
                    "bg-white/95",
                    "backdrop-blur-md",
                    "shadow-sm",
                    "border-gray-100",
                );
                header.classList.add("bg-transparent", "border-transparent");
            }
        }
    };

    window.addEventListener("scroll", handleScroll);
    window.addEventListener("load", handleScroll);

    // MENU TOGGLE
    menuBtn?.addEventListener("click", () => {
        menu?.classList.remove("translate-x-full");
        document.body.style.overflow = 'hidden'; // Prevent body scroll
    });
    
    closeBtn?.addEventListener("click", () => {
        menu?.classList.add("translate-x-full");
        document.body.style.overflow = ''; // Restore body scroll
    });

    // MOBILE ACCORDION LOGIC
    accordionBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const content = btn.nextElementSibling;
            const icon = btn.querySelector('svg');
            
            // Toggle Logic
            if (content.classList.contains('hidden')) {
                 // Close others (optional)
                 accordionBtns.forEach(otherBtn => {
                    if(otherBtn !== btn) {
                        otherBtn.nextElementSibling.classList.add('hidden');
                        otherBtn.querySelector('svg').style.transform = 'rotate(0deg)';
                    }
                 });

                 content.classList.remove('hidden');
                 icon.style.transform = 'rotate(180deg)';
            } else {
                 content.classList.add('hidden');
                 icon.style.transform = 'rotate(0deg)';
            }
        });
    });
</script>
