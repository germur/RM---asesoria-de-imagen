---
import { ChevronDown } from "lucide-react";

const navItems = [
    {
        label: "Servicios",
        href: "/servicios",
        type: "dropdown",
        items: [
            { label: "Consultoría Integral", href: "/servicios/asesoria-integral-imagen" },
            { label: "Color & Salud",         href: "/servicios/color-salud-capilar" },
            { label: "Visagismo & Corte",     href: "/servicios/visagismo-corte" },
            { label: "Imagen Ejecutiva",      href: "/servicios/imagen-ejecutiva-autoridad" },
            { label: "Tarifas",               href: "/servicios/precios" },
        ]
    },
    { label: "La Firma",     href: "/nosotros",    type: "simple" },
    {
        label: "Academia",
        href: "/academia",
        type: "dropdown",
        items: [
            { label: "Todos los cursos",  href: "/academia" },
            { label: "Curso Descúbrete",  href: "/academia/curso-descubrete" },
            { label: "Curso Diseñate",    href: "/academia/crea-tu-iconologia" },
            { label: "Curso Conquista",   href: "/academia/disena-tu-voz" },
            { label: "Curso Destaca",     href: "/academia/el-correcto-uso-del-color" },
            { label: "Libro Oficial",     href: "/libro" },
        ]
    },
    { label: "Herramientas", href: "/herramientas", type: "simple" },
];
---

<!-- ─── HEADER ───────────────────────────────────────────────────── -->
<header
    id="main-header"
    class="fixed w-full top-0 z-50 transition-all duration-400"
>
    <!-- Gradient scrim: da contraste al texto blanco sobre cualquier fondo -->
    <div
        class="nav-scrim absolute inset-0 pointer-events-none transition-opacity duration-400"
        style="background: linear-gradient(to bottom, rgba(0,0,0,0.38) 0%, rgba(0,0,0,0.12) 60%, transparent 100%);"
    ></div>

    <div class="relative container mx-auto px-6 h-16 md:h-[72px] flex items-center justify-between">

        <!-- LOGO -->
        <a href="/" class="block z-50 flex-shrink-0">
            <img
                src="/images/logo_rm.png"
                alt="Roger Murillo Asesoría de Imagen"
                class="nav-logo h-7 md:h-8 w-auto object-contain transition-all duration-400"
            />
        </a>

        <!-- DESKTOP NAV -->
        <nav class="hidden md:flex items-center gap-9 absolute left-1/2 -translate-x-1/2">
            {navItems.map((item) => (
                <div class="relative group h-[72px] flex items-center">
                    <a
                        href={item.href}
                        class="nav-link text-[11px] tracking-[0.18em] uppercase font-light flex items-center gap-1
                               transition-opacity duration-300 hover:opacity-60"
                    >
                        {item.label}
                        {item.type === "dropdown" && (
                            <ChevronDown
                                className="w-3 h-3 opacity-40 group-hover:rotate-180 transition-transform duration-300 flex-shrink-0"
                            />
                        )}
                    </a>

                    <!-- DROPDOWN -->
                    {item.type === "dropdown" && (
                        <div class="absolute top-full left-1/2 -translate-x-1/2 mt-0 w-56
                                    bg-white/[0.98] backdrop-blur-sm border border-neutral-100
                                    opacity-0 invisible pointer-events-none
                                    group-hover:opacity-100 group-hover:visible group-hover:pointer-events-auto
                                    transition-all duration-200
                                    translate-y-1 group-hover:translate-y-0
                                    py-2 shadow-[0_8px_40px_rgba(0,0,0,0.1)]">
                            {item.items?.map((sub) => (
                                <a
                                    href={sub.href}
                                    class="block px-5 py-2.5 text-[11px] tracking-[0.12em] uppercase
                                           text-neutral-500 hover:text-brand-primary hover:bg-neutral-50
                                           transition-colors duration-150"
                                >
                                    {sub.label}
                                </a>
                            ))}
                        </div>
                    )}
                </div>
            ))}
        </nav>

        <!-- CTA + MOBILE BTN -->
        <div class="flex items-center gap-4 z-50 flex-shrink-0">
            <a
                href="/contacto"
                class="nav-cta hidden md:block px-5 py-2 text-[11px] tracking-[0.18em] uppercase
                       border transition-all duration-300"
            >
                Contacto
            </a>

            <!-- Hamburger -->
            <button
                id="mobile-menu-btn"
                class="nav-mobile-btn md:hidden focus:outline-none p-1.5 transition-colors duration-300"
                aria-label="Abrir menú"
            >
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
        </div>

    </div>
</header>

<!-- ─── MOBILE MENU (full-screen dark overlay) ──────────────────── -->
<div
    id="mobile-menu"
    class="fixed inset-0 bg-[#0a0a0a] z-[60]
           transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)]
           md:hidden flex flex-col"
>
    <!-- top bar -->
    <div class="px-6 flex justify-between items-center h-16 border-b border-white/[0.07]">
        <span class="text-[10px] tracking-[0.4em] uppercase text-neutral-600">Menú</span>
        <button
            id="close-menu-btn"
            class="text-neutral-500 hover:text-white transition-colors p-2 -mr-2"
            aria-label="Cerrar menú"
        >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>
    </div>

    <!-- links -->
    <div class="flex-1 px-8 py-8 flex flex-col overflow-y-auto">
        {navItems.map((item) =>
            item.type === "simple" ? (
                <a
                    href={item.href}
                    class="text-[2rem] font-serif text-white hover:text-neutral-400
                           transition-colors duration-200 py-5 border-b border-white/[0.06]"
                >
                    {item.label}
                </a>
            ) : (
                <div class="border-b border-white/[0.06]">
                    <button
                        class="mobile-accordion-btn text-[2rem] font-serif text-white hover:text-neutral-400
                               transition-colors duration-200 w-full flex justify-between items-center py-5"
                    >
                        {item.label}
                        <ChevronDown className="w-4 h-4 text-neutral-600 transition-transform duration-300 flex-shrink-0" />
                    </button>
                    <div class="mobile-accordion-content hidden pl-1 pb-6 space-y-2">
                        {item.items?.map((sub) => (
                            <a
                                href={sub.href}
                                class="block text-xs text-neutral-500 tracking-[0.15em] uppercase
                                       hover:text-white transition-colors duration-150 py-1.5"
                            >
                                {sub.label}
                            </a>
                        ))}
                    </div>
                </div>
            )
        )}

        <!-- mobile CTA -->
        <a
            href="/contacto"
            class="mt-10 bg-brand-primary text-white text-center py-4
                   text-[11px] tracking-[0.2em] uppercase hover:opacity-85 transition-opacity"
        >
            Reservar Consulta
        </a>

        <!-- Instagram -->
        <a
            href="https://www.instagram.com/rogermurilloai/"
            target="_blank"
            rel="noopener"
            class="mt-4 flex items-center justify-center gap-2.5 text-neutral-600
                   hover:text-neutral-300 transition-colors duration-200 py-3"
        >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            <span class="text-[11px] tracking-[0.2em] uppercase">@rogermurilloai</span>
        </a>
    </div>
</div>

<!-- ─── STYLES (is:global para evitar scoping de Astro) ──────────── -->
<style is:global>
    /* DEFAULT: transparente + blanco */
    .nav-logo       { filter: brightness(0) invert(1); }
    .nav-link       { color: rgba(255,255,255,0.92); }
    .nav-cta        { color: rgba(255,255,255,0.85); border-color: rgba(255,255,255,0.35); }
    .nav-cta:hover  { color: white; border-color: rgba(255,255,255,0.8); background-color: rgba(255,255,255,0.08); }
    .nav-mobile-btn { color: rgba(255,255,255,0.9); }

    /* SCROLLED: frosted glass + oscuro */
    #main-header.scrolled {
        background-color: rgba(255,255,255,0.97) !important;
        backdrop-filter: blur(12px) !important;
        -webkit-backdrop-filter: blur(12px) !important;
        border-bottom: 1px solid rgba(0,0,0,0.06) !important;
        box-shadow: 0 1px 24px rgba(0,0,0,0.05) !important;
    }
    #main-header.scrolled .nav-scrim      { opacity: 0 !important; }
    #main-header.scrolled .nav-logo       { filter: brightness(0) !important; }
    #main-header.scrolled .nav-link       { color: rgb(10,10,10) !important; }
    #main-header.scrolled .nav-cta        { color: rgb(10,10,10) !important; border-color: rgba(10,10,10,0.2) !important; }
    #main-header.scrolled .nav-cta:hover  { background-color: rgb(10,10,10) !important; color: white !important; border-color: rgb(10,10,10) !important; }
    #main-header.scrolled .nav-mobile-btn { color: rgb(10,10,10) !important; }
</style>

<!-- ─── SCRIPT ────────────────────────────────────────────────────── -->
<script>
    const header   = document.getElementById("main-header");
    const menuBtn  = document.getElementById("mobile-menu-btn");
    const closeBtn = document.getElementById("close-menu-btn");
    const menu     = document.getElementById("mobile-menu");

    // Scroll handler
    const onScroll = () => {
        header?.classList.toggle("scrolled", window.scrollY > 48);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    // Mobile open / close
    menuBtn?.addEventListener("click", () => {
        menu?.classList.remove("translate-x-full");
        document.body.style.overflow = "hidden";
    });
    const closeMenu = () => {
        menu?.classList.add("translate-x-full");
        document.body.style.overflow = "";
    };
    closeBtn?.addEventListener("click", closeMenu);

    // Close on nav link click
    menu?.querySelectorAll("a").forEach(a => a.addEventListener("click", closeMenu));

    // Mobile accordion
    document.querySelectorAll<HTMLButtonElement>(".mobile-accordion-btn").forEach(btn => {
        btn.addEventListener("click", () => {
            const content = btn.nextElementSibling as HTMLElement;
            const icon    = btn.querySelector("svg") as SVGElement;
            if (!content || !icon) return;

            const wasHidden = content.classList.contains("hidden");

            // Close all
            document.querySelectorAll<HTMLElement>(".mobile-accordion-content")
                .forEach(c => c.classList.add("hidden"));
            document.querySelectorAll<SVGElement>(".mobile-accordion-btn svg")
                .forEach(i => (i.style.transform = ""));

            if (wasHidden) {
                content.classList.remove("hidden");
                icon.style.transform = "rotate(180deg)";
            }
        });
    });
</script>
