---
import { ChevronDown } from "lucide-react";

const navItems = [
    {
        label: "Servicios",
        href: "/servicios",
        type: "dropdown",
        items: [
            { label: "Consultoría Integral", href: "/servicios/asesoria-integral-imagen" },
            { label: "Color & Salud", href: "/servicios/color-salud-capilar" },
            { label: "Visagismo & Corte", href: "/servicios/visagismo-corte" },
            { label: "Imagen Ejecutiva", href: "/servicios/imagen-ejecutiva-autoridad" },
        ]
    },
    {
        label: "La Firma",
        href: "/nosotros",
        type: "simple"
    },
    {
        label: "Academia",
        href: "/academia",
        type: "dropdown",
        items: [
            { label: "Todos los cursos", href: "/academia" },
            { label: "Curso Descúbrete", href: "/academia/curso-descubrete" },
            { label: "Curso Diseñate", href: "/academia/crea-tu-iconologia" },
            { label: "Curso Conquista", href: "/academia/disena-tu-voz" },
            { label: "Curso Destaca", href: "/academia/el-correcto-uso-del-color" },
            { label: "Libro Oficial", href: "/libro" },
        ]
    },
    {
        label: "Herramientas",
        href: "/herramientas",
        type: "simple"
    },
];

const { theme = 'dark' } = Astro.props;

const isDark = theme === 'dark';
const textColorClass = isDark
    ? "text-brand-black group-[.scrolled]/header:text-brand-black group-hover/header:text-brand-black"
    : "text-brand-black";

const logoClass = isDark
    ? "brightness-0 group-[.scrolled]/header:brightness-0 group-hover/header:brightness-0"
    : "brightness-0";

const mobileMenuBtnClass = isDark
    ? "text-brand-black group-[.scrolled]/header:text-brand-black group-hover/header:text-brand-black"
    : "text-brand-black";
---

<header
    id="main-header"
    class="fixed w-full top-0 z-50 transition-all duration-500 bg-transparent border-b border-transparent group/header"
>
    <div class="container mx-auto px-6 h-20 md:h-24 flex items-center justify-between">
        <!-- LOGO -->
        <a href="/" class="block relative z-50">
            <img
                src="/images/logo_rm.png"
                alt="Roger Murillo Asesoría de Imagen"
                class={`h-7 md:h-10 w-auto object-contain transition-all duration-500 ${logoClass}`}
            />
        </a>

        <!-- DESKTOP NAV -->
        <nav class="hidden md:flex items-center gap-10">
            {
                navItems.map((item) => (
                    <div class="relative group h-24 flex items-center">
                        <a
                            href={item.href}
                            class={`text-[11px] tracking-[0.2em] uppercase py-2 relative hover:text-brand-primary transition-colors duration-300 flex items-center gap-1 ${textColorClass}`}
                        >
                            {item.label}
                            {item.type === 'dropdown' && <ChevronDown className="w-3 h-3 opacity-40 group-hover:rotate-180 transition-transform duration-300" />}
                        </a>

                        {/* DROPDOWN */}
                        {item.type === 'dropdown' && (
                            <div class="absolute top-full left-1/2 -translate-x-1/2 w-56 bg-white border border-neutral-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 py-3 shadow-lg">
                                {item.items?.map(subItem => (
                                    <a
                                        href={subItem.href}
                                        class="block px-6 py-2.5 text-[11px] tracking-[0.15em] uppercase text-neutral-600 hover:text-brand-primary hover:bg-neutral-50 transition-colors text-left"
                                    >
                                        {subItem.label}
                                    </a>
                                ))}
                            </div>
                        )}
                    </div>
                ))
            }
        </nav>

        <!-- CTA + MOBILE BTN -->
        <div class="flex items-center gap-6 relative z-50">
            <a
                href="/contacto"
                class="hidden md:block px-7 py-3 text-[11px] tracking-[0.2em] uppercase bg-brand-black text-white hover:bg-brand-primary transition-colors duration-500"
            >
                Contacto
            </a>

            <button
                id="mobile-menu-btn"
                class={`md:hidden focus:outline-none p-2 transition-colors duration-500 ${mobileMenuBtnClass}`}
                aria-label="Abrir menú"
            >
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </div>

    <!-- MOBILE MENU -->
    <div
        id="mobile-menu"
        class="fixed inset-0 bg-white z-40 transform translate-x-full transition-transform duration-500 md:hidden flex flex-col h-screen"
    >
        <div class="px-6 flex justify-between items-center h-20 border-b border-neutral-100">
            <span class="text-[11px] tracking-[0.3em] uppercase text-neutral-400">Menu</span>
            <button
                id="close-menu-btn"
                class="text-brand-black hover:text-brand-primary transition-colors w-8 h-8 flex items-center justify-center"
            >
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <div class="flex-1 px-6 py-10 flex flex-col gap-0 overflow-y-auto">
            {
                navItems.map((item) => (
                    item.type === 'simple' ? (
                        <a
                            href={item.href}
                            class="text-2xl font-serif text-brand-black hover:text-brand-primary transition-colors py-5 border-b border-neutral-100"
                        >
                            {item.label}
                        </a>
                    ) : (
                        <div class="border-b border-neutral-100">
                            <button class="mobile-accordion-btn text-2xl font-serif text-brand-black hover:text-brand-primary transition-colors w-full flex justify-between items-center py-5">
                                {item.label}
                                <ChevronDown className="w-4 h-4 text-neutral-400 transition-transform duration-300" />
                            </button>
                            <div class="mobile-accordion-content hidden pl-4 pb-5 space-y-4">
                                {item.items?.map(subItem => (
                                    <a href={subItem.href} class="block text-sm text-neutral-500 tracking-[0.1em] uppercase hover:text-brand-primary transition-colors">
                                        {subItem.label}
                                    </a>
                                ))}
                            </div>
                        </div>
                    )
                ))
            }

            <a
                href="/contacto"
                class="mt-10 bg-brand-black text-white text-center py-4 text-xs tracking-[0.2em] uppercase hover:bg-brand-primary transition-colors"
            >
                Contacto
            </a>
        </div>
    </div>
</header>

<script>
    const header = document.getElementById("main-header");
    const menuBtn = document.getElementById("mobile-menu-btn");
    const closeBtn = document.getElementById("close-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const accordionBtns = document.querySelectorAll('.mobile-accordion-btn');

    const handleScroll = () => {
        if (header) {
            if (window.scrollY > 20) {
                header.classList.add("scrolled", "bg-white", "border-neutral-100");
                header.classList.remove("bg-transparent", "border-transparent");
            } else {
                header.classList.remove("scrolled", "bg-white", "border-neutral-100");
                header.classList.add("bg-transparent", "border-transparent");
            }
        }
    };

    window.addEventListener("scroll", handleScroll);
    window.addEventListener("load", handleScroll);

    menuBtn?.addEventListener("click", () => {
        menu?.classList.remove("translate-x-full");
        document.body.style.overflow = 'hidden';
    });

    closeBtn?.addEventListener("click", () => {
        menu?.classList.add("translate-x-full");
        document.body.style.overflow = '';
    });

    accordionBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const content = btn.nextElementSibling;
            const icon = btn.querySelector('svg');
            if (!content || !icon) return;

            if (content.classList.contains('hidden')) {
                accordionBtns.forEach(otherBtn => {
                    if(otherBtn !== btn) {
                        const otherContent = otherBtn.nextElementSibling;
                        const otherIcon = otherBtn.querySelector('svg');
                        if (otherContent && otherIcon) {
                            otherContent.classList.add('hidden');
                            otherIcon.style.transform = 'rotate(0deg)';
                        }
                    }
                });
                content.classList.remove('hidden');
                icon.style.transform = 'rotate(180deg)';
            } else {
                content.classList.add('hidden');
                icon.style.transform = 'rotate(0deg)';
            }
        });
    });
</script>
