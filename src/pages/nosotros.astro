---
import MainLayout from "@/layouts/MainLayout.astro";
import AnimatedTitleWords from "@/components/ui/AnimatedTitleWords.astro";

const organizationSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    name: "Roger Murillo & Adriana Garzón - Consultoría de Imagen",
    url: "https://rogermurillo.co/nosotros",
    image: "https://rogermurillo.co/images/roger-adriana-duo.jpg",
    founder: [
        { "@type": "Person", name: "Roger Murillo", jobTitle: "Director Creativo & Estratega de Imagen", description: "Especialista en Visagismo y Arquitectura Facial." },
        { "@type": "Person", name: "Adriana Garzón", jobTitle: "Consultora Senior & Especialista en Colorimetría", description: "Experta en salud capilar y diseño de color. Certificada por el IDB y el New York Institute." },
    ],
    description: "Firma de consultoría de imagen estratégica en Bogotá. Especialistas en visagismo, colorimetría y proyección ejecutiva.",
});
---

<MainLayout
    title="Asesores de Imagen Personal · Visagismo · Colorimetría | Roger Murillo & Adriana Garzón"
    description="Roger Murillo y Adriana Garzón: expertos en consultoría de imagen, visagismo profesional y colorimetría en Bogotá. Más de 20 años transformando la presencia de líderes y ejecutivos."
    schema={organizationSchema}
>

    <style>
        .reveal{opacity:0;transform:translateY(36px);transition:opacity 1s cubic-bezier(.16,1,.3,1) var(--delay,0s),transform 1s cubic-bezier(.16,1,.3,1) var(--delay,0s)}
        .reveal.is-in{opacity:1;transform:translateY(0)}
        .num-huge{font-style:italic;line-height:.8;position:absolute;pointer-events:none;user-select:none}
        .tag{display:inline-block;font-size:10px;letter-spacing:.3em;text-transform:uppercase;padding:6px 14px;border:1px solid currentColor;border-radius:999px}
        .marquee{display:flex;gap:4rem;white-space:nowrap;animation:marquee 45s linear infinite}
        @keyframes marquee{to{transform:translateX(-50%)}}
        .pillar-num{transition:all .5s;color:transparent;-webkit-text-stroke:1px rgba(255,255,255,.2)}
        .pillar:hover .pillar-num{-webkit-text-stroke-color:var(--color-brand-primary, #C41230)}
    </style>

    <!-- HERO -->
    <section class="pt-40 pb-32 md:pt-48 md:pb-40 bg-brand-black text-white relative overflow-hidden min-h-screen flex flex-col justify-center">
        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <div class="flex items-center gap-5 mb-14">
                <span class="w-12 h-px bg-brand-primary"></span>
                <p class="text-[10px] tracking-[0.4em] uppercase text-white/60">La Firma</p>
            </div>
            <h1 class="font-serif leading-[0.85]">
                <AnimatedTitleWords text="No cambiamos" class="block text-5xl md:text-7xl lg:text-8xl text-white" />
                <AnimatedTitleWords text="tu apariencia." class="block text-5xl md:text-7xl lg:text-8xl italic text-neutral-500 pl-[6%]" delay={300} />
                <AnimatedTitleWords text="Revelamos tu autoridad." class="block text-5xl md:text-7xl lg:text-8xl text-brand-primary pl-[2%]" delay={500} />
            </h1>
            <div class="mt-16 grid md:grid-cols-12 gap-8">
                <div class="md:col-span-5 md:col-start-8 border-l-2 border-brand-primary pl-8">
                    <p class="text-lg font-light text-white/70 leading-relaxed mb-6">La imagen no es vanidad, es semiótica. En un mundo donde se juzga en 7 segundos, tu presencia es tu primera herramienta de negociación.</p>
                    <p class="text-sm text-white/50 font-light italic leading-relaxed">La imagen personal no empieza en la ropa — empieza en la identidad.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- MARQUEE -->
    <div class="py-9 border-y border-white/10 bg-brand-black overflow-hidden">
        <div class="marquee">
            <div class="flex gap-16 items-center shrink-0">
                <span class="font-serif italic text-2xl text-white/20">Intimidad</span><span class="font-serif italic text-2xl text-white/20">·</span>
                <span class="font-serif italic text-2xl text-white/20">Confianza</span><span class="font-serif italic text-2xl text-white/20">·</span>
                <span class="font-serif italic text-2xl text-white/20">Confort</span><span class="font-serif italic text-2xl text-white/20">·</span>
                <span class="font-serif italic text-2xl text-white/20">Dos miradas</span><span class="font-serif italic text-2xl text-white/20">·</span>
                <span class="font-serif italic text-2xl text-white/20">Una estrategia</span><span class="font-serif italic text-2xl text-white/20">·</span>
            </div>
            <div class="flex gap-16 items-center shrink-0" aria-hidden="true">
                <span class="font-serif italic text-2xl text-white/20">Intimidad</span><span class="font-serif italic text-2xl text-white/20">·</span>
                <span class="font-serif italic text-2xl text-white/20">Confianza</span><span class="font-serif italic text-2xl text-white/20">·</span>
                <span class="font-serif italic text-2xl text-white/20">Confort</span><span class="font-serif italic text-2xl text-white/20">·</span>
                <span class="font-serif italic text-2xl text-white/20">Dos miradas</span><span class="font-serif italic text-2xl text-white/20">·</span>
                <span class="font-serif italic text-2xl text-white/20">Una estrategia</span><span class="font-serif italic text-2xl text-white/20">·</span>
            </div>
        </div>
    </div>

    <!-- DOS MIRADAS -->
    <section class="py-32 md:py-40 bg-brand-black text-white relative overflow-hidden">
        <span class="num-huge font-serif text-[28vw] -right-[4%] -top-[8%] absolute" style="color:rgba(255,255,255,.04)">01</span>
        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <div class="max-w-3xl mb-20">
                <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-6">El diferencial</p>
                <h2 class="font-serif text-5xl md:text-7xl leading-[0.92]">Dos miradas.<br/>Una sola <span class="italic text-neutral-500">estrategia.</span></h2>
                <p class="mt-10 text-lg font-light text-white/70 leading-relaxed max-w-2xl">Lo que nos hace únicos es el cruce de perspectivas. Roger aporta la visión masculina, Adriana la femenina. Cada cliente recibe el beneficio de ambas lecturas: cómo te percibe un hombre, cómo te percibe una mujer. Un plus que nadie más te da.</p>
            </div>
            <div class="grid md:grid-cols-2 gap-px bg-white/10">
                <div class="bg-brand-black p-12 md:p-16">
                    <span class="tag text-brand-primary mb-8">Perspectiva masculina</span>
                    <h3 class="font-serif text-4xl mb-6 mt-8">Roger Murillo</h3>
                    <p class="text-base text-white/60 font-light leading-relaxed">La lectura desde la autoridad, la presencia ejecutiva y los códigos de poder. Roger analiza cómo tu imagen comunica liderazgo, confianza y competencia en entornos de alta dirección.</p>
                </div>
                <div class="bg-brand-black p-12 md:p-16">
                    <span class="tag text-brand-primary mb-8">Perspectiva femenina</span>
                    <h3 class="font-serif text-4xl mb-6 mt-8">Adriana Garzón</h3>
                    <p class="text-base text-white/60 font-light leading-relaxed">La lectura desde la armonía, la coherencia estética y la sensibilidad del color. Evalúa cómo tu imagen comunica sofisticación, equilibrio y autenticidad en cada detalle.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ROGER -->
    <section id="roger" class="py-32 md:py-40 bg-white relative overflow-hidden">
        <span class="num-huge font-serif text-[28vw] -left-[4%] -top-[8%] absolute" style="color:rgba(196,18,48,.06)">02</span>
        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-24 items-center">
                <div class="lg:col-span-5 relative">
                    <img src="/images/roger-portrait-bw.jpg" alt="Roger Murillo" class="w-full aspect-[4/5] object-cover grayscale" />
                    <div class="absolute bottom-0 left-0 w-1 h-24 bg-brand-primary"></div>
                </div>
                <div class="lg:col-span-7">
                    <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-6">El estratega</p>
                    <h2 class="font-serif text-5xl md:text-7xl leading-[0.95] text-brand-black mb-8">Roger Murillo</h2>
                    <p class="text-lg text-neutral-600 font-light leading-relaxed mb-6">Con más de dos décadas en la industria, Roger trascendió la peluquería tradicional para fundar una metodología basada en la arquitectura del rostro. Su enfoque no es "cortar cabello", es diseñar líneas geométricas que corrijan proporciones y proyecten carácter.</p>
                    <p class="text-lg text-neutral-600 font-light leading-relaxed mb-8">Es el cerebro detrás del concepto "A Puerta Cerrada", entendiendo que el verdadero lujo para un ejecutivo es la privacidad y la personalización absoluta.</p>
                    <p class="text-[10px] tracking-[0.25em] uppercase text-brand-black mb-10">Fundador — Especialista en imagen ejecutiva</p>
                    <div class="flex gap-12 flex-wrap">
                        <div class="border-l-2 border-brand-primary pl-4">
                            <span class="font-serif italic text-4xl text-brand-black block leading-none">20+</span>
                            <span class="text-[11px] tracking-[0.2em] uppercase text-neutral-500 mt-2 block">Años de trayectoria</span>
                        </div>
                        <div class="border-l-2 border-brand-primary pl-4">
                            <span class="font-serif italic text-4xl text-brand-black block leading-none">07</span>
                            <span class="text-[11px] tracking-[0.2em] uppercase text-neutral-500 mt-2 block">Geometrías faciales</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ADRIANA -->
    <section id="adriana" class="py-32 md:py-40 bg-neutral-50 relative overflow-hidden">
        <span class="num-huge font-serif text-[28vw] -right-[4%] -top-[8%] absolute" style="color:rgba(196,18,48,.06)">03</span>
        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-24 items-center">
                <div class="lg:col-span-7 order-2 lg:order-1">
                    <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-6">La especialista</p>
                    <h2 class="font-serif text-5xl md:text-7xl leading-[0.95] text-brand-black mb-8">Adriana Garzón</h2>
                    <p class="text-lg text-neutral-600 font-light leading-relaxed mb-6">Adriana aporta la precisión técnica y la visión integral al equipo. Su dominio de la Colorimetría Avanzada y el cuidado capilar transforma no solo cómo te ves, sino la salud real de tu imagen.</p>
                    <p class="text-lg text-neutral-600 font-light leading-relaxed mb-8">Su enfoque se centra en la coherencia estética: asegurar que el color, la textura y el estilo comuniquen el mismo mensaje de sofisticación. Experta en traducir códigos de vestimenta para la mujer contemporánea y el hombre moderno.</p>
                    <p class="text-[10px] tracking-[0.25em] uppercase text-brand-black mb-8">Consultora de imagen — Especialista en colorimetría</p>
                    <div class="flex flex-wrap gap-3">
                        <span class="px-4 py-2 text-[10px] tracking-[0.2em] uppercase border border-neutral-300 text-neutral-600">Certificada por el IDB</span>
                        <span class="px-4 py-2 text-[10px] tracking-[0.2em] uppercase border border-neutral-300 text-neutral-600">New York Institute</span>
                        <span class="px-4 py-2 text-[10px] tracking-[0.2em] uppercase border border-neutral-300 text-neutral-600">Instituto de Imagen Personal</span>
                    </div>
                </div>
                <div class="lg:col-span-5 order-1 lg:order-2 relative">
                    <img src="/images/adriana-portrait-bw.jpg" alt="Adriana Garzón" class="w-full aspect-[4/5] object-cover grayscale" />
                    <div class="absolute bottom-0 left-0 w-1 h-24 bg-brand-primary"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- A PUERTA CERRADA -->
    <section class="py-32 md:py-40 bg-brand-black text-white relative overflow-hidden">
        <span class="num-huge font-serif text-[28vw] -left-[4%] -bottom-[10%] absolute" style="color:rgba(255,255,255,.04)">04</span>
        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <div class="max-w-3xl mb-20">
                <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-6">El modelo</p>
                <h2 class="font-serif text-5xl md:text-7xl leading-[0.92]">¿Por qué<br/>"A puerta <span class="italic text-neutral-500">cerrada"?</span></h2>
                <p class="mt-10 text-lg font-light text-white/70 leading-relaxed max-w-2xl">Porque la imagen es un proceso profundamente personal. Priorizamos la intimidad, la confianza y el confort. En nuestro estudio privado, no eres un turno más: eres el único foco de atención.</p>
            </div>
            <div class="grid md:grid-cols-3 gap-12 md:gap-6">
                <div class="pillar reveal">
                    <span class="pillar-num font-serif italic text-[12vw] md:text-[7vw] leading-none block">01</span>
                    <div class="border-t border-white/20 pt-6 mt-4">
                        <h3 class="font-serif text-3xl mb-4">Intimidad</h3>
                        <p class="text-sm text-white/50 font-light leading-relaxed">Sin vitrinas a la calle. Sin miradas indiscretas. Tu proceso de transformación es privado, como debe ser. Un espacio seguro para ser vulnerable y honesto.</p>
                    </div>
                </div>
                <div class="pillar reveal" style="--delay:.1s">
                    <span class="pillar-num font-serif italic text-[12vw] md:text-[7vw] leading-none block">02</span>
                    <div class="border-t border-white/20 pt-6 mt-4">
                        <h3 class="font-serif text-3xl mb-4">Confianza</h3>
                        <p class="text-sm text-white/50 font-light leading-relaxed">Roger y Adriana dedicados exclusivamente a tu análisis. Sin asistentes junior. Un vínculo de confianza real donde puedes expresar quién quieres ser.</p>
                    </div>
                </div>
                <div class="pillar reveal" style="--delay:.2s">
                    <span class="pillar-num font-serif italic text-[12vw] md:text-[7vw] leading-none block">03</span>
                    <div class="border-t border-white/20 pt-6 mt-4">
                        <h3 class="font-serif text-3xl mb-4">Confort</h3>
                        <p class="text-sm text-white/50 font-light leading-relaxed">Tu tiempo es dinero. Agendamos con márgenes amplios, sin esperas. Cuando llegas, empezamos. Un ambiente diseñado para que te sientas en casa.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- MANIFIESTO -->
    <section class="py-32 md:py-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-24">
                <div class="lg:col-span-5 lg:sticky lg:top-24 self-start">
                    <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-6">El manifiesto</p>
                    <h2 class="font-serif text-5xl md:text-7xl leading-[0.92] text-brand-black">Lo que<br/>creemos.</h2>
                </div>
                <div class="lg:col-span-7 space-y-14">
                    <div class="reveal border-l border-neutral-200 pl-8">
                        <p class="font-serif italic text-brand-primary text-xl mb-4">i.</p>
                        <h3 class="font-serif text-3xl text-brand-black mb-3">La imagen no es vanidad, es estrategia.</h3>
                        <p class="text-neutral-600 font-light leading-relaxed">Es semiótica aplicada. Cada prenda, cada corte, cada color comunica algo. La pregunta no es "¿me veo bien?", sino "¿estoy comunicando lo correcto?".</p>
                    </div>
                    <div class="reveal border-l border-neutral-200 pl-8" style="--delay:.1s">
                        <p class="font-serif italic text-brand-primary text-xl mb-4">ii.</p>
                        <h3 class="font-serif text-3xl text-brand-black mb-3">Empieza en la identidad, no en la ropa.</h3>
                        <p class="text-neutral-600 font-light leading-relaxed">Primero definimos quién eres y quién quieres ser. Después, y solo después, diseñamos cómo lo comunicas visualmente. El orden inverso es moda; este orden es estrategia.</p>
                    </div>
                    <div class="reveal border-l border-neutral-200 pl-8" style="--delay:.2s">
                        <p class="font-serif italic text-brand-primary text-xl mb-4">iii.</p>
                        <h3 class="font-serif text-3xl text-brand-black mb-3">Dos miradas ven lo que una pasa por alto.</h3>
                        <p class="text-neutral-600 font-light leading-relaxed">Roger y Adriana trabajan juntos en cada sesión. Lo que un hombre nota, una mujer lo confirma o lo cuestiona. Lo que una mujer ve, un hombre lo valida. Ese cruce es nuestro activo.</p>
                    </div>
                    <div class="reveal border-l border-neutral-200 pl-8" style="--delay:.3s">
                        <p class="font-serif italic text-brand-primary text-xl mb-4">iv.</p>
                        <h3 class="font-serif text-3xl text-brand-black mb-3">Privacidad antes que escaparate.</h3>
                        <p class="text-neutral-600 font-light leading-relaxed">No somos un salón. Somos un estudio privado. Sin vitrinas, sin filas, sin esperas. Tu proceso te pertenece a ti.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-32 md:py-40 bg-brand-black text-white text-center relative overflow-hidden">
        <span class="num-huge font-serif text-[28vw] left-1/2 -translate-x-1/2 top-0 absolute" style="color:rgba(255,255,255,.04)">→</span>
        <div class="container mx-auto px-6 max-w-4xl relative z-10">
            <h2 class="font-serif text-5xl md:text-7xl leading-[0.92] mb-10">¿Listo para elevar<br/><span class="italic text-neutral-500">tu estándar?</span></h2>
            <p class="text-lg font-light text-white/70 leading-relaxed max-w-xl mx-auto mb-12">La agenda de Roger y Adriana es limitada debido a la naturaleza exclusiva del servicio.</p>
            <div class="flex flex-col sm:flex-row gap-5 justify-center">
                <a href="/servicios" class="bg-brand-primary text-white px-12 py-5 text-[11px] tracking-[0.25em] uppercase hover:bg-white hover:text-brand-black transition-all duration-500">Ver servicios →</a>
                <a href="/contacto" class="px-12 py-5 text-[11px] tracking-[0.25em] uppercase text-white border border-white/30 hover:border-white transition-colors duration-500">Solicitar cita</a>
            </div>
        </div>
    </section>

    <script>
        const ro = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-in'); ro.unobserve(e.target) } }), { threshold: .15, rootMargin: '0px 0px -60px 0px' });
        document.querySelectorAll('.reveal').forEach(el => ro.observe(el));
    </script>

</MainLayout>
