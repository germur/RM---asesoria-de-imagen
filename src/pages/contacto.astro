---
import MainLayout from "../layouts/MainLayout.astro";

const contactSchema = {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    mainEntity: {
        "@type": "LocalBusiness",
        name: "Roger Murillo Asesoría de Imagen",
        image: "https://rogermurillo.co/logo.png",
        telephone: "+573000000000",
        email: "contacto@rogermurillo.co",
        address: {
            "@type": "PostalAddress",
            streetAddress: "Calle 161 con Av. Boyacá",
            addressLocality: "Bogotá",
            addressRegion: "Cundinamarca",
            addressCountry: "CO",
        },
        openingHoursSpecification: {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
            opens: "09:00",
            closes: "19:00",
        },
    },
};
---

<MainLayout
    title="Agendar Consultoría de Imagen · Visagismo · Colorimetría en Bogotá | Roger Murillo"
    description="Agenda tu consultoría de imagen personal o ejecutiva en Bogotá. Estudio privado a puerta cerrada. Atención 1 a 1 con Roger Murillo y Adriana Garzón."
    schema={contactSchema}
    navbarTheme="light"
>
    <!-- HERO -->
    <section class="relative min-h-screen bg-white overflow-hidden pt-24 pb-20">
        <div class="container mx-auto px-6 max-w-7xl h-full">
            <div class="grid lg:grid-cols-12 gap-12 items-end min-h-[calc(100vh-12rem)]">
                <div class="lg:col-span-8">
                    <div class="flex items-center gap-5 mb-12">
                        <span class="w-12 h-px bg-brand-primary"></span>
                        <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-500">Contacto &middot; Estudio privado</p>
                    </div>

                    <h1 class="font-serif leading-[0.88]">
                        <span class="hero-line block text-[13vw] md:text-[9vw] lg:text-[7.5vw] text-brand-black">Cruza la</span>
                        <span class="hero-line block text-[13vw] md:text-[9vw] lg:text-[7.5vw] italic text-neutral-400 pl-[10%]">puerta.</span>
                        <span class="hero-line block text-[13vw] md:text-[9vw] lg:text-[7.5vw] text-brand-primary pl-[25%]">Empezamos.</span>
                    </h1>

                    <p class="text-lg text-neutral-500 font-light leading-relaxed max-w-xl mt-12">
                        La transformación comienza con una decisión. Reserva tu espacio en nuestra agenda exclusiva al norte de Bogotá &mdash; y déjanos el resto.
                    </p>
                </div>

                <!-- status card -->
                <div class="lg:col-span-4">
                    <div class="relative bg-brand-black text-white p-10">
                        <div class="flex items-center gap-3 mb-6">
                            <span class="relative inline-block w-2 h-2 rounded-full bg-brand-primary pulse-dot"></span>
                            <span class="text-[10px] tracking-[0.3em] uppercase text-neutral-400">Agenda abierta</span>
                        </div>
                        <p class="font-serif text-3xl leading-tight mb-8">
                            Próximos cupos:<br/>
                            <span class="italic text-brand-primary">esta semana.</span>
                        </p>
                        <div class="space-y-3 border-t border-neutral-800 pt-6 text-sm text-neutral-300 font-light">
                            <div class="flex justify-between"><span>Lunes &mdash; Sábado</span><span class="text-white">09:00 &mdash; 19:00</span></div>
                            <div class="flex justify-between"><span>Domingo &amp; festivos</span><span class="text-neutral-500">Cerrado</span></div>
                        </div>
                        <a href="#form" class="mt-8 flex items-center justify-between text-[11px] tracking-[0.25em] uppercase border-t border-neutral-800 pt-6 hover:text-brand-primary transition-colors">
                            <span>Reservar ahora</span>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CONTACT CHANNELS -->
    <section class="relative bg-neutral-50 py-24 border-y border-neutral-100">
        <div class="container mx-auto px-6 max-w-7xl">
            <div class="grid md:grid-cols-3 gap-px bg-neutral-200">
                <a href="https://wa.me/573000000000" target="_blank" class="group bg-neutral-50 p-12 hover:bg-white transition-colors duration-500">
                    <p class="text-[10px] tracking-[0.3em] uppercase text-brand-primary mb-8">Canal &middot; 01</p>
                    <h3 class="font-serif text-4xl text-brand-black mb-3">WhatsApp</h3>
                    <p class="text-sm text-neutral-500 font-light leading-relaxed mb-10">
                        Para dudas rápidas o para conocer disponibilidad inmediata. Respondemos en menos de 2 horas hábiles.
                    </p>
                    <span class="inline-flex items-center gap-3 text-[11px] tracking-[0.25em] uppercase text-brand-black group-hover:text-brand-primary transition-colors">
                        +57 300 000 0000
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 17L17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                </a>

                <a href="mailto:contacto@rogermurillo.co" class="group bg-neutral-50 p-12 hover:bg-white transition-colors duration-500">
                    <p class="text-[10px] tracking-[0.3em] uppercase text-brand-primary mb-8">Canal &middot; 02</p>
                    <h3 class="font-serif text-4xl text-brand-black mb-3">Correo</h3>
                    <p class="text-sm text-neutral-500 font-light leading-relaxed mb-10">
                        Para briefings corporativos, invitaciones a medios o colaboraciones profesionales con la firma.
                    </p>
                    <span class="inline-flex items-center gap-3 text-[11px] tracking-[0.25em] uppercase text-brand-black group-hover:text-brand-primary transition-colors break-all">
                        contacto@rogermurillo.co
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 17L17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                </a>

                <a href="#form" class="group bg-neutral-50 p-12 hover:bg-white transition-colors duration-500">
                    <p class="text-[10px] tracking-[0.3em] uppercase text-brand-primary mb-8">Canal &middot; 03</p>
                    <h3 class="font-serif text-4xl text-brand-black mb-3">Agenda</h3>
                    <p class="text-sm text-neutral-500 font-light leading-relaxed mb-10">
                        El camino directo. Completa el formulario de calificación y reserva tu cita de consultoría privada.
                    </p>
                    <span class="inline-flex items-center gap-3 text-[11px] tracking-[0.25em] uppercase text-brand-black group-hover:text-brand-primary transition-colors">
                        Empezar formulario
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12l7 7 7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                </a>
            </div>
        </div>
    </section>

    <!-- FORM -->
    <section id="form" class="relative bg-white py-32 md:py-40 overflow-hidden">
        <span class="absolute -right-10 top-10 font-serif italic text-[22vw] leading-[0.8] text-neutral-50 select-none pointer-events-none">Agenda</span>

        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <div class="grid lg:grid-cols-12 gap-16">
                <div class="lg:col-span-4 lg:pr-8">
                    <p class="text-[10px] tracking-[0.4em] uppercase text-brand-primary mb-6">Reserva &middot; 3 pasos</p>
                    <h2 class="font-serif text-5xl md:text-6xl leading-[0.95] text-brand-black mb-10">
                        Calificación <span class="italic text-neutral-400">privada.</span>
                    </h2>
                    <p class="text-base text-neutral-500 font-light leading-relaxed mb-10">
                        Este formulario nos ayuda a entender tu contexto antes del primer encuentro. Nada se comparte: es la base para personalizar tu sesión.
                    </p>

                    <div class="space-y-4 border-t border-neutral-200 pt-8">
                        <div class="flex items-center gap-4 step-indicator" data-step="1">
                            <span class="w-10 h-10 border border-neutral-300 rounded-full flex items-center justify-center font-serif italic text-sm step-circle">01</span>
                            <span class="text-[11px] tracking-[0.25em] uppercase text-neutral-500 step-label">Sobre ti</span>
                        </div>
                        <div class="flex items-center gap-4 step-indicator" data-step="2">
                            <span class="w-10 h-10 border border-neutral-300 rounded-full flex items-center justify-center font-serif italic text-sm step-circle">02</span>
                            <span class="text-[11px] tracking-[0.25em] uppercase text-neutral-500 step-label">Tu objetivo</span>
                        </div>
                        <div class="flex items-center gap-4 step-indicator" data-step="3">
                            <span class="w-10 h-10 border border-neutral-300 rounded-full flex items-center justify-center font-serif italic text-sm step-circle">03</span>
                            <span class="text-[11px] tracking-[0.25em] uppercase text-neutral-500 step-label">Agendar</span>
                        </div>
                    </div>
                </div>

                <div class="lg:col-span-8">
                    <form id="rm-form" class="relative">
                        <!-- STEP 1 -->
                        <div class="form-step" data-step="1">
                            <p class="text-[10px] tracking-[0.3em] uppercase text-neutral-400 mb-8">Paso 01 &mdash; Sobre ti</p>
                            <div class="grid md:grid-cols-2 gap-x-12 gap-y-10">
                                <div class="rm-field">
                                    <input type="text" id="f-name" placeholder=" " autocomplete="name"/>
                                    <label for="f-name">Nombre completo</label>
                                </div>
                                <div class="rm-field">
                                    <input type="email" id="f-email" placeholder=" " autocomplete="email"/>
                                    <label for="f-email">Correo electrónico</label>
                                </div>
                                <div class="rm-field">
                                    <input type="tel" id="f-phone" placeholder=" " autocomplete="tel"/>
                                    <label for="f-phone">Teléfono / WhatsApp</label>
                                </div>
                                <div class="rm-field select-field">
                                    <select id="f-age">
                                        <option value="" disabled selected></option>
                                        <option>25 &mdash; 34</option>
                                        <option>35 &mdash; 44</option>
                                        <option>45 &mdash; 54</option>
                                        <option>55+</option>
                                    </select>
                                    <label for="f-age">Rango de edad</label>
                                </div>
                            </div>
                            <div class="flex justify-end mt-14">
                                <button type="button" class="next-btn inline-flex items-center gap-4 bg-brand-black text-white px-10 py-5 text-[11px] tracking-[0.25em] uppercase hover:bg-brand-primary transition-colors duration-500" data-to="2">
                                    Continuar
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                </button>
                            </div>
                        </div>

                        <!-- STEP 2 -->
                        <div class="form-step hidden" data-step="2">
                            <p class="text-[10px] tracking-[0.3em] uppercase text-neutral-400 mb-8">Paso 02 &mdash; Tu objetivo</p>
                            <p class="text-[11px] tracking-[0.25em] uppercase text-brand-black mb-5">¿Qué te trae a la firma?</p>
                            <div class="grid md:grid-cols-2 gap-3 mb-10" id="goals">
                                <label class="goal-chip cursor-pointer border border-neutral-200 px-5 py-4 text-sm hover:border-brand-black transition-colors">
                                    <input type="checkbox" class="hidden" value="Imagen ejecutiva"/> Imagen ejecutiva
                                </label>
                                <label class="goal-chip cursor-pointer border border-neutral-200 px-5 py-4 text-sm hover:border-brand-black transition-colors">
                                    <input type="checkbox" class="hidden" value="Colorimetría"/> Colorimetría
                                </label>
                                <label class="goal-chip cursor-pointer border border-neutral-200 px-5 py-4 text-sm hover:border-brand-black transition-colors">
                                    <input type="checkbox" class="hidden" value="Visagismo y corte"/> Visagismo y corte
                                </label>
                                <label class="goal-chip cursor-pointer border border-neutral-200 px-5 py-4 text-sm hover:border-brand-black transition-colors">
                                    <input type="checkbox" class="hidden" value="Transición personal"/> Transición personal
                                </label>
                                <label class="goal-chip cursor-pointer border border-neutral-200 px-5 py-4 text-sm hover:border-brand-black transition-colors">
                                    <input type="checkbox" class="hidden" value="Peluquería"/> Peluquería
                                </label>
                                <label class="goal-chip cursor-pointer border border-neutral-200 px-5 py-4 text-sm hover:border-brand-black transition-colors">
                                    <input type="checkbox" class="hidden" value="Otro"/> Aún no lo sé
                                </label>
                            </div>
                            <div class="rm-field">
                                <textarea id="f-context" placeholder=" " rows="4"></textarea>
                                <label for="f-context">Contexto (opcional)</label>
                            </div>
                            <div class="flex justify-between mt-14">
                                <button type="button" class="prev-btn text-[11px] tracking-[0.25em] uppercase text-neutral-500 hover:text-brand-black transition-colors" data-to="1">← Volver</button>
                                <button type="button" class="next-btn inline-flex items-center gap-4 bg-brand-black text-white px-10 py-5 text-[11px] tracking-[0.25em] uppercase hover:bg-brand-primary transition-colors duration-500" data-to="3">
                                    Continuar
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                </button>
                            </div>
                        </div>

                        <!-- STEP 3 -->
                        <div class="form-step hidden" data-step="3">
                            <p class="text-[10px] tracking-[0.3em] uppercase text-neutral-400 mb-8">Paso 03 &mdash; Agendar</p>
                            <p class="text-[11px] tracking-[0.25em] uppercase text-brand-black mb-5">Preferencia horaria</p>
                            <div class="grid grid-cols-3 md:grid-cols-4 gap-2 mb-10" id="slots">
                                <button type="button" class="time-slot border border-neutral-200 py-3 text-[11px] tracking-[0.2em] uppercase">Mañana</button>
                                <button type="button" class="time-slot border border-neutral-200 py-3 text-[11px] tracking-[0.2em] uppercase">Mediodía</button>
                                <button type="button" class="time-slot border border-neutral-200 py-3 text-[11px] tracking-[0.2em] uppercase">Tarde</button>
                                <button type="button" class="time-slot border border-neutral-200 py-3 text-[11px] tracking-[0.2em] uppercase">Noche</button>
                            </div>
                            <div class="rm-field">
                                <input type="text" id="f-date" placeholder=" "/>
                                <label for="f-date">Fecha tentativa (ej: 15 de mayo)</label>
                            </div>
                            <label class="flex items-start gap-3 mt-8 text-sm text-neutral-500 font-light cursor-pointer">
                                <input type="checkbox" class="mt-1.5" id="f-terms"/>
                                <span>Acepto que mi información se use únicamente para coordinar la consultoría y recibir comunicaciones relacionadas.</span>
                            </label>
                            <div class="flex justify-between mt-14">
                                <button type="button" class="prev-btn text-[11px] tracking-[0.25em] uppercase text-neutral-500 hover:text-brand-black transition-colors" data-to="2">← Volver</button>
                                <button type="submit" class="inline-flex items-center gap-4 bg-brand-primary text-white px-10 py-5 text-[11px] tracking-[0.25em] uppercase hover:bg-brand-black transition-colors duration-500">
                                    Enviar solicitud
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                </button>
                            </div>
                        </div>

                        <!-- SUCCESS -->
                        <div class="form-step hidden text-center py-16" data-step="4">
                            <div class="inline-flex w-20 h-20 rounded-full bg-brand-primary items-center justify-center mb-10">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.5"><path d="M5 12l5 5L20 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </div>
                            <h3 class="font-serif text-4xl md:text-5xl text-brand-black mb-6">Recibimos tu solicitud.</h3>
                            <p class="text-lg text-neutral-500 font-light leading-relaxed max-w-md mx-auto">
                                Te contactaremos en menos de 24 horas hábiles para confirmar fecha y depósito de reserva.
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- LOCATION -->
    <section class="relative bg-brand-black text-white py-32 md:py-48 overflow-hidden">
        <div class="container mx-auto px-6 max-w-7xl">
            <div class="grid lg:grid-cols-12 gap-16 items-end mb-16">
                <div class="lg:col-span-7">
                    <p class="text-[10px] tracking-[0.4em] uppercase text-brand-primary mb-6">El estudio</p>
                    <h2 class="font-serif text-5xl md:text-7xl leading-[0.95]">
                        Al norte de<br/><span class="italic text-neutral-500">Bogotá.</span>
                    </h2>
                </div>
                <div class="lg:col-span-5">
                    <p class="text-lg text-neutral-400 font-light leading-relaxed">
                        Ingreso con código de seguridad. Parqueo interno disponible. Atención exclusivamente con cita previa.
                    </p>
                </div>
            </div>

            <div class="grid lg:grid-cols-12 gap-px bg-neutral-800">
                <div class="lg:col-span-8 bg-brand-black h-[500px] relative ph-studio">
                    <iframe
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3976.1440236850794!2d-74.06593672418667!3d4.745016041270061!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e3f850847721223%3A0x836e954dff5dd886!2sROGER%20MURILLO%20IMAGE%20ADVISORS!5e0!3m2!1sen!2sco!4v1777071797708!5m2!1sen!2sco"
                        width="100%" height="100%"
                        style="border:0; filter: grayscale(100%) invert(90%) contrast(83%);"
                        allowfullscreen=""
                        loading="lazy"
                    ></iframe>
                    <span class="absolute top-6 left-6 text-[10px] tracking-[0.3em] uppercase text-neutral-500 bg-black/40 backdrop-blur px-3 py-1.5 z-10">Colina Campestre</span>
                </div>
                <div class="lg:col-span-4 bg-brand-black p-10 space-y-10">
                    <div>
                        <p class="text-[10px] tracking-[0.3em] uppercase text-neutral-500 mb-3">Dirección</p>
                        <p class="font-serif text-2xl leading-tight">Calle 161 con<br/>Av. Boyacá</p>
                        <p class="text-sm text-neutral-500 mt-2">Colina Campestre &middot; Bogotá</p>
                    </div>
                    <div class="border-t border-neutral-800 pt-8">
                        <p class="text-[10px] tracking-[0.3em] uppercase text-neutral-500 mb-3">Horario</p>
                        <p class="text-sm text-neutral-300 leading-relaxed">Lunes &mdash; Sábado<br/><span class="text-white">09:00 &mdash; 19:00</span></p>
                    </div>
                    <div class="border-t border-neutral-800 pt-8">
                        <a href="https://maps.google.com/?q=Roger+Murillo+Image+Advisors+Bogota" target="_blank" class="inline-flex items-center gap-3 text-[11px] tracking-[0.25em] uppercase hover:text-brand-primary transition-colors">
                            Abrir en Maps
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 17L17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="relative bg-white py-32 md:py-40">
        <div class="container mx-auto px-6 max-w-4xl">
            <p class="text-[10px] tracking-[0.4em] uppercase text-brand-primary mb-6 text-center">Dudas frecuentes</p>
            <h2 class="font-serif text-5xl md:text-6xl leading-[0.95] text-brand-black mb-16 text-center">Antes de <span class="italic text-neutral-400">escribirnos.</span></h2>

            <div class="divide-y divide-neutral-200 border-t border-b border-neutral-200">
                <details class="group py-8 cursor-pointer">
                    <summary class="flex justify-between items-start list-none gap-6">
                        <span class="font-serif text-2xl text-brand-black leading-tight">¿Cuál es el costo de la valoración inicial?</span>
                        <span class="text-neutral-300 group-open:rotate-45 transition-transform text-3xl leading-none shrink-0">+</span>
                    </summary>
                    <p class="text-base text-neutral-500 font-light leading-relaxed mt-6 max-w-2xl">
                        La valoración tiene un costo que funciona como depósito. Si decides tomar el servicio completo, este valor se deduce del total.
                    </p>
                </details>
                <details class="group py-8 cursor-pointer">
                    <summary class="flex justify-between items-start list-none gap-6">
                        <span class="font-serif text-2xl text-brand-black leading-tight">¿Puedo ir acompañado o acompañada?</span>
                        <span class="text-neutral-300 group-open:rotate-45 transition-transform text-3xl leading-none shrink-0">+</span>
                    </summary>
                    <p class="text-base text-neutral-500 font-light leading-relaxed mt-6 max-w-2xl">
                        Debido al protocolo "A Puerta Cerrada", priorizamos la privacidad del cliente. Se permite un acompañante máximo si es estrictamente necesario.
                    </p>
                </details>
                <details class="group py-8 cursor-pointer">
                    <summary class="flex justify-between items-start list-none gap-6">
                        <span class="font-serif text-2xl text-brand-black leading-tight">¿Cómo debo ir vestido o vestida?</span>
                        <span class="text-neutral-300 group-open:rotate-45 transition-transform text-3xl leading-none shrink-0">+</span>
                    </summary>
                    <p class="text-base text-neutral-500 font-light leading-relaxed mt-6 max-w-2xl">
                        Ven como te vistes normalmente en tu día a día. Esto nos ayuda a tener un punto de partida real para el diagnóstico.
                    </p>
                </details>
                <details class="group py-8 cursor-pointer">
                    <summary class="flex justify-between items-start list-none gap-6">
                        <span class="font-serif text-2xl text-brand-black leading-tight">¿Atienden fuera de Bogotá?</span>
                        <span class="text-neutral-300 group-open:rotate-45 transition-transform text-3xl leading-none shrink-0">+</span>
                    </summary>
                    <p class="text-base text-neutral-500 font-light leading-relaxed mt-6 max-w-2xl">
                        Por la naturaleza del servicio presencial, atendemos exclusivamente en el estudio. Sin embargo, ofrecemos sesiones virtuales complementarias para clientes activos.
                    </p>
                </details>
            </div>
        </div>
    </section>
</MainLayout>

<style>
    .hero-line {
        opacity: 0;
        transform: translateY(100%);
        animation: heroLineIn 1.1s cubic-bezier(.22, 1, .36, 1) forwards;
        display: block;
        overflow: hidden;
    }
    .hero-line:nth-child(1) { animation-delay: .15s; }
    .hero-line:nth-child(2) { animation-delay: .3s; }
    .hero-line:nth-child(3) { animation-delay: .45s; }
    @keyframes heroLineIn {
        to { opacity: 1; transform: translateY(0); }
    }

    /* Form fields */
    .rm-field { position: relative; }
    .rm-field input,
    .rm-field textarea,
    .rm-field select {
        width: 100%;
        background: transparent;
        border: 0;
        border-bottom: 1px solid #e5e5e5;
        padding: 22px 0 12px 0;
        font-size: 16px;
        color: #0a0a0a;
        outline: none;
        transition: border-color .4s;
        appearance: none;
        border-radius: 0;
    }
    .rm-field select {
        padding-right: 24px;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'><path fill='none' stroke='%23999' stroke-width='1.2' d='M1 1l4 4 4-4'/></svg>");
        background-repeat: no-repeat;
        background-position: right 0 center;
    }
    .rm-field textarea { resize: none; min-height: 100px; }
    .rm-field input:focus,
    .rm-field textarea:focus,
    .rm-field select:focus { border-color: #0a0a0a; }
    .rm-field label {
        position: absolute;
        left: 0;
        top: 22px;
        font-size: 16px;
        color: #9a9a9a;
        pointer-events: none;
        transition: all .35s cubic-bezier(.2, .8, .2, 1);
    }
    .rm-field input:focus + label,
    .rm-field input:not(:placeholder-shown) + label,
    .rm-field textarea:focus + label,
    .rm-field textarea:not(:placeholder-shown) + label {
        top: 0;
        font-size: 10px;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: #C41230;
    }
    .rm-field.select-field label {
        top: 0;
        font-size: 10px;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: #9a9a9a;
    }
    .rm-field.select-field:focus-within label { color: #C41230; }

    .pulse-dot::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 9999px;
        background: #C41230;
        animation: pulse 2s ease-out infinite;
    }
    @keyframes pulse {
        0% { opacity: .6; transform: scale(1); }
        100% { opacity: 0; transform: scale(2.8); }
    }

    .ph-studio {
        background:
            radial-gradient(circle at 30% 30%, rgba(196, 18, 48, .08), transparent 40%),
            linear-gradient(135deg, #0a0a0a 0%, #181818 50%, #262626 100%);
    }

    .time-slot { transition: all .3s; }
    .time-slot.selected { background: #0a0a0a; color: #fff; border-color: #0a0a0a; }
    .time-slot:hover { border-color: #0a0a0a; }
</style>

<script is:inline>
    const steps = document.querySelectorAll('.form-step');
    const indicators = document.querySelectorAll('.step-indicator');
    const goTo = (n) => {
        steps.forEach(s => s.classList.toggle('hidden', s.dataset.step !== String(n)));
        indicators.forEach(i => {
            const step = Number(i.dataset.step);
            const circle = i.querySelector('.step-circle');
            const label = i.querySelector('.step-label');
            if (step < n) {
                circle.style.background = '#0a0a0a'; circle.style.color = '#fff'; circle.style.borderColor = '#0a0a0a';
                label.style.color = '#0a0a0a';
            } else if (step === n) {
                circle.style.background = '#C41230'; circle.style.color = '#fff'; circle.style.borderColor = '#C41230';
                label.style.color = '#C41230';
            } else {
                circle.style.background = 'transparent'; circle.style.color = '#9a9a9a'; circle.style.borderColor = '#e5e5e5';
                label.style.color = '#9a9a9a';
            }
        });
    };
    document.querySelectorAll('.next-btn,.prev-btn').forEach(b =>
        b.addEventListener('click', () => goTo(Number(b.dataset.to)))
    );
    goTo(1);

    document.querySelectorAll('.goal-chip').forEach(chip => {
        chip.addEventListener('click', () => {
            const inp = chip.querySelector('input');
            inp.checked = !inp.checked;
            chip.style.background = inp.checked ? '#0a0a0a' : '';
            chip.style.color = inp.checked ? '#fff' : '';
            chip.style.borderColor = inp.checked ? '#0a0a0a' : '';
        });
    });

    document.querySelectorAll('#slots .time-slot').forEach(s => {
        s.addEventListener('click', () => {
            document.querySelectorAll('#slots .time-slot').forEach(x => x.classList.remove('selected'));
            s.classList.add('selected');
        });
    });

    const form = document.getElementById('rm-form');
    if (form) {
        form.addEventListener('submit', (e) => {
            e.preventDefault();
            goTo(4);
        });
    }
</script>
