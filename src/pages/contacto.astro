---
import MainLayout from "../layouts/MainLayout.astro";
import QualificationForm from "../components/react/QualificationForm";

const contactSchema = {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    mainEntity: {
        "@type": "LocalBusiness",
        name: "Roger Murillo Asesoría de Imagen",
        image: "https://rogermurillo.co/logo.png",
        telephone: "+573000000000",
        email: "contacto@rogermurillo.co",
        address: {
            "@type": "PostalAddress",
            streetAddress: "Calle 161 con Av. Boyacá",
            addressLocality: "Bogotá",
            addressRegion: "Cundinamarca",
            addressCountry: "CO",
        },
        openingHoursSpecification: {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: [
                "Monday",
                "Tuesday",
                "Wednesday",
                "Thursday",
                "Friday",
                "Saturday",
            ],
            opens: "09:00",
            closes: "19:00",
        },
    },
};
---

<MainLayout
    title="Agendar Consultoría de Imagen · Visagismo · Colorimetría en Bogotá | Roger Murillo"
    description="Agenda tu consultoría de imagen personal o ejecutiva en Bogotá. Estudio privado a puerta cerrada. Atención 1 a 1 con Roger Murillo y Adriana Garzón."
    schema={contactSchema}
    navbarTheme="light"
>
    <section class="pt-40 pb-32 md:pt-48 md:pb-40 bg-white">
        <div class="container mx-auto px-6 max-w-3xl text-center">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">
                Contacto
            </p>

            <h1 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black mb-8">
                Hablemos de tu Imagen
            </h1>

            <p class="text-lg text-neutral-500 font-light leading-relaxed max-w-xl mx-auto">
                La transformación comienza con una decisión. Reserva tu espacio
                en nuestra agenda exclusiva al norte de Bogotá.
            </p>
        </div>
    </section>

    <section class="py-32 md:py-40 bg-neutral-50">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="flex flex-col lg:flex-row gap-16 xl:gap-24">
                <div class="w-full lg:w-1/2">
                    <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">
                        Estudio Privado
                    </p>
                    <h2 class="font-serif text-3xl text-brand-black mb-12">
                        Información del Estudio
                    </h2>

                    <div class="space-y-10 mb-16">
                        <div>
                            <h4 class="text-xs font-medium uppercase tracking-[0.2em] text-brand-black mb-3">
                                Ubicación
                            </h4>
                            <p class="text-neutral-500 font-light leading-relaxed">
                                Calle 161 con Av. Boyacá (Colina Campestre)<br />
                                Bogotá, Colombia<br />
                                <span class="text-xs text-neutral-400 mt-2 block">
                                    * Ingreso con código de seguridad.
                                </span>
                            </p>
                        </div>

                        <div>
                            <h4 class="text-xs font-medium uppercase tracking-[0.2em] text-brand-black mb-3">
                                Horario de Atención
                            </h4>
                            <p class="text-neutral-500 font-light leading-relaxed">
                                Lunes a Sábado: 9:00 AM - 7:00 PM<br />
                                Domingos y Festivos: Cerrado
                            </p>
                        </div>

                        <div>
                            <h4 class="text-xs font-medium uppercase tracking-[0.2em] text-brand-black mb-3">
                                Contacto Rápido
                            </h4>
                            <p class="text-neutral-500 font-light leading-relaxed mb-4">
                                ¿Consultas urgentes? Escríbenos directamente.
                            </p>
                            <a
                                href="https://wa.me/573000000000?text=Hola,%20quisiera%20agendar%20una%20cita"
                                target="_blank"
                                class="bg-brand-primary text-white px-10 py-4 text-xs font-medium uppercase tracking-[0.2em] hover:bg-brand-black transition-colors duration-500 inline-block"
                            >
                                Chat en WhatsApp
                            </a>
                        </div>
                    </div>

                    <div class="w-full h-80 border border-neutral-200 overflow-hidden">
                        <iframe
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3976.336427384784!2d-74.05649962416174!3d4.711099541589136!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e3f854666d925ad%3A0x673997e0b25d070!2sAv.%20Boyac%C3%A1%20%26%20Cl.%20161%2C%20Bogot%C3%A1!5e0!3m2!1ses!2sco!4v1709823456789!5m2!1ses!2sco"
                            width="100%"
                            height="100%"
                            style="border:0; filter: grayscale(100%);"
                            allowfullscreen=""
                            loading="lazy"
                        ></iframe>
                    </div>
                </div>

                <div class="w-full lg:w-1/2">
                    <QualificationForm client:load />
                </div>
            </div>
        </div>
    </section>

    <section class="py-32 md:py-40 bg-white">
        <div class="container mx-auto px-6 text-center max-w-3xl">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">
                FAQ
            </p>
            <h3 class="font-serif text-3xl text-brand-black mb-12">
                Dudas Frecuentes
            </h3>
            <div class="space-y-0 text-left">
                <details class="border-t border-neutral-200 py-6 cursor-pointer group">
                    <summary class="font-medium flex justify-between items-center list-none text-brand-black text-sm uppercase tracking-[0.1em]">
                        ¿Cuál es el costo de la valoración inicial?
                        <span class="text-neutral-400 group-open:rotate-180 transition-transform duration-300 text-xs">&#9660;</span>
                    </summary>
                    <p class="text-neutral-500 font-light leading-relaxed mt-4">
                        La valoración tiene un costo que funciona como depósito.
                        Si decides tomar el servicio completo, este valor se
                        deduce del total.
                    </p>
                </details>

                <details class="border-t border-neutral-200 py-6 cursor-pointer group">
                    <summary class="font-medium flex justify-between items-center list-none text-brand-black text-sm uppercase tracking-[0.1em]">
                        ¿Puedo ir acompañado/a?
                        <span class="text-neutral-400 group-open:rotate-180 transition-transform duration-300 text-xs">&#9660;</span>
                    </summary>
                    <p class="text-neutral-500 font-light leading-relaxed mt-4">
                        Debido al protocolo "A Puerta Cerrada", priorizamos la
                        privacidad del cliente. Se permite un acompañante máximo
                        si es estrictamente necesario.
                    </p>
                </details>

                <details class="border-t border-b border-neutral-200 py-6 cursor-pointer group">
                    <summary class="font-medium flex justify-between items-center list-none text-brand-black text-sm uppercase tracking-[0.1em]">
                        ¿Cómo debo ir vestido/a?
                        <span class="text-neutral-400 group-open:rotate-180 transition-transform duration-300 text-xs">&#9660;</span>
                    </summary>
                    <p class="text-neutral-500 font-light leading-relaxed mt-4">
                        Ven como te vistes normalmente en tu día a día. Esto nos
                        ayuda a tener un punto de partida real para el diagnóstico.
                    </p>
                </details>
            </div>
        </div>
    </section>
</MainLayout>
