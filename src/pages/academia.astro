---
import MainLayout from "@/layouts/MainLayout.astro";
import AnimatedTitleWords from "@/components/ui/AnimatedTitleWords.astro";

const academiaSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Academia Roger Murillo",
  description: "Cursos y recursos de imagen personal, colorimetría y visagismo."
};
---

<MainLayout
  title="Academia de Imagen Personal · Cursos Online | Roger Murillo"
  description="Aprende los fundamentos de la imagen estratégica: colorimetría, visagismo, morfología y estilo. Cursos desde $25 USD."
  schema={academiaSchema}
>

  <style>
    .reveal{opacity:0;transform:translateY(36px);transition:opacity 1s cubic-bezier(.16,1,.3,1) var(--delay,0s),transform 1s cubic-bezier(.16,1,.3,1) var(--delay,0s)}
    .reveal.is-in{opacity:1;transform:translateY(0)}
    .course-card{transition:all .6s cubic-bezier(.16,1,.3,1);cursor:pointer}
    .course-card:hover{transform:translateY(-8px)}
    .course-card:hover .card-title{color:var(--color-brand-primary, #C41230)}
    .card-title{transition:color .4s}
  </style>

  <!-- HERO -->
  <section class="pt-40 pb-32 md:pt-48 md:pb-40 bg-white relative overflow-hidden">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="flex items-center gap-5 mb-14">
        <span class="w-12 h-px bg-brand-primary"></span>
        <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-500">Formación · Digital</p>
      </div>
      <h1 class="font-serif leading-[0.85] text-brand-black max-w-4xl">
        <AnimatedTitleWords text="Aprende" class="block text-6xl md:text-8xl lg:text-9xl" />
        <AnimatedTitleWords text="las reglas" class="block text-6xl md:text-8xl lg:text-9xl italic text-neutral-400 pl-[6%]" delay={300} />
        <AnimatedTitleWords text="del juego." class="block text-6xl md:text-8xl lg:text-9xl text-brand-primary pl-[2%]" delay={500} />
      </h1>
      <div class="mt-14 max-w-xl">
        <p class="text-base text-neutral-700 font-light leading-relaxed">Cursos, guías y masterclasses para entender las reglas del color, el corte y el estilo. Desde $25 USD.</p>
      </div>
    </div>
  </section>

  <!-- COURSES GRID -->
  <section class="py-32 md:py-40 bg-neutral-50">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="max-w-2xl mb-20">
        <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-6">Catálogo</p>
        <h2 class="font-serif text-5xl md:text-6xl leading-[0.95] text-brand-black">5 cursos.<br/><span class="italic text-neutral-400">Un sistema.</span></h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Libro -->
        <a href="/libro" class="course-card bg-white p-8 border border-neutral-200 reveal">
          <p class="text-[10px] tracking-[0.3em] uppercase text-neutral-400 mb-4">Libro · Fundacional</p>
          <h3 class="card-title font-serif text-3xl text-brand-black mb-3">Revoluciona tu Imagen</h3>
          <p class="text-sm text-neutral-500 font-light leading-relaxed mb-8">El manual fundacional. Físico + digital.</p>
          <div class="flex items-baseline justify-between border-t border-neutral-100 pt-6">
            <p class="font-serif text-2xl text-brand-black">$19<span class="text-sm text-neutral-400"> USD</span></p>
            <span class="text-[10px] tracking-[0.3em] uppercase text-neutral-400">→</span>
          </div>
        </a>

        <!-- Descúbrete -->
        <a href="/academia/curso-descubrete" class="course-card bg-white p-8 border border-neutral-200 reveal" style="--delay:.1s">
          <p class="text-[10px] tracking-[0.3em] uppercase text-neutral-400 mb-4">Curso 01 · Fundamentos</p>
          <h3 class="card-title font-serif text-3xl text-brand-black mb-3">Descúbrete</h3>
          <p class="text-sm text-neutral-500 font-light leading-relaxed mb-8">El poder de tu imagen personal.</p>
          <div class="flex items-baseline justify-between border-t border-neutral-100 pt-6">
            <p class="font-serif text-2xl text-brand-black">$25<span class="text-sm text-neutral-400"> USD</span></p>
            <span class="text-[10px] tracking-[0.3em] uppercase text-neutral-400">→</span>
          </div>
        </a>

        <!-- Diseñate -->
        <a href="/academia/crea-tu-iconologia" class="course-card bg-white p-8 border border-neutral-200 reveal" style="--delay:.2s">
          <p class="text-[10px] tracking-[0.3em] uppercase text-neutral-400 mb-4">Curso 02 · Iconología</p>
          <h3 class="card-title font-serif text-3xl text-brand-black mb-3">Diseñate</h3>
          <p class="text-sm text-neutral-500 font-light leading-relaxed mb-8">Crea tu iconología personal.</p>
          <div class="flex items-baseline justify-between border-t border-neutral-100 pt-6">
            <p class="font-serif text-2xl text-brand-black">$35<span class="text-sm text-neutral-400"> USD</span></p>
            <span class="text-[10px] tracking-[0.3em] uppercase text-neutral-400">→</span>
          </div>
        </a>

        <!-- Conquista -->
        <a href="/academia/disena-tu-voz" class="course-card bg-white p-8 border border-neutral-200 reveal" style="--delay:.3s">
          <p class="text-[10px] tracking-[0.3em] uppercase text-neutral-400 mb-4">Curso 03 · Comunicación</p>
          <h3 class="card-title font-serif text-3xl text-brand-black mb-3">Conquista</h3>
          <p class="text-sm text-neutral-500 font-light leading-relaxed mb-8">Diseña tu voz y tu mensaje.</p>
          <div class="flex items-baseline justify-between border-t border-neutral-100 pt-6">
            <p class="font-serif text-2xl text-brand-black">$40<span class="text-sm text-neutral-400"> USD</span></p>
            <span class="text-[10px] tracking-[0.3em] uppercase text-neutral-400">→</span>
          </div>
        </a>

        <!-- Destaca -->
        <a href="/academia/el-correcto-uso-del-color" class="course-card bg-white p-8 border border-neutral-200 reveal" style="--delay:.4s">
          <p class="text-[10px] tracking-[0.3em] uppercase text-neutral-400 mb-4">Curso 04 · Color</p>
          <h3 class="card-title font-serif text-3xl text-brand-black mb-3">Destaca</h3>
          <p class="text-sm text-neutral-500 font-light leading-relaxed mb-8">El correcto uso del color.</p>
          <div class="flex items-baseline justify-between border-t border-neutral-100 pt-6">
            <p class="font-serif text-2xl text-brand-black">$40<span class="text-sm text-neutral-400"> USD</span></p>
            <span class="text-[10px] tracking-[0.3em] uppercase text-neutral-400">→</span>
          </div>
        </a>

        <!-- Bundle placeholder -->
        <div class="course-card bg-brand-black text-white p-8 border border-brand-primary reveal" style="--delay:.5s">
          <p class="text-[10px] tracking-[0.3em] uppercase text-brand-primary mb-4">Bundle · Ahorra 30%</p>
          <h3 class="card-title font-serif text-3xl mb-3">Pack Completo</h3>
          <p class="text-sm text-white/60 font-light leading-relaxed mb-8">Los 4 cursos + libro a precio especial.</p>
          <div class="flex items-baseline justify-between border-t border-white/20 pt-6">
            <p class="font-serif text-2xl">$99<span class="text-sm text-white/40"> USD</span></p>
            <span class="text-[10px] tracking-[0.3em] uppercase text-white/40">→</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-32 md:py-40 bg-white border-t border-neutral-200">
    <div class="container mx-auto px-6 max-w-5xl text-center">
      <h2 class="font-serif text-5xl md:text-7xl leading-[0.95] text-brand-black mb-10">
        Empieza con<br/><span class="italic text-brand-primary">lo gratuito.</span>
      </h2>
      <p class="text-lg text-neutral-600 font-light max-w-xl mx-auto mb-12">Prueba nuestras herramientas sin costo. Después decide qué curso tomar.</p>
      <a href="/herramientas" class="inline-flex items-center gap-4 bg-brand-black text-white px-10 py-5 text-[11px] tracking-[0.25em] uppercase hover:bg-brand-primary transition-colors duration-500">Ver herramientas gratuitas →</a>
    </div>
  </section>

  <script>
    const ro = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-in'); ro.unobserve(e.target) } }), { threshold: .15, rootMargin: '0px 0px -60px 0px' });
    document.querySelectorAll('.reveal').forEach(el => ro.observe(el));
  </script>

</MainLayout>
