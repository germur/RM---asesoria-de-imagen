---
// /src/pages/productos.astro
// Vitrina editorial · Roger Murillo
// Versión inicial: showroom sin carrito. CTAs a WhatsApp con mensaje pre-cargado.
// Migrable: PRODUCTS array → Shopify/Stripe sin cambiar el render.
import MainLayout from "../layouts/MainLayout.astro";

const WA_NUMBER = "573214189010";

const PRODUCTS = [
  // ── Alfaparf ──
  { id:"alf-01", brand:"Alfaparf", cat:"tratamiento", hair:["seco","teñido"], shape:"tarro",  dark:false, title:"Semi di Lino Reconstruction", sub:"Máscara reconstructora 500ml", price:189000, pricePro:134000, rmPick:true,  studio:true,  desc:"Restaura la fibra capilar desde la primera aplicación. Ideal post-decoloración. Uso semanal." },
  { id:"alf-02", brand:"Alfaparf", cat:"shampoo",     hair:["teñido"],         shape:"botella",dark:false, title:"Semi di Lino Color Shampoo",  sub:"Protector de color 250ml",     price:98000,  pricePro:68000,  rmPick:false, studio:true,  desc:"Preserva la vibración del color con tecnología UV-shield. Cabellos teñidos." },
  { id:"alf-03", brand:"Alfaparf", cat:"styling",     hair:["rizado"],         shape:"tubo",   dark:true,  title:"Curls Defining Cream",        sub:"Crema definidora 200ml",       price:112000, pricePro:82000,  rmPick:false, studio:false, desc:"Define sin apelmazar. Hidratación profunda para rizos definidos hasta 48h." },
  { id:"alf-04", brand:"Alfaparf", cat:"color",       hair:["teñido"],         shape:"tubo",   dark:true,  title:"Evolution of the Color",      sub:"Tinte permanente 60ml",        price:54000,  pricePro:32000,  rmPick:false, studio:true,  desc:"Color de alta fidelidad con tecnología microlight. 60+ tonos disponibles." },
  { id:"alf-05", brand:"Alfaparf", cat:"tratamiento", hair:["seco"],           shape:"botella",dark:true,  title:"Keratin Liss Fluid",          sub:"Sérum anti-frizz 125ml",       price:145000, pricePro:102000, rmPick:true,  studio:false, desc:"Alisado ligero con keratina hidrolizada. Control del frizz hasta 72h." },
  { id:"alf-06", brand:"Alfaparf", cat:"styling",     hair:["graso"],          shape:"spray",  dark:false, title:"Volume Boost Spray",          sub:"Spray volumen 200ml",          price:89000,  pricePro:60000,  rmPick:false, studio:false, desc:"Volumen desde la raíz sin residuos. Ideal cabellos finos o con tendencia a aplanarse." },

  // ── L'Oréal Professionnel ──
  { id:"lor-01", brand:"L'Oréal", cat:"shampoo",     hair:["seco","teñido"],  shape:"botella",dark:false, title:"Absolut Repair Shampoo",      sub:"Shampoo reparador 300ml",      price:115000, pricePro:79000,  rmPick:true,  studio:true,  desc:"Con aminoácidos Gold Quinoa. Reconstrucción molecular para cabellos muy dañados." },
  { id:"lor-02", brand:"L'Oréal", cat:"tratamiento", hair:["seco"],           shape:"tarro",  dark:true,  title:"Absolut Repair Mask",         sub:"Máscara reparadora 250ml",     price:168000, pricePro:118000, rmPick:true,  studio:true,  desc:"Tratamiento intensivo en 3 minutos. Cabellos severamente sensibilizados." },
  { id:"lor-03", brand:"L'Oréal", cat:"color",       hair:["teñido"],         shape:"tubo",   dark:false, title:"Majirel Cool Cover",          sub:"Tinte cobertura canas 50ml",   price:48000,  pricePro:28000,  rmPick:false, studio:true,  desc:"100% cobertura de canas con reflejos frios. Resultado natural y duradero." },
  { id:"lor-04", brand:"L'Oréal", cat:"styling",     hair:["rizado"],         shape:"tubo",   dark:true,  title:"Tecni.Art Curl Contour",      sub:"Crema activa rizos 150ml",     price:92000,  pricePro:64000,  rmPick:false, studio:false, desc:"Hidrata, define y controla el frizz. Hold flexible con brillo natural." },
  { id:"lor-05", brand:"L'Oréal", cat:"shampoo",     hair:["graso"],          shape:"botella",dark:false, title:"Scalp Advanced Anti-Gras",    sub:"Shampoo purificante 300ml",    price:108000, pricePro:74000,  rmPick:false, studio:true,  desc:"Regula la producción de sebo en el cuero cabelludo. Uso diario sin resecar." },
  { id:"lor-06", brand:"L'Oréal", cat:"styling",     hair:["seco","teñido"],  shape:"spray",  dark:true,  title:"Infinium Pure Strong",        sub:"Fijador fuerte 500ml",         price:78000,  pricePro:52000,  rmPick:false, studio:true,  desc:"Fijación profesional sin residuos. Listo para peinar de nuevo en segundos." },

  // ── Kerastase ──
  { id:"ker-01", brand:"Kerastase", cat:"tratamiento", hair:["seco","teñido"], shape:"tarro",  dark:false, title:"Masque Magistral",            sub:"Máscara ultra-nutritiva 200ml",price:245000, pricePro:172000, rmPick:true,  studio:true,  desc:"Cabellos muy secos. Con ceramidas y omega 3. La máscara insignia de Kerastase." },
  { id:"ker-02", brand:"Kerastase", cat:"shampoo",     hair:["teñido"],         shape:"botella",dark:false, title:"Bain Chromatique",            sub:"Shampoo cabello teñido 250ml", price:165000, pricePro:116000, rmPick:false, studio:true,  desc:"Protege el color hasta 40 días. Nutre y sella la fibra para un brillo espejo." },
  { id:"ker-03", brand:"Kerastase", cat:"styling",     hair:["seco","teñido"], shape:"spray",  dark:true,  title:"Elixir Ultime Oil",           sub:"Aceite finalizador 100ml",     price:198000, pricePro:138000, rmPick:true,  studio:true,  desc:"Aceite multi-usos. Sérum de noche, leave-in, acabado brillante. El clásico." },
  { id:"ker-04", brand:"Kerastase", cat:"tratamiento", hair:["seco"],           shape:"botella",dark:true,  title:"Resistance Ciment Thermique", sub:"Sérum reconstructor 150ml",    price:142000, pricePro:99000,  rmPick:false, studio:false, desc:"Protector térmico reconstructor. Fortalece la fibra antes del calor." },
  { id:"ker-05", brand:"Kerastase", cat:"styling",     hair:["rizado"],         shape:"tubo",   dark:false, title:"Curl Manifesto Cream",        sub:"Crema hidratante 150ml",       price:178000, pricePro:124000, rmPick:false, studio:false, desc:"Hidratación sin peso para rizos definidos y elásticos. Sin parabenos." },
  { id:"ker-06", brand:"Kerastase", cat:"color",       hair:["teñido"],         shape:"tubo",   dark:true,  title:"Chroma Absolu Booster",       sub:"Booster de color 10ml × 3",    price:89000,  pricePro:58000,  rmPick:false, studio:true,  desc:"Aditivo pre-shampoo que prolonga el color y neutraliza reflejos no deseados." },
];

const fmt = (n) => "$ " + n.toLocaleString("es-CO");
---

<MainLayout title="Productos · Roger Murillo" description="Curaduría RM: Alfaparf, L'Oréal Professionnel y Kerastase. Los productos que usamos en el estudio.">

<!-- ─── HERO ───────────────────────────── -->
<section class="hero py-20 md:py-28">
  <div class="relative container mx-auto px-6 max-w-[1400px]">
    <p class="hero-label text-[10px] uppercase text-[#C41230] mb-6">Productos · Curaduría RM</p>
    <h1 class="font-serif text-5xl md:text-7xl leading-[1.03] mb-6 max-w-3xl">
      Los productos <span class="italic text-neutral-400">que realmente usamos</span> en el estudio.
    </h1>
    <p class="max-w-xl text-sm md:text-base text-neutral-300 font-light leading-relaxed">
      Una selección curada de Alfaparf, L'Oréal Professionnel y Kerastase — los mismos que recomendamos
      en consulta. Consulta disponibilidad y reserva por WhatsApp; despachamos en Bogotá y a todo Colombia.
    </p>
    <div class="mt-10 flex flex-wrap gap-x-10 gap-y-4 text-[11px] tracking-[0.25em] uppercase text-neutral-400">
      <span>· {PRODUCTS.length} productos</span>
      <span>· 3 marcas</span>
      <span>· 4 categorías</span>
      <span>· Envío nacional</span>
    </div>
  </div>
</section>

<!-- ─── FILTROS ────────────────────────── -->
<div class="filter-bar">
  <div class="container mx-auto px-6 max-w-[1400px] py-5">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 items-center">
      <div class="search-wrap max-w-md">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <circle cx="11" cy="11" r="7"></circle><path d="M21 21l-4.35-4.35"></path>
        </svg>
        <input id="search" type="search" class="search-input" placeholder="Buscar producto, marca, necesidad..." />
      </div>
      <div class="text-[10px] tracking-[0.3em] uppercase text-neutral-500">
        <span id="results-count">{PRODUCTS.length}</span> productos
      </div>
    </div>

    <div class="mt-4 flex gap-3 overflow-x-auto pb-1">
      <button class="chip is-active" data-filter="cat" data-value="all">Todos <span class="count">{PRODUCTS.length}</span></button>
      <button class="chip" data-filter="cat" data-value="tratamiento">Tratamiento</button>
      <button class="chip" data-filter="cat" data-value="shampoo">Shampoo & Acond.</button>
      <button class="chip" data-filter="cat" data-value="styling">Styling</button>
      <button class="chip" data-filter="cat" data-value="color">Color</button>
    </div>

    <div class="mt-3 flex flex-wrap gap-3">
      <button class="chip" data-filter="brand" data-value="all">Todas las marcas</button>
      <button class="chip" data-filter="brand" data-value="Alfaparf">Alfaparf</button>
      <button class="chip" data-filter="brand" data-value="L'Oréal">L'Oréal Pro</button>
      <button class="chip" data-filter="brand" data-value="Kerastase">Kerastase</button>
      <span class="w-px h-6 bg-neutral-200 mx-2 self-center hidden md:block"></span>
      <button class="chip" data-filter="hair" data-value="all">Todo tipo de cabello</button>
      <button class="chip" data-filter="hair" data-value="seco">Seco/Dañado</button>
      <button class="chip" data-filter="hair" data-value="teñido">Teñido</button>
      <button class="chip" data-filter="hair" data-value="graso">Graso</button>
      <button class="chip" data-filter="hair" data-value="rizado">Rizado</button>
    </div>
  </div>
</div>

<!-- ─── GRID ───────────────────────────── -->
<main class="container mx-auto px-6 max-w-[1400px] py-12 md:py-16">
  <div id="grid" class="grid grid-density-3 gap-6">
    {PRODUCTS.map((p) => (
      <article class="prod-card" data-id={p.id} data-cat={p.cat} data-brand={p.brand} data-hair={p.hair.join(",")}
               data-search={`${p.title} ${p.brand} ${p.sub} ${p.desc}`.toLowerCase()}>
        <div class={`prod-media ${p.dark ? "bg-dark" : ""}`}>
          <div class="prod-badges">
            {p.rmPick && <span class="badge-rm">Roger recomienda</span>}
            {p.studio && <span class="badge-studio">Usado en el estudio</span>}
          </div>
          <span class="badge-pro" style="display:none">Pro</span>
          <div class="prod-svg" data-shape={p.shape} data-dark={p.dark ? "1" : "0"}></div>
        </div>
        <div class="prod-body">
          <span class="prod-brand">{p.brand}</span>
          <h3 class="prod-title">{p.title}</h3>
          <p class="prod-sub">{p.sub}</p>
          <div class="prod-price">{fmt(p.price)}<span class="iva">IVA incl.</span></div>
          <div class="price-pro">Pro: {fmt(p.pricePro)}</div>
          <button class="prod-cta" data-wa={`Hola, me interesa ${p.title} (${p.brand}) · ${fmt(p.price)}. ¿Disponibilidad?`}>
            <svg class="wa" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.297-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.42 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
            Consultar
          </button>
          <div class="prod-row">
            <button class="quick" data-quick={p.id}>Quick view</button>
            <button class="heart" data-fav={p.id} aria-label="Favorito">
              <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            </button>
          </div>
        </div>
      </article>
    ))}
  </div>
  <div id="empty-state" class="hidden text-center py-20">
    <p class="font-serif italic text-3xl text-neutral-400 mb-3">Sin resultados.</p>
    <p class="text-sm text-neutral-500">Prueba con otra combinación de filtros o <button class="underline" id="reset-filters">limpiar filtros</button>.</p>
  </div>
</main>

<!-- ─── BUNDLE ─────────────────────────── -->
<section class="bundle py-20 md:py-24">
  <div class="relative container mx-auto px-6 max-w-[1400px] grid md:grid-cols-2 gap-12 items-center">
    <div>
      <p class="text-[10px] tracking-[0.4em] uppercase text-[#C41230] mb-5">Bundle · Edición limitada</p>
      <h2 class="font-serif text-4xl md:text-5xl leading-[1.05] mb-6">
        La rutina RM <span class="italic text-neutral-400">en tres pasos.</span>
      </h2>
      <p class="text-neutral-400 font-light leading-relaxed mb-8 max-w-md">
        Shampoo restaurador + tratamiento intensivo + aceite final. La combinación que usamos
        después de cada consulta de color. Curada para cabello tratado químicamente.
      </p>
      <div class="space-y-3 text-sm text-neutral-300 mb-10">
        <div class="flex gap-3"><span class="text-[#C41230] font-serif italic">01</span>Shampoo Absolut Repair · L'Oréal Professionnel</div>
        <div class="flex gap-3"><span class="text-[#C41230] font-serif italic">02</span>Máscara Keratine Forte · Alfaparf</div>
        <div class="flex gap-3"><span class="text-[#C41230] font-serif italic">03</span>Elixir Ultime · Kerastase</div>
      </div>
      <div class="flex items-baseline gap-4 mb-8">
        <span class="font-serif text-3xl">$ 289.000</span>
        <span class="text-sm line-through text-neutral-500">$ 340.000</span>
        <span class="text-[10px] tracking-[0.25em] uppercase text-[#C41230]">Ahorra 15%</span>
      </div>
      <a href="#" data-wa="Hola, quiero el bundle La Rutina RM (3 productos · $289.000). ¿Disponibilidad?"
         class="wa-cta inline-flex items-center gap-3 px-7 py-4 bg-white text-black text-[10px] tracking-[0.25em] uppercase hover:bg-[#C41230] hover:text-white transition-colors">
        Consultar bundle
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.297-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.42 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
      </a>
    </div>
    <div class="grid grid-cols-3 gap-4">
      <div class="bundle-bottle flex items-center justify-center p-4"><div class="prod-svg" data-shape="botella" data-dark="1"></div></div>
      <div class="bundle-bottle flex items-center justify-center p-4 mt-8"><div class="prod-svg" data-shape="tarro" data-dark="1"></div></div>
      <div class="bundle-bottle flex items-center justify-center p-4"><div class="prod-svg" data-shape="spray" data-dark="1"></div></div>
    </div>
  </div>
</section>

<!-- ─── REVIEWS ────────────────────────── -->
<section class="py-20 md:py-24 bg-white">
  <div class="container mx-auto px-6 max-w-[1200px]">
    <p class="text-[10px] tracking-[0.4em] uppercase text-[#C41230] mb-5">Testimonios</p>
    <h2 class="font-serif text-4xl md:text-5xl leading-[1.05] mb-12 max-w-2xl">
      Lo que dicen <span class="italic text-neutral-400">nuestras clientas.</span>
    </h2>
    <div class="grid md:grid-cols-3 gap-10">
      <div class="review">
        <div class="stars mb-4" set:html={'<svg viewBox=\'0 0 24 24\'><path d=\'M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z\'/></svg>'.repeat(5)} />
        <p class="font-serif italic text-lg leading-relaxed text-neutral-700 mb-4">"El kit de color que Roger me recomendó me cambió la fibra. Por fin un salón que te dice exactamente qué usar en casa."</p>
        <p class="text-[11px] tracking-[0.2em] uppercase text-neutral-500">Valentina G. · Bogotá</p>
      </div>
      <div class="review">
        <div class="stars mb-4" set:html={'<svg viewBox=\'0 0 24 24\'><path d=\'M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z\'/></svg>'.repeat(5)} />
        <p class="font-serif italic text-lg leading-relaxed text-neutral-700 mb-4">"Llevo dos años con el mismo protocolo que me diseñaron aquí. Mi cabello nunca estuvo mejor."</p>
        <p class="text-[11px] tracking-[0.2em] uppercase text-neutral-500">María Fernanda A. · Medellín</p>
      </div>
      <div class="review">
        <div class="stars mb-4" set:html={'<svg viewBox=\'0 0 24 24\'><path d=\'M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z\'/></svg>'.repeat(5)} />
        <p class="font-serif italic text-lg leading-relaxed text-neutral-700 mb-4">"Consultar por WhatsApp fue rapidísimo. Me enviaron foto, precio y me llegó en 2 días."</p>
        <p class="text-[11px] tracking-[0.2em] uppercase text-neutral-500">Laura C. · Cali</p>
      </div>
    </div>
  </div>
</section>

<!-- ─── GUÍA ───────────────────────────── -->
<section class="guia py-20 md:py-24">
  <div class="container mx-auto px-6 max-w-[1400px] grid md:grid-cols-[1fr_1.2fr] gap-12 items-center">
    <div>
      <p class="text-[10px] tracking-[0.4em] uppercase text-[#C41230] mb-5">¿No sabes qué llevar?</p>
      <h2 class="font-serif text-4xl md:text-5xl leading-[1.05] mb-6">
        Cada cabello <span class="italic text-neutral-500">es distinto.</span>
      </h2>
      <p class="text-neutral-600 font-light leading-relaxed mb-8 max-w-md">
        Si estás entre dos productos o no sabes qué necesita tu cabello hoy, agenda una
        consulta de 20 minutos. Sin costo. Te recomendamos exactamente lo que usa tu estilista.
      </p>
      <a href="/contacto" class="inline-flex items-center gap-3 px-7 py-4 bg-brand-black text-white text-[10px] tracking-[0.25em] uppercase hover:bg-[#C41230] transition-colors">
        Agendar consulta gratuita
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
      </a>
    </div>
    <div class="grid grid-cols-2 gap-3 text-sm">
      <div class="p-5 bg-white border border-neutral-200"><p class="text-[10px] tracking-[0.3em] uppercase text-[#C41230] mb-2">01</p><p class="font-serif text-lg mb-1">Cabello teñido</p><p class="text-neutral-500 leading-relaxed">Protector de color + máscara nutritiva semanal.</p></div>
      <div class="p-5 bg-white border border-neutral-200"><p class="text-[10px] tracking-[0.3em] uppercase text-[#C41230] mb-2">02</p><p class="font-serif text-lg mb-1">Cabello seco</p><p class="text-neutral-500 leading-relaxed">Rutina hidratante con aceites + tratamiento profundo.</p></div>
      <div class="p-5 bg-white border border-neutral-200"><p class="text-[10px] tracking-[0.3em] uppercase text-[#C41230] mb-2">03</p><p class="font-serif text-lg mb-1">Cabello graso</p><p class="text-neutral-500 leading-relaxed">Shampoo purificante + balance en cuero cabelludo.</p></div>
      <div class="p-5 bg-white border border-neutral-200"><p class="text-[10px] tracking-[0.3em] uppercase text-[#C41230] mb-2">04</p><p class="font-serif text-lg mb-1">Cabello rizado</p><p class="text-neutral-500 leading-relaxed">Styling definidor + antifrizz sin residuos.</p></div>
    </div>
  </div>
</section>


<!-- ─── QUICK VIEW MODAL ─────────────── -->
<div id="quickview" role="dialog" aria-modal="true">
  <div class="qv-card">
