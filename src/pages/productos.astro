<!-- ═══ STYLES ═══════════════════════════════════════════ -->
<style is:global>
  :root {
    --brand-primary:#C41230;
    --brand-black:#0a0a0a;
    --cream-1:#f6f4f0;
    --cream-2:#ebe3d2;
    --cream-3:#d9d1bf;
  }
  /* page-scoped background — only main, not html/body, to avoid breaking navbar/footer */
  main { background: var(--cream-1); color: var(--brand-black); }

  /* HERO */
  .hero { background: var(--brand-black); color:#fff; position:relative; overflow:hidden; }
  .hero::before {
    content:""; position:absolute; inset:0; pointer-events:none;
    background:
      radial-gradient(ellipse at 75% 30%, rgba(196,18,48,.22), transparent 45%),
      repeating-linear-gradient(90deg, transparent 0 14.28%, rgba(255,255,255,.04) 14.28%, rgba(255,255,255,.04) calc(14.28% + 1px), transparent calc(14.28% + 1px) 16%);
    opacity:.7;
  }
  .hero-label { letter-spacing:.4em; }

  /* CARDS */
  .prod-card { position:relative; background:#fff; transition: transform .5s cubic-bezier(.7,0,.3,1), box-shadow .5s; display:flex; flex-direction:column; }
  .prod-card:hover { box-shadow: 0 20px 60px rgba(10,10,10,.08); }
  .prod-card.is-hidden { display:none; }
  .prod-media { aspect-ratio: 4/5; position:relative; overflow:hidden; background: linear-gradient(180deg, #f6f1e8 0%, #e8ddc7 100%); transition: background .4s; }
  .prod-media.bg-dark { background: radial-gradient(ellipse at 60% 35%, #2a2020 0%, #0f0a08 80%); }
  .prod-media svg { position:absolute; top:50%; left:50%; transform: translate(-50%, -50%); transition: transform .8s cubic-bezier(.7,0,.3,1); }
  .prod-card:hover .prod-media svg { transform: translate(-50%, -50%) scale(1.04); }

  .prod-body { padding: 18px 20px 22px; display:flex; flex-direction:column; gap:6px; flex:1; }
  .prod-brand { font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:rgba(10,10,10,.5); }
  .prod-title { font-family:'Playfair Display', serif; font-size:18px; line-height:1.15; color:var(--brand-black); transition: color .3s; }
  .prod-card:hover .prod-title { color: var(--brand-primary); }
  .prod-sub   { font-size:12px; color:rgba(10,10,10,.55); line-height:1.5; }
  .prod-price { font-family:'Playfair Display', serif; font-size:17px; color:var(--brand-black); margin-top:6px; }
  .prod-price .iva { font-family:'Inter', sans-serif; font-size:9px; color:rgba(10,10,10,.45); letter-spacing:.2em; text-transform:uppercase; margin-left:4px; }
  .prod-cta { margin-top:14px; display:flex; align-items:center; gap:10px; padding:10px 14px; border:1px solid rgba(10,10,10,.15); font-size:10px; letter-spacing:.22em; text-transform:uppercase; transition: all .4s; cursor:pointer; background:#fff; }
  .prod-cta:hover { background: var(--brand-black); color:#fff; border-color: var(--brand-black); }
  .prod-cta .wa { width:12px; height:12px; fill:currentColor; }

  .prod-row { display:flex; gap:8px; margin-top:auto; padding-top:12px; }
  .prod-row .quick { flex:1; font-size:9px; letter-spacing:.22em; text-transform:uppercase; padding:10px; border:1px solid rgba(10,10,10,.1); background:transparent; cursor:pointer; transition: border-color .3s, color .3s; }
  .prod-row .quick:hover { border-color: var(--brand-black); }
  .prod-row .heart { width:38px; height:38px; display:inline-flex; align-items:center; justify-content:center; border:1px solid rgba(10,10,10,.1); cursor:pointer; transition: all .3s; flex-shrink:0; }
  .prod-row .heart:hover { border-color: var(--brand-primary); }
  .prod-row .heart svg { width:14px; height:14px; stroke:currentColor; fill:none; transition: all .3s; }
  .prod-row .heart.is-active { border-color: var(--brand-primary); color:var(--brand-primary); }
  .prod-row .heart.is-active svg { fill: var(--brand-primary); stroke: var(--brand-primary); }

  .prod-badges { position:absolute; top:12px; left:12px; z-index:3; display:flex; flex-direction:column; gap:6px; align-items:flex-start; }
  .badge-rm { background: var(--brand-primary); color:#fff; padding: 4px 9px 4px 8px; font-size:9px; letter-spacing:.25em; text-transform:uppercase; display:inline-flex; align-items:center; gap:5px; }
  .badge-rm::before { content:""; width:5px; height:5px; border-radius:50%; background:#fff; }
  .badge-studio { background: rgba(10,10,10,.85); color:#fff; padding: 4px 9px; font-size:9px; letter-spacing:.25em; text-transform:uppercase; backdrop-filter: blur(4px); }
  .badge-pro { position:absolute; top:12px; right:12px; z-index:3; background: #fff; color: var(--brand-black); border:1px solid var(--brand-black); padding: 4px 9px; font-size:9px; letter-spacing:.25em; text-transform:uppercase; }

  .price-pro { display:none; color: var(--brand-primary); font-size:12px; margin-top:2px; }
  body.mode-pro .price-pro { display:block; }
  body.mode-pro .prod-price { color: rgba(10,10,10,.4); text-decoration: line-through; font-size:13px; }

  /* FILTROS */
  .filter-bar { position: sticky; top: 0; z-index: 30; background: rgba(246,244,240,.92); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); border-bottom: 1px solid rgba(10,10,10,.08); }
  .chip { display:inline-flex; align-items:center; gap:8px; padding:9px 14px; border:1px solid rgba(10,10,10,.15); font-size:10px; letter-spacing:.2em; text-transform:uppercase; background:#fff; cursor:pointer; transition: all .3s; white-space:nowrap; }
  .chip:hover { border-color: var(--brand-black); }
  .chip.is-active { background: var(--brand-black); color:#fff; border-color: var(--brand-black); }
  .chip .count { font-size:9px; opacity:.6; }
  .search-input { width:100%; padding:12px 16px 12px 42px; border:1px solid rgba(10,10,10,.12); background:#fff; font-size:13px; color:var(--brand-black); font-weight:300; transition: border-color .3s; }
  .search-input:focus { outline:none; border-color: var(--brand-black); }
  .search-wrap { position:relative; }
  .search-wrap > svg { position:absolute; left:14px; top:50%; transform: translateY(-50%); color: rgba(10,10,10,.4); }

  /* GRID density */
  .grid-density-2 { grid-template-columns: repeat(2, 1fr); }
  .grid-density-3 { grid-template-columns: repeat(3, 1fr); }
  .grid-density-4 { grid-template-columns: repeat(4, 1fr); }
  @media (max-width:767px) { .grid-density-2, .grid-density-3, .grid-density-4 { grid-template-columns: repeat(2, 1fr); } }

  /* BUNDLE */
  .bundle { background: var(--brand-black); color:#fff; position:relative; overflow:hidden; }
  .bundle::before { content:""; position:absolute; inset:0; pointer-events:none; background: radial-gradient(ellipse at 20% 80%, rgba(196,18,48,.25), transparent 50%), linear-gradient(135deg, transparent 60%, rgba(244,217,160,.08) 100%); }
  .bundle-bottle { background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.01)); border:1px solid rgba(255,255,255,.1); aspect-ratio: 3/4; position:relative; }

  /* QUICK VIEW */
  #quickview { position: fixed; inset: 0; z-index: 80; background: rgba(10,10,10,.7); backdrop-filter: blur(10px); opacity: 0; visibility: hidden; transition: opacity .4s, visibility .4s; display: flex; align-items: center; justify-content: center; padding: 24px; }
  #quickview.is-open { opacity: 1; visibility: visible; }
  .qv-card { background:#fff; width:100%; max-width: 980px; max-height: 90vh; overflow:hidden; display:grid; grid-template-columns: 1fr 1fr; transform: scale(.96) translateY(12px); transition: transform .45s cubic-bezier(.7,0,.3,1); position:relative; }
  @media (max-width:767px) { .qv-card { grid-template-columns: 1fr; max-height: 94vh; overflow-y:auto; } }
  #quickview.is-open .qv-card { transform: scale(1) translateY(0); }
  .qv-close { position: absolute; top: 14px; right: 14px; z-index:3; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,.9); color: #0a0a0a; cursor: pointer; }
  .qv-media { background: var(--cream-2); position:relative; min-height:360px; }
  .qv-media.dark { background: radial-gradient(ellipse at 60% 35%, #2a2020, #0f0a08 80%); }
  .qv-media svg { position:absolute; top:50%; left:50%; transform: translate(-50%, -50%); }
  .qv-body { padding: 40px 36px; overflow-y:auto; }

  .stars { display:inline-flex; gap:2px; }
  .stars svg { width:14px; height:14px; fill: var(--brand-primary); }

  /* REVIEWS */
  .review { border-top:1px solid rgba(10,10,10,.1); padding:28px 0; }

  /* GUÍA */
  .guia { background: var(--cream-2); }

  /* TWEAKS */
  #tweaks { position: fixed; right: 24px; bottom: 24px; z-index:70; background:#fff; border:1px solid rgba(10,10,10,.1); box-shadow: 0 20px 60px rgba(10,10,10,.12); width: 280px; padding: 18px 18px 16px; transform: translateY(8px); opacity:0; pointer-events:none; transition: opacity .3s, transform .3s; }
  #tweaks.is-open { opacity:1; transform: translateY(0); pointer-events:auto; }
  #tweaks-toggle { position: fixed; right: 24px; bottom: 24px; z-index:69; width: 52px; height: 52px; border-radius: 50%; background: var(--brand-black); color:#fff; display:flex; align-items:center; justify-content:center; cursor:pointer; box-shadow: 0 12px 30px rgba(10,10,10,.2); border:none; transition: transform .3s; }
  #tweaks-toggle:hover { transform: scale(1.05); }
  .tw-section { margin-bottom: 14px; }
  .tw-section:last-child { margin-bottom: 0; }
  .tw-label { font-size:9px; letter-spacing:.3em; text-transform:uppercase; color: rgba(10,10,10,.5); margin-bottom:8px; display:block; }
  .tw-row { display:flex; gap:6px; }
  .tw-btn { flex:1; padding: 7px 4px; font-size:10px; letter-spacing:.15em; text-transform:uppercase; border:1px solid rgba(10,10,10,.15); background:#fff; cursor:pointer; transition: all .3s; }
  .tw-btn.is-active { background: var(--brand-black); color:#fff; border-color: var(--brand-black); }

  /* WA FLOAT */
  .wa-float { position: fixed; left: 24px; bottom: 24px; z-index: 60; background: #25D366; color: #fff; width: 52px; height: 52px; border-radius: 50%; display:flex; align-items:center; justify-content:center; box-shadow: 0 10px 30px rgba(37,211,102,.35); transition: transform .3s; }
  .wa-float:hover { transform: scale(1.08); }
</style>

<!-- ═══ SCRIPTS ═══════════════════════════════════════════ -->
<script is:inline define:vars={{ PRODUCTS, WA_NUMBER }}>
/* SVG factories */
const SVG = {
  botella(dark){
    const fill=dark?'#2a1c18':'#f1e4c8', stroke=dark?'#d4a474':'#8b6f4a', cap=dark?'#0a0606':'#3a2818';
    return `<svg width="160" height="220" viewBox="0 0 160 220" fill="none">
      <rect x="62" y="6" width="36" height="26" rx="2" fill="${cap}"/>
      <path d="M68 32h24l4 18c10 4 18 14 18 28v120c0 8-6 14-14 14H60c-8 0-14-6-14-14V78c0-14 8-24 18-28l4-18z" fill="${fill}" stroke="${stroke}" stroke-width="1"/>
      <rect x="56" y="100" width="48" height="56" fill="none" stroke="${stroke}" stroke-width=".8" opacity=".6"/>
      <text x="80" y="125" text-anchor="middle" font-family="Playfair Display" font-style="italic" font-size="11" fill="${stroke}">RM</text>
      <rect x="56" y="134" width="48" height="1.5" fill="#C41230"/>
      <text x="80" y="148" text-anchor="middle" font-family="Inter" font-size="6" letter-spacing="1.5" fill="${stroke}">NUTRITIVO</text>
    </svg>`;
  },
  tubo(dark){
    const fill=dark?'#1a1210':'#e8ddc7', stroke=dark?'#d4a474':'#8b6f4a', cap=dark?'#0a0606':'#2a2020';
    return `<svg width="160" height="220" viewBox="0 0 160 220" fill="none">
      <path d="M40 8 L120 8 L120 14 L40 14 Z" fill="${cap}"/>
      <path d="M42 14 L118 14 L124 30 C128 40 128 55 124 70 L120 200 C120 208 114 214 106 214 L54 214 C46 214 40 208 40 200 L36 70 C32 55 32 40 36 30 Z" fill="${fill}" stroke="${stroke}" stroke-width="1"/>
      <rect x="44" y="80" width="72" height="90" fill="none" stroke="${stroke}" stroke-width=".8" opacity=".5"/>
      <text x="80" y="120" text-anchor="middle" font-family="Playfair Display" font-style="italic" font-size="22" fill="${stroke}">RM</text>
      <line x1="46" y1="135" x2="114" y2="135" stroke="#C41230" stroke-width="1"/>
      <text x="80" y="152" text-anchor="middle" font-family="Inter" font-size="6.5" letter-spacing="2" fill="${stroke}">TREATMENT</text>
    </svg>`;
  },
  spray(dark){
    const fill=dark?'#2a1c18':'#f1e4c8', stroke=dark?'#d4a474':'#8b6f4a', cap=dark?'#0a0606':'#2a2020';
    return `<svg width="160" height="220" viewBox="0 0 160 220" fill="none">
      <rect x="68" y="4" width="22" height="10" fill="${cap}"/>
      <path d="M64 14h32l2 14h-36z" fill="${cap}"/>
      <rect x="70" y="28" width="20" height="8" fill="${stroke}"/>
      <rect x="52" y="36" width="56" height="178" rx="4" fill="${fill}" stroke="${stroke}" stroke-width="1"/>
      <rect x="56" y="90" width="48" height="60" fill="none" stroke="${stroke}" stroke-width=".8" opacity=".5"/>
      <text x="80" y="115" text-anchor="middle" font-family="Playfair Display" font-style="italic" font-size="14" fill="${stroke}">RM</text>
      <line x1="58" y1="124" x2="102" y2="124" stroke="#C41230" stroke-width=".8"/>
      <text x="80" y="140" text-anchor="middle" font-family="Inter" font-size="5.5" letter-spacing="1.5" fill="${stroke}">FINISHING SPRAY</text>
    </svg>`;
  },
  tarro(dark){
    const fill=dark?'#1a1210':'#ebe3d2', stroke=dark?'#d4a474':'#8b6f4a', cap=dark?'#0a0606':'#2a2020';
    return `<svg width="180" height="220" viewBox="0 0 180 220" fill="none">
      <ellipse cx="90" cy="42" rx="60" ry="10" fill="${cap}"/>
      <rect x="30" y="36" width="120" height="14" fill="${cap}"/>
      <path d="M36 50 L144 50 L148 180 C148 198 138 208 120 210 L60 210 C42 208 32 198 32 180 Z" fill="${fill}" stroke="${stroke}" stroke-width="1"/>
      <rect x="48" y="90" width="84" height="68" fill="none" stroke="${stroke}" stroke-width=".8" opacity=".5"/>
      <text x="90" y="128" text-anchor="middle" font-family="Playfair Display" font-style="italic" font-size="26" fill="${stroke}">RM</text>
      <line x1="52" y1="140" x2="128" y2="140" stroke="#C41230" stroke-width="1"/>
      <text x="90" y="155" text-anchor="middle" font-family="Inter" font-size="7" letter-spacing="2" fill="${stroke}">HAIR MASK</text>
    </svg>`;
  }
};

/* Render placeholder SVGs */
document.querySelectorAll('.prod-svg').forEach(el => {
  const shape = el.dataset.shape, dark = el.dataset.dark === '1';
  if (SVG[shape]) el.innerHTML = SVG[shape](dark);
});

const fmt = (n) => '$ ' + n.toLocaleString('es-CO');
const grid = document.getElementById('grid');
const emptyState = document.getElementById('empty-state');
const state = {
  cat:'all', brand:'all', hair:'all', search:'',
  wishlist: JSON.parse(localStorage.getItem('rm_wishlist') || '[]')
};

/* Init wishlist hearts */
state.wishlist.forEach(id => {
  document.querySelector(`[data-fav="${id}"]`)?.classList.add('is-active');
});

/* Filters */
function applyFilters(){
  const q = state.search.toLowerCase().trim();
  let visible = 0;
  document.querySelectorAll('.prod-card').forEach(card => {
    const cat = card.dataset.cat;
    const brand = card.dataset.brand;
    const hair = card.dataset.hair.split(',');
    const search = card.dataset.search;
    let show = true;
    if (state.cat   !== 'all' && cat   !== state.cat)   show = false;
    if (state.brand !== 'all' && brand !== state.brand) show = false;
    if (state.hair  !== 'all' && !hair.includes(state.hair)) show = false;
    if (q && !search.includes(q)) show = false;
    card.classList.toggle('is-hidden', !show);
    if (show) visible++;
  });
  document.getElementById('results-count').textContent = visible;
  emptyState.classList.toggle('hidden', visible !== 0);
  grid.classList.toggle('hidden', visible === 0);
}

document.querySelectorAll('.chip').forEach(chip => {
  chip.addEventListener('click', () => {
    const f = chip.dataset.filter, v = chip.dataset.value;
    state[f] = v;
    document.querySelectorAll(`.chip[data-filter="${f}"]`).forEach(c => c.classList.toggle('is-active', c === chip));
    applyFilters();
  });
});

document.getElementById('search').addEventListener('input', e => {
  state.search = e.target.value;
  applyFilters();
});

document.addEventListener('click', e => {
  if (e.target.id === 'reset-filters') {
    state.cat='all'; state.brand='all'; state.hair='all'; state.search='';
    document.getElementById('search').value = '';
    document.querySelectorAll('.chip').forEach(c => c.classList.toggle('is-active', c.dataset.value === 'all'));
    applyFilters();
  }
});

/* WhatsApp handlers */
document.addEventListener('click', e => {
  const t = e.target.closest('[data-wa]');
  if (!t) return;
  e.preventDefault();
  const msg = encodeURIComponent(t.dataset.wa);
  window.open(`https://wa.me/${WA_NUMBER}?text=${msg}`, '_blank', 'noopener');
});

/* Wishlist */
document.addEventListener('click', e => {
  const b = e.target.closest('[data-fav]');
  if (!b) return;
  const id = b.dataset.fav;
  const i = state.wishlist.indexOf(id);
  if (i === -1) state.wishlist.push(id); else state.wishlist.splice(i, 1);
  localStorage.setItem('rm_wishlist', JSON.stringify(state.wishlist));
  document.querySelectorAll(`[data-fav="${id}"]`).forEach(el => el.classList.toggle('is-active'));
});

/* Quick view */
const qv      = document.getElementById('quickview');
const qvMedia = document.getElementById('qv-media');
const qvBody  = document.getElementById('qv-body');

document.addEventListener('click', e => {
  const b = e.target.closest('[data-quick]');
  if (!b) return;
  const p = PRODUCTS.find(x => x.id === b.dataset.quick);
  if (!p) return;
  qvMedia.className = 'qv-media ' + (p.dark ? 'dark' : '');
  qvMedia.innerHTML = SVG[p.shape](p.dark);
  qvBody.innerHTML = `
    <p class="text-[10px] tracking-[0.3em] uppercase text-[#C41230] mb-3">${p.brand}</p>
    <h3 class="font-serif text-3xl leading-tight mb-3">${p.title}</h3>
    <p class="text-neutral-500 mb-6">${p.sub}</p>
    <div class="flex items-center gap-2 mb-5">
      <div class="stars">${'<svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z"/></svg>'.repeat(5)}</div>
      <span class="text-xs text-neutral-500">4.9 · 128 reseñas</span>
    </div>
    <p class="text-sm text-neutral-600 leading-relaxed mb-8">${p.desc}</p>
    <div class="mb-8">
      <span class="prod-price font-serif text-2xl">${fmt(p.price)}</span>
      <span class="iva">IVA incl.</span>
      <div class="price-pro text-[#C41230] text-sm mt-1">Precio Pro: ${fmt(p.pricePro)}</div>
    </div>
    <div class="flex gap-3">
      <button class="flex-1 py-4 bg-brand-black text-white text-[10px] tracking-[0.25em] uppercase" data-wa="Hola, quiero consultar por ${p.title} (${p.brand}) · ${fmt(p.price)}">
        Consultar por WhatsApp
      </button>
      <button class="heart ${state.wishlist.includes(p.id)?'is-active':''} w-14 h-14 border border-neutral-200 flex items-center justify-center" data-fav="${p.id}">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="${state.wishlist.includes(p.id) ? '#C41230' : 'none'}" stroke="${state.wishlist.includes(p.id) ? '#C41230' : 'currentColor'}" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </button>
    </div>
    <div class="mt-8 pt-6 border-t border-neutral-200 grid grid-cols-2 gap-3 text-[11px] text-neutral-500">
      <div><strong class="text-neutral-800 block text-[10px] tracking-[0.25em] uppercase mb-1">Envío</strong>Nacional · 2-4 días hábiles</div>
      <div><strong class="text-neutral-800 block text-[10px] tracking-[0.25em] uppercase mb-1">Autenticidad</strong>Importación directa</div>
    </div>
  `;
  qv.classList.add('is-open');
  document.body.style.overflow = 'hidden';
});

document.getElementById('qv-close').addEventListener('click', () => {
  qv.classList.remove('is-open'); document.body.style.overflow = '';
});
qv.addEventListener('click', e => { if (e.target === qv) { qv.classList.remove('is-open'); document.body.style.overflow = ''; } });
document.addEventListener('keydown', e => {
  if (e.key === 'Escape' && qv.classList.contains('is-open')) { qv.classList.remove('is-open'); document.body.style.overflow = ''; }
});

/* Tweaks */
const tweaksEl = document.getElementById('tweaks');
const tweaksToggle = document.getElementById('tweaks-toggle');
tweaksToggle.addEventListener('click', () => {
  tweaksEl.classList.toggle('is-open');
  tweaksToggle.style.display = tweaksEl.classList.contains('is-open') ? 'none' : 'flex';
});
document.querySelectorAll('[data-mode]').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('[data-mode]').forEach(b => b.classList.toggle('is-active', b === btn));
    document.body.classList.toggle('mode-pro', btn.dataset.mode === 'pro');
    document.querySelectorAll('.badge-pro').forEach(el => el.style.display = btn.dataset.mode === 'pro' ? 'inline-block' : 'none');
  });
});
document.querySelectorAll('[data-density]').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('[data-density]').forEach(b => b.classList.toggle('is-active', b === btn));
    grid.className = 'grid grid-density-' + btn.dataset.density + ' gap-6';
  });
});
document.querySelectorAll('[data-badges]').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('[data-badges]').forEach(b => b.classList.toggle('is-active', b === btn));
    document.querySelectorAll('.prod-badges').forEach(el => el.style.display = btn.dataset.badges === 'off' ? 'none' : 'flex');
  });
});
document.addEventListener('click', e => {
  if (tweaksEl.classList.contains('is-open') && !tweaksEl.contains(e.target) && e.target !== tweaksToggle && !tweaksToggle.contains(e.target)) {
    tweaksEl.classList.remove('is-open');
    tweaksToggle.style.display = 'flex';
  }
});
</script>

</MainLayout>
