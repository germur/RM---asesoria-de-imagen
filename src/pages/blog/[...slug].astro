---
import { type CollectionEntry, getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: post,
    }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await post.render();
---

<MainLayout title={post.data.title} description={post.data.description}>
    <article class="py-20 max-w-3xl mx-auto px-6">
        <div class="mb-8 text-center">
            {
                post.data.heroImage && (
                    <img
                        width={1020}
                        height={510}
                        src={post.data.heroImage}
                        alt=""
                        class="rounded-lg shadow-lg mb-8"
                    />
                )
            }
            <h1
                class="text-4xl md:text-5xl font-serif font-bold text-gray-900 mb-4"
            >
                {post.data.title}
            </h1>
            <div class="text-gray-500 text-sm">
                <time datetime={post.data.pubDate.toISOString()}>
                    {
                        post.data.pubDate.toLocaleDateString("es-co", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        })
                    }
                </time>
            </div>
        </div>

        <div class="prose prose-stone prose-lg mx-auto">
            <Content />
        </div>
    </article>
</MainLayout>
