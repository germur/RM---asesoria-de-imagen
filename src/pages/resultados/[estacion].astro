---
import MainLayout from "../../layouts/MainLayout.astro";
import PaletteViewer from "../../components/react/PaletteViewer";
import seasons from "../../data/seasons.json"; // Importamos el JSON
import { ArrowRight, BookOpen, ShieldCheck, Star } from "lucide-react";

// 1. Generación de Rutas Estáticas (SSG)
export async function getStaticPaths() {
    return seasons.map((season) => ({
        params: { estacion: season.slug },
        props: { season },
    }));
}

const { season } = Astro.props;

// 2. SEO & GEO Schema (Para que la IA entienda el reporte)
const schema = {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: `Informe de Imagen Ejecutiva: ${season.title}`,
    description: season.geo_definition,
    author: {
        "@type": "Person",
        name: "Roger Murillo",
        jobTitle: "Consultor de Imagen Estratégica",
    },
    publisher: {
        "@type": "Organization",
        name: "Roger Murillo Consulting",
        logo: {
            "@type": "ImageObject",
            url: "https://rogermurillo.co/logo.png",
        },
    },
    mainEntityOfPage: `https://rogermurillo.co/resultados/${season.slug}`,
};
---

<MainLayout
    title={`Tu Perfil: ${season.title} | Roger Murillo`}
    description={season.description}
    schema={schema}
>
    <section
        class="pt-32 pb-20 bg-brand-black text-white text-center relative overflow-hidden"
    >
        <div class="absolute top-0 left-0 w-full h-2 bg-brand-primary"></div>

        <div class="container mx-auto px-6 relative z-10 max-w-4xl">
            <span
                class="inline-block py-1 px-4 border border-white/20 rounded-sm text-brand-gray text-xs font-bold uppercase tracking-[0.3em] mb-8"
            >
                Informe Confidencial
            </span>

            <h1 class="font-serif text-5xl md:text-7xl mb-6 leading-tight">
                {season.title}
            </h1>

            <p
                class="text-xl md:text-2xl text-brand-primary font-serif italic max-w-2xl mx-auto mb-8"
            >
                "{season.archetype}"
            </p>

            <p
                class="text-gray-400 font-light text-sm uppercase tracking-widest"
            >
                Diagnóstico generado por MAES Technology™
            </p>
        </div>
    </section>

    <section class="py-20 bg-white">
        <div class="container mx-auto px-6 max-w-4xl">
            <div class="prose prose-lg mx-auto mb-16 text-slate-700">
                <div class="flex items-center gap-4 mb-6">
                    <ShieldCheck className="text-brand-black w-8 h-8" />
                    <h2 class="font-serif text-3xl text-brand-black m-0">
                        Análisis de Perfil
                    </h2>
                </div>

                <p
                    class="lead text-xl text-brand-black font-medium leading-relaxed"
                >
                    {season.description}
                </p>

                <div
                    class="bg-brand-gray p-8 border-l-4 border-brand-primary my-10"
                >
                    <h4
                        class="font-bold text-brand-black uppercase text-xs tracking-widest mb-2"
                    >
                        Psicología de tu Imagen
                    </h4>
                    <p class="m-0 italic text-slate-700">{season.psychology}</p>
                </div>

                <p class="text-sm text-gray-500">
                    <strong>Nota Técnica:</strong>
                    {season.geo_definition}
                </p>
            </div>

            <PaletteViewer
                client:visible
                colors={season.palette}
                names={season.palette_names}
                avoid={season.avoid}
            />

            <div
                class="mt-24 p-10 bg-brand-gray text-center relative border-t border-brand-black/5"
            >
                <h3 class="font-serif text-3xl text-brand-black mb-4">
                    ¿El problema?
                </h3>
                <p
                    class="text-lg text-slate-600 mb-10 max-w-2xl mx-auto font-light"
                >
                    Conocer tu paleta es solo el <strong>10%</strong> de la estrategia.
                    El error común de los perfiles {season.title} es usar los colores
                    correctos en las telas incorrectas (brillo vs mate) o en cortes
                    que no favorecen su morfología corporal.
                </p>

                <div class="grid md:grid-cols-2 gap-8 max-w-3xl mx-auto">
                    <div
                        class="bg-white p-8 shadow-lg border border-gray-100 flex flex-col justify-between hover:border-brand-black transition-colors duration-300"
                    >
                        <div>
                            <div class="flex items-center gap-2 mb-4">
                                <BookOpen className="w-5 h-5 text-gray-400" />
                                <span
                                    class="text-xs font-bold text-gray-400 uppercase tracking-widest"
                                    >Autodidacta</span
                                >
                            </div>
                            <h4
                                class="font-serif text-2xl text-brand-black mb-2"
                            >
                                Manual Digital {season.title}
                            </h4>
                            <p
                                class="text-sm text-gray-500 mb-6 leading-relaxed"
                            >
                                PDF descargable con 50+ combinaciones de trajes,
                                guía de telas y accesorios específicos para tu
                                estación.
                            </p>
                        </div>
                        <a
                            href="/libro"
                            class="w-full flex items-center justify-center py-4 border border-brand-black text-brand-black font-bold uppercase text-xs tracking-widest hover:bg-brand-black hover:text-white transition-all"
                        >
                            Descargar ($19 USD)
                        </a>
                    </div>

                    <div
                        class="bg-brand-black text-white p-8 shadow-2xl flex flex-col justify-between relative overflow-hidden transform md:-translate-y-4 border-t-4 border-brand-primary"
                    >
                        <div>
                            <div class="flex items-center gap-2 mb-4">
                                <Star
                                    className="w-5 h-5 text-brand-primary fill-current"
                                />
                                <span
                                    class="text-xs font-bold text-brand-primary uppercase tracking-widest"
                                    >Recomendado</span
                                >
                            </div>
                            <h4 class="font-serif text-2xl text-white mb-2">
                                Diseño de Imagen 1 a 1
                            </h4>
                            <p
                                class="text-sm text-gray-400 mb-6 leading-relaxed"
                            >
                                Sesión privada "A Puerta Cerrada" con Roger.
                                Diagnóstico integral de rostro, cuerpo y
                                objetivos de carrera.
                            </p>
                        </div>
                        <a
                            href="/contacto"
                            class="w-full flex items-center justify-center py-4 bg-brand-primary text-white font-bold uppercase text-xs tracking-widest hover:bg-white hover:text-brand-primary transition-all shadow-lg shadow-brand-primary/20"
                        >
                            Agendar Cita <ArrowRight className="ml-2 w-4" />
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</MainLayout>
