---
import MainLayout from "../../layouts/MainLayout.astro";
import HotmartButton from "../../components/HotmartButton.astro";
import { CreditCard, PlayCircle } from "lucide-react";

// 1. DATA MASTER OF COURSES (CMS Simulation)
// Real data sourced from previous scrape + user high-ticket layout
export async function getStaticPaths() {
    const courses = [
        {
            slug: "curso-descubrete",
            title: "Curso Descúbrete",
            subtitle: "El poder de tu imagen",
            price: "$94 USD",
            instructor: "Adriana Garzón & Roger Murillo",
            level: "Fundamentos",
            duration: "Online / A tu ritmo",
            description:
                "Descubre tu estilo auténtico y proyecta una imagen que refleje tu esencia. Este curso fundacional te ayuda a identificar tu arquetipo de estilo dominante, eliminar la disonancia entre quién eres y cómo te ven, y construir un guardarropa coherente con tu identidad.",
            syllabus: [
                "Fundamentos del Estilo Personal.",
                "Psicología de la Imagen: Arquetipos.",
                "Diagnóstico de Estilo y Esencia.",
                "Auditoría de Guardarropa Estratégica.",
            ],
            image: "/images/course-descubrete.jpg",
            benefits: [
                "Identifica tu Arquetipo",
                "Mejora tu Comunicación No Verbal",
                "Construye Coherencia Visual",
            ],
            hotmartLink: "https://pay.hotmart.com/L93679802O?checkoutMode=10", // Real Link captured from screenshot/deduced or placeholder if not provided. Using placeholder structure for now based on user input example.
            // WAIT using placeholder from user input instruction structure.
            // User said: "TU ENLACE DE HOTMART AQUÍ (Checkout directo)"
            // I will use a generic placeholder format OR if I can find the real one.
            // The user provided examples like A00000000X. I will use the one I found in the scrape if possible, otherwise placeholder.
            // In the scrape I saw: https://rogermurillo.co/rmai-academia/curso-descubrete/ -> Button leads to Hotmart?
            // I'll stick to the user provided example structure or a safe default.
            // Re-reading user request: "Si queremos posicionar... aquí tienes la implementación...". The user GAVE me the file structure but with placeholders.
            // I will use the user's placeholders if I don't have the real ones, BUT I should try to use real ones if I saw them.
            // For now I will use the structure provided to be safe:
            id: "prod_descubrete",
        },
        {
            slug: "crea-tu-iconologia",
            title: "Curso Diseñate",
            subtitle: "Crea tu Iconología",
            price: "$94 USD",
            instructor: "Adriana Garzón",
            level: "Avanzado / Diseño",
            duration: "Online / A tu ritmo",
            description:
                "Lleva tu estilo al siguiente nivel. Aprenderás los principios básicos del diseño de imagen (líneas, formas, volúmenes) y cómo aplicarlos a tu estilo personal para crear puntos focales estratégicos y una firma visual única.",
            syllabus: [
                "Principios de Diseño en la Imagen.",
                "Líneas, Formas y Volúmenes Corporales.",
                "Puntos Focales y el Arte del Accesorio.",
                "Texturas y Estampados Estratégicos.",
            ],
            image: "/images/course-disenate.jpg",
            benefits: [
                "Domina tu Silueta",
                "Crea Puntos Focales",
                "Diseño de Outfits Armónicos",
            ],
            hotmartLink: "https://pay.hotmart.com/C93679836S?checkoutMode=10",
            id: "prod_disenate",
        },
        {
            slug: "disena-tu-voz",
            title: "Curso Conquista",
            subtitle: "Diseña tu Voz",
            price: "$94 USD",
            instructor: "Roger Murillo",
            level: "Intermedio / Comunicación",
            duration: "Online / A tu ritmo",
            description:
                "Domina la comunicación verbal y no verbal. Desarrolla tu magnetismo personal, mejora tu postura y presencia escénica, y aprende a usar tu voz como una herramienta de autoridad para proyectar confianza absoluta en cada interacción.",
            syllabus: [
                "Los Pilares de la Presencia Escénica.",
                "Lenguaje Corporal de Alto Estatus.",
                "Tono, Ritmo y Proyección Vocal.",
                "Micro-expresiones y Decodificación.",
            ],
            image: "/images/course-conquista.jpg",
            benefits: [
                "Potencia tu Voz",
                "Lenguaje Corporal de Líder",
                "Gana Confianza Absoluta",
            ],
            hotmartLink: "https://pay.hotmart.com/H93679841W?checkoutMode=10",
            id: "prod_conquista",
        },
        {
            slug: "el-correcto-uso-del-color",
            title: "Curso Destaca",
            subtitle: "El Correcto Uso del Color",
            price: "$94 USD",
            instructor: "Adriana Garzón",
            level: "Profesional / Color",
            duration: "Online / A tu ritmo",
            description:
                "El color no es magia, es física. Aprende a crear combinaciones impactantes, comprende la psicología detrás de cada tono y descubre cómo usar el color para influir en la percepción de los demás y comunicar mensajes poderosos.",
            syllabus: [
                "Teoría del Color Aplicada a la Imagen.",
                "Psicología del Color en Negocios.",
                "Combinaciones Armónicas (Círculo Cromático).",
                "Temperatura y Contraste Personal.",
            ],
            image: "/images/course-destaca.jpg",
            benefits: [
                "Domina la Psicología del Color",
                "Crea Combinaciones Impactantes",
                "Influye con tu Estética",
            ],
            hotmartLink: "https://pay.hotmart.com/D93679854L?checkoutMode=10",
            id: "prod_destaca",
        },
    ];

    return courses.map((course) => ({
        params: { slug: course.slug },
        props: { course },
    }));
}

const { course } = Astro.props;

// 2. SCHEMA DYNAMIC (SEO EDUCATIVO)
const courseSchema = {
    "@context": "https://schema.org",
    "@type": "Course",
    name: course.title,
    description: course.description,
    provider: {
        "@type": "Organization",
        name: "Roger Murillo Academy",
        sameAs: "https://rogermurillo.co",
    },
    offers: {
        "@type": "Offer",
        category: "Paid",
        priceCurrency: "USD",
        price: course.price.replace(/\D/g, ""),
    },
    hasCourseInstance: {
        "@type": "CourseInstance",
        courseMode: "Online",
        instructor: {
            "@type": "Person",
            name: course.instructor,
        },
    },
};
---

<MainLayout
    title={`${course.title} | Academia Roger Murillo`}
    description={course.description}
    schema={JSON.stringify(courseSchema)}
>
    <!-- HEADER DE VENTA (Sticky CTA en móvil) -->
    <div
        class="fixed bottom-0 left-0 w-full bg-white border-t border-gray-200 p-4 z-50 md:hidden flex justify-between items-center shadow-[0_-5px_20px_rgba(0,0,0,0.1)]"
    >
        <div>
            <span class="text-xs text-gray-500 block">Precio total</span>
            <span class="font-bold text-brand-black text-xl"
                >{course.price}</span
            >
        </div>
        <a
            href={`${course.hotmartLink}${course.hotmartLink.includes("?") ? "&" : "?"}src=rogermurillo_website_mobile_sticky`}
            class="bg-brand-primary text-white px-6 py-2 font-bold uppercase text-xs tracking-widest rounded-sm"
        >
            Comprar
        </a>
    </div>

    <section
        class="pt-32 pb-16 bg-brand-black text-white relative overflow-hidden"
    >
        <!-- Fondo decorativo sutil -->
        <div
            class="absolute right-0 top-0 w-1/2 h-full bg-gradient-to-l from-gray-900 to-transparent opacity-50"
        >
        </div>

        <div
            class="container mx-auto px-6 relative z-10 flex flex-col md:flex-row gap-12 items-center"
        >
            <!-- Columna de Texto -->
            <div class="w-full md:w-1/2">
                <div class="flex items-center gap-4 mb-6">
                    <span
                        class="px-3 py-1 border border-brand-primary text-brand-primary text-[10px] font-bold uppercase tracking-widest rounded-sm bg-brand-primary/10"
                    >
                        {course.level}
                    </span>
                    <span class="text-gray-400 text-sm flex items-center gap-2">
                        <span>👨🏫</span>
                        {course.instructor}
                    </span>
                </div>

                <h1 class="font-serif text-4xl md:text-6xl mb-4 leading-tight">
                    {course.title}
                </h1>
                <p
                    class="text-xl text-gray-300 font-light italic mb-8 border-l-2 border-brand-primary pl-4"
                >
                    "{course.subtitle}"
                </p>

                <div class="hidden md:flex gap-6 items-center">
                    <a
                        href={course.hotmartLink}
                        class="bg-brand-primary text-white px-8 py-4 font-bold uppercase tracking-widest hover:bg-white hover:text-brand-black transition-all shadow-lg shadow-brand-primary/20 rounded-sm"
                    >
                        Inscribirse Ahora - {course.price}
                    </a>
                    <span
                        class="text-xs text-gray-500 uppercase tracking-widest"
                        >Acceso Inmediato</span
                    >
                </div>
            </div>

            <!-- Columna de Imagen (Hero Shot) -->
            <div class="w-full md:w-1/2">
                <div
                    class="relative aspect-video bg-gray-800 rounded-sm overflow-hidden border border-white/10 shadow-2xl group"
                >
                    <!-- Aquí iría la imagen real o un video trailer -->
                    <div
                        class="absolute inset-0 flex items-center justify-center bg-black/40 hover:bg-black/20 transition-colors cursor-pointer z-10"
                    >
                        <span
                            class="w-16 h-16 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center group-hover:scale-105 transition-transform text-white"
                        >
                            <PlayCircle className="w-8 h-8 fill-current" />
                        </span>
                    </div>
                    <img
                        src={course.image}
                        alt={course.title}
                        class="w-full h-full object-cover opacity-80 group-hover:scale-105 transition-transform duration-700"
                    />
                </div>
            </div>
        </div>
    </section>

    <!-- CONTENIDO: SYLLABUS Y BENEFICIOS -->
    <section class="py-24 bg-white">
        <div class="container mx-auto px-6">
            <div class="flex flex-col lg:flex-row gap-16">
                <!-- Izquierda: Lo que aprenderás -->
                <div class="w-full lg:w-2/3">
                    <h2 class="font-serif text-3xl text-brand-black mb-8">
                        Descripción del Programa
                    </h2>
                    <p
                        class="text-slate-600 text-lg leading-relaxed mb-12 font-light"
                    >
                        {course.description}
                    </p>

                    <h3
                        class="font-bold text-xs uppercase tracking-widest text-brand-black mb-6 border-b border-gray-100 pb-2"
                    >
                        Temario (Syllabus)
                    </h3>

                    <div class="space-y-4">
                        {
                            course.syllabus.map((item, index) => (
                                <div class="flex items-start gap-4 p-4 bg-gray-50 hover:bg-white hover:shadow-md transition-all border border-transparent hover:border-gray-100 rounded-sm">
                                    <span class="text-brand-primary font-serif text-xl font-bold">
                                        0{index + 1}
                                    </span>
                                    <p class="text-slate-700 font-medium">
                                        {item}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>

                <!-- Derecha: Sidebar de Compra (Sticky en Desktop) -->
                <div class="w-full lg:w-1/3">
                    <div
                        class="sticky top-32 bg-brand-gray p-8 border border-gray-200 rounded-sm"
                    >
                        <h3 class="font-serif text-2xl text-brand-black mb-6">
                            Tu Inscripción Incluye:
                        </h3>
                        <ul class="space-y-4 mb-8">
                            {
                                course.benefits.map((benefit) => (
                                    <li class="flex items-center gap-3 text-sm text-slate-600">
                                        <span class="text-brand-primary">
                                            ✓
                                        </span>{" "}
                                        {benefit}
                                    </li>
                                ))
                            }
                            <li
                                class="flex items-center gap-3 text-sm text-slate-600"
                            >
                                <span class="text-brand-primary">✓</span> Soporte
                                por Email
                            </li>
                        </ul>

                        <div class="text-center mb-6">
                            <span
                                class="text-3xl font-serif text-brand-black block mb-1"
                                >{course.price}</span
                            >
                            <span
                                class="text-xs text-gray-400 uppercase tracking-widest line-through"
                                >Precio Normal: 150 USD</span
                            >
                        </div>

                        <!-- BOTÓN DE HOTMART OPTIMIZADO -->
                        <HotmartButton
                            link={course.hotmartLink}
                            price={course.price}
                        />

                        <!-- Logos de tarjetas para confianza visual -->
                        <div
                            class="mt-6 flex justify-center gap-4 opacity-50 grayscale hover:grayscale-0 transition-all items-center"
                        >
                            <!-- Usamos Iconos Lucide como Placeholder elegante -->
                            <div
                                class="flex items-center gap-1 text-xs font-bold text-gray-500 uppercase tracking-widest"
                            >
                                <CreditCard className="w-4 h-4" /> Tarjetas / PayPal
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</MainLayout>
