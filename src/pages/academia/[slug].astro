---
import MainLayout from "@/layouts/MainLayout.astro";
import AnimatedTitleWords from "@/components/ui/AnimatedTitleWords.astro";

// ─── COURSES DATA ─────────────────────────────────────────────────────
export async function getStaticPaths() {
    const courses = [
        {
            slug: "curso-descubrete",
            number: "01",
            tag: "Fundamentos",
            title: "Descúbrete",
            subtitle: "El poder de tu imagen personal.",
            priceUsd: 25,
            duration: "4 semanas",
            lessons: 18,
            level: "Principiante",
            heroLineA: "Antes de vestirte,",
            heroLineB: "descúbrete.",
            overview:
                "El curso fundacional de la Academia. Aquí no hablamos de ropa: hablamos de identidad. Porque la imagen personal no empieza en el clóset — empieza en conocer quién eres, qué comunicas y qué quieres proyectar.",
            forWho: [
                "Profesionales que quieren invertir en su imagen con criterio",
                "Quienes sienten que su imagen actual no refleja quién son",
                "Personas en transición (nuevo rol, nueva etapa, nuevo país)",
                "Cualquiera que quiera dejar de improvisar frente al espejo",
            ],
            modules: [
                { n: "01", title: "Semiótica de la imagen", summary: "Qué comunicas sin darte cuenta. Lectura de primeras impresiones y efecto halo." },
                { n: "02", title: "Arquetipos e identidad", summary: "Los 12 arquetipos de Jung aplicados a tu presencia personal." },
                { n: "03", title: "Estilo vs. moda", summary: "Por qué el estilo dura y la moda caduca. Cómo construir el tuyo." },
                { n: "04", title: "Audit de imagen actual", summary: "Diagnóstico honesto: qué funciona, qué no y por qué." },
                { n: "05", title: "Plan de evolución", summary: "Tu hoja de ruta: 90 días para transformar tu imagen con intención." },
            ],
            outcomes: [
                "Entender qué comunicas hoy sin decir nada",
                "Identificar tu arquetipo de imagen personal",
                "Construir un criterio propio para decidir qué comprar y qué no",
                "Dejar de seguir tendencias que no te pertenecen",
            ],
            image: "/images/course-descubrete.jpg",
            hotmartLink: "https://pay.hotmart.com/U99309978M",
        },
        {
            slug: "crea-tu-iconologia",
            number: "02",
            tag: "Diseño",
            title: "Diseñate",
            subtitle: "Crea tu iconología.",
            priceUsd: 35,
            duration: "5 semanas",
            lessons: 22,
            level: "Avanzado",
            heroLineA: "Diseña la silueta",
            heroLineB: "que te representa.",
            overview:
                "Lleva tu estilo al siguiente nivel. Aprenderás los principios básicos del diseño de imagen (líneas, formas, volúmenes) y cómo aplicarlos a tu estilo personal para crear puntos focales estratégicos y una firma visual única.",
            forWho: [
                "Quienes ya conocen su estilo y quieren refinarlo",
                "Profesionales que quieren una firma visual reconocible",
                "Personas que buscan entender el lenguaje técnico del diseño",
                "Amantes de la moda que quieren dominarla, no seguirla",
            ],
            modules: [
                { n: "01", title: "Principios de diseño", summary: "Líneas, formas y volúmenes aplicados a la imagen personal." },
                { n: "02", title: "Líneas y siluetas", summary: "Cómo leer tu cuerpo y elegir prendas que lo dialoguen, no lo escondan." },
                { n: "03", title: "Puntos focales estratégicos", summary: "Dónde quieres que la mirada del otro aterrice. Y cómo lograrlo." },
                { n: "04", title: "Accesorios con intención", summary: "El arte de acentuar sin saturar. Joyas, gafas, relojes como lenguaje." },
                { n: "05", title: "Texturas y estampados", summary: "Cuándo funcionan, cuándo no, y por qué." },
            ],
            outcomes: [
                "Dominar los códigos del diseño de imagen personal",
                "Crear outfits armónicos sin improvisar",
                "Entender qué silueta potencia tu geometría",
                "Desarrollar una firma visual reconocible",
            ],
            image: "/images/course-disenate.jpg",
            hotmartLink: "https://pay.hotmart.com/O99463899F",
        },
        {
            slug: "disena-tu-voz",
            number: "03",
            tag: "Comunicación",
            title: "Conquista",
            subtitle: "Diseña tu voz.",
            priceUsd: 40,
            duration: "6 semanas",
            lessons: 24,
            level: "Intermedio",
            heroLineA: "Tu voz también",
            heroLineB: "es imagen.",
            overview:
                "Domina la comunicación verbal y no verbal. Desarrolla tu magnetismo personal, mejora tu postura y presencia escénica, y aprende a usar tu voz como herramienta de autoridad para proyectar confianza absoluta en cada interacción.",
            forWho: [
                "Líderes que deben hablar en público con autoridad",
                "Emprendedores que venden con su presencia",
                "Profesionales que quieren dominar su lenguaje corporal",
                "Quienes sienten que su mensaje no se escucha",
            ],
            modules: [
                { n: "01", title: "Pilares de la presencia escénica", summary: "Cómo entrar a un espacio y ser notado sin decir palabra." },
                { n: "02", title: "Lenguaje corporal de alto estatus", summary: "Las posturas y gestos que el cerebro lee como autoridad." },
                { n: "03", title: "Tono, ritmo y proyección vocal", summary: "Tu voz como instrumento. Cómo afinar su impacto." },
                { n: "04", title: "Micro-expresiones y decodificación", summary: "Leer lo que el otro no dice. Adaptar tu mensaje en tiempo real." },
                { n: "05", title: "Conversaciones de alto impacto", summary: "Del networking al board meeting. Estructura y presencia." },
            ],
            outcomes: [
                "Potenciar tu voz como herramienta de autoridad",
                "Dominar el lenguaje corporal de liderazgo",
                "Ganar confianza absoluta al hablar en público",
                "Proyectar magnetismo en cualquier entorno",
            ],
            image: "/images/course-conquista.jpg",
            hotmartLink: "https://pay.hotmart.com/U99476935H",
        },
        {
            slug: "el-correcto-uso-del-color",
            number: "04",
            tag: "Color",
            title: "Destaca",
            subtitle: "El correcto uso del color.",
            priceUsd: 40,
            duration: "5 semanas",
            lessons: 20,
            level: "Profesional",
            heroLineA: "El color no es magia.",
            heroLineB: "Es física.",
            overview:
                "El color no es magia, es física. Aprende a crear combinaciones impactantes, comprende la psicología detrás de cada tono y descubre cómo usar el color para influir en la percepción de los demás y comunicar mensajes poderosos.",
            forWho: [
                "Quienes ya hicieron test de colorimetría y quieren profundizar",
                "Profesionales que negocian y quieren usar el color estratégicamente",
                "Amantes del estilo que quieren entender el por qué de cada tono",
                "Creativos que trabajan con imagen de marca propia",
            ],
            modules: [
                { n: "01", title: "Teoría del color aplicada", summary: "Del círculo cromático a tu guardarropa real." },
                { n: "02", title: "Psicología del color en negocios", summary: "Qué comunica cada tono y cuándo usarlo." },
                { n: "03", title: "Combinaciones armónicas", summary: "Análogos, complementarios y tríadas. Reglas y excepciones." },
                { n: "04", title: "Temperatura y contraste personal", summary: "Por qué un azul te favorece y otro te apaga." },
                { n: "05", title: "Color estratégico por contexto", summary: "Negociación, seducción, autoridad. Un color para cada misión." },
            ],
            outcomes: [
                "Dominar la psicología del color aplicada a imagen",
                "Crear combinaciones impactantes sin improvisar",
                "Elegir el color según el contexto y la intención",
                "Influir en la percepción del otro con tu estética",
            ],
            image: "/images/course-destaca.jpg",
            hotmartLink: "https://pay.hotmart.com/W99484170E",
        },
    ];

    return courses.map((course) => ({
        params: { slug: course.slug },
        props: { course },
    }));
}

const { course } = Astro.props;
---

<MainLayout
    title={`${course.title} · Curso ${course.number} | Academia Roger Murillo`}
    description={course.overview}
>

    <style>
        .reveal{opacity:0;transform:translateY(36px);transition:opacity 1s cubic-bezier(.16,1,.3,1) var(--delay,0s),transform 1s cubic-bezier(.16,1,.3,1) var(--delay,0s)}
        .reveal.is-in{opacity:1;transform:translateY(0)}
        .num-huge{font-style:italic;line-height:.8;position:absolute;pointer-events:none;user-select:none}
        .mod-row{transition:all .5s cubic-bezier(.16,1,.3,1)}
        .mod-row:hover{background:#0a0a0a;color:white;padding-left:2rem}
        .mod-row:hover .mod-num{color:var(--color-brand-primary,#C41230)}
        .mod-num{transition:color .5s}
    </style>

    <!-- HERO -->
    <section class="pt-40 pb-32 md:pt-48 md:pb-40 bg-white relative overflow-hidden min-h-screen flex flex-col justify-center">
        <span class="num-huge font-serif text-[38vw] -right-[6%] top-[10%]" style="color:rgba(196,18,48,.05)">{course.number}</span>
        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <div class="flex items-center gap-5 mb-14">
                <span class="w-12 h-px bg-brand-primary"></span>
                <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-500">Curso {course.number} · {course.tag}</p>
            </div>
            <h1 class="font-serif leading-[0.85] text-brand-black">
                <AnimatedTitleWords text={course.heroLineA} class="block text-5xl md:text-7xl lg:text-8xl" />
                <AnimatedTitleWords text={course.heroLineB} class="block text-5xl md:text-7xl lg:text-8xl italic text-brand-primary pl-[6%]" delay={300} />
            </h1>
            <div class="mt-16 grid md:grid-cols-12 gap-8 items-end">
                <div class="md:col-span-6 border-l-2 border-brand-primary pl-8">
                    <p class="text-lg font-light text-neutral-700 leading-relaxed">{course.overview}</p>
                </div>
                <div class="md:col-span-5 md:col-start-8 flex flex-wrap gap-8">
                    <div>
                        <span class="font-serif italic text-4xl text-brand-black block leading-none">{course.duration.split(' ')[0]}</span>
                        <span class="text-[10px] tracking-[0.2em] uppercase text-neutral-400 mt-2 block">Semanas</span>
                    </div>
                    <div>
                        <span class="font-serif italic text-4xl text-brand-black block leading-none">{course.lessons}</span>
                        <span class="text-[10px] tracking-[0.2em] uppercase text-neutral-400 mt-2 block">Lecciones</span>
                    </div>
                    <div>
                        <span class="font-serif italic text-4xl text-brand-black block leading-none">${course.priceUsd}</span>
                        <span class="text-[10px] tracking-[0.2em] uppercase text-neutral-400 mt-2 block">USD</span>
                    </div>
                </div>
            </div>
            <div class="mt-16 flex gap-4 flex-wrap">
                <a href={course.hotmartLink} target="_blank" rel="noopener" class="bg-brand-black text-white px-10 py-4 text-[11px] tracking-[0.25em] uppercase hover:bg-brand-primary transition-colors duration-500">Inscribirme →</a>
                <a href="#programa" class="px-10 py-4 text-[11px] tracking-[0.25em] uppercase text-brand-black border border-neutral-300 hover:border-brand-black transition-colors duration-500">Ver programa</a>
            </div>
        </div>
    </section>

    <!-- PARA QUIÉN -->
    <section class="py-32 md:py-40 bg-neutral-50 relative overflow-hidden">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-24">
                <div class="lg:col-span-5">
                    <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-6">Para quién</p>
                    <h2 class="font-serif text-5xl md:text-6xl leading-[0.92] text-brand-black">¿Este curso<br/>es para <span class="italic text-neutral-400">ti?</span></h2>
                </div>
                <div class="lg:col-span-7 space-y-8">
                    {course.forWho.map((item, i) => (
                        <div class="reveal flex gap-6 border-t border-neutral-200 pt-8" style={`--delay:${i * 0.08}s`}>
                            <span class="font-serif italic text-brand-primary text-2xl shrink-0">{String(i + 1).padStart(2, '0')}</span>
                            <p class="text-lg text-neutral-700 font-light leading-relaxed">{item}</p>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- PROGRAMA -->
    <section id="programa" class="py-32 md:py-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="max-w-2xl mb-16">
                <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-6">Programa</p>
                <h2 class="font-serif text-5xl md:text-6xl leading-[0.92] text-brand-black">{course.modules.length} módulos.<br/><span class="italic text-neutral-400">Una metodología.</span></h2>
            </div>
            <div class="border-t border-neutral-200">
                {course.modules.map((m) => (
                    <a href={course.hotmartLink} target="_blank" rel="noopener" class="mod-row flex items-start gap-8 py-8 px-4 border-b border-neutral-200 cursor-pointer">
                        <span class="mod-num font-serif italic text-3xl text-neutral-300 shrink-0 w-16">{m.n}</span>
                        <div class="flex-1">
                            <h3 class="font-serif text-2xl md:text-3xl mb-2">{m.title}</h3>
                            <p class="text-sm font-light leading-relaxed opacity-70">{m.summary}</p>
                        </div>
                        <span class="text-[10px] tracking-[0.3em] uppercase shrink-0 mt-3">→</span>
                    </a>
                ))}
            </div>
        </div>
    </section>

    <!-- RESULTADOS -->
    <section class="py-32 md:py-40 bg-brand-black text-white relative overflow-hidden">
        <span class="num-huge font-serif text-[30vw] -left-[6%] -bottom-[15%]" style="color:rgba(255,255,255,.04)">→</span>
        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <div class="max-w-3xl mb-16">
                <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-6">Al terminar</p>
                <h2 class="font-serif text-5xl md:text-6xl leading-[0.92]">Lo que te <span class="italic text-neutral-500">llevas.</span></h2>
            </div>
            <div class="grid md:grid-cols-2 gap-12">
                {course.outcomes.map((o, i) => (
                    <div class="reveal border-l-2 border-brand-primary pl-6" style={`--delay:${i * 0.1}s`}>
                        <span class="font-serif italic text-brand-primary text-xl block mb-3">{String(i + 1).padStart(2, '0')}</span>
                        <p class="text-lg font-light text-white/80 leading-relaxed">{o}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- CTA COMPRAR -->
    <section id="comprar" class="py-32 md:py-40 bg-white text-center">
        <div class="container mx-auto px-6 max-w-3xl">
            <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-6">Empieza hoy</p>
            <h2 class="font-serif text-5xl md:text-7xl leading-[0.92] text-brand-black mb-8">Una decisión.<br/><span class="italic text-neutral-400">Un antes y un después.</span></h2>
            <p class="text-lg font-light text-neutral-600 leading-relaxed max-w-xl mx-auto mb-10">Acceso inmediato. De por vida. Ritmo propio. Comunidad privada de estudiantes.</p>
            <div class="flex items-baseline justify-center gap-4 mb-12">
                <span class="font-serif italic text-6xl md:text-8xl text-brand-black">${course.priceUsd}</span>
                <span class="text-sm tracking-[0.2em] uppercase text-neutral-400">USD · pago único</span>
            </div>
            <a href={course.hotmartLink} target="_blank" rel="noopener" class="inline-block bg-brand-primary text-white px-14 py-5 text-[11px] tracking-[0.25em] uppercase hover:bg-brand-black transition-colors duration-500">Inscribirme ahora →</a>
            <p class="mt-8 text-[10px] tracking-[0.25em] uppercase text-neutral-400">Garantía de 7 días · 100% reembolsable</p>
        </div>
    </section>

    <!-- VOLVER -->
    <section class="py-16 border-t border-neutral-200 bg-white">
        <div class="container mx-auto px-6 max-w-6xl flex justify-between items-center">
            <a href="/academia" class="text-[11px] tracking-[0.25em] uppercase text-neutral-500 hover:text-brand-black transition-colors">← Todos los cursos</a>
            <a href="/contacto" class="text-[11px] tracking-[0.25em] uppercase text-neutral-500 hover:text-brand-black transition-colors">¿Dudas? Contáctanos →</a>
        </div>
    </section>

</MainLayout>
