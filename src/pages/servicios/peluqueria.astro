---
import MainLayout from "@/layouts/MainLayout.astro";
import { ArrowRight } from "lucide-react";

const seoData = {
    title: "Peluquería de Autor | Roger Murillo",
    description:
        "Servicio de peluquería con perspectiva masculina y femenina. Corte con tijera, color, recuperación capilar y colorimetría aplicada. Estudio a puerta cerrada en Bogotá.",
    image: "/og-image.jpg",
};

const servicios = [
    {
        n: "01",
        title: "Corte con Tijera",
        desc: "Nuestro servicio estrella. Cada corte responde a un diagnóstico previo de visagismo. No seguimos tendencias: diseñamos líneas que equilibran tus facciones y proyectan tu personalidad.",
        sub: "Hombre & Mujer",
    },
    {
        n: "02",
        title: "Tintura & Color",
        desc: "Diseño de color basado en tu paleta estacional y colorimetría personal. Trabajamos con productos de alta gama que priorizan la salud de la fibra capilar sobre todo.",
        sub: "Hombre & Mujer",
    },
    {
        n: "03",
        title: "Recuperación Capilar",
        desc: "Tratamientos profesionales para restaurar la salud del cabello. Diagnóstico del cuero cabelludo, hidratación profunda y protocolos de reconstrucción.",
        sub: "Hombre & Mujer",
    },
    {
        n: "04",
        title: "Colorimetría Aplicada",
        desc: "Antes de tocar tu cabello, analizamos tu temperatura de piel, tus subtonos y tu estación. El color perfecto no es el que está de moda: es el que te pertenece.",
        sub: "Hombre & Mujer",
    },
];

const diferenciales = [
    { n: "01", title: "A puerta cerrada",  desc: "Intimidad total. Sin esperas. Sin ruido." },
    { n: "02", title: "Doble perspectiva", desc: "La visión masculina y femenina trabajando juntas." },
    { n: "03", title: "Productos premium", desc: "L'Oréal, Kérastase, Olaplex. Solo lo mejor." },
];
---

<MainLayout seo={seoData}>
    <div id="rm-progress" class="fixed top-0 left-0 right-0 h-[2px] bg-brand-primary z-[80] origin-left" style="transform:scaleX(0)"></div>

    <!-- HERO -->
    <section class="relative min-h-[92vh] bg-[#faf7f2] overflow-hidden flex items-center pt-28 pb-24">
        <svg class="absolute right-[-4%] top-[14%] w-[36vw] h-[36vw] scissor opacity-[0.18] pointer-events-none" viewBox="0 0 100 100" fill="none" stroke="#0a0a0a" stroke-width="0.8">
            <circle cx="28" cy="72" r="13"/>
            <circle cx="72" cy="72" r="13"/>
            <line x1="28" y1="72" x2="76" y2="18"/>
            <line x1="72" y1="72" x2="24" y2="18"/>
            <circle cx="50" cy="45" r="1.6" fill="#C41230"/>
        </svg>
        <div class="absolute left-0 right-0 top-[38%] h-px bg-brand-black/5"></div>

        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <div class="flex items-center gap-4 mb-12">
                <span class="marker"></span>
                <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-500">Roger Murillo · Servicio · Peluquería</p>
            </div>

            <h1 class="font-serif leading-[0.92] text-brand-black max-w-4xl">
                <span class="hero-line block text-5xl md:text-7xl lg:text-[5.6rem]">La tijera</span>
                <span class="hero-line block text-5xl md:text-7xl lg:text-[5.6rem] italic text-brand-primary">como instrumento</span>
                <span class="hero-line block text-5xl md:text-7xl lg:text-[5.6rem] text-neutral-400">de precisión.</span>
            </h1>

            <div class="mt-14 grid lg:grid-cols-12 gap-10 items-end max-w-5xl">
                <p class="lg:col-span-7 text-base md:text-lg text-neutral-600 font-light leading-relaxed">
                    No usamos máquina por defecto. El corte con tijera es nuestro servicio estrella
                    porque permite <strong class="text-brand-black font-medium">controlar cada línea, cada ángulo,
                    cada milímetro</strong> según la geometría de tu rostro.
                </p>
                <div class="lg:col-span-5">
                    <a href="/contacto" class="cta-btn inline-flex items-center gap-3 bg-brand-primary text-white px-10 py-4 text-[11px] font-medium uppercase tracking-[0.25em] hover:bg-brand-black">
                        Reservar Cita
                        <ArrowRight className="w-3.5 h-3.5" />
                    </a>
                </div>
            </div>
        </div>

        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-[10px] tracking-[0.4em] uppercase text-neutral-400">✂ Estudio a puerta cerrada · Bogotá</div>
    </section>

    <!-- SERVICES GRID -->
    <section class="bg-neutral-50 py-28 md:py-40">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="max-w-xl mb-20 reveal">
                <p class="text-[10px] tracking-[0.4em] uppercase text-brand-primary mb-6">Servicios</p>
                <h2 class="font-serif text-4xl md:text-6xl leading-[1] text-brand-black">
                    Todo bajo<br/>
                    <span class="italic text-neutral-400">un mismo techo.</span>
                </h2>
            </div>

            <div class="grid md:grid-cols-2 gap-px bg-neutral-200">
                {servicios.map((s, i) => (
                    <article class="svc-card bg-neutral-50 p-10 md:p-14 reveal" style={`--delay:${i * 0.05}s`}>
                        <span class="svc-num block text-5xl md:text-6xl mb-8">{s.n}</span>
                        <h3 class="font-serif text-2xl md:text-3xl text-brand-black mb-4 svc-title">{s.title}</h3>
                        <p class="svc-desc text-sm md:text-[15px] text-neutral-500 font-light leading-relaxed mb-6">{s.desc}</p>
                        <p class="svc-sub text-[10px] tracking-[0.3em] uppercase text-neutral-400 pt-4 border-t border-neutral-200">{s.sub}</p>
                    </article>
                ))}
            </div>
        </div>
    </section>

    <!-- GALLERY / PORTAFOLIO -->
    <section class="py-28 md:py-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="flex items-end justify-between mb-16 gap-10 flex-wrap">
                <div class="max-w-xl reveal">
                    <p class="text-[10px] tracking-[0.4em] uppercase text-brand-primary mb-6">Portafolio</p>
                    <h2 class="font-serif text-4xl md:text-6xl leading-[1] text-brand-black">
                        El trabajo<br/><span class="italic text-neutral-400">habla por sí solo.</span>
                    </h2>
                </div>
                <p class="text-sm text-neutral-500 font-light max-w-xs reveal" style="--delay:.1s">
                    Cada pieza del portafolio es un diagnóstico hecho corte.
                    Mismo cliente, misma cabeza, geometría distinta.
                </p>
            </div>

            <div class="grid grid-cols-12 gap-4 md:gap-6">
                <figure class="col-span-12 md:col-span-7 ph bg-neutral-100 aspect-[4/5] md:aspect-[5/6] relative reveal">
                    <div class="absolute inset-0 flex items-center justify-center text-neutral-400">
                        <div class="text-center">
                            <svg class="mx-auto mb-3 opacity-40" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                                <rect x="3" y="3" width="18" height="18" rx="1"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/>
                            </svg>
                            <p class="text-[10px] tracking-[0.3em] uppercase">Corte con tijera · Editorial 01</p>
                        </div>
                    </div>
                    <figcaption class="absolute left-6 bottom-6 text-[10px] tracking-[0.3em] uppercase text-brand-black/60">01 / Tijera</figcaption>
                </figure>

                <div class="col-span-12 md:col-span-5 grid grid-cols-1 gap-4 md:gap-6">
                    <figure class="ph bg-neutral-100 aspect-[4/3] relative reveal" style="--delay:.1s">
                        <div class="absolute inset-0 flex items-center justify-center text-neutral-400">
                            <p class="text-[10px] tracking-[0.3em] uppercase">Color · 02</p>
                        </div>
                    </figure>
                    <figure class="ph bg-neutral-100 aspect-[4/3] relative reveal" style="--delay:.15s">
                        <div class="absolute inset-0 flex items-center justify-center text-neutral-400">
                            <p class="text-[10px] tracking-[0.3em] uppercase">Recuperación · 03</p>
                        </div>
                    </figure>
                </div>

                <figure class="col-span-6 md:col-span-4 ph bg-neutral-100 aspect-square relative reveal" style="--delay:.1s">
                    <div class="absolute inset-0 flex items-center justify-center text-neutral-400">
                        <p class="text-[10px] tracking-[0.3em] uppercase">Detalle · 04</p>
                    </div>
                </figure>
                <figure class="col-span-6 md:col-span-4 ph bg-neutral-100 aspect-square relative reveal" style="--delay:.15s">
                    <div class="absolute inset-0 flex items-center justify-center text-neutral-400">
                        <p class="text-[10px] tracking-[0.3em] uppercase">Proceso · 05</p>
                    </div>
                </figure>
                <figure class="col-span-12 md:col-span-4 ph bg-neutral-100 aspect-square relative reveal" style="--delay:.2s">
                    <div class="absolute inset-0 flex items-center justify-center text-neutral-400">
                        <p class="text-[10px] tracking-[0.3em] uppercase">Retrato · 06</p>
                    </div>
                </figure>
            </div>

            <p class="mt-10 text-[10px] tracking-[0.3em] uppercase text-neutral-400 text-center">
                — Espacio reservado para fotografías del estudio —
            </p>
        </div>
    </section>

    <!-- DIFFERENTIATOR -->
    <section class="py-28 md:py-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="grid md:grid-cols-12 gap-16 md:gap-24 items-start">
                <div class="md:col-span-7 reveal">
                    <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-400 mb-6">El Diferencial</p>
                    <h2 class="font-serif text-4xl md:text-6xl leading-[1] text-brand-black mb-10">
                        Peluquería<br/>
                        <span class="italic">con ciencia detrás.</span>
                    </h2>
                    <p class="text-lg text-neutral-500 font-light leading-relaxed mb-8">
                        Aquí no entras a "cortarte el pelo". Entras a un estudio privado donde dos profesionales
                        &mdash;uno con perspectiva masculina, otra con perspectiva femenina&mdash; analizan tu rostro,
                        tu estilo de vida y tus objetivos antes de tomar la tijera.
                    </p>
                    <blockquote class="text-base md:text-lg text-brand-black font-light leading-relaxed border-l-2 border-brand-primary pl-6 italic max-w-lg">
                        La imagen personal no empieza en la ropa &mdash; empieza en la identidad.
                        Y tu cabello es parte fundamental de esa identidad.
                    </blockquote>
                </div>

                <div class="md:col-span-5 md:pt-20 reveal" style="--delay:.1s">
                    {diferenciales.map((d) => (
                        <div class="diff-row py-7">
                            <p class="text-[10px] tracking-[0.3em] uppercase text-brand-primary mb-2">{d.n}</p>
                            <h4 class="font-serif text-xl text-brand-black mb-2">{d.title}</h4>
                            <p class="text-sm text-neutral-500 font-light leading-relaxed">{d.desc}</p>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-28 md:py-40 bg-brand-black text-white text-center relative overflow-hidden">
        <span class="num-huge text-[40vw] -right-[18%] top-1/2 -translate-y-1/2" style="color:rgba(255,255,255,.03)">✂</span>
        <div class="container mx-auto px-6 max-w-3xl relative z-10">
            <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-500 mb-8">Solo con cita previa</p>
            <h2 class="font-serif text-4xl md:text-6xl leading-[1.02] mb-10">
                Reserva tu cita<br/>
                <span class="text-neutral-500 italic">de peluquería.</span>
            </h2>
            <p class="text-base md:text-lg text-neutral-400 font-light leading-relaxed max-w-xl mx-auto mb-12">
                Trabajamos exclusivamente con cita previa. Agenda tu espacio y vive la experiencia "A Puerta Cerrada".
            </p>
            <a href="/contacto" class="cta-btn inline-flex items-center gap-3 bg-brand-primary text-white px-12 py-5 text-[11px] font-medium uppercase tracking-[0.25em] hover:bg-white hover:text-brand-black">
                Agendar Cita
                <ArrowRight className="w-3.5 h-3.5" />
            </a>
        </div>
    </section>
</MainLayout>

<style is:global>
    /* Editorial service shared styles */
    .reveal { opacity:0; transform:translateY(36px); transition: opacity 1s cubic-bezier(.16,1,.3,1) var(--delay,0s), transform 1s cubic-bezier(.16,1,.3,1) var(--delay,0s); }
    .reveal.is-in { opacity:1; transform:translateY(0); }

    .hero-line { opacity:0; transform:translateY(100%); animation: heroLineIn 1.1s cubic-bezier(.22,1,.36,1) forwards; display:block; }
    .hero-line:nth-child(1) { animation-delay:.15s; }
    .hero-line:nth-child(2) { animation-delay:.3s; }
    .hero-line:nth-child(3) { animation-delay:.45s; }
    @keyframes heroLineIn { to { opacity:1; transform:translateY(0); } }

    .num-huge { font-family:'Playfair Display',serif; font-style:italic; line-height:.8; position:absolute; pointer-events:none; user-select:none; }
    .ph { position:relative; overflow:hidden; }
    .ph::after { content:""; position:absolute; inset:0; background: linear-gradient(135deg, rgba(255,255,255,.04) 0%, transparent 50%, rgba(0,0,0,.25) 100%); }

    .marker { display:inline-block; width:28px; height:1px; background:#C41230; vertical-align:middle; margin-right:14px; }

    /* Scissor animation */
    .scissor { animation: snip 3.2s cubic-bezier(.7,0,.3,1) infinite; transform-origin:center; }
    @keyframes snip { 0%,100% { transform: rotate(-6deg); } 50% { transform: rotate(6deg); } }

    /* Service cards · negro entra desde arriba en hover, todos los textos a blanco */
    .svc-card { transition: background .5s cubic-bezier(.16,1,.3,1), color .5s; position:relative; overflow:hidden; }
    .svc-card::before { content:""; position:absolute; left:0; top:0; width:100%; height:0; background:#0a0a0a; transition: height .6s cubic-bezier(.7,0,.3,1); z-index:0; }
    .svc-card:hover::before { height:100%; }
    .svc-card > * { position:relative; z-index:1; }
    .svc-card:hover .svc-title { color:#fff; }
    .svc-card:hover .svc-num { color:#C41230; }
    .svc-card:hover .svc-sub { color: rgba(255,255,255,.55); border-color: rgba(255,255,255,.15); }
    .svc-card:hover .svc-desc { color: rgba(255,255,255,.8); }
    .svc-title { transition: color .5s; }
    .svc-desc { transition: color .5s; }
    .svc-sub { transition: color .5s, border-color .5s; }
    .svc-num { font-family:'Playfair Display',serif; font-style:italic; color:#C41230; line-height:.85; transition: color .4s; }

    .diff-row { border-top: 1px solid rgba(10,10,10,.1); }
    .diff-row:last-child { border-bottom: 1px solid rgba(10,10,10,.1); }

    .cta-btn { transition: background .5s, color .5s; }
</style>

<script>
    // Scroll progress bar
    const bar = document.getElementById('rm-progress');
    if (bar) {
        addEventListener('scroll', () => {
            const h = document.documentElement;
            const p = h.scrollTop / (h.scrollHeight - h.clientHeight);
            bar.style.transform = `scaleX(${p})`;
        });
    }
    // Reveal on scroll
    const io = new IntersectionObserver(es => es.forEach(e => e.isIntersecting && e.target.classList.add('is-in')), { threshold: .12 });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
</script>
