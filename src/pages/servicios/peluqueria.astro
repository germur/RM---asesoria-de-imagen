---
import MainLayout from "@/layouts/MainLayout.astro";
import { ArrowRight } from "lucide-react";

const seoData = {
    title: "Peluquería de Autor · Corte con Tijera · Tintura · Recuperación Capilar | Roger Murillo",
    description:
        "Peluquería profesional a puerta cerrada en Bogotá. Corte con tijera, tintura, recuperación capilar y colorimetría para hombre y mujer. Servicio exclusivo con Roger Murillo y Adriana Garzón.",
};

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Peluquería de Autor",
    provider: { "@type": "ProfessionalService", name: "Roger Murillo & Adriana Garzón" },
    description: "Corte con tijera, tintura, recuperación capilar y colorimetría para hombre y mujer.",
});
---

<MainLayout
    title={seoData.title}
    description={seoData.description}
    schema={schema}
>
    <!-- Hero -->
    <section class="pt-40 pb-32 md:pt-48 md:pb-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Peluquería</p>
            <h1 class="font-serif text-4xl md:text-6xl leading-[1.05] text-brand-black max-w-3xl mb-8">
                La tijera como instrumento de precisión.
            </h1>
            <p class="text-lg text-neutral-500 font-light leading-relaxed max-w-xl mb-12">
                No usamos máquina por defecto. El corte con tijera es nuestro servicio estrella
                porque permite <strong class="text-brand-black font-medium">controlar cada línea, cada ángulo,
                cada milímetro</strong> según la geometría de tu rostro.
            </p>
            <a
                href="/contacto"
                class="inline-flex items-center gap-3 bg-brand-primary text-white px-10 py-4 text-xs font-medium uppercase tracking-[0.2em] hover:bg-brand-black transition-colors duration-500"
            >
                Reservar Cita
                <ArrowRight size={14} />
            </a>
        </div>
    </section>

    <!-- Services Grid -->
    <section class="py-32 md:py-40 bg-neutral-50">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="max-w-xl mb-20">
                <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Servicios</p>
                <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black">
                    Todo bajo un mismo techo.
                </h2>
            </div>

            <div class="grid md:grid-cols-2 gap-px bg-neutral-200">
                <div class="bg-neutral-50 p-12 md:p-16">
                    <span class="font-serif text-4xl text-brand-primary block mb-6">01</span>
                    <h3 class="font-serif text-2xl text-brand-black mb-4">Corte con Tijera</h3>
                    <p class="text-sm text-neutral-500 leading-relaxed mb-3">
                        Nuestro servicio estrella. Cada corte responde a un diagnóstico
                        previo de visagismo. No seguimos tendencias: diseñamos líneas
                        que equilibran tus facciones y proyectan tu personalidad.
                    </p>
                    <p class="text-xs text-neutral-400 uppercase tracking-[0.15em]">Hombre & Mujer</p>
                </div>

                <div class="bg-neutral-50 p-12 md:p-16">
                    <span class="font-serif text-4xl text-brand-primary block mb-6">02</span>
                    <h3 class="font-serif text-2xl text-brand-black mb-4">Tintura & Color</h3>
                    <p class="text-sm text-neutral-500 leading-relaxed mb-3">
                        Diseño de color basado en tu paleta estacional y colorimetría personal.
                        Trabajamos con productos de alta gama que priorizan la salud
                        de la fibra capilar sobre todo.
                    </p>
                    <p class="text-xs text-neutral-400 uppercase tracking-[0.15em]">Hombre & Mujer</p>
                </div>

                <div class="bg-neutral-50 p-12 md:p-16">
                    <span class="font-serif text-4xl text-brand-primary block mb-6">03</span>
                    <h3 class="font-serif text-2xl text-brand-black mb-4">Recuperación Capilar</h3>
                    <p class="text-sm text-neutral-500 leading-relaxed mb-3">
                        Tratamientos profesionales para restaurar la salud del cabello.
                        Diagnóstico del cuero cabelludo, hidratación profunda y
                        protocolos de reconstrucción.
                    </p>
                    <p class="text-xs text-neutral-400 uppercase tracking-[0.15em]">Hombre & Mujer</p>
                </div>

                <div class="bg-neutral-50 p-12 md:p-16">
                    <span class="font-serif text-4xl text-brand-primary block mb-6">04</span>
                    <h3 class="font-serif text-2xl text-brand-black mb-4">Colorimetría Aplicada</h3>
                    <p class="text-sm text-neutral-500 leading-relaxed mb-3">
                        Antes de tocar tu cabello, analizamos tu temperatura de piel,
                        tus subtonos y tu estación. El color perfecto no es el que
                        está de moda: es el que te pertenece.
                    </p>
                    <p class="text-xs text-neutral-400 uppercase tracking-[0.15em]">Hombre & Mujer</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Differentiator -->
    <section class="py-32 md:py-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="grid md:grid-cols-12 gap-16 md:gap-24 items-center">
                <div class="md:col-span-7">
                    <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">El Diferencial</p>
                    <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black mb-8">
                        Peluquería con ciencia detrás.
                    </h2>
                    <p class="text-lg text-neutral-500 font-light leading-relaxed mb-6">
                        Aquí no entras a "cortarte el pelo". Entras a un estudio privado
                        donde dos profesionales &mdash;uno con perspectiva masculina, otra con
                        perspectiva femenina&mdash; analizan tu rostro, tu estilo de vida y
                        tus objetivos antes de tomar la tijera.
                    </p>
                    <p class="text-base text-neutral-500 font-light leading-relaxed border-l-2 border-brand-primary pl-6 italic">
                        La imagen personal no empieza en la ropa &mdash; empieza en la identidad.
                        Y tu cabello es parte fundamental de esa identidad.
                    </p>
                </div>

                <div class="md:col-span-5">
                    <div class="space-y-6">
                        <div class="border-l border-brand-primary pl-8">
                            <h4 class="text-sm font-medium uppercase tracking-[0.15em] text-brand-black mb-2">A puerta cerrada</h4>
                            <p class="text-sm text-neutral-500 font-light">Intimidad total. Sin esperas. Sin ruido.</p>
                        </div>
                        <div class="border-l border-brand-primary pl-8">
                            <h4 class="text-sm font-medium uppercase tracking-[0.15em] text-brand-black mb-2">Doble perspectiva</h4>
                            <p class="text-sm text-neutral-500 font-light">La visión masculina y femenina trabajando juntas.</p>
                        </div>
                        <div class="border-l border-brand-primary pl-8">
                            <h4 class="text-sm font-medium uppercase tracking-[0.15em] text-brand-black mb-2">Productos premium</h4>
                            <p class="text-sm text-neutral-500 font-light">L'Oréal, Kérastase, Olaplex. Solo lo mejor.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-32 md:py-40 bg-brand-black text-white text-center">
        <div class="container mx-auto px-6 max-w-3xl">
            <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] mb-8">
                Reserva tu cita <span class="text-neutral-400">de peluquería.</span>
            </h2>
            <p class="text-lg text-neutral-300 font-light leading-relaxed max-w-xl mx-auto mb-12">
                Trabajamos exclusivamente con cita previa. Agenda tu espacio
                y vive la experiencia "A Puerta Cerrada".
            </p>
            <a
                href="/contacto"
                class="inline-flex items-center gap-3 bg-brand-primary text-white px-10 py-4 text-xs font-medium uppercase tracking-[0.2em] hover:bg-white hover:text-brand-black transition-colors duration-500"
            >
                Agendar Cita <ArrowRight size={14} />
            </a>
        </div>
    </section>
</MainLayout>
