---
import MainLayout from "@/layouts/MainLayout.astro";
import { ArrowRight } from "lucide-react";

const serviceSchema = {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Color y Salud Capilar",
    provider: {
        "@type": "LocalBusiness",
        name: "Roger Murillo Asesoría de Imagen",
        image: "https://rogermurillo.co/images/logo.png"
    },
    areaServed: {
        "@type": "City",
        name: "Bogotá"
    },
    description: "Diagnóstico bioquímico, visagismo y coloración estratégica para CEOs y Ejecutivas."
};
---

<MainLayout
    title="Colorimetría Capilar · Salud del Cabello · Color Estratégico en Bogotá | Adriana Garzón"
    description="Colorimetría capilar profesional y salud del cabello en Bogotá. Diagnóstico bioquímico, diseño de color estratégico y visagismo capilar a cargo de Adriana Garzón. Exclusivo a puerta cerrada."
    schema={JSON.stringify(serviceSchema)}
>
    <!-- Hero -->
    <section class="pt-40 pb-32 md:pt-48 md:pb-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Adriana Garzón</p>
            <h1 class="font-serif text-4xl md:text-6xl leading-[1.05] text-brand-black max-w-4xl mb-8">
                Arquitectura Capilar Estratégica
            </h1>
            <p class="text-lg text-neutral-500 font-light leading-relaxed max-w-xl mb-12">
                Un mal tinte puede envejecerte 10 años y arruinar tu reputación visual. Usamos ciencia, bioquímica y colorimetría para estructurar tu cabello como un activo de poder.
            </p>
            <a
                href="/contacto?ref=capilar"
                class="inline-flex items-center gap-3 bg-brand-primary text-white px-10 py-4 text-xs font-medium uppercase tracking-[0.2em] hover:bg-brand-black transition-colors duration-500"
            >
                Agendar Diagnóstico Privado
                <ArrowRight size={14} />
            </a>
        </div>
    </section>

    <!-- Problem -->
    <section class="py-32 md:py-40 bg-neutral-50">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="grid md:grid-cols-12 gap-16 md:gap-24">
                <div class="md:col-span-5">
                    <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">El Problema</p>
                    <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black">
                        Por qué los salones tradicionales están destruyendo tu imagen.
                    </h2>
                </div>
                <div class="md:col-span-7 flex items-center">
                    <div>
                        <p class="text-lg text-neutral-500 font-light leading-relaxed mb-8">
                            La peluquería comercial sigue "tendencias". La asesoría de imagen estratégica sigue <strong class="text-brand-black font-medium">ciencia y matemáticas</strong>.
                        </p>
                        <p class="text-lg text-neutral-500 font-light leading-relaxed mb-10">
                            No puedes aplicar un diseño "balayage" genérico a un rostro Diamante con colorimetría Invierno. El resultado es desconexión visual, facciones endurecidas y una percepción de cansancio crónico. Nosotros reparamos ese daño.
                        </p>
                        <ul class="space-y-4">
                            <li class="text-sm text-neutral-500 font-light">
                                <span class="text-brand-black font-medium">--</span>&nbsp;&nbsp;Tintes sin análisis de subtono piel.
                            </li>
                            <li class="text-sm text-neutral-500 font-light">
                                <span class="text-brand-black font-medium">--</span>&nbsp;&nbsp;Decoloraciones extremas que rompen el puente disulfuro del cabello.
                            </li>
                            <li class="text-sm text-neutral-500 font-light">
                                <span class="text-brand-black font-medium">--</span>&nbsp;&nbsp;Cortes que no corresponden a tu morfología ósea.
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Process -->
    <section class="py-32 md:py-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">El Proceso</p>
            <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black mb-20">
                Nuestro Protocolo Clínico-Estético
            </h2>
            <div class="grid md:grid-cols-3 gap-px bg-neutral-200">
                <div class="bg-white p-10">
                    <span class="font-serif text-4xl text-brand-primary block mb-6">01</span>
                    <h3 class="text-sm font-medium uppercase tracking-[0.15em] text-brand-black mb-4">Tricología Express</h3>
                    <p class="text-sm text-neutral-500 font-light leading-relaxed">
                        Análisis del cuero cabelludo y biología de la hebra capilar. Diagnosticamos el daño estructural para prescribir la química exacta que restaurará su vitalidad.
                    </p>
                </div>
                <div class="bg-white p-10">
                    <span class="font-serif text-4xl text-brand-primary block mb-6">02</span>
                    <h3 class="text-sm font-medium uppercase tracking-[0.15em] text-brand-black mb-4">Ingeniería de Color</h3>
                    <p class="text-sm text-neutral-500 font-light leading-relaxed">
                        Uso del Sistema de Munsell para encontrar el nivel exacto de saturación, valor y matiz que neutralice imperfecciones de la tez y potencie la mirada.
                    </p>
                </div>
                <div class="bg-white p-10">
                    <span class="font-serif text-4xl text-brand-primary block mb-6">03</span>
                    <h3 class="text-sm font-medium uppercase tracking-[0.15em] text-brand-black mb-4">Diseño Visagista</h3>
                    <p class="text-sm text-neutral-500 font-light leading-relaxed">
                        Esculpimos el cabello en función de las proporciones matemáticas de tu cráneo. Direccionamos la mirada de tu interlocutor hacia donde queremos.
                    </p>
                </div>
            </div>
        </div>
    </section>
</MainLayout>
