---
import MainLayout from "@/layouts/MainLayout.astro";
import AnimatedTitleWords from "@/components/ui/AnimatedTitleWords.astro";
import { CheckCircle2, ChevronRight, Droplets, Sparkles, AlertCircle } from "lucide-react";

const serviceSchema = {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Color y Salud Capilar",
    provider: {
        "@type": "LocalBusiness",
        name: "Roger Murillo Asesoría de Imagen",
        image: "https://rogermurillo.co/images/logo.png"
    },
    areaServed: {
        "@type": "City",
        name: "Bogotá"
    },
    description: "Diagnóstico bioquímico, visagismo y coloración estratégica para CEOs y Ejecutivas."
};
---

<MainLayout 
    title="Colorimetría y Salud Capilar | Roger Murillo Asesoría de Imagen" 
    description="No es peluquería, es arquitectura capilar. Diseñamos el color y estructura de tu cabello basándonos en tu biometría y salud capilar. Exclusivo en Bogotá."
    schema={JSON.stringify(serviceSchema)}
>
    <!-- HERO SECTION -->
    <section class="relative pt-32 pb-20 bg-brand-black text-white overflow-hidden">
        <div class="absolute inset-0 bg-brand-black z-0"></div>
        <div class="absolute inset-0 z-0 bg-[url('/images/noise.png')] opacity-10 mix-blend-overlay"></div>
        
        <div class="container mx-auto px-6 relative z-10">
            <div class="max-w-4xl">
                <a href="/servicios" class="inline-flex items-center gap-2 text-brand-primary text-xs font-bold uppercase tracking-widest mb-6 hover:text-white transition-colors">
                    <ChevronRight size={14} className="rotate-180" />
                    Volver a Servicios
                </a>

                <h1 class="font-serif text-5xl md:text-7xl mb-6 leading-tight">
                    <AnimatedTitleWords text="Arquitectura" class="block text-white" />
                    <span class="text-white">
                        <AnimatedTitleWords text="Capilar Estratégica" delay={400} />
                    </span>
                </h1>

                <p class="text-xl text-gray-400 font-light mb-10 max-w-2xl leading-relaxed">
                    Un mal tinte puede envejecerte 10 años y arruinar tu reputación visual. Usamos ciencia, bioquímica y colorimetría para estructurar tu cabello como un activo de poder.
                </p>

                <div class="flex flex-col sm:flex-row gap-6">
                    <a href="/contacto?ref=capilar" class="bg-brand-primary text-white px-8 py-4 text-center font-bold uppercase tracking-widest hover:bg-white hover:text-brand-primary transition-all rounded-sm shadow-lg shadow-brand-primary/20">
                        Agendar Diagnóstico Privado
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- THE PROBLEM -->
    <section class="py-24 bg-white">
        <div class="container mx-auto px-6">
            <div class="flex flex-col md:flex-row gap-16 items-center">
                <div class="w-full md:w-1/2">
                    <h2 class="font-serif text-4xl text-brand-black mb-6 leading-tight">
                        Por qué los salones tradicionales están destruyendo tu imagen.
                    </h2>
                    <p class="text-gray-600 mb-6 leading-relaxed">
                        La peluquería comercial sigue "tendencias". La asesoría de imagen estratégica sigue <strong class="text-brand-black">ciencia y matemáticas</strong>.
                    </p>
                    <p class="text-gray-600 mb-8 leading-relaxed">
                        No puedes aplicar un diseño "balayage" genérico a un rostro Diamante con colorimetría Invierno. El resultado es desconexión visual, facciones endurecidas y una percepción de cansancio crónico. Nosotros reparamos ese daño.
                    </p>

                    <div class="space-y-4">
                        <div class="flex gap-4">
                            <AlertCircle className="w-6 h-6 text-brand-primary shrink-0" />
                            <p class="text-sm font-bold text-brand-black">Tintes sin análisis de subtono piel.</p>
                        </div>
                        <div class="flex gap-4">
                            <AlertCircle className="w-6 h-6 text-brand-primary shrink-0" />
                            <p class="text-sm font-bold text-brand-black">Decoloraciones extremas que rompen el puente disulfuro del cabello.</p>
                        </div>
                        <div class="flex gap-4">
                            <AlertCircle className="w-6 h-6 text-brand-primary shrink-0" />
                            <p class="text-sm font-bold text-brand-black">Cortes que no corresponden a tu morfología ósea.</p>
                        </div>
                    </div>
                </div>

                <div class="w-full md:w-1/2">
                    <!-- Placeholder using styling until user uploads an asset -->
                    <div class="bg-brand-gray w-full aspect-[4/5] rounded-sm p-12 flex flex-col justify-center border border-gray-200 shadow-xl relative overflow-hidden group">
                        <div class="absolute inset-0 bg-brand-primary/5 group-hover:bg-brand-primary/10 transition-colors"></div>
                        <Sparkles size={48} className="text-brand-primary mb-6" />
                        <h3 class="font-serif text-3xl text-brand-black mb-4">El Enfoque MAES™</h3>
                        <p class="text-slate-600 font-light">Evaluamos ph, porosidad, grosor de la hebra y biometría capilar antes de siquiera tocar la tijera. Es ingeniería estética pura.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- THE SOLUTION - PROCESS -->
    <section class="py-24 bg-brand-gray">
        <div class="container mx-auto px-6 max-w-5xl">
            <h2 class="font-serif text-4xl text-brand-black mb-16 text-center">Nuestro Protocolo Clínico-Estético</h2>

            <div class="grid md:grid-cols-3 gap-8">
                <div class="bg-white p-8 border border-gray-100 hover:border-brand-primary/30 transition-colors rounded-sm shadow-sm group">
                    <div class="w-12 h-12 bg-gray-50 flex items-center justify-center text-brand-primary font-serif text-xl mb-6 group-hover:bg-brand-primary group-hover:text-white transition-colors">
                        01
                    </div>
                    <h3 class="font-bold text-xl mb-4 text-brand-black">Tricología Express</h3>
                    <p class="text-gray-500 text-sm">
                        Análisis del cuero cabelludo y biología de la hebra capilar. Diagnosticamos el daño estructural para prescribir la química exacta que restaurará su vitalidad.
                    </p>
                </div>
                
                <div class="bg-white p-8 border border-gray-100 hover:border-brand-primary/30 transition-colors rounded-sm shadow-sm group">
                    <div class="w-12 h-12 bg-gray-50 flex items-center justify-center text-brand-primary font-serif text-xl mb-6 group-hover:bg-brand-primary group-hover:text-white transition-colors">
                        02
                    </div>
                    <h3 class="font-bold text-xl mb-4 text-brand-black">Ingeniería de Color</h3>
                    <p class="text-gray-500 text-sm">
                        Uso del Sistema de Munsell para encontrar el nivel exacto de saturación, valor y matiz que neutralice imperfecciones de la tez y potencie la mirada.
                    </p>
                </div>
                
                <div class="bg-white p-8 border border-gray-100 hover:border-brand-primary/30 transition-colors rounded-sm shadow-sm group">
                    <div class="w-12 h-12 bg-gray-50 flex items-center justify-center text-brand-primary font-serif text-xl mb-6 group-hover:bg-brand-primary group-hover:text-white transition-colors">
                        03
                    </div>
                    <h3 class="font-bold text-xl mb-4 text-brand-black">Diseño Visagista</h3>
                    <p class="text-gray-500 text-sm">
                        Esculpimos el cabello en función de las proporciones matemáticas de tu cráneo. Direccionamos la mirada de tu interlocutor hacia donde queremos (Tus ojos).
                    </p>
                </div>
            </div>
        </div>
    </section>

</MainLayout>
