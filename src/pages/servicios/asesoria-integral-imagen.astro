---
import MainLayout from "@/layouts/MainLayout.astro";
import AnimatedTitleWords from "@/components/ui/AnimatedTitleWords.astro";
import { ArrowRight } from "lucide-react";

const seoData = {
    title: "Consultoría de Imagen Integral · Colorimetría · Visagismo en Bogotá | Roger Murillo",
    description:
        "Consultoría de imagen personal integral en Bogotá: análisis de color, visagismo, morfología y diseño capilar en una sesión exclusiva a puerta cerrada. Para ejecutivos y personas en transición.",
};

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "Consultoría de Imagen Integral",
    provider: {
        "@type": "ProfessionalService",
        name: "Roger Murillo & Adriana Garzón",
        url: "https://rogermurillo.co",
    },
    areaServed: { "@type": "City", name: "Bogotá" },
    description: seoData.description,
});
---

<MainLayout title={seoData.title} description={seoData.description} schema={schema}>

    <!-- HERO -->
    <section class="pt-40 pb-32 md:pt-48 md:pb-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Signature Service</p>
            <h1 class="font-serif text-4xl md:text-6xl leading-[1.05] text-brand-black max-w-4xl mb-8">
                <AnimatedTitleWords text="Descubre a la persona" class="block" />
                <AnimatedTitleWords text="que deberías ver en el espejo." class="block text-neutral-400" delay={400} />
            </h1>
            <p class="text-lg text-neutral-500 font-light leading-relaxed max-w-2xl mb-12">
                Una inmersión total de 360°. Alineamos tu morfología, colorimetría y estilo con quién eres hoy — no con quien eras hace diez años.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
                <a href="/contacto" class="bg-brand-primary text-white px-10 py-4 text-xs font-medium uppercase tracking-[0.2em] hover:bg-brand-black transition-colors duration-500 rounded-sm text-center">
                    Aplicar para Consultoría
                </a>
                <a href="/servicios/precios" class="px-10 py-4 text-xs font-medium uppercase tracking-[0.2em] text-brand-black border border-brand-black/20 hover:border-brand-black transition-colors duration-500 rounded-sm text-center">
                    Ver Inversión
                </a>
            </div>
            <p class="mt-8 text-sm text-neutral-400">
                Agenda limitada — máximo 4 clientes por mes
            </p>
        </div>
    </section>

    <!-- PARA QUIÉN ES / NO ES -->
    <section class="py-32 md:py-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Perfil de Cliente</p>
            <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black mb-20">¿Es para ti?</h2>

            <div class="grid md:grid-cols-12 gap-16 md:gap-24">
                <div class="md:col-span-6 border-l border-brand-black pl-8">
                    <h3 class="font-serif text-2xl text-brand-black mb-8">Sí es para ti si…</h3>
                    <ul class="space-y-5">
                        {[
                            "Tu cargo cambió pero tu imagen no ha evolucionado.",
                            "Estás en una transición: divorcio, nueva empresa, cambio de década.",
                            "Inviertes en ropa cara pero nada termina de funcionar.",
                            "Quieres proyectar autoridad antes de abrir la boca.",
                            "Nunca has tenido un análisis profesional de tu colorimetría ni tu morfología.",
                            "Valoras la privacidad y la atención exclusiva 1 a 1.",
                        ].map(item => (
                            <li class="text-sm text-neutral-500 leading-relaxed">{item}</li>
                        ))}
                    </ul>
                </div>
                <div class="md:col-span-6 border-l border-neutral-200 pl-8">
                    <h3 class="font-serif text-2xl text-brand-black mb-8">No es para ti si…</h3>
                    <ul class="space-y-5">
                        {[
                            "Buscas seguir tendencias de temporada, no estrategia.",
                            "Quieres solo un corte rápido sin diagnóstico.",
                            "No estás dispuesto a cuestionar tus hábitos de vestir actuales.",
                            "Esperas resultados de una sola sesión sin implementarlos.",
                        ].map(item => (
                            <li class="text-sm text-neutral-500 leading-relaxed">{item}</li>
                        ))}
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- EL PROCESO -->
    <section class="py-32 md:py-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Metodología</p>
            <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black mb-6">El Proceso Integral</h2>
            <p class="text-lg text-neutral-500 font-light leading-relaxed max-w-2xl mb-20">Todo en una sola sesión privada. Sin prisa. Sin interrupciones.</p>

            <div class="divide-y divide-neutral-200">
                {[
                    {
                        n: "01",
                        title: "Colorimetría Avanzada — 12 Estaciones",
                        body: "Test de telas físicas (Draping) bajo luz natural. Determinamos tu paleta de poder: los colores que iluminan tu piel, neutralizan ojeras e impulsan tu autoridad visual.",
                    },
                    {
                        n: "02",
                        title: "Visagismo y Geometría Facial",
                        body: "Análisis craneal y análisis de perfil. Definimos corte, volúmenes, diseño de barba (hombres), estructura de peinado y marcos visuales que potencian tu mirada.",
                    },
                    {
                        n: "03",
                        title: "Morfología Corporal",
                        body: "Vestir el cuerpo real, no el ideal. Equilibramos proporciones usando cortes estratégicos, efectos ópticos y reglas de proporción para cada tipo de figura.",
                    },
                    {
                        n: "04",
                        title: "Diseño y Ejecución Capilar",
                        body: "Roger y Adriana ejecutan el corte y el color definidos en el diagnóstico. No hay asistentes. Solo los especialistas que analizaron tu caso.",
                    },
                    {
                        n: "05",
                        title: "Dossier de Imagen Personalizado",
                        body: "Entregamos un manual digital con tu paleta de colores, siluetas que funcionan para tu cuerpo, reglas de proporción y recomendaciones de guardarropa específicas para tu vida.",
                    },
                ].map(step => (
                    <div class="grid md:grid-cols-12 gap-8 md:gap-16 py-12 first:pt-0">
                        <div class="md:col-span-2">
                            <span class="font-serif text-4xl text-neutral-400">{step.n}</span>
                        </div>
                        <div class="md:col-span-10">
                            <h3 class="font-serif text-2xl text-brand-black mb-3">{step.title}</h3>
                            <p class="text-sm text-neutral-500 leading-relaxed max-w-xl">{step.body}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- COMPARATIVA -->
    <section class="py-32 md:py-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Comparativa</p>
            <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black mb-20">La diferencia es estructural</h2>

            <div class="grid md:grid-cols-2">
                <div class="bg-white p-10 md:p-16">
                    <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-10">Peluquería Tradicional</p>
                    <ul class="space-y-6">
                        {[
                            "Sigue tendencias de temporada",
                            "Ambiente público, múltiples turnos",
                            "Corte estándar sin análisis previo",
                            "El colorista elige el tinte",
                            "Sin documento de seguimiento",
                        ].map(i => (
                            <li class="text-sm text-neutral-400 leading-relaxed">{i}</li>
                        ))}
                    </ul>
                </div>
                <div class="bg-brand-black p-10 md:p-16">
                    <p class="text-xs tracking-[0.3em] uppercase text-neutral-500 mb-10">Roger Murillo</p>
                    <ul class="space-y-6">
                        {[
                            "Estrategia basada en tus rasgos y objetivos",
                            "Estudio privado, eres el único cliente del día",
                            "Diagnóstico biométrico antes de tocar la tijera",
                            "Paleta de color definida por ciencia cromática",
                            "Dossier digital con tu código visual completo",
                        ].map(i => (
                            <li class="text-sm text-neutral-300 leading-relaxed">{i}</li>
                        ))}
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- TESTIMONIAL -->
    <section class="py-32 md:py-40 bg-white">
        <div class="container mx-auto px-6 max-w-3xl text-center">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-12">Testimonio</p>
            <blockquote class="font-serif text-2xl md:text-3xl text-brand-black leading-relaxed mb-10 italic">
                "Llevaba años sintiendo que algo no cuadraba con mi imagen. Después de la consultoría entendí por qué: estaba vistiendo para quien era hace diez años, no para el cargo que tengo hoy. El dossier que me entregaron cambió la forma en que me veo cada mañana."
            </blockquote>
            <p class="text-sm text-brand-black font-medium">Mauricio R.</p>
            <p class="text-xs text-neutral-400 uppercase tracking-[0.2em] mt-1">Director Comercial · Sector Financiero · Bogotá</p>
        </div>
    </section>

    <!-- PRIVACIDAD + EXCLUSIVIDAD -->
    <section class="py-32 md:py-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Experiencia</p>
            <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black mb-20">Lo que nos define</h2>

            <div class="grid md:grid-cols-3 gap-px bg-neutral-200">
                <div class="bg-white p-10 md:p-12">
                    <h3 class="font-serif text-xl text-brand-black mb-4">Privacidad Total</h3>
                    <p class="text-sm text-neutral-500 leading-relaxed">Sin vitrinas a la calle. Sin otros clientes en la sesión. Ideal para figuras públicas y directivos que valoran la discreción.</p>
                </div>
                <div class="bg-white p-10 md:p-12">
                    <h3 class="font-serif text-xl text-brand-black mb-4">Solo los Maestros</h3>
                    <p class="text-sm text-neutral-500 leading-relaxed">Roger y Adriana ejecutan cada paso. Sin asistentes. Sin delegación. La persona que diagnosticó tu caso es la misma que trabaja contigo.</p>
                </div>
                <div class="bg-white p-10 md:p-12">
                    <h3 class="font-serif text-xl text-brand-black mb-4">Sin Esperas</h3>
                    <p class="text-sm text-neutral-500 leading-relaxed">Tu tiempo es tu activo más valioso. Agendamos con márgenes amplios. Cuando llegas, empezamos.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA FINAL -->
    <section class="py-32 md:py-40 bg-brand-black text-white text-center">
        <div class="container mx-auto px-6 max-w-3xl">
            <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] mb-8">
                La agenda es limitada.<br />
                <span class="text-neutral-400 italic">4 cupos por mes.</span>
            </h2>
            <p class="text-neutral-300 font-light text-lg leading-relaxed mb-12">
                No porque sea un truco de marketing, sino porque cada sesión requiere toda nuestra atención. Si estás considerándolo, no lo dejes para después.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a
                    href="/contacto"
                    class="bg-brand-primary text-white px-10 py-4 text-xs font-medium uppercase tracking-[0.2em] hover:bg-white hover:text-brand-black transition-colors duration-500 rounded-sm"
                >
                    Solicitar mi Consultoría
                </a>
                <a
                    href="/servicios/precios"
                    class="inline-flex items-center justify-center gap-3 text-xs tracking-[0.2em] uppercase text-white border border-white/20 hover:border-white px-10 py-4 transition-colors duration-500 rounded-sm"
                >
                    Ver Inversión <ArrowRight size={14} />
                </a>
            </div>
            <p class="mt-10 text-xs text-neutral-300">
                ¿Dudas sobre precios o qué servicio elegir? <a href="/servicios/precios" class="inline-flex items-center gap-3 text-xs tracking-[0.2em] uppercase text-white hover:text-brand-primary transition-colors duration-500">Ver página de inversión</a>
            </p>
        </div>
    </section>

</MainLayout>
