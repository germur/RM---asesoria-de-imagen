---
import MainLayout from "@/layouts/MainLayout.astro";
import { ArrowRight } from "lucide-react";

const seoData = {
    title: "Visagismo · Corte según Rostro · Diseño de Barba en Bogotá | Roger Murillo",
    description:
        "Visagismo profesional en Bogotá: corte de cabello según la geometría del rostro y diseño de barba a medida. El corte correcto para tu tipo de cara, ejecutado a puerta cerrada.",
    h1: "Ingeniería Estética aplicada a tu Rostro",
};

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Visagismo y Corte",
    provider: { "@type": "Person", name: "Roger Murillo" },
    description: "Estudio geométrico del rostro para diseño de corte y barba.",
});
---

<MainLayout
    title={seoData.title}
    description={seoData.description}
    schema={schema}
>
    <!-- Hero -->
    <section class="pt-40 pb-32 md:pt-48 md:pb-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Visagismo</p>
            <h1 class="font-serif text-4xl md:text-6xl leading-[1.05] text-brand-black max-w-3xl mb-8">
                {seoData.h1}
            </h1>
            <p class="text-lg text-neutral-500 font-light leading-relaxed max-w-xl mb-12">
                No cortamos cabello, <strong class="text-brand-black font-medium">equilibramos facciones</strong>. El visagismo es el estudio geométrico de tu rostro para potenciar tus rasgos dominantes y disimular asimetrías.
            </p>
            <a
                href="/contacto"
                class="inline-flex items-center gap-3 bg-brand-primary text-white px-10 py-4 text-xs font-medium uppercase tracking-[0.2em] hover:bg-brand-black transition-colors duration-500"
            >
                Reservar Cita de Diseño
                <ArrowRight size={14} />
            </a>
        </div>
    </section>

    <!-- Problem -->
    <section class="py-32 md:py-40 bg-neutral-50">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="grid md:grid-cols-12 gap-16 md:gap-24">
                <div class="md:col-span-5">
                    <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">El Problema</p>
                    <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black">
                        ¿Por qué ese corte de moda no te queda bien?
                    </h2>
                </div>
                <div class="md:col-span-7 flex items-center">
                    <p class="text-lg text-neutral-500 font-light leading-relaxed">
                        La respuesta es matemática: <strong class="text-brand-black font-medium">porque no respeta tu estructura ósea.</strong> Un corte diseñado para un rostro ovalado puede desequilibrar por completo un rostro cuadrado o diamante. Nosotros analizamos tus líneas mandibulares, la altura de tu frente y la separación de tus ojos antes de tocar la tijera.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Process -->
    <section class="py-32 md:py-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">El Proceso</p>
            <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black mb-20">
                El Ritual "Puerta Cerrada"
            </h2>
            <div class="grid md:grid-cols-4 gap-px bg-neutral-200">
                <div class="bg-white p-10">
                    <span class="font-serif text-4xl text-brand-primary block mb-6">01</span>
                    <h3 class="text-sm font-medium uppercase tracking-[0.15em] text-brand-black mb-4">Diagnóstico</h3>
                    <p class="text-sm text-neutral-500 font-light leading-relaxed">
                        Análisis craneal y facial completo. Medimos proporciones y definimos tu tipo de rostro.
                    </p>
                </div>
                <div class="bg-white p-10">
                    <span class="font-serif text-4xl text-brand-primary block mb-6">02</span>
                    <h3 class="text-sm font-medium uppercase tracking-[0.15em] text-brand-black mb-4">Lavado Spa</h3>
                    <p class="text-sm text-neutral-500 font-light leading-relaxed">
                        Preparación del cabello con productos profesionales. Limpieza profunda del cuero cabelludo.
                    </p>
                </div>
                <div class="bg-white p-10">
                    <span class="font-serif text-4xl text-brand-primary block mb-6">03</span>
                    <h3 class="text-sm font-medium uppercase tracking-[0.15em] text-brand-black mb-4">Corte Precisión</h3>
                    <p class="text-sm text-neutral-500 font-light leading-relaxed">
                        Técnica geométrica aplicada. Cada corte responde a la estructura ósea de tu rostro.
                    </p>
                </div>
                <div class="bg-white p-10">
                    <span class="font-serif text-4xl text-brand-primary block mb-6">04</span>
                    <h3 class="text-sm font-medium uppercase tracking-[0.15em] text-brand-black mb-4">Educación</h3>
                    <p class="text-sm text-neutral-500 font-light leading-relaxed">
                        Te enseñamos a peinar y mantener tu corte. Autonomía total desde el día uno.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Calculadora -->
    <section class="py-32 md:py-40 bg-brand-black text-white">
        <div class="container mx-auto px-6 max-w-6xl text-center">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Herramienta Gratuita</p>
            <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-white mb-8">
                ¿No sabes cuál es tu tipo de rostro?
            </h2>
            <p class="text-lg text-neutral-300 font-light leading-relaxed max-w-xl mx-auto mb-12">
                Usa nuestra Calculadora de Visagismo con IA antes de agendar. Es gratis.
            </p>
            <a
                href="/herramientas/calculadora-rostro"
                class="inline-flex items-center gap-3 px-10 py-4 text-xs font-medium uppercase tracking-[0.2em] text-white border border-white/20 hover:border-white transition-colors duration-500"
            >
                Usar Calculadora Facial
                <ArrowRight size={14} />
            </a>
        </div>
    </section>
</MainLayout>
