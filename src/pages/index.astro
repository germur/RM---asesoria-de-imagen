---
import MainLayout from "@/layouts/MainLayout.astro";
import { ArrowRight, User, Palette, BookOpen } from "lucide-react";
import AnimatedTitleWords from "@/components/ui/AnimatedTitleWords.astro";

const geoSchema = {
	"@context": "https://schema.org",
	"@type": "ProfessionalService",
	name: "Roger Murillo",
	image: "https://rogermurillo.co/images/roger-hero.jpg",
	description:
		"Consultoría de imagen estratégica y visagismo para ejecutivos en Bogotá.",
	address: {
		"@type": "PostalAddress",
		addressLocality: "Bogotá",
		addressCountry: "CO",
	},
	priceRange: "$$$",
};
---

<MainLayout
	title="Roger Murillo | Asesor de Imagen Ejecutiva · Visagismo · Colorimetría en Bogotá"
	description="Consultoría de imagen personal y ejecutiva a puerta cerrada en Bogotá. Especialistas en visagismo, colorimetría y estilo estratégico para CEOs, directivos y líderes."
	schema={geoSchema}
>
	<!-- HERO — image right, text left -->
	<section class="relative min-h-screen flex items-end bg-white overflow-hidden pb-20 md:pb-32">
		<div class="absolute top-0 right-0 w-full md:w-1/2 h-full z-0">
			<img
				src="/images/roger-murillo.jpg"
				alt="Roger Murillo Consultoría de Imagen Directiva"
				class="w-full h-full object-cover opacity-20 md:opacity-50"
				fetchpriority="high"
			/>
			<div class="absolute inset-0 bg-gradient-to-r from-white via-white/90 to-transparent md:from-white md:via-white/30 md:to-transparent"></div>
		</div>

		<div class="container mx-auto px-6 relative z-10 pt-40 md:pt-48">
			<div class="max-w-3xl">
				<div class="flex items-center gap-4 mb-8">
					<span class="w-8 h-px bg-brand-primary"></span>
					<p class="text-xs tracking-[0.3em] uppercase text-neutral-400">
						Consultoría de imagen &mdash; Bogotá
					</p>
				</div>

				<h1 class="font-serif text-[3.2rem] md:text-[5.5rem] lg:text-[7rem] leading-[0.95] mb-10 text-brand-black">
					<AnimatedTitleWords text="Tu Imagen" class="block" />
					<AnimatedTitleWords text="Es Tu Activo." class="block" delay={400} />
				</h1>

				<p class="text-lg md:text-xl text-neutral-500 max-w-lg leading-relaxed mb-6 font-light">
					Deja de vestir para la persona que eras. Empieza a vestir
					para la posición que quieres ocupar.
				</p>

				<p class="text-sm text-neutral-400 max-w-md leading-relaxed mb-14 italic">
					La imagen personal no empieza en la ropa, empieza en la identidad.
				</p>

				<div class="flex flex-col sm:flex-row gap-5">
					<a
						href="/herramientas/test-colorimetria-online"
						class="bg-brand-primary text-white px-10 py-4 text-xs font-medium uppercase tracking-[0.2em] hover:bg-brand-black transition-colors duration-500 text-center"
					>
						Diagnóstico Gratuito
					</a>
					<a
						href="/servicios"
						class="px-10 py-4 text-xs font-medium uppercase tracking-[0.2em] text-brand-black border border-brand-black/20 hover:border-brand-black transition-colors duration-500 text-center"
					>
						Explorar Servicios
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- BRANDS -->
	<section class="py-10 border-y border-neutral-100 bg-white">
		<div class="container mx-auto px-6">
			<div class="flex flex-wrap justify-center items-center gap-12 md:gap-20 opacity-30">
				<span class="text-sm tracking-[0.15em] uppercase">L'Oréal</span>
				<span class="text-sm tracking-[0.15em] uppercase">Kérastase</span>
				<span class="text-sm tracking-[0.15em] uppercase">Zara</span>
				<span class="text-sm tracking-[0.15em] uppercase">Olaplex</span>
			</div>
		</div>
	</section>

	<!-- PROBLEM — dark with photo grid -->
	<section class="py-32 md:py-40 bg-brand-black text-white">
		<div class="container mx-auto px-6 max-w-6xl">
			<div class="grid md:grid-cols-12 gap-16 md:gap-24 items-center">
				<div class="md:col-span-5 order-2 md:order-1">
					<!-- Photo mosaic -->
					<div class="grid grid-cols-2 gap-2">
						<img src="/images/service-consulting-full.jpg" alt="Consultoría de imagen" class="w-full h-48 object-cover grayscale opacity-70" />
						<img src="/images/roger-adriana-duo.jpg" alt="Roger y Adriana" class="w-full h-48 object-cover grayscale opacity-70" />
						<img src="/images/executive-consulting.webp" alt="Imagen ejecutiva" class="w-full h-32 object-cover grayscale opacity-50 col-span-2" />
					</div>
				</div>

				<div class="md:col-span-7 order-1 md:order-2">
					<p class="text-xs tracking-[0.3em] uppercase text-neutral-500 mb-6">El Problema</p>
					<h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-white mb-10">
						¿Tu imagen se quedó en una versión anterior de ti?
					</h2>
					<p class="text-lg text-neutral-400 leading-relaxed mb-10 font-light">
						Sea un ascenso que no llega, una etapa de vida que ya superaste o simplemente ropa cara que no te funciona: el problema casi siempre es el mismo.
						<strong class="text-white font-normal">Tu imagen no está alineada con quién eres hoy.</strong>
					</p>

					<div class="space-y-5 border-l border-neutral-700 pl-8">
						{[
							"Estancamiento profesional invisible.",
							"Inseguridad en juntas directivas de alto nivel.",
							"Un espejo que ya no refleja quién eres hoy.",
							"Ropa cara que no te funciona. Dinero tirado.",
						].map(item => (
							<p class="text-sm text-neutral-400 leading-relaxed">{item}</p>
						))}
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- METHOD — white, image + stats -->
	<section class="py-32 md:py-40 bg-white text-brand-black">
		<div class="container mx-auto px-6 max-w-6xl">
			<div class="grid md:grid-cols-12 gap-16 md:gap-24 items-center">
				<div class="md:col-span-7">
					<p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">El Método</p>
					<h2 class="font-serif text-4xl md:text-6xl leading-[1.05] mb-10 text-brand-black">
						No usamos moda.<br />
						<span class="text-neutral-400">Usamos ciencia.</span>
					</h2>
					<p class="text-lg text-neutral-500 leading-relaxed mb-8 font-light max-w-xl">
						Antropometría, visagismo y semiótica para construir una estrategia
						visual que alinee tu exterior con tu capacidad interior.
					</p>
					<p class="text-base text-neutral-500 leading-relaxed mb-12 font-light max-w-xl border-l-2 border-brand-primary pl-6 italic">
						Porque la imagen personal no empieza en la ropa &mdash; empieza en la identidad.
					</p>

					<div class="flex gap-16">
						<div>
							<span class="block font-serif text-5xl text-brand-primary">12</span>
							<span class="text-xs tracking-[0.2em] uppercase text-neutral-400 mt-2 block">Estaciones</span>
						</div>
						<div>
							<span class="block font-serif text-5xl text-brand-primary">7</span>
							<span class="text-xs tracking-[0.2em] uppercase text-neutral-400 mt-2 block">Rostros</span>
						</div>
						<div>
							<span class="block font-serif text-5xl text-brand-primary">20+</span>
							<span class="text-xs tracking-[0.2em] uppercase text-neutral-400 mt-2 block">Años</span>
						</div>
					</div>
				</div>

				<div class="md:col-span-5">
					<img
						src="/images/roger-portrait-bw.jpg"
						alt="Roger Murillo"
						class="w-full grayscale"
					/>
				</div>
			</div>
		</div>
	</section>

	<!-- ECOSYSTEM — cards with images -->
	<section class="py-32 md:py-40 bg-neutral-50">
		<div class="container mx-auto px-6 max-w-6xl">
			<div class="max-w-xl mb-20">
				<p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Ecosistema</p>
				<h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black">
					Tres vías para transformar tu imagen.
				</h2>
			</div>

			<div class="grid md:grid-cols-3 gap-px bg-neutral-200">
				<!-- Card 1: Consultoría -->
				<a href="/servicios/asesoria-integral-imagen" class="group bg-white flex flex-col">
					<div class="overflow-hidden h-56">
						<img
							src="/images/service-consulting-full.jpg"
							alt="Consultoría integral de imagen"
							class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
						/>
					</div>
					<div class="p-10 flex flex-col justify-between flex-1">
						<div>
							<span class="text-xs tracking-[0.3em] uppercase text-neutral-400 block mb-4">01 · Premium</span>
							<h3 class="font-serif text-2xl md:text-3xl text-brand-black mb-4 group-hover:text-brand-primary transition-colors duration-500">
								A Puerta Cerrada
							</h3>
							<p class="text-sm text-neutral-500 leading-relaxed">
								Consultoría integral 1 a 1. Diagnóstico de rostro,
								cuerpo y armario. La experiencia definitiva en estudio privado.
							</p>
						</div>
						<span class="inline-flex items-center gap-3 text-xs tracking-[0.2em] uppercase text-brand-black group-hover:text-brand-primary transition-colors duration-500 mt-8">
							Agendar Cita <ArrowRight size={14} />
						</span>
					</div>
				</a>

				<!-- Card 2: Colorimetría -->
				<a href="/herramientas/test-colorimetria-online" class="group bg-white flex flex-col">
					<div class="overflow-hidden h-56 bg-brand-black flex items-center justify-center relative">
						<img
							src="/images/roger-murillo.jpg"
							alt="Test de colorimetría"
							class="w-full h-full object-cover opacity-40 group-hover:opacity-60 group-hover:scale-105 transition-all duration-700"
						/>
						<div class="absolute inset-0 flex items-center justify-center">
							<Palette size={48} className="text-brand-primary opacity-80" />
						</div>
					</div>
					<div class="p-10 flex flex-col justify-between flex-1">
						<div>
							<span class="text-xs tracking-[0.3em] uppercase text-neutral-400 block mb-4">02 · Digital · Gratis</span>
							<h3 class="font-serif text-2xl md:text-3xl text-brand-black mb-4 group-hover:text-brand-primary transition-colors duration-500">
								Test de Colorimetría
							</h3>
							<p class="text-sm text-neutral-500 leading-relaxed">
								Descubre tu paleta estacional con nuestro algoritmo de IA.
								Invierno, Verano, Otoño o Primavera. En 2 minutos.
							</p>
						</div>
						<span class="inline-flex items-center gap-3 text-xs tracking-[0.2em] uppercase text-brand-black group-hover:text-brand-primary transition-colors duration-500 mt-8">
							Hacer Test <ArrowRight size={14} />
						</span>
					</div>
				</a>

				<!-- Card 3: Academia -->
				<a href="/academia" class="group bg-white flex flex-col">
					<div class="overflow-hidden h-56">
						<img
							src="/images/course-descubrete.jpg"
							alt="La Academia Roger Murillo"
							class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
						/>
					</div>
					<div class="p-10 flex flex-col justify-between flex-1">
						<div>
							<span class="text-xs tracking-[0.3em] uppercase text-neutral-400 block mb-4">03 · Educación · Desde $25</span>
							<h3 class="font-serif text-2xl md:text-3xl text-brand-black mb-4 group-hover:text-brand-primary transition-colors duration-500">
								La Academia
							</h3>
							<p class="text-sm text-neutral-500 leading-relaxed">
								Cursos, guías y masterclasses para entender las reglas
								del color, el corte y el estilo. Deja de gastar en ropa que no funciona.
							</p>
						</div>
						<span class="inline-flex items-center gap-3 text-xs tracking-[0.2em] uppercase text-brand-black group-hover:text-brand-primary transition-colors duration-500 mt-8">
							Ver Catálogo <ArrowRight size={14} />
						</span>
					</div>
				</a>
			</div>
		</div>
	</section>

	<!-- ABOUT ROGER — dark, full image + text -->
	<section class="py-32 md:py-40 bg-brand-black text-white">
		<div class="container mx-auto px-6 max-w-6xl">
			<div class="grid md:grid-cols-12 gap-16 md:gap-24 items-center">
				<div class="md:col-span-5 order-2 md:order-1 relative">
					<img
						src="/images/roger-portrait-bw.jpg"
						alt="Roger Murillo"
						class="w-full object-cover"
					/>
					<!-- Red accent line -->
					<div class="absolute bottom-0 left-0 w-1 h-24 bg-brand-primary"></div>
				</div>

				<div class="md:col-span-7 order-1 md:order-2">
					<p class="text-xs tracking-[0.3em] uppercase text-neutral-500 mb-6">Roger Murillo</p>
					<h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-white mb-10">
						No soy un Personal Shopper.<br />
						<span class="text-neutral-500">Soy un Estratega.</span>
					</h2>
					<p class="text-lg text-neutral-400 leading-relaxed mb-8 font-light">
						Con más de 20 años de experiencia, he desarrollado una
						metodología que combina la precisión técnica del visagismo
						con la psicología del comportamiento.
					</p>
					<p class="text-lg text-neutral-400 leading-relaxed mb-10 font-light">
						Mi objetivo no es que te veas "bonito". Mi objetivo es que
						tu imagen sea una herramienta de negociación que trabaje a
						tu favor antes de que abras la boca.
					</p>
					<a href="/nosotros" class="inline-flex items-center gap-3 text-xs tracking-[0.2em] uppercase text-neutral-400 hover:text-brand-primary transition-colors duration-500">
						Conocer la Firma <ArrowRight size={14} />
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA FINAL -->
	<section class="py-32 md:py-40 bg-white">
		<div class="container mx-auto px-6 max-w-3xl text-center">
			<h2 class="font-serif text-4xl md:text-6xl leading-[1.05] text-brand-black mb-8">
				Tu próximo nivel<br />empieza aquí.
			</h2>
			<p class="text-lg text-neutral-500 font-light mb-14 max-w-lg mx-auto leading-relaxed">
				Agenda tu consultoría privada o comienza con un diagnóstico gratuito de colorimetría.
			</p>
			<div class="flex flex-col sm:flex-row gap-5 justify-center">
				<a
					href="/contacto"
					class="bg-brand-black text-white px-12 py-4 text-xs font-medium uppercase tracking-[0.2em] hover:bg-brand-primary transition-colors duration-500"
				>
					Agendar Consultoría
				</a>
				<a
					href="/herramientas/test-colorimetria-online"
					class="px-12 py-4 text-xs font-medium uppercase tracking-[0.2em] text-brand-black border border-brand-black/20 hover:border-brand-black transition-colors duration-500"
				>
					Test Gratuito
				</a>
			</div>
		</div>
	</section>
</MainLayout>
