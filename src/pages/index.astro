---
import MainLayout from "@/layouts/MainLayout.astro";
import AnimatedTitleWords from "@/components/ui/AnimatedTitleWords.astro";

const geoSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    name: "Roger Murillo",
    image: "https://rogermurillo.co/images/roger-hero.jpg",
    description: "Consultoría de imagen estratégica y visagismo para ejecutivos en Bogotá.",
    address: { "@type": "PostalAddress", addressLocality: "Bogotá", addressCountry: "CO" },
    priceRange: "$$$",
});
---

<MainLayout
    title="Roger Murillo | Asesor de Imagen Ejecutiva · Visagismo · Colorimetría en Bogotá"
    description="Consultoría de imagen personal y ejecutiva a puerta cerrada en Bogotá. Especialistas en visagismo, colorimetría y estilo estratégico para CEOs, directivos y líderes."
    schema={geoSchema}
>

    <style>
        .reveal{opacity:0;transform:translateY(36px);transition:opacity 1s cubic-bezier(.16,1,.3,1) var(--delay,0s),transform 1s cubic-bezier(.16,1,.3,1) var(--delay,0s)}
        .reveal.is-in{opacity:1;transform:translateY(0)}
        .num-huge{font-style:italic;color:rgba(196,18,48,.08);line-height:.8;position:absolute;pointer-events:none;user-select:none}
        .tag{display:inline-block;font-size:10px;letter-spacing:.3em;text-transform:uppercase;padding:6px 14px;border:1px solid currentColor;border-radius:999px}
        .eco-card{transition:all .6s cubic-bezier(.16,1,.3,1)}
        .eco-card:hover{transform:translateY(-4px)}
        .eco-card:hover .eco-title{color:var(--color-brand-primary, #C41230)}
        .eco-title{transition:color .5s}
        .marquee{display:flex;gap:5rem;white-space:nowrap;animation:marquee 40s linear infinite}
        @keyframes marquee{to{transform:translateX(-50%)}}
        .pillar-num{transition:all .5s}
        .stat-num{font-style:italic}
    </style>

    <!-- HERO — editorial, negro, líneas grandes -->
    <section class="pt-40 pb-32 md:pt-48 md:pb-40 bg-brand-black text-white relative overflow-hidden min-h-screen flex flex-col justify-center">
        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <div class="flex items-center gap-5 mb-14">
                <span class="w-12 h-px bg-brand-primary"></span>
                <p class="text-[10px] tracking-[0.4em] uppercase text-white/60">Consultoría de imagen · Bogotá</p>
            </div>
            <h1 class="font-serif leading-[0.85]">
                <AnimatedTitleWords text="Tu imagen" class="block text-6xl md:text-8xl lg:text-9xl text-white" />
                <AnimatedTitleWords text="es tu activo" class="block text-6xl md:text-8xl lg:text-9xl italic text-neutral-500 pl-[6%]" delay={300} />
                <AnimatedTitleWords text="más honesto." class="block text-6xl md:text-8xl lg:text-9xl text-brand-primary pl-[2%]" delay={500} />
            </h1>
            <div class="mt-16 grid md:grid-cols-12 gap-8">
                <div class="md:col-span-5 md:col-start-8 border-l-2 border-brand-primary pl-8">
                    <p class="text-lg font-light text-white/70 leading-relaxed mb-6">Deja de vestir para la persona que eras. Empieza a vestir para la posición que quieres ocupar.</p>
                    <p class="text-sm text-white/50 font-light italic leading-relaxed mb-10">La imagen personal no empieza en la ropa — empieza en la identidad.</p>
                    <div class="flex flex-col sm:flex-row gap-4">
                        <a href="/herramientas/test-colorimetria-online" class="bg-brand-primary text-white px-10 py-4 text-[11px] tracking-[0.25em] uppercase hover:bg-white hover:text-brand-black transition-all duration-500 text-center">Diagnóstico gratuito</a>
                        <a href="/servicios" class="px-10 py-4 text-[11px] tracking-[0.25em] uppercase text-white border border-white/30 hover:border-white transition-colors duration-500 text-center">Servicios</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- MARQUEE DE MARCAS -->
    <section class="py-12 border-y border-neutral-200 bg-white overflow-hidden">
        <div class="marquee">
            <div class="flex gap-20 items-center shrink-0">
                <span class="font-serif italic text-2xl text-neutral-300">L'Oréal</span>
                <span class="font-serif italic text-2xl text-neutral-300">·</span>
                <span class="font-serif italic text-2xl text-neutral-300">Kérastase</span>
                <span class="font-serif italic text-2xl text-neutral-300">·</span>
                <span class="font-serif italic text-2xl text-neutral-300">Zara</span>
                <span class="font-serif italic text-2xl text-neutral-300">·</span>
                <span class="font-serif italic text-2xl text-neutral-300">Olaplex</span>
                <span class="font-serif italic text-2xl text-neutral-300">·</span>
            </div>
            <div class="flex gap-20 items-center shrink-0" aria-hidden="true">
                <span class="font-serif italic text-2xl text-neutral-300">L'Oréal</span>
                <span class="font-serif italic text-2xl text-neutral-300">·</span>
                <span class="font-serif italic text-2xl text-neutral-300">Kérastase</span>
                <span class="font-serif italic text-2xl text-neutral-300">·</span>
                <span class="font-serif italic text-2xl text-neutral-300">Zara</span>
                <span class="font-serif italic text-2xl text-neutral-300">·</span>
                <span class="font-serif italic text-2xl text-neutral-300">Olaplex</span>
                <span class="font-serif italic text-2xl text-neutral-300">·</span>
            </div>
        </div>
    </section>

    <!-- EL PROBLEMA -->
    <section class="py-32 md:py-40 bg-white relative overflow-hidden">
        <span class="num-huge font-serif text-[28vw] -right-[4%] -top-[8%] absolute">01</span>
        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <div class="grid lg:grid-cols-12 gap-12">
                <div class="lg:col-span-5 lg:sticky lg:top-24 self-start">
                    <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-6">El problema</p>
                    <h2 class="font-serif text-4xl md:text-6xl leading-[0.95] text-brand-black mb-8">
                        Tu imagen<br/><span class="italic">se quedó</span><br/>en una versión<br/>anterior de ti.
                    </h2>
                    <p class="text-base text-neutral-500 font-light leading-relaxed max-w-md">
                        Sea un ascenso que no llega o una etapa que ya superaste: el problema casi siempre es el mismo.
                        <strong class="text-brand-black font-normal">Tu imagen no está alineada con quién eres hoy.</strong>
                    </p>
                </div>
                <div class="lg:col-span-7 space-y-16">
                    <div class="reveal border-l border-neutral-200 pl-8">
                        <p class="font-serif italic text-brand-primary text-xl mb-4">i.</p>
                        <h3 class="font-serif text-3xl text-brand-black mb-3">Estancamiento invisible</h3>
                        <p class="text-neutral-600 font-light leading-relaxed">Haces el trabajo, pero no lo ven. Porque tu presencia aún comunica al profesional de hace cinco años, no al de hoy.</p>
                    </div>
                    <div class="reveal border-l border-neutral-200 pl-8" style="--delay:.1s">
                        <p class="font-serif italic text-brand-primary text-xl mb-4">ii.</p>
                        <h3 class="font-serif text-3xl text-brand-black mb-3">Inseguridad en la sala</h3>
                        <p class="text-neutral-600 font-light leading-relaxed">Juntas directivas, presentaciones, negociaciones. Sentir que tu ropa habla antes que tú — y que no dice lo correcto.</p>
                    </div>
                    <div class="reveal border-l border-neutral-200 pl-8" style="--delay:.2s">
                        <p class="font-serif italic text-brand-primary text-xl mb-4">iii.</p>
                        <h3 class="font-serif text-3xl text-brand-black mb-3">Un espejo que ya no refleja</h3>
                        <p class="text-neutral-600 font-light leading-relaxed">Te ves bien en la foto, pero no te reconoces. La imagen quedó en otro capítulo mientras tú ya cambiaste de libro.</p>
                    </div>
                    <div class="reveal border-l border-neutral-200 pl-8" style="--delay:.3s">
                        <p class="font-serif italic text-brand-primary text-xl mb-4">iv.</p>
                        <h3 class="font-serif text-3xl text-brand-black mb-3">Ropa cara que no funciona</h3>
                        <p class="text-neutral-600 font-light leading-relaxed">Armarios llenos, nada que ponerse. Dinero invertido en prendas que no dialogan entre sí ni contigo.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- EL MÉTODO -->
    <section class="py-32 md:py-40 bg-brand-black text-white relative overflow-hidden">
        <span class="num-huge font-serif text-[28vw] -left-[4%] -top-[8%] absolute" style="color:rgba(255,255,255,.04)">02</span>
        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <div class="max-w-3xl mb-24">
                <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-6">El método</p>
                <h2 class="font-serif text-5xl md:text-7xl leading-[0.92]">
                    No usamos moda.<br/>Usamos <span class="italic text-neutral-500">ciencia.</span>
                </h2>
                <p class="mt-10 text-lg font-light text-white/70 leading-relaxed max-w-2xl">
                    Antropometría, visagismo y semiótica para construir una estrategia visual que alinee tu exterior con tu capacidad interior.
                </p>
                <p class="mt-6 text-base font-light italic text-white/50 leading-relaxed max-w-2xl border-l-2 border-brand-primary pl-6">
                    La imagen personal no empieza en la ropa — empieza en la identidad.
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-12 md:gap-6 border-t border-white/10 pt-16">
                <div class="reveal">
                    <span class="stat-num font-serif text-[10vw] md:text-[7vw] leading-none text-brand-primary block">12</span>
                    <p class="text-sm text-white/50 tracking-[0.15em] uppercase mt-4">Estaciones<br/>de colorimetría</p>
                </div>
                <div class="reveal" style="--delay:.1s">
                    <span class="stat-num font-serif text-[10vw] md:text-[7vw] leading-none text-brand-primary block">07</span>
                    <p class="text-sm text-white/50 tracking-[0.15em] uppercase mt-4">Geometrías<br/>faciales</p>
                </div>
                <div class="reveal" style="--delay:.2s">
                    <span class="stat-num font-serif text-[10vw] md:text-[7vw] leading-none text-brand-primary block">20+</span>
                    <p class="text-sm text-white/50 tracking-[0.15em] uppercase mt-4">Años<br/>de trayectoria</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ECOSISTEMA -->
    <section class="py-32 md:py-40 bg-white relative overflow-hidden">
        <span class="num-huge font-serif text-[28vw] -right-[4%] top-[10%] absolute">03</span>
        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <div class="max-w-3xl mb-24">
                <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-6">Ecosistema</p>
                <h2 class="font-serif text-5xl md:text-7xl leading-[0.92] text-brand-black">
                    Tres vías<br/>para <span class="italic text-neutral-400">transformarte.</span>
                </h2>
            </div>

            <div class="grid md:grid-cols-3 gap-px bg-neutral-200">
                <a href="/servicios/asesoria-integral-imagen" class="eco-card group bg-white flex flex-col">
                    <div class="overflow-hidden aspect-[4/3]">
                        <img src="/images/service-consulting-full.jpg" alt="Consultoría integral" class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" />
                    </div>
                    <div class="p-10 flex flex-col justify-between flex-1">
                        <div>
                            <span class="tag text-neutral-500 mb-6">01 · Premium</span>
                            <h3 class="eco-title font-serif text-3xl text-brand-black mb-4 mt-6">A puerta cerrada</h3>
                            <p class="text-sm text-neutral-500 leading-relaxed font-light">Consultoría integral 1 a 1. Diagnóstico de rostro, cuerpo y armario. La experiencia definitiva en estudio privado.</p>
                        </div>
                        <span class="inline-flex items-center gap-3 text-[10px] tracking-[0.25em] uppercase text-brand-black group-hover:text-brand-primary transition-colors duration-500 mt-10">Agendar cita →</span>
                    </div>
                </a>

                <a href="/herramientas/test-colorimetria-online" class="eco-card group bg-white flex flex-col">
                    <div class="overflow-hidden aspect-[4/3] bg-brand-black relative flex items-center justify-center">
                        <img src="/images/roger-murillo.jpg" alt="Test de colorimetría" class="w-full h-full object-cover opacity-30 group-hover:opacity-50 group-hover:scale-105 transition-all duration-700" />
                        <svg class="absolute" width="56" height="56" fill="none" stroke="#C41230" stroke-width="1" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 2a10 10 0 0 1 0 20"/><path d="M12 2v20"/></svg>
                    </div>
                    <div class="p-10 flex flex-col justify-between flex-1">
                        <div>
                            <span class="tag text-neutral-500 mb-6">02 · Digital · Gratis</span>
                            <h3 class="eco-title font-serif text-3xl text-brand-black mb-4 mt-6">Test de colorimetría</h3>
                            <p class="text-sm text-neutral-500 leading-relaxed font-light">Descubre tu paleta estacional con nuestro algoritmo de IA. Invierno, Verano, Otoño o Primavera. En dos minutos.</p>
                        </div>
                        <span class="inline-flex items-center gap-3 text-[10px] tracking-[0.25em] uppercase text-brand-black group-hover:text-brand-primary transition-colors duration-500 mt-10">Hacer test →</span>
                    </div>
                </a>

                <a href="/academia" class="eco-card group bg-white flex flex-col">
                    <div class="overflow-hidden aspect-[4/3]">
                        <img src="/images/course-descubrete.jpg" alt="La Academia" class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" />
                    </div>
                    <div class="p-10 flex flex-col justify-between flex-1">
                        <div>
                            <span class="tag text-neutral-500 mb-6">03 · Desde $25</span>
                            <h3 class="eco-title font-serif text-3xl text-brand-black mb-4 mt-6">La Academia</h3>
                            <p class="text-sm text-neutral-500 leading-relaxed font-light">Cursos, guías y masterclasses para entender las reglas del color, el corte y el estilo. Deja de gastar en ropa que no funciona.</p>
                        </div>
                        <span class="inline-flex items-center gap-3 text-[10px] tracking-[0.25em] uppercase text-brand-black group-hover:text-brand-primary transition-colors duration-500 mt-10">Ver catálogo →</span>
                    </div>
                </a>
            </div>
        </div>
    </section>

    <!-- DOS MIRADAS -->
    <section class="py-32 md:py-40 bg-neutral-50 relative overflow-hidden">
        <span class="num-huge font-serif text-[28vw] -left-[4%] -bottom-[10%] absolute">04</span>
        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <div class="max-w-3xl mb-20">
                <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-6">El diferencial</p>
                <h2 class="font-serif text-5xl md:text-7xl leading-[0.92] text-brand-black">
                    Dos miradas.<br/>Una sola <span class="italic text-neutral-400">estrategia.</span>
                </h2>
                <p class="mt-10 text-lg font-light text-neutral-600 leading-relaxed max-w-2xl">
                    Roger aporta la mirada masculina — autoridad, códigos de poder, presencia ejecutiva. Adriana, la femenina — armonía, coherencia estética, sensibilidad del color. Cada cliente recibe el beneficio de ambas lecturas. Un plus que nadie más te da.
                </p>
            </div>

            <div class="grid md:grid-cols-2 gap-px bg-neutral-200">
                <div class="bg-neutral-50 p-12 md:p-16">
                    <p class="tag text-brand-primary mb-8">Perspectiva masculina</p>
                    <h3 class="font-serif text-3xl md:text-4xl text-brand-black mb-6 mt-8">Roger Murillo</h3>
                    <p class="text-base text-neutral-600 font-light leading-relaxed mb-8">La lectura desde la autoridad, la presencia ejecutiva y los códigos de poder. Roger analiza cómo tu imagen comunica liderazgo, confianza y competencia.</p>
                    <a href="/nosotros#roger" class="inline-flex items-center gap-3 text-[10px] tracking-[0.25em] uppercase text-brand-black hover:text-brand-primary transition-colors duration-500">Leer su historia →</a>
                </div>
                <div class="bg-white p-12 md:p-16">
                    <p class="tag text-brand-primary mb-8">Perspectiva femenina</p>
                    <h3 class="font-serif text-3xl md:text-4xl text-brand-black mb-6 mt-8">Adriana Garzón</h3>
                    <p class="text-base text-neutral-600 font-light leading-relaxed mb-8">La lectura desde la armonía, la coherencia estética y la sensibilidad del color. Certificada por el IDB y el New York Institute.</p>
                    <a href="/nosotros#adriana" class="inline-flex items-center gap-3 text-[10px] tracking-[0.25em] uppercase text-brand-black hover:text-brand-primary transition-colors duration-500">Leer su historia →</a>
                </div>
            </div>
        </div>
    </section>

    <!-- CASOS DE ÉXITO TEASER -->
    <section class="py-32 md:py-40 bg-brand-black text-white relative overflow-hidden">
        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <div class="grid lg:grid-cols-12 gap-16 items-center">
                <div class="lg:col-span-7">
                    <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-6">Casos de éxito</p>
                    <h2 class="font-serif text-5xl md:text-7xl leading-[0.92] mb-10">
                        Cómo entran.<br/><span class="italic text-neutral-500">Cómo salen.</span>
                    </h2>
                    <p class="text-lg font-light text-white/70 leading-relaxed mb-12 max-w-xl">
                        Historias reales contadas en primera persona. El antes, el proceso y el después de quienes se sentaron en el estudio.
                    </p>
                    <a href="/casos-de-exito" class="inline-flex items-center gap-4 px-10 py-4 text-[11px] tracking-[0.25em] uppercase text-white border border-white/30 hover:border-white hover:bg-white hover:text-brand-black transition-all duration-500">Ver todas las historias →</a>
                </div>
                <div class="lg:col-span-5">
                    <div class="relative aspect-[4/5] overflow-hidden">
                        <img src="/images/roger-adriana-duo.jpg" alt="Caso de éxito" class="w-full h-full object-cover grayscale" />
                        <div class="absolute bottom-0 left-0 w-1 h-24 bg-brand-primary"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA FINAL -->
    <section class="py-32 md:py-40 bg-white relative overflow-hidden">
        <span class="num-huge font-serif text-[28vw] left-1/2 -translate-x-1/2 top-0 absolute">→</span>
        <div class="container mx-auto px-6 max-w-4xl text-center relative z-10">
            <h2 class="font-serif text-5xl md:text-8xl leading-[0.92] text-brand-black mb-10">
                Tu próximo nivel<br/><span class="italic text-brand-primary">empieza aquí.</span>
            </h2>
            <p class="text-lg font-light text-neutral-600 leading-relaxed max-w-xl mx-auto mb-14">
                Agenda tu consultoría privada o comienza con un diagnóstico gratuito de colorimetría.
            </p>
            <div class="flex flex-col sm:flex-row gap-5 justify-center">
                <a href="/contacto" class="bg-brand-black text-white px-12 py-5 text-[11px] tracking-[0.25em] uppercase hover:bg-brand-primary transition-colors duration-500">Agendar consultoría</a>
                <a href="/herramientas/test-colorimetria-online" class="px-12 py-5 text-[11px] tracking-[0.25em] uppercase text-brand-black border border-brand-black/20 hover:border-brand-black transition-colors duration-500">Test gratuito</a>
            </div>
        </div>
    </section>

    <script>
        const ro = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-in'); ro.unobserve(e.target) } }), { threshold: .15, rootMargin: '0px 0px -60px 0px' });
        document.querySelectorAll('.reveal').forEach(el => ro.observe(el));
    </script>

</MainLayout>
