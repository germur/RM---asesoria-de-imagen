---
import MainLayout from "@/layouts/MainLayout.astro";
import { ArrowRight, Star, ShieldCheck, Zap } from "lucide-react";
import AnimatedTitleWords from "@/components/ui/AnimatedTitleWords.astro";

const geoSchema = {
	"@context": "https://schema.org",
	"@type": "ProfessionalService",
	name: "Roger Murillo",
	image: "https://rogermurillo.co/images/roger-hero.jpg",
	description:
		"Consultoría de imagen estratégica y visagismo para ejecutivos en Bogotá.",
	address: {
		"@type": "PostalAddress",
		addressLocality: "Bogotá",
		addressCountry: "CO",
	},
	priceRange: "$$$",
};
---

<MainLayout
	title="Roger Murillo | Consultoría de Imagen Estratégica y Visagismo"
	description="Eleva tu estatus profesional. Consultoría de imagen 'A Puerta Cerrada' para CEOs y directivos. Especialista en Visagismo y Colorimetría."
	schema={geoSchema}
>
	<section
		class="relative min-h-[95vh] flex items-center bg-brand-black overflow-hidden"
	>
		<div class="absolute inset-0 z-0">
			<div
				class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/60 to-transparent z-10"
			>
			</div>
			<img
				src="/images/hero-editorial.jpg"
				alt="Roger Murillo Consultoría de Imagen Directiva"
				class="w-full h-full object-cover opacity-60"
				fetchpriority="high"
			/>
		</div>

		<div
			class="container mx-auto px-6 relative z-20 grid md:grid-cols-2 gap-12 items-center"
		>
			<div class="max-w-4xl">
				<div
					class="inline-flex items-center gap-2 mb-6 border-l-4 border-brand-primary pl-4 animate-fade-in-up"
				>
					<span
						class="text-brand-primary font-bold tracking-[0.2em] uppercase text-xs"
					>
						Estrategia &bull; Poder &bull; Estilo
					</span>
				</div>

				<h1
					class="font-serif text-6xl md:text-8xl lg:text-9xl text-white leading-[0.9] mb-8"
				>
					<AnimatedTitleWords text="Tu Imagen" class="block" />
					<AnimatedTitleWords
						text="Es Tu Activo."
						class="text-white"
						delay={400}
					/>
				</h1>

				<p
					class="text-xl md:text-2xl text-stone-300 mb-12 font-light max-w-xl leading-relaxed animate-fade-in-up delay-200"
				>
					Deja de vestir para la persona que eras. Empieza a vestir
					para la posición que quieres ocupar.
					<strong class="text-white"
						>Arquitectura de imagen para líderes.</strong
					>
				</p>

				<div
					class="flex flex-col sm:flex-row gap-6 animate-fade-in-up delay-300"
				>
					<a
						href="/herramientas/test-colorimetria-online"
						class="bg-brand-primary text-white px-10 py-5 text-sm font-bold uppercase tracking-widest hover:bg-brand-secondary transition-all duration-300 shadow-xl shadow-brand-primary/20 transform hover:-translate-y-1 flex items-center justify-center gap-3 rounded-sm"
					>
						<Zap size={18} fill="currentColor" /> Diagnóstico Gratuito
					</a>

					<a
						href="/servicios"
						class="px-10 py-5 text-sm font-bold uppercase tracking-widest text-white border border-white/30 hover:bg-white hover:text-brand-black transition-all duration-300 flex items-center justify-center rounded-sm"
					>
						Explorar Servicios
					</a>
				</div>
			</div>
		</div>
	</section>

	<section class="py-12 border-b border-brand-gray bg-white">
		<div class="container mx-auto px-6">
			<div
				class="flex flex-wrap justify-between items-center gap-8 md:gap-12 opacity-40 grayscale hover:grayscale-0 transition-all duration-700"
			>
				<span class="text-3xl font-serif font-bold tracking-tighter"
					>FORBES</span
				>
				<span class="text-3xl font-serif font-bold tracking-tighter"
					>GQ</span
				>
				<span class="text-3xl font-serif font-bold tracking-tighter"
					>VOGUE</span
				>
				<span class="text-3xl font-serif font-bold tracking-tighter"
					>L'OFFICIEL</span
				>
				<span class="text-3xl font-serif font-bold tracking-tighter"
					>TEDx</span
				>
			</div>
		</div>
	</section>

	<section class="py-32 bg-brand-gray">
		<div
			class="container mx-auto px-6 grid md:grid-cols-2 gap-20 items-center"
		>
			<div class="relative">
				<h2
					class="font-serif text-5xl md:text-6xl text-brand-black mb-8 leading-none"
				>
					¿Tu talento ha superado <br /> a tu presencia?
				</h2>
				<p
					class="text-brand-black/80 text-lg leading-relaxed mb-8 font-light"
				>
					Eres un experto en tu campo, pero cuando entras a una sala,
					no proyectas esa autoridad. En el mundo corporativo, <strong
						class="text-brand-black font-medium"
						>ser bueno no es suficiente. Tienes que parecerlo.</strong
					>
				</p>

				<div class="space-y-4">
					<div class="flex items-start gap-4">
						<div
							class="mt-1 w-2 h-2 bg-brand-primary rounded-full shrink-0"
						>
						</div>
						<p class="text-sm m-0">
							Estancamiento profesional invisible.
						</p>
					</div>
					<div class="flex items-start gap-4">
						<div
							class="mt-1 w-2 h-2 bg-brand-primary rounded-full shrink-0"
						>
						</div>
						<p class="text-sm m-0">
							Inseguridad en juntas directivas de alto nivel.
						</p>
					</div>
					<div class="flex items-start gap-4">
						<div
							class="mt-1 w-2 h-2 bg-brand-primary rounded-full shrink-0"
						>
						</div>
						<p class="text-sm m-0">
							Desconexión con tu equipo y clientes.
						</p>
					</div>
				</div>
			</div>

			<div
				class="bg-white p-12 shadow-2xl relative border-t-4 border-brand-primary relative"
			>
				<div
					class="absolute -top-6 -right-6 w-24 h-24 bg-brand-primary/10 rounded-full blur-3xl"
				>
				</div>

				<h3 class="font-serif text-3xl mb-6 text-brand-black">
					El Método Roger Murillo
				</h3>
				<p class="text-base text-gray-500 mb-10 leading-relaxed">
					No usamos "moda". Usamos <strong
						>antropometría, visagismo y semiótica</strong
					> para construir una estrategia visual que alinee tu exterior
					con tu capacidad interior.
				</p>

				<div class="grid grid-cols-2 gap-4 text-center">
					<div class="bg-brand-gray p-6 border border-stone-200">
						<span
							class="block text-4xl font-serif text-brand-primary mb-2"
							>12</span
						>
						<span
							class="text-xs uppercase tracking-widest font-bold"
							>Estaciones</span
						>
					</div>
					<div class="bg-brand-gray p-6 border border-stone-200">
						<span
							class="block text-4xl font-serif text-brand-primary mb-2"
							>7</span
						>
						<span
							class="text-xs uppercase tracking-widest font-bold"
							>Rostros</span
						>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="py-32 bg-white">
		<div class="container mx-auto px-6">
			<div
				class="flex flex-col md:flex-row justify-between items-end mb-20 border-b border-brand-black pb-6"
			>
				<div class="max-w-xl">
					<h2 class="font-serif text-5xl text-brand-black mb-4">
						Ecosistema de Imagen
					</h2>
					<p class="text-gray-500 font-light text-lg">
						Tres vías para transformar tu proyección profesional.
					</p>
				</div>
				<a
					href="/servicios"
					class="hidden md:block text-xs font-bold uppercase tracking-widest hover:text-brand-primary transition-colors mb-2"
				>
					Ver todos los servicios &rarr;
				</a>
			</div>

			<div class="grid md:grid-cols-3 gap-0 border-l border-brand-gray">
				<article
					class="group relative bg-white border-r border-y border-brand-gray p-10 hover:bg-brand-black transition-all duration-500 h-full flex flex-col justify-between"
				>
					<div>
						<span
							class="text-brand-primary font-bold text-xs uppercase tracking-widest mb-6 block"
							>01. Premium</span
						>
						<h3
							class="font-serif text-3xl mb-6 group-hover:text-white transition-colors"
						>
							A Puerta Cerrada
						</h3>
						<p
							class="text-gray-500 text-sm mb-8 leading-relaxed group-hover:text-gray-400"
						>
							Consultoría integral 1 a 1. Diagnóstico de rostro,
							cuerpo y armario. La experiencia definitiva de
							transformación en estudio privado.
						</p>
					</div>
					<a
						href="/servicios/asesoria-integral-imagen"
						class="inline-flex items-center text-xs font-bold uppercase tracking-widest text-brand-black group-hover:text-white group-hover:underline decoration-brand-primary underline-offset-4"
					>
						Agendar Cita <ArrowRight
							className="ml-2 w-4 group-hover:text-brand-primary"
						/>
					</a>
				</article>

				<article
					class="group relative bg-white border-r border-y border-brand-gray p-10 hover:bg-brand-black transition-all duration-500 h-full flex flex-col justify-between"
				>
					<div>
						<span
							class="text-brand-primary font-bold text-xs uppercase tracking-widest mb-6 block"
							>02. Digital</span
						>
						<h3
							class="font-serif text-3xl mb-6 group-hover:text-white transition-colors"
						>
							Test de Colorimetría
						</h3>
						<p
							class="text-gray-500 text-sm mb-8 leading-relaxed group-hover:text-gray-400"
						>
							Descubre tu paleta estacional (Invierno, Verano,
							Otoño, Primavera) con nuestro algoritmo de IA.
							Gratis y al instante.
						</p>
					</div>
					<a
						href="/herramientas/test-colorimetria-online"
						class="inline-flex items-center text-xs font-bold uppercase tracking-widest text-brand-black group-hover:text-white group-hover:underline decoration-brand-primary underline-offset-4"
					>
						Hacer Test <ArrowRight
							className="ml-2 w-4 group-hover:text-brand-primary"
						/>
					</a>
				</article>

				<article
					class="group relative bg-white border-r border-y border-brand-gray p-10 hover:bg-brand-black transition-all duration-500 h-full flex flex-col justify-between"
				>
					<div>
						<span
							class="text-brand-primary font-bold text-xs uppercase tracking-widest mb-6 block"
							>03. Educación</span
						>
						<h3
							class="font-serif text-3xl mb-6 group-hover:text-white transition-colors"
						>
							La Academia
						</h3>
						<p
							class="text-gray-500 text-sm mb-8 leading-relaxed group-hover:text-gray-400"
						>
							Libros, guías y masterclasses para dominar tu estilo
							a tu propio ritmo. Formación técnica para
							profesionales y entusiastas.
						</p>
					</div>
					<a
						href="/academia"
						class="inline-flex items-center text-xs font-bold uppercase tracking-widest text-brand-black group-hover:text-white group-hover:underline decoration-brand-primary underline-offset-4"
					>
						Ver Catálogo <ArrowRight
							className="ml-2 w-4 group-hover:text-brand-primary"
						/>
					</a>
				</article>
			</div>
		</div>
	</section>

	<section class="py-32 bg-brand-black text-white relative overflow-hidden">
		<div
			class="absolute top-0 right-0 w-1/3 h-full bg-brand-primary opacity-5 skew-x-12 transform origin-top-right"
		>
		</div>

		<div
			class="container mx-auto px-6 grid md:grid-cols-12 gap-16 items-center relative z-10"
		>
			<div class="md:col-span-7 order-2 md:order-1">
				<h2 class="font-serif text-5xl md:text-7xl mb-8 leading-none">
					No soy un "Personal Shopper". <br />
					<span class="text-brand-primary italic font-serif"
						>Soy un Estratega.</span
					>
				</h2>
				<div class="w-24 h-1 bg-white/20 mb-8"></div>
				<p
					class="text-xl text-gray-400 mb-6 leading-relaxed font-light"
				>
					Con más de 20 años de experiencia, he desarrollado una
					metodología que combina la precisión técnica del <strong
						>visagismo</strong
					> con la psicología del comportamiento.
				</p>
				<p
					class="text-xl text-gray-400 mb-12 leading-relaxed font-light"
				>
					Mi objetivo no es que te veas "bonito". Mi objetivo es que
					tu imagen sea una herramienta de negociación que trabaje a
					tu favor antes de que abras la boca.
				</p>
				<div class="flex items-center gap-4">
					<ShieldCheck class="text-brand-primary w-8 h-8" />
					<span
						class="text-xs font-bold uppercase tracking-widest text-white"
						>Certificado Internacional</span
					>
				</div>
			</div>

			<div class="md:col-span-5 order-1 md:order-2 relative">
				<div
					class="relative z-10 border-2 border-brand-primary p-4 rounded-sm"
				>
					<img
						src="/images/roger-portrait-editorial.jpg"
						alt="Roger Murillo"
						class="w-full grayscale contrast-125 hover:grayscale-0 transition-all duration-700"
					/>
				</div>
				<div
					class="absolute top-8 left-8 w-full h-full bg-brand-gray/10 -z-10"
				>
				</div>
			</div>
		</div>
	</section>
</MainLayout>
