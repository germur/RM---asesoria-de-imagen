---
import MainLayout from "@/layouts/MainLayout.astro";

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "Reto Revoluciona Tu Imagen",
  description: "Dossier cinematográfico de construcción de personaje."
});

const GENRES = ["Acción","Intriga","De época","Deporte","Documental","Drama","Fantasía","Fe y Espiritualidad","Independiente","Humor","Musical","Romance","Ciencia Ficción","Terror","Policial"];
const RATINGS = ["Todo público","+7","+13","+16","Solo Adultos"];
const ROLES = [
  { key:"familia",      label:"Familia",             q:"¿Qué personaje soy aquí?" },
  { key:"hobbies",      label:"Hobbies",             q:"¿Qué energía proyecto?" },
  { key:"trabajo",      label:"Trabajo",             q:"¿Soy referente, aprendiz, invisible, indispensable?" },
  { key:"viajes",       label:"Viajes",              q:"¿Viajo para expandirme o por obligación?" },
  { key:"profesion",    label:"Profesión",           q:"¿Tengo espacio para mi expresión personal?" },
  { key:"pareja",       label:"Pareja",              q:"¿Qué rol interpreto?" },
  { key:"amigos",       label:"Amigos",              q:"¿Soy auténtica o interpreto algo distinto?" },
  { key:"espiritualidad", label:"Espiritualidad",    q:"¿Es parte visible o privada?" },
  { key:"diversion",    label:"Diversión",           q:"¿Mi personaje sabe disfrutar?" },
  { key:"crecimiento",  label:"Crecimiento",         q:"¿Estoy evolucionando o sobreviviendo?" },
  { key:"educacion",    label:"Educación",           q:"¿Me actualizo acorde al personaje que quiero ser?" },
];
const SCENES = [
  { n:"01", t:"EL LEGADO",      s:"Rol Profesional · Misión" },
  { n:"02", t:"LA INTIMIDAD",   s:"Rol Pareja · Magnetismo" },
  { n:"03", t:"LA TRIBU",       s:"Rol Social · Amigos" },
  { n:"04", t:"EL RECREO",      s:"Rol Hobbies · Yo conmigo" },
  { n:"05", t:"ESCENA LIBRE",   s:"Define tú" },
  { n:"06", t:"ESCENA LIBRE",   s:"Define tú" },
];
const LEVELS = [
  { n:"01", t:"Propósito & Trascendencia", s:"El mensaje", q:"¿Para qué existe este personaje en el mundo? ¿A quién sirvo e inspiro?" },
  { n:"02", t:"Identidad",                 s:"El protagonista", q:"Yo soy... (metáforas, arquetipos, no cargos laborales)." },
  { n:"03", t:"Creencias & Valores",       s:"El subtexto", q:"¿Me creo merecedora de esa vida? ¿Cuál es mi valor innegociable?" },
  { n:"04", t:"Capacidades",               s:"Las herramientas", q:"¿Qué habilidades debo empezar a cultivar HOY?" },
  { n:"05", t:"Comportamiento",            s:"La acción", q:"Un martes cualquiera dentro de 10 años... ¿cómo saludas? ¿de qué hablas?" },
  { n:"06", t:"Entorno",                   s:"El set", q:"Describe el entorno físico que rodea a esa identidad." },
];

// Estructura del wizard (11 pasos)
const STEPS = [
  { id: 1, part: "00", title: "Portada" },
  { id: 2, part: "01", title: "La película actual" },
  { id: 3, part: "01", title: "El personaje de hoy" },
  { id: 4, part: "01", title: "Roles que protagonizo" },
  { id: 5, part: "01", title: "El costo de no cambiar" },
  { id: 6, part: "02", title: "Punto de quiebre" },
  { id: 7, part: "03", title: "La nueva película" },
  { id: 8, part: "03", title: "Construcción de roles" },
  { id: 9, part: "03", title: "Las 6 escenas" },
  { id: 10, part: "04", title: "Proyección 10 años" },
  { id: 11, part: "05", title: "Declaración final" },
];
---

<MainLayout
  title="Reto Revoluciona Tu Imagen · Dossier Cinematográfico | Roger Murillo"
  description="Construye el personaje que interpretarás los próximos 10 años. Guía interactiva en 11 pasos."
  schema={schema}
>

  <style is:global>
    :root{--rm-red:#C41230}
    .reto-body{background:#0a0a0a;color:#fff;font-family:inherit}
    .reto-body{--rm-navH:150px}
    .reto-body::before{content:"";position:fixed;top:0;left:0;right:0;height:var(--rm-navH);background:#fff;z-index:1;pointer-events:none}
    @media(max-width:900px){.reto-body{--rm-navH:120px}}

    /* INPUTS unificados */
    .fi{background:transparent;border:0;border-bottom:1px solid rgba(255,255,255,.18);color:#fff;width:100%;padding:14px 0;font-size:1.05rem;font-weight:300;outline:none;transition:border-color .3s}
    .fi:focus{border-bottom-color:var(--rm-red)}
    .fi::placeholder{color:rgba(255,255,255,.3);font-style:italic}
    .ft{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.12);color:#fff;width:100%;padding:16px;font-size:1rem;font-weight:300;line-height:1.6;resize:vertical;min-height:110px;outline:none;transition:border-color .3s;font-family:inherit}
    .ft:focus{border-color:rgba(255,255,255,.4)}
    .ft::placeholder{color:rgba(255,255,255,.3);font-style:italic}

    /* CHIPS */
    .chip{display:inline-flex;padding:8px 14px;font-size:10px;letter-spacing:.18em;text-transform:uppercase;border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.65);cursor:pointer;transition:all .2s;user-select:none}
    .chip:hover{border-color:#fff;color:#fff}
    .chip.active{background:var(--rm-red);border-color:var(--rm-red);color:#fff}

    /* WIZARD LAYOUT */
    .wizard{min-height:100vh;display:grid;grid-template-columns:260px 1fr;gap:0;padding-top:var(--rm-navH)}
    @media(max-width:900px){.wizard{grid-template-columns:1fr;padding-top:var(--rm-navH)}.wiz-side{display:none}}
    .wiz-side{background:#050505;border-right:1px solid rgba(255,255,255,.08);padding:40px 24px;position:sticky;top:var(--rm-navH);height:calc(100vh - var(--rm-navH));overflow-y:auto}
    .wiz-main{padding:40px 40px 140px;max-width:780px;margin:0 auto;width:100%}
    @media(max-width:900px){.wiz-main{padding:16px 20px 160px}}
    @media(max-width:480px){.wiz-main{padding:12px 16px 180px}}

    /* MOBILE STEP STRIP */
    .wiz-mobile-strip{display:none}
    @media(max-width:900px){
      .wiz-mobile-strip{display:flex;position:sticky;top:var(--rm-navH);z-index:30;background:#050505;border-bottom:1px solid rgba(255,255,255,.08);padding:10px 12px;gap:8px;overflow-x:auto;scrollbar-width:none;-webkit-overflow-scrolling:touch;margin:0 -20px 20px}
      .wiz-mobile-strip::-webkit-scrollbar{display:none}
      .wiz-pill{flex:0 0 auto;display:flex;align-items:center;gap:6px;padding:8px 12px;font-size:10px;letter-spacing:.15em;text-transform:uppercase;border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.55);background:transparent;font-family:inherit;cursor:pointer;white-space:nowrap}
      .wiz-pill.active{border-color:var(--rm-red);background:var(--rm-red);color:#fff}
      .wiz-pill.done{color:#fff;border-color:rgba(255,255,255,.35)}
      .wiz-pill-n{font-family:serif;font-style:italic;font-size:11px}
    }

    .step-item{display:flex;align-items:flex-start;gap:12px;padding:10px 8px;cursor:pointer;border-left:2px solid transparent;transition:all .25s;text-align:left;width:100%;background:none;border-right:0;border-top:0;border-bottom:0;font-family:inherit}
    .step-item:hover{background:rgba(255,255,255,.03)}
    .step-item.active{border-left-color:var(--rm-red);background:rgba(196,18,48,.07)}
    .step-item.done .step-n{background:var(--rm-red);color:#fff;border-color:var(--rm-red)}
    .step-n{display:flex;align-items:center;justify-content:center;width:22px;height:22px;border:1px solid rgba(255,255,255,.2);font-size:10px;font-family:serif;font-style:italic;color:rgba(255,255,255,.5);flex-shrink:0;margin-top:2px}
    .step-item.active .step-n{border-color:var(--rm-red);color:#fff}
    .step-tl{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.35)}
    .step-ti{font-size:13px;color:rgba(255,255,255,.75);font-weight:300;margin-top:2px}
    .step-item.active .step-ti{color:#fff}

    /* STEP CONTENT */
    .step-panel{display:none;animation:fadeIn .4s ease}
    .step-panel.active{display:block}
    @keyframes fadeIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

    .step-head{margin-bottom:40px}
    @media(max-width:600px){.step-head{margin-bottom:28px}}
    .step-tag{font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--rm-red);margin-bottom:12px}
    .step-title{font-family:serif;font-size:2.5rem;line-height:1.05;font-weight:400;word-wrap:break-word;overflow-wrap:break-word;hyphens:auto}
    @media(max-width:600px){.step-title{font-size:1.75rem;line-height:1.1}}
    .step-sub{font-family:serif;font-style:italic;color:rgba(255,255,255,.5);font-size:1.1rem;margin-top:14px;line-height:1.4}
    @media(max-width:600px){.step-sub{font-size:1rem}}
    @media(max-width:600px){.accent-box{padding:20px}.decl{padding:22px;font-size:1rem}.pullq{font-size:1.1rem;padding-left:14px;margin:24px 0}}
    .two-col{display:grid;grid-template-columns:1fr 1fr;gap:24px}
    @media(max-width:600px){.two-col{grid-template-columns:1fr;gap:16px}}

    .field{margin-bottom:32px}
    .field-label{display:block;font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:10px}
    .field-prompt{font-family:serif;font-style:italic;color:rgba(255,255,255,.75);font-size:1.05rem;margin-bottom:10px;line-height:1.4}
    .field-hint{font-size:12px;color:rgba(255,255,255,.4);margin-top:6px;font-style:italic}

    /* NAV */
    .wiz-nav{position:fixed;bottom:0;left:260px;right:0;background:rgba(10,10,10,.96);backdrop-filter:blur(12px);border-top:1px solid rgba(255,255,255,.08);padding:16px 40px;display:flex;justify-content:space-between;align-items:center;z-index:40;padding-bottom:calc(16px + env(safe-area-inset-bottom,0))}
    @media(max-width:900px){.wiz-nav{left:0;padding:12px 14px;padding-bottom:calc(12px + env(safe-area-inset-bottom,0));gap:8px}.wiz-nav .wiz-count{display:none}.wiz-progress{margin:0 8px}}
    @media(max-width:480px){.wiz-nav{padding:10px 10px;padding-bottom:calc(10px + env(safe-area-inset-bottom,0))}}
    .wiz-btn{padding:14px 28px;font-size:10px;letter-spacing:.25em;text-transform:uppercase;border:1px solid rgba(255,255,255,.25);color:#fff;background:transparent;cursor:pointer;transition:all .3s;font-family:inherit}
    @media(max-width:480px){.wiz-btn{padding:11px 14px;font-size:9px;letter-spacing:.18em;flex-shrink:0}}
    .wiz-btn:hover{border-color:#fff;background:rgba(255,255,255,.05)}
    .wiz-btn:disabled{opacity:.25;cursor:not-allowed}
    .wiz-btn.primary{background:var(--rm-red);border-color:var(--rm-red)}
    .wiz-btn.primary:hover{background:#fff;color:var(--rm-red);border-color:#fff}
    .wiz-progress{flex:1;margin:0 24px;height:2px;background:rgba(255,255,255,.1);position:relative;max-width:300px}
    .wiz-progress-fill{position:absolute;top:0;left:0;height:100%;background:var(--rm-red);transition:width .4s cubic-bezier(.16,1,.3,1)}
    .wiz-count{font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:rgba(255,255,255,.45);white-space:nowrap}

    /* Accordion styling */
    details.rolebox{border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.02);margin-bottom:10px}
    details.rolebox summary{display:flex;justify-content:space-between;align-items:center;padding:16px 20px;cursor:pointer;list-style:none}
    details.rolebox summary::-webkit-details-marker{display:none}
    details.rolebox[open]{background:rgba(255,255,255,.04)}
    .chev{transition:transform .3s;width:14px;height:14px;opacity:.5}
    details[open] .chev{transform:rotate(180deg)}

    /* Scene cards */
    .scene-card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.1);padding:20px;transition:border-color .4s}
    .scene-card:hover,.scene-card:focus-within{border-color:var(--rm-red)}

    /* Pull quote */
    .pullq{font-family:serif;font-style:italic;font-size:1.3rem;line-height:1.45;color:rgba(255,255,255,.7);border-left:2px solid var(--rm-red);padding-left:20px;margin:32px 0}

    /* Box accent */
    .accent-box{background:linear-gradient(135deg,rgba(196,18,48,.1),rgba(196,18,48,0));border-left:3px solid var(--rm-red);padding:28px}

    /* Declaration */
    .decl{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.12);padding:32px;font-family:serif;font-size:1.1rem;line-height:1.65;color:rgba(255,255,255,.85)}
    .decl p{margin-bottom:14px}
    .decl em{font-style:italic;color:rgba(255,255,255,.7)}
    .decl .highlight{color:var(--rm-red);font-style:italic}

    /* ─── PRINT MODE ───
       Aplasta el wizard en una versión larga y limpia.
       Oculta nav, barra de progreso, CTAs externos, botones, aviso de cookies, etc.
    */
    @media print{
      @page{margin:18mm 14mm;size:A4}
      html,body{background:#fff !important;color:#000 !important;font-family:Georgia,serif}
      body *{color:#000 !important;background:transparent !important;border-color:rgba(0,0,0,.2) !important;box-shadow:none !important}
      /* Oculta toda la estructura que no sea el dossier */
      header,footer,nav,.no-print,.wiz-side,.wiz-nav,#main-header,#mobile-menu,
      [class*="cookie"],[id*="cookie"],[class*="Cookie"],[id*="Cookie"],
      iframe,.wiz-progress,button{display:none !important}
      /* Expande TODOS los pasos */
      .step-panel{display:block !important;page-break-inside:avoid;page-break-after:always;padding-top:20px}
      .step-panel:last-child{page-break-after:auto}
      .wizard{display:block !important;grid-template-columns:none !important}
      .wiz-main{max-width:100% !important;padding:0 !important}
      .step-title{font-size:28pt !important;color:#000 !important}
      .step-tag{color:#C41230 !important;font-size:9pt !important}
      .field-prompt,.field-label{color:#000 !important}
      .fi,.ft{border-color:#000 !important;color:#000 !important;min-height:60px;background:rgba(0,0,0,.02) !important;padding:8px !important}
      .chip{border-color:#000 !important;color:#000 !important}
      .chip.active{background:#C41230 !important;color:#fff !important;border-color:#C41230 !important}
      .chip.active,.chip.active *{color:#fff !important}
      .pullq,.decl em,.step-sub{color:#444 !important}
      .highlight,.step-tag{color:#C41230 !important}
      details.rolebox{background:transparent !important;border:1px solid #ccc !important}
      details.rolebox[open]{background:transparent !important}
      details.rolebox summary{padding:10px !important}
      .chev{display:none !important}
      details.rolebox > div{display:block !important;padding:0 10px 10px}
      .scene-card{border:1px solid #ccc !important;padding:12px !important;margin-bottom:12px}
      .accent-box{border-left:3px solid #C41230 !important;padding:16px !important}
      .decl{border:1px solid #000 !important;padding:20px !important}
      /* Abre TODOS los details al imprimir */
      details{display:block !important}
      details > summary{display:block !important}
      details > *:not(summary){display:block !important}
    }
  </style>

  <div class="reto-body">
    <div class="wizard">

      <!-- ─── SIDEBAR: navegación de pasos ─── -->
      <aside class="wiz-side">
        <p style="font-size:10px;letter-spacing:.35em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:8px">Dossier</p>
        <p style="font-family:serif;font-size:1.3rem;line-height:1.1;margin-bottom:28px">Revoluciona<br/><em style="font-style:italic;color:var(--rm-red)">tu imagen</em></p>
        <nav id="sideNav" style="display:flex;flex-direction:column">
          {STEPS.map(s => (
            <button class="step-item" data-goto={s.id}>
              <span class="step-n">{String(s.id).padStart(2,'0')}</span>
              <span>
                <span class="step-tl">Parte {s.part}</span>
                <span class="step-ti" style="display:block">{s.title}</span>
              </span>
            </button>
          ))}
        </nav>
        <div style="margin-top:40px;padding-top:24px;border-top:1px solid rgba(255,255,255,.08)">
          <button id="btnPrintSide" class="wiz-btn" style="width:100%;margin-bottom:8px;font-size:9px">Imprimir / PDF</button>
          <button id="btnResetSide" class="wiz-btn" style="width:100%;font-size:9px;border-color:rgba(255,255,255,.12)">Reiniciar</button>
        </div>
      </aside>

      <!-- ─── MAIN: panels ─── -->
      <main class="wiz-main">

        <!-- Mobile step strip (visible <900px) -->
        <nav class="wiz-mobile-strip" id="mobileStrip" aria-label="Pasos del reto">
          {STEPS.map(s => (
            <button class="wiz-pill" data-goto={s.id}>
              <span class="wiz-pill-n">{String(s.id).padStart(2,'0')}</span>
              <span>{s.title}</span>
            </button>
          ))}
        </nav>

        <!-- PASO 1 — PORTADA -->
        <section class="step-panel active" data-step="1">
          <p style="font-size:10px;letter-spacing:.4em;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:24px">Dossier Cinematográfico · Primera Edición</p>
          <h1 style="font-family:serif;font-size:clamp(2rem,7vw,5.5rem);line-height:.9;margin-bottom:8px">Construcción</h1>
          <h1 style="font-family:serif;font-size:clamp(2rem,7vw,5.5rem);line-height:.9;font-style:italic;color:var(--rm-red);margin-bottom:40px">del personaje.</h1>

          <div class="pullq">
            "La imagen personal no comienza en la ropa.<br/>Comienza en la identidad."
          </div>

          <p style="color:rgba(255,255,255,.7);line-height:1.7;margin-bottom:16px">Durante años hemos aprendido a proyectarnos hacia afuera: cómo vestirnos, cómo maquillarnos, cómo comportarnos. Pero pocas veces nos hemos detenido a definir quién queremos ser.</p>
          <p style="color:rgba(255,255,255,.7);line-height:1.7;margin-bottom:16px">Cada persona interpreta un personaje en la película de su vida. Cuando el personaje no es consciente, la imagen se vuelve improvisada.</p>
          <p style="color:rgba(255,255,255,.85);line-height:1.7;margin-bottom:32px">Aquí no trabajaremos únicamente apariencia. Trabajaremos <span style="color:var(--rm-red)">narrativa</span>, <span style="color:var(--rm-red)">coherencia</span> y <span style="color:var(--rm-red)">presencia</span>.</p>

          <div class="accent-box">
            <p style="font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--rm-red);margin-bottom:10px">Cómo funciona</p>
            <p style="color:rgba(255,255,255,.85);line-height:1.7;font-size:.95rem">11 pasos · sin prisa · cada respuesta se guarda automáticamente en este navegador. Al final, podrás imprimir tu dossier completo o guardarlo como PDF.</p>
          </div>
        </section>

        <!-- PASO 2 — La película actual -->
        <section class="step-panel" data-step="2">
          <div class="step-head">
            <p class="step-tag">Parte 01 · Diagnóstico</p>
            <h2 class="step-title">La película<br/><em style="font-style:italic;color:rgba(255,255,255,.5)">que protagonizas hoy.</em></h2>
          </div>

          <div class="field">
            <label class="field-label">01 · Título de la película actual</label>
            <p class="field-prompt">Si mi vida hoy fuera una película, se llamaría...</p>
            <input type="text" class="fi" data-save="titulo_actual" placeholder='Ej. "La eterna preparación"' />
          </div>

          <div class="field">
            <label class="field-label">02 · Género</label>
            <div style="display:flex;flex-wrap:wrap;gap:8px" data-chips="genero_actual">
              {GENRES.map(g => <span class="chip" data-val={g}>{g}</span>)}
            </div>
          </div>

          <div class="field">
            <label class="field-label">03 · Audiencia</label>
            <p class="field-hint" style="margin:0 0 10px">Revisa el contenido sexual, lenguaje y violencia que aparece hoy en tu vida.</p>
            <div style="display:flex;flex-wrap:wrap;gap:8px" data-chips="audiencia">
              {RATINGS.map(r => <span class="chip" data-val={r}>{r}</span>)}
            </div>
          </div>
        </section>

        <!-- PASO 3 — El personaje de hoy -->
        <section class="step-panel" data-step="3">
          <div class="step-head">
            <p class="step-tag">Parte 01 · Diagnóstico</p>
            <h2 class="step-title">El personaje<br/><em style="font-style:italic;color:rgba(255,255,255,.5)">que interpreto hoy.</em></h2>
          </div>

          <div class="field">
            <label class="field-label">Nombre simbólico del personaje</label>
            <input type="text" class="fi" data-save="personaje_nombre" placeholder='Ej. "La guerrera cansada", "El rey silencioso"' />
          </div>

          <div class="field">
            <p class="field-prompt">¿Cómo vive? ¿Cómo se muestra? ¿Qué energía proyecta?</p>
            <textarea class="ft" data-save="personaje_descripcion"></textarea>
          </div>

          <div class="field accent-box" style="margin-top:40px">
            <label class="field-label" style="color:var(--rm-red)">Valor cinematográfico</label>
            <p class="field-hint" style="margin:0 0 16px;color:rgba(255,255,255,.6)">Si este personaje fuera un actor en el mercado internacional, ¿cuál sería su valor? No es dinero literal — es percepción, posicionamiento, impacto.</p>
            <div style="display:flex;align-items:baseline;gap:14px;margin-bottom:20px">
              <span style="font-family:serif;font-style:italic;font-size:2.5rem;color:var(--rm-red)">US$</span>
              <input type="text" class="fi" data-save="valor_actual" placeholder="0" style="font-family:serif;font-style:italic;font-size:2rem" />
            </div>
            <p class="field-prompt">¿Por qué le asignaste este valor?</p>
            <textarea class="ft" data-save="valor_actual_razon" style="margin-bottom:14px"></textarea>
            <p class="field-prompt">¿Qué tendría que cambiar para que se duplicara o triplicara?</p>
            <textarea class="ft" data-save="valor_actual_multiplicar"></textarea>
          </div>
        </section>

        <!-- PASO 4 — Roles -->
        <section class="step-panel" data-step="4">
          <div class="step-head">
            <p class="step-tag">Parte 01 · Diagnóstico</p>
            <h2 class="step-title">Roles<br/><em style="font-style:italic;color:rgba(255,255,255,.5)">que protagonizo.</em></h2>
            <p class="step-sub">Evalúa el personaje que interpretas en cada rol. Honestidad, sin juicios.</p>
          </div>

          {ROLES.map(r => (
            <details class="rolebox">
              <summary>
                <div>
                  <p class="step-tl" style="font-size:9px">{r.key.toUpperCase()}</p>
                  <h4 style="font-family:serif;font-size:1.3rem;margin-top:2px">{r.label}</h4>
                </div>
                <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
              </summary>
              <div style="padding:0 20px 20px">
                <p class="field-prompt" style="margin-top:6px">{r.q}</p>
                <textarea class="ft" data-save={`rol_${r.key}`}></textarea>
              </div>
            </details>
          ))}

          <div class="field" style="margin-top:40px">
            <label class="field-label">Coherencia</label>
            <p class="field-prompt">¿Mi imagen externa es coherente con el personaje que interpreto?</p>
            <div style="display:flex;gap:8px;margin-bottom:14px" data-chips="coherencia">
              <span class="chip" data-val="Sí">Sí</span>
              <span class="chip" data-val="No">No</span>
              <span class="chip" data-val="Parcialmente">Parcialmente</span>
            </div>
            <textarea class="ft" data-save="coherencia_explica" placeholder="Explica tu respuesta..."></textarea>
          </div>
        </section>

        <!-- PASO 5 — Costo de no cambiar -->
        <section class="step-panel" data-step="5">
          <div class="step-head">
            <p class="step-tag">Parte 01 · Diagnóstico</p>
            <h2 class="step-title">El costo<br/><em style="font-style:italic;color:rgba(255,255,255,.5)">de no cambiar.</em></h2>
          </div>

          <div class="field">
            <label class="field-label">Lo que ya no me gusta de esta película</label>
            <p class="field-prompt">Escenas que no quiero repetir:</p>
            <textarea class="ft" data-save="escenas_no_repetir" style="margin-bottom:16px"></textarea>
            <p class="field-prompt">Actitudes que ya no me representan:</p>
            <textarea class="ft" data-save="actitudes_no_representan"></textarea>
          </div>

          <div class="accent-box" style="margin-top:40px">
            <label class="field-label" style="color:var(--rm-red)">10 años más</label>
            <p class="field-prompt" style="color:#fff;font-size:1.2rem;margin-bottom:14px">Si nada cambia, dentro de 10 años esta historia será...</p>
            <textarea class="ft" data-save="costo_10_anios" rows="6" placeholder="Describe ese futuro — sin filtros."></textarea>
          </div>
        </section>

        <!-- PASO 6 — Punto de quiebre -->
        <section class="step-panel" data-step="6">
          <div class="step-head">
            <p class="step-tag">Parte 02 · Decisión creativa</p>
            <h2 class="step-title">El punto<br/><em style="font-style:italic;color:var(--rm-red)">de quiebre.</em></h2>
          </div>

          <div class="field">
            <label class="field-label">01 · Verdad innegociable</label>
            <p class="field-prompt">¿Qué verdad ya no puedo ignorar?</p>
            <textarea class="ft" data-save="punto_quiebre" rows="5"></textarea>
          </div>

          <div class="field accent-box">
            <label class="field-label" style="color:var(--rm-red)">02 · La decisión</label>
            <p class="field-prompt" style="color:#fff;font-size:1.15rem">Ya no quiero seguir interpretando este personaje porque...</p>
            <textarea class="ft" data-save="decision" rows="6" placeholder="Sin rodeos."></textarea>
          </div>
        </section>

        <!-- PASO 7 — Nueva película -->
        <section class="step-panel" data-step="7">
          <div class="step-head">
            <p class="step-tag">Parte 03 · Nuevo personaje</p>
            <h2 class="step-title">La película<br/><em style="font-style:italic;color:rgba(255,255,255,.5)">que comienza hoy.</em></h2>
          </div>

          <div class="field">
            <label class="field-label">01 · Título de mi nueva película</label>
            <input type="text" class="fi" data-save="titulo_nuevo" placeholder="¿Cómo se llamará?" />
          </div>

          <div class="field">
            <label class="field-label">02 · Nuevo género</label>
            <div style="display:flex;flex-wrap:wrap;gap:8px" data-chips="genero_nuevo">
              {GENRES.map(g => <span class="chip" data-val={g}>{g}</span>)}
            </div>
          </div>
        </section>

        <!-- PASO 8 — Construcción de roles -->
        <section class="step-panel" data-step="8">
          <div class="step-head">
            <p class="step-tag">Parte 03 · Nuevo personaje</p>
            <h2 class="step-title">Construcción<br/><em style="font-style:italic;color:rgba(255,255,255,.5)">de roles.</em></h2>
            <p class="step-sub">"Un personaje unidimensional no puede sostener una película durante 10 años."</p>
          </div>

          <div class="field">
            <label class="field-label">A · Rol de pareja / romance</label>
            <p class="field-prompt">¿Cómo se viste tu nuevo personaje para una cita (consigo misma o con otro)?</p>
            <textarea class="ft" data-save="rol_pareja_vestuario" style="margin-bottom:14px"></textarea>
            <p class="field-prompt">¿Qué quieres provocar? (misterio, cercanía, pasión)</p>
            <textarea class="ft" data-save="rol_pareja_intencion"></textarea>
          </div>

          <div class="field" style="border-top:1px solid rgba(255,255,255,.1);padding-top:32px">
            <label class="field-label">B · Rol social & amigos</label>
            <p class="field-prompt">Ante una invitación inesperada, ¿qué usa tu personaje?</p>
            <textarea class="ft" data-save="rol_social_vestuario" style="margin-bottom:14px"></textarea>
            <p class="field-prompt">Actividad que hoy evitas por "no tener qué ponerte":</p>
            <textarea class="ft" data-save="rol_social_actividad"></textarea>
          </div>

          <div class="field" style="border-top:1px solid rgba(255,255,255,.1);padding-top:32px">
            <label class="field-label">C · Rol de disfrute & hobbies</label>
            <p class="field-prompt">¿Cómo se ve tu personaje cuando está disfrutando?</p>
            <textarea class="ft" data-save="rol_disfrute_vestuario" style="margin-bottom:14px"></textarea>
            <p class="field-prompt">El compromiso: ¿qué actividad requiere un nuevo "vestuario" en tu vida real?</p>
            <textarea class="ft" data-save="rol_disfrute_compromiso"></textarea>
          </div>
        </section>

        <!-- PASO 9 — 6 escenas -->
        <section class="step-panel" data-step="9">
          <div class="step-head">
            <p class="step-tag">Parte 03 · Nuevo personaje</p>
            <h2 class="step-title">Las 6 escenas<br/><em style="font-style:italic;color:rgba(255,255,255,.5)">clave.</em></h2>
            <p class="step-sub">"Tu película tiene muchas locaciones. No uses el mismo vestuario para todas."</p>
          </div>

          <div style="display:grid;gap:16px">
            {SCENES.map(sc => (
              <div class="scene-card">
                <div style="display:flex;align-items:baseline;gap:14px;margin-bottom:10px">
                  <span style="font-family:serif;font-style:italic;font-size:1.8rem;color:var(--rm-red)">{sc.n}</span>
                  <div>
                    <h4 style="font-family:serif;font-size:1.2rem">{sc.t}</h4>
                    <p class="step-tl" style="font-size:9px">{sc.s}</p>
                  </div>
                </div>
                <textarea class="ft" data-save={`escena_${sc.n}`} rows="3" placeholder="Vestuario, escenografía, energía..."></textarea>
              </div>
            ))}
          </div>
        </section>

        <!-- PASO 10 — Proyección 10 años -->
        <section class="step-panel" data-step="10">
          <div class="step-head">
            <p class="step-tag">Parte 04 · Proyección</p>
            <h2 class="step-title">De fantasía<br/><em style="font-style:italic;color:rgba(255,255,255,.5)">a fecha de estreno.</em></h2>
            <p class="step-sub">"Un sueño sin estrategia es solo una fantasía."</p>
          </div>

          {LEVELS.map((lv, i) => (
            <details class="rolebox" open={i === 0}>
              <summary>
                <div style="display:flex;align-items:baseline;gap:14px">
                  <span style="font-family:serif;font-style:italic;font-size:1.4rem;color:var(--rm-red)">{lv.n}</span>
                  <div>
                    <p class="step-tl" style="font-size:9px">Nivel {lv.n}</p>
                    <h4 style="font-family:serif;font-size:1.2rem">{lv.t}</h4>
                    <p class="step-tl" style="font-size:9px;font-style:italic;color:rgba(255,255,255,.5);text-transform:none;letter-spacing:.08em;margin-top:2px">{lv.s}</p>
                  </div>
                </div>
                <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
              </summary>
              <div style="padding:0 20px 20px">
                <p class="field-prompt">{lv.q}</p>
                <textarea class="ft" data-save={`nivel_${lv.n}`} rows="4"></textarea>
              </div>
            </details>
          ))}
        </section>

        <!-- PASO 11 — Declaración final -->
        <section class="step-panel" data-step="11">
          <div class="step-head">
            <p class="step-tag">Parte 05 · Declaración</p>
            <h2 class="step-title">Contrato con<br/><em style="font-style:italic;color:var(--rm-red)">tu nueva versión.</em></h2>
          </div>

          <div class="decl">
            <p>Hoy dejo de vivir mi historia en automático.</p>
            <p>Reconozco el personaje que he interpretado hasta ahora — con sus luces y sus sombras — y asumo la responsabilidad de su evolución.</p>
            <p><em>Decido dejar de repetir escenas que no me representan. Decido cuestionar los diálogos que me limitan. Decido elevar el estándar de mi propia narrativa.</em></p>
            <p>A partir de este momento, tomo el rol de director/a y protagonista de mi vida. Cada elección que haga será coherente con la versión de mí que estoy construyendo.</p>
            <p><span class="highlight">No estoy cambiando mi imagen. Estoy redefiniendo mi personaje.</span></p>
            <p>Y me comprometo a sostener esta transformación más allá de este reto.</p>
          </div>

          <div class="field two-col" style="margin-top:40px">
            <div>
              <label class="field-label">Firma</label>
              <input type="text" class="fi" data-save="firma" placeholder="Tu nombre completo" />
            </div>
            <div>
              <label class="field-label">Fecha</label>
              <input type="date" class="fi" data-save="fecha" />
            </div>
          </div>

          <div class="pullq" style="text-align:center;border:0;padding:0;margin-top:40px">
            "No viniste a improvisar tu papel.<br/>Viniste a protagonizar tu propia obra maestra."
          </div>

          <div style="display:flex;gap:12px;justify-content:center;margin-top:40px;flex-wrap:wrap" class="no-print">
            <button id="btnPrintEnd" class="wiz-btn primary">Imprimir mi dossier</button>
            <a href="/servicios/asesoria-integral-imagen" class="wiz-btn" style="text-decoration:none;display:inline-flex;align-items:center">Agendar consultoría →</a>
          </div>
        </section>

        <!-- Spacer for fixed nav -->
        <div style="height:80px" class="no-print"></div>
      </main>

      <!-- ─── FIXED NAV ─── -->
      <div class="wiz-nav no-print">
        <button id="btnPrev" class="wiz-btn">← Atrás</button>
        <div style="display:flex;align-items:center;gap:14px;flex:1;justify-content:center">
          <span class="wiz-count" id="wizCount">01 / 11</span>
          <div class="wiz-progress"><div class="wiz-progress-fill" id="wizFill"></div></div>
        </div>
        <button id="btnNext" class="wiz-btn primary">Siguiente →</button>
      </div>
    </div>
  </div>

  <script is:inline>
    (function(){
      const KEY = 'reto_revoluciona_v2';
      const TOTAL = 11;
      const state = JSON.parse(localStorage.getItem(KEY) || '{}');
      const save = () => localStorage.setItem(KEY, JSON.stringify(state));
      let current = Number(state.__step) || 1;

      // Bind saves
      document.querySelectorAll('[data-save]').forEach(el => {
        const k = el.getAttribute('data-save');
        if (state[k] != null) el.value = state[k];
        el.addEventListener('input', () => { state[k] = el.value; save(); });
      });

      // Bind chip groups
      document.querySelectorAll('[data-chips]').forEach(group => {
        const k = group.getAttribute('data-chips');
        group.querySelectorAll('.chip').forEach(c => {
          if (state[k] === c.getAttribute('data-val')) c.classList.add('active');
          c.addEventListener('click', () => {
            group.querySelectorAll('.chip').forEach(x => x.classList.remove('active'));
            c.classList.add('active');
            state[k] = c.getAttribute('data-val');
            save();
          });
        });
      });

      // Mark step as "done" if it has any saved input linked to its data-save fields
      function stepHasData(stepEl){
        return Array.from(stepEl.querySelectorAll('[data-save]')).some(el => (state[el.getAttribute('data-save')] || '').length > 0)
            || Array.from(stepEl.querySelectorAll('[data-chips]')).some(g => !!state[g.getAttribute('data-chips')]);
      }

      const panels = document.querySelectorAll('.step-panel');
      const sideItems = document.querySelectorAll('.step-item');
      const pills = document.querySelectorAll('.wiz-pill');
      const fill = document.getElementById('wizFill');
      const count = document.getElementById('wizCount');
      const btnPrev = document.getElementById('btnPrev');
      const btnNext = document.getElementById('btnNext');

      function goto(n){
        current = Math.max(1, Math.min(TOTAL, n));
        state.__step = current; save();
        panels.forEach(p => p.classList.toggle('active', Number(p.dataset.step) === current));
        sideItems.forEach((it,i) => {
          const isActive = (i+1) === current;
          it.classList.toggle('active', isActive);
          it.classList.toggle('done', i+1 < current || stepHasData(panels[i]));
        });
        pills.forEach((p,i) => {
          const isActive = (i+1) === current;
          p.classList.toggle('active', isActive);
          p.classList.toggle('done', i+1 < current || stepHasData(panels[i]));
          if (isActive) p.scrollIntoView({behavior:'smooth', inline:'center', block:'nearest'});
        });
        fill.style.width = ((current-1) / (TOTAL-1) * 100) + '%';
        count.textContent = String(current).padStart(2,'0') + ' / ' + String(TOTAL).padStart(2,'0');
        btnPrev.disabled = current === 1;
        btnNext.textContent = current === TOTAL ? 'Finalizar ✓' : 'Siguiente →';
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      btnPrev.addEventListener('click', () => goto(current - 1));
      btnNext.addEventListener('click', () => {
        if (current === TOTAL) { document.getElementById('btnPrintEnd')?.click(); return; }
        goto(current + 1);
      });
      sideItems.forEach(it => it.addEventListener('click', () => goto(Number(it.dataset.goto))));
      pills.forEach(p => p.addEventListener('click', () => goto(Number(p.dataset.goto))));

      // Print
      const doPrint = () => window.print();
      document.getElementById('btnPrintSide')?.addEventListener('click', doPrint);
      document.getElementById('btnPrintEnd')?.addEventListener('click', doPrint);
      document.getElementById('btnResetSide')?.addEventListener('click', () => {
        if (!confirm('¿Borrar todas tus respuestas?')) return;
        localStorage.removeItem(KEY); location.reload();
      });

      // Keyboard
      document.addEventListener('keydown', (e) => {
        if (['INPUT','TEXTAREA'].includes(e.target.tagName)) return;
        if (e.key === 'ArrowRight') goto(current + 1);
        if (e.key === 'ArrowLeft') goto(current - 1);
      });

      goto(current);
    })();
  </script>

</MainLayout>
