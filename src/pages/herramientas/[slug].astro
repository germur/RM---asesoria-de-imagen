---
import MainLayout from "@/layouts/MainLayout.astro";
import { ArrowRight } from "lucide-react";

// Generate paths for ALL missing tools linked in herramientas.astro
export function getStaticPaths() {
  return [
    { params: { slug: 'test-colorimetria' } },
    { params: { slug: 'calculadora-contraste' } },
    { params: { slug: 'generador-paletas' } },
    { params: { slug: 'test-psicologia-color' } },
    { params: { slug: 'detector-errores-color' } },
    { params: { slug: 'analizador-rostro' } },
    { params: { slug: 'simulador-gafas' } },
    { params: { slug: 'guia-barbas' } },
    { params: { slug: 'calculadora-aurea' } },
    { params: { slug: 'simulador-peinados' } },
    { params: { slug: 'calculadora-cuerpo' } },
    { params: { slug: 'generador-guia-estilo' } },
    { params: { slug: 'detector-errores-vestuario' } },
    { params: { slug: 'simulador-siluetas' } },
    { params: { slug: 'test-proporcion' } },
    { params: { slug: 'audit-linkedin' } },
    { params: { slug: 'generador-outfits' } },
    { params: { slug: 'test-arquetipos' } },
    { params: { slug: 'nivel-sofisticacion' } },
    { params: { slug: 'calculadora-roi' } },
  ];
}

const { slug } = Astro.params;

// Redirect slugs that have a real page to avoid dead-ends
const redirects: Record<string, string> = {
  'analizador-rostro': '/herramientas/calculadora-rostro',
  'simulador-siluetas': '/herramientas/calculadora-tipo-cuerpo',
  'calculadora-cuerpo': '/herramientas/calculadora-tipo-cuerpo',
  'test-colorimetria': '/herramientas/test-colorimetria-online',
};
if (redirects[slug]) {
  return Astro.redirect(redirects[slug], 301);
}

const formattedName = slug.split('-').map((word: string) => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
---

<MainLayout
    title={`${formattedName} | Herramienta en Beta Privada`}
    description="Esta herramienta se encuentra actualmente en fase de Beta Privada. Solicita acceso anticipado al Laboratorio de Roger Murillo."
>
    <section class="pt-40 pb-32 md:pt-48 md:pb-40 bg-white">
        <div class="container mx-auto px-6 max-w-3xl text-center">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">
                Beta Privada
            </p>

            <h1 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black mb-8">
                {formattedName}
            </h1>

            <p class="text-lg text-neutral-500 font-light leading-relaxed max-w-xl mx-auto mb-6">
                En desarrollo
            </p>

            <p class="text-neutral-400 font-light leading-relaxed max-w-xl mx-auto mb-16">
                Actualmente estamos calibrando el algoritmo de esta herramienta con clientes presenciales
                para asegurar una <strong class="text-brand-black font-medium">precision del 98%</strong>.
                No liberamos herramientas basadas en "tendencias".
            </p>

            <div class="max-w-md mx-auto mb-16">
                <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">
                    Acceso anticipado
                </p>

                <form action="/contacto" method="GET" class="space-y-4">
                    <input type="hidden" name="ref" value={`beta_${slug}`} />
                    <input
                        type="email"
                        placeholder="Tu correo electronico"
                        class="w-full border border-neutral-200 bg-white px-4 py-3 text-sm text-brand-black focus:outline-none focus:border-brand-black transition-colors duration-500"
                        required
                    />
                    <button
                        type="submit"
                        class="w-full bg-brand-primary text-white px-10 py-4 text-xs font-medium uppercase tracking-[0.2em] hover:bg-brand-black transition-colors duration-500 flex items-center justify-center gap-2"
                    >
                        Solicitar Invitacion <ArrowRight size={14} />
                    </button>
                </form>

                <p class="text-xs text-neutral-400 mt-4">
                    Cero spam. Notificacion de lanzamiento exclusivo.
                </p>
            </div>

            <a
                href="/herramientas"
                class="text-xs uppercase tracking-[0.2em] text-neutral-400 hover:text-brand-black transition-colors duration-500"
            >
                &larr; Volver al Laboratorio
            </a>
        </div>
    </section>
</MainLayout>
