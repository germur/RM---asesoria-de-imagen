---
import MainLayout from "@/layouts/MainLayout.astro";
import AnimatedTitleWords from "@/components/ui/AnimatedTitleWords.astro";
import { LockIcon, Mail, ShieldCheck } from "lucide-react";

// Generate paths for ALL missing tools linked in herramientas.astro
export function getStaticPaths() {
  return [
    { params: { slug: 'test-colorimetria' } },
    { params: { slug: 'calculadora-contraste' } },
    { params: { slug: 'generador-paletas' } },
    { params: { slug: 'test-psicologia-color' } },
    { params: { slug: 'detector-errores-color' } },
    { params: { slug: 'analizador-rostro' } },
    { params: { slug: 'simulador-gafas' } },
    { params: { slug: 'guia-barbas' } },
    { params: { slug: 'calculadora-aurea' } },
    { params: { slug: 'simulador-peinados' } },
    { params: { slug: 'calculadora-cuerpo' } },
    { params: { slug: 'generador-guia-estilo' } },
    { params: { slug: 'detector-errores-vestuario' } },
    { params: { slug: 'simulador-siluetas' } },
    { params: { slug: 'test-proporcion' } },
    { params: { slug: 'audit-linkedin' } },
    { params: { slug: 'generador-outfits' } },
    { params: { slug: 'test-arquetipos' } },
    { params: { slug: 'nivel-sofisticacion' } },
    { params: { slug: 'calculadora-roi' } },
  ];
}

const { slug } = Astro.params;
const formattedName = slug.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
---

<MainLayout 
    title={`${formattedName} | Herramienta en Beta Privada`} 
    description="Esta herramienta se encuentra actualmente en fase de Beta Privada. Solicita acceso anticipado al Laboratorio de Roger Murillo."
    class="bg-brand-black"
>
    <section class="relative min-h-[85vh] flex items-center bg-brand-black text-white overflow-hidden py-32">
        <div class="absolute inset-0 bg-[url('/images/noise.png')] opacity-10 mix-blend-overlay"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-brand-primary rounded-full blur-[150px] opacity-10"></div>
        
        <div class="container mx-auto px-6 relative z-10">
            <div class="max-w-3xl mx-auto bg-white/5 border border-white/10 p-12 backdrop-blur-md rounded-sm text-center relative overflow-hidden group hover:border-brand-primary/30 transition-colors duration-500">
                
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-brand-primary to-transparent opacity-50"></div>
                
                <LockIcon className="w-16 h-16 mx-auto text-brand-primary mb-8" />
                
                <span class="inline-block py-1 px-3 border border-brand-primary/50 text-brand-primary text-[10px] font-bold uppercase tracking-[0.3em] mb-6 rounded-sm bg-brand-primary/10">
                    Acceso Restringido - Beta Cerrada
                </span>
                
                <h1 class="font-serif text-4xl md:text-5xl mb-6 leading-tight">
                    <span class="text-white block mb-2">{formattedName}</span>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-gray-400 to-gray-600 text-3xl">En Desarrollo Activo</span>
                </h1>
                
                <p class="text-gray-400 font-light mb-10 text-lg leading-relaxed max-w-xl mx-auto">
                    Actualmente estamos calibrando el algoritmo de esta herramienta con clientes presenciales para asegurar una <strong>precisión clínica del 98%</strong>. No liberamos herramientas basadas en "tendencias".
                </p>
                
                <div class="bg-black/50 p-6 rounded-sm border border-white/5 text-left max-w-md mx-auto mb-10 space-y-4">
                    <h3 class="text-sm font-bold uppercase tracking-widest text-white mb-4">¿Quieres acceso anticipado?</h3>
                    <form action="/contacto" method="GET" class="flex flex-col gap-3">
                        <input type="hidden" name="ref" value={`beta_${slug}`} />
                        <div class="flex gap-2">
                            <input 
                                type="email" 
                                placeholder="Tu correo electrónico ejecutivo" 
                                class="w-full bg-white/5 border border-white/10 p-3 text-sm text-white focus:outline-none focus:border-brand-primary transition-colors"
                                required
                            />
                        </div>
                        <button type="submit" class="w-full bg-brand-primary text-white font-bold uppercase tracking-widest text-xs p-4 hover:bg-white hover:text-brand-black transition-colors flex items-center justify-center gap-2">
                            <Mail size={16} /> Solicitar Invitación VIP
                        </button>
                    </form>
                    <p class="text-[10px] text-gray-500 flex items-center gap-1 mt-2">
                        <ShieldCheck size={12} /> Cero Spam. Notificación de lanzamiento exclusivo.
                    </p>
                </div>
                
                <a href="/herramientas" class="text-xs uppercase tracking-widest text-gray-500 hover:text-brand-primary transition-colors border-b border-transparent hover:border-brand-primary pb-1">
                    &larr; Volver al Laboratorio
                </a>
            </div>
        </div>
    </section>
</MainLayout>
