---
import MainLayout from "@/layouts/MainLayout.astro";
import FaceShapeCalculator from "@/components/tools/FaceShapeCalculator";

const seoData = {
    title: "Calculadora de Visagismo Online | ¿Qué tipo de rostro tengo?",
    description:
        "No es magia, son matemáticas. Mide tus proporciones faciales y descubre la geometría exacta de tu rostro para elegir el corte, barba y gafas perfectas.",
    h1: "Calculadora de Visagismo",
};

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "Calculadora de Tipo de Rostro Roger Murillo",
    applicationCategory: "LifestyleApplication",
    featureList:
        "Análisis de rostro, Recomendación de corte, Recomendación de gafas",
});
---

<MainLayout
    title={seoData.title}
    description={seoData.description}
    schema={schema}
>
    <section class="pt-40 pb-32 md:pt-48 md:pb-40 bg-white">
        <div class="container mx-auto px-6 max-w-3xl text-center">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">
                Herramienta de Visagismo
            </p>

            <h1 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black mb-8">
                {seoData.h1}
            </h1>

            <p class="text-lg text-neutral-500 font-light leading-relaxed max-w-2xl mx-auto">
                Toma una cinta metrica. Vamos a decodificar tus facciones para
                que dejes de copiar cortes que no te favorecen.
            </p>
        </div>
    </section>

    <section class="py-32 md:py-40 bg-neutral-50">
        <div class="container mx-auto px-6 max-w-2xl">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">
                Medidas
            </p>
            <h3 class="font-serif text-2xl text-brand-black mb-8">
                Introduce tus medidas
            </h3>
            <FaceShapeCalculator client:visible />
        </div>
    </section>

    <section class="py-32 md:py-40 bg-white text-center">
        <div class="container mx-auto px-6 max-w-3xl">
            <p class="text-lg text-neutral-500 font-light leading-relaxed mb-8">
                Ya tienes tu resultado?
            </p>
            <a
                href="/servicios/visagismo-corte/"
                class="bg-brand-primary text-white px-10 py-4 text-xs font-medium uppercase tracking-[0.2em] hover:bg-brand-black transition-colors duration-500 inline-block"
            >
                Agenda tu Diseno de Corte Profesional
            </a>
        </div>
    </section>
</MainLayout>
