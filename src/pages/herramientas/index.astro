---
import MainLayout from "@/layouts/MainLayout.astro";
import { Button } from "@/components/ui/button";
import { Palette, ScanFace, Ruler, ArrowRight } from "lucide-react";

const seoData = {
    title: "Herramientas de Diagnóstico de Imagen y Estilo con IA | Roger Murillo",
    description:
        "Diagnóstico de imagen gratuito con inteligencia artificial. Descubre tu colorimetría, tipo de rostro y morfología corporal en segundos. Sin adivinanzas.",
    h1: "Diagnóstico de Imagen con Inteligencia Artificial",
};

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Herramientas de Diagnóstico de Imagen",
    description: seoData.description,
    hasPart: [
        {
            "@type": "SoftwareApplication",
            name: "Test de Colorimetría",
            url: "https://rogermurillo.co/herramientas/test-colorimetria-online",
        },
        {
            "@type": "SoftwareApplication",
            name: "Calculadora de Visagismo",
            url: "https://rogermurillo.co/herramientas/calculadora-rostro",
        },
    ],
});
---

<MainLayout
    title={seoData.title}
    description={seoData.description}
    schema={schema}
>
    <section
        class="py-24 px-6 bg-[#0c0a09] text-white text-center overflow-hidden relative"
    >
        <div
            class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-[#d4af37] via-transparent to-transparent animate-pulse-slow"
        >
        </div>

        <div class="max-w-4xl mx-auto relative z-10">
            <span
                class="text-xs font-bold text-[#d4af37] uppercase tracking-[0.3em] mb-6 block"
            >
                Product-Led SEO
            </span>
            <h1 class="text-5xl md:text-7xl font-serif leading-tight mb-8">
                {seoData.h1}
            </h1>
            <p
                class="text-xl text-stone-300 font-light max-w-2xl mx-auto mb-10 leading-relaxed"
            >
                Deja de adivinar frente al espejo. Utiliza nuestras herramientas
                de precisión para descubrir tu <strong>ADN estético</strong> (Color,
                Rostro, Cuerpo) con datos, no con opiniones.
            </p>
        </div>
    </section>

    <section class="py-20 px-6 bg-[#fafaf9] -mt-10 relative z-20">
        <div class="max-w-7xl mx-auto grid md:grid-cols-3 gap-8">
            <div
                class="group bg-white p-8 rounded-xl shadow-lg border border-stone-200 hover:border-[#d4af37] transition-all duration-300 hover:-translate-y-2 flex flex-col h-full"
            >
                <div
                    class="w-14 h-14 bg-stone-100 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#d4af37] group-hover:text-black transition-colors"
                >
                    <Palette size={28} />
                </div>
                <h3 class="text-2xl font-serif text-[#0c0a09] mb-4">
                    ColorMatch AI™
                </h3>
                <p class="text-stone-600 mb-6 font-light flex-grow">
                    ¿Eres Invierno o Verano? Descubre los colores que iluminan
                    tu piel y cuáles te hacen ver cansado. Algoritmo basado en
                    las 12 estaciones.
                </p>
                <div class="mt-auto pt-6 border-t border-stone-100">
                    <a href="/herramientas/test-colorimetria-online">
                        <Button
                            className="w-full bg-[#0c0a09] hover:bg-[#d4af37] hover:text-black transition-colors"
                        >
                            Iniciar Test de Color <ArrowRight
                                className="ml-2 w-4"
                            />
                        </Button>
                    </a>
                </div>
            </div>

            <div
                class="group bg-white p-8 rounded-xl shadow-lg border border-stone-200 hover:border-[#d4af37] transition-all duration-300 hover:-translate-y-2 flex flex-col h-full"
            >
                <div
                    class="w-14 h-14 bg-stone-100 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#d4af37] group-hover:text-black transition-colors"
                >
                    <ScanFace size={28} />
                </div>
                <h3 class="text-2xl font-serif text-[#0c0a09] mb-4">
                    Visagismo Scanner
                </h3>
                <p class="text-stone-600 mb-6 font-light flex-grow">
                    La geometría de tu rostro decodificada. Introduce tus
                    medidas y descubre la forma exacta de tu cara para elegir el
                    corte y las gafas perfectas.
                </p>
                <div class="mt-auto pt-6 border-t border-stone-100">
                    <a href="/herramientas/calculadora-rostro">
                        <Button
                            variant="outline"
                            className="w-full border-stone-300 hover:border-[#d4af37] hover:text-[#d4af37]"
                        >
                            Analizar mi Rostro <ArrowRight
                                className="ml-2 w-4"
                            />
                        </Button>
                    </a>
                </div>
            </div>

            <div
                class="group bg-white p-8 rounded-xl shadow-lg border border-stone-200 hover:border-[#d4af37] transition-all duration-300 hover:-translate-y-2 flex flex-col h-full"
            >
                <div
                    class="w-14 h-14 bg-stone-100 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#d4af37] group-hover:text-black transition-colors"
                >
                    <Ruler size={28} />
                </div>
                <h3 class="text-2xl font-serif text-[#0c0a09] mb-4">
                    Calculadora Corporal
                </h3>
                <p class="text-stone-600 mb-6 font-light flex-grow">
                    Identifica tu tipo de cuerpo (Reloj de Arena, Triángulo,
                    etc.) con medidas exactas para aprender a vestir
                    estratégicamente.
                </p>
                <div class="mt-auto pt-6 border-t border-stone-100">
                    <a href="/herramientas/calculadora-tipo-cuerpo">
                        <Button
                            variant="outline"
                            className="w-full border-stone-300 hover:border-[#d4af37] hover:text-[#d4af37]"
                        >
                            Calcular Ahora <ArrowRight className="ml-2 w-4" />
                        </Button>
                    </a>
                </div>
            </div>
        </div>
    </section>
</MainLayout>
