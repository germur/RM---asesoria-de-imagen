---
import MainLayout from "@/layouts/MainLayout.astro";
import ImpactTest from "@/components/tools/ImpactTest";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "Test de Impacto Ejecutivo — Roger Murillo",
    applicationCategory: "LifestyleApplication",
    description:
        "Diagnóstico de imagen ejecutiva en 5 dimensiones: Autoridad, Confianza, Competencia, Presencia y Coherencia de Marca. 15 preguntas, resultado inmediato con gráfico radar.",
    featureList:
        "Diagnóstico de imagen, Radar de 5 dimensiones, Nivel de impacto ejecutivo, Recomendación personalizada",
});
---

<MainLayout
    title="Test de Impacto Ejecutivo | Roger Murillo Asesoría de Imagen"
    description="Descubre en 15 preguntas si tu imagen está generando o saboteando tu autoridad ejecutiva. Diagnóstico en 5 dimensiones con gráfico radar personalizado."
    schema={schema}
>
    <!-- Hero -->
    <section class="pt-40 pb-20 md:pt-48 md:pb-24 bg-white">
        <div class="container mx-auto px-6 max-w-3xl text-center">
            <p class="text-xs tracking-[0.4em] uppercase text-neutral-400 mb-6">
                Diagnóstico de Imagen Ejecutiva
            </p>
            <h1 class="font-serif text-4xl md:text-6xl leading-[1.05] text-brand-black mb-8">
                Test de Impacto<br/>
                <span class="text-neutral-400">Ejecutivo</span>
            </h1>
            <p class="text-lg text-neutral-500 font-light leading-relaxed max-w-xl mx-auto">
                15 preguntas. 5 dimensiones. Un diagnóstico honesto de si tu imagen
                está trabajando <em>para</em> ti o <em>en tu contra</em>.
            </p>
        </div>
    </section>

    <!-- Test + sidebar -->
    <section class="pb-32 md:pb-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="grid md:grid-cols-[1fr_360px] gap-16 items-start">

                <!-- Test card -->
                <div class="border border-neutral-100 bg-white p-8 md:p-10 shadow-[0_4px_40px_rgba(0,0,0,0.06)]">
                    <ImpactTest client:load />
                </div>

                <!-- Sidebar info -->
                <div class="space-y-10">
                    <!-- What it measures -->
                    <div>
                        <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-400 mb-6">
                            Qué mide este test
                        </p>
                        <ul class="space-y-5">
                            {[
                                ['Autoridad', '¿Tu imagen comunica poder y jerarquía antes de hablar?'],
                                ['Confianza', '¿Proyectas seguridad en contextos de alta exigencia?'],
                                ['Competencia', '¿Tu apariencia señala expertise de forma visual?'],
                                ['Presencia', '¿Tienes impacto no verbal medible en cualquier sala?'],
                                ['Coherencia', '¿Existe una marca personal consistente en todos tus contextos?'],
                            ].map(([dim, desc]) => (
                                <li class="flex gap-3 items-start">
                                    <span class="text-brand-primary mt-0.5 flex-shrink-0 text-xs">◆</span>
                                    <div>
                                        <p class="text-xs font-medium text-brand-black uppercase tracking-wider mb-0.5">{dim}</p>
                                        <p class="text-xs text-neutral-400 font-light leading-relaxed">{desc}</p>
                                    </div>
                                </li>
                            ))}
                        </ul>
                    </div>

                    <!-- Divider -->
                    <div class="h-px bg-neutral-100"></div>

                    <!-- Score levels -->
                    <div>
                        <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-400 mb-5">
                            Niveles de resultado
                        </p>
                        <ul class="space-y-3">
                            {[
                                ['Élite', '90–100%', '#c0392b'],
                                ['Estratégico', '75–89%', '#2c3e50'],
                                ['Potencial', '60–74%', '#7f8c8d'],
                                ['En Construcción', '45–59%', '#e67e22'],
                                ['Auditoría Urgente', '< 45%', '#95a5a6'],
                            ].map(([label, range, color]) => (
                                <li class="flex items-center gap-3">
                                    <span class="w-2 h-2 rounded-full flex-shrink-0" style={`background:${color}`}></span>
                                    <span class="text-xs text-brand-black font-medium">{label}</span>
                                    <span class="text-xs text-neutral-400 ml-auto">{range}</span>
                                </li>
                            ))}
                        </ul>
                    </div>

                    <!-- Divider -->
                    <div class="h-px bg-neutral-100"></div>

                    <!-- Quote -->
                    <blockquote class="border-l-2 border-brand-primary pl-5">
                        <p class="text-sm font-serif text-neutral-600 italic leading-relaxed">
                            "La imagen ejecutiva no es vanidad — es el primer idioma que habla tu liderazgo."
                        </p>
                        <footer class="mt-3 text-[10px] uppercase tracking-widest text-neutral-400">
                            — Roger Murillo
                        </footer>
                    </blockquote>
                </div>

            </div>
        </div>
    </section>

    <!-- Bottom CTA -->
    <section class="py-24 bg-[#0a0a0a] text-white text-center">
        <div class="container mx-auto px-6 max-w-2xl">
            <p class="text-xs tracking-[0.4em] uppercase text-neutral-500 mb-6">
                Consultoría Privada
            </p>
            <h2 class="font-serif text-3xl md:text-4xl text-white mb-6 leading-tight">
                El test es el mapa.<br/>
                <span class="text-neutral-500">La sesión es el territorio.</span>
            </h2>
            <p class="text-neutral-400 font-light mb-10 max-w-lg mx-auto text-sm leading-relaxed">
                El diagnóstico te muestra dónde estás. Una sesión 1 a 1 con Roger
                define exactamente cómo cerrar cada brecha de impacto en tu imagen ejecutiva.
            </p>
            <a
                href="/contacto"
                class="inline-flex items-center gap-4 bg-brand-primary text-white
                       px-10 py-4 text-xs tracking-[0.2em] uppercase
                       hover:bg-white hover:text-brand-black transition-colors duration-400"
            >
                Reservar Diagnóstico Privado
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
            </a>
        </div>
    </section>
</MainLayout>
