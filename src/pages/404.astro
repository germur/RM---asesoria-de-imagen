---
import MainLayout from "@/layouts/MainLayout.astro";
import { Button } from "@/components/ui/button";

const seoData = {
    title: "Página no encontrada | Roger Murillo",
    description:
        "Lo sentimos, la página que buscas no existe. Regresa al inicio o explora nuestras herramientas de imagen.",
    h1: "404: Estilo no Encontrado",
};
---

<MainLayout title={seoData.title} description={seoData.description}>
    <section class="py-32 px-6 text-center bg-[#fafaf9]">
        <div class="max-w-2xl mx-auto">
            <h1 class="text-6xl md:text-8xl font-serif text-[#d4af37] mb-6">
                404
            </h1>
            <h2 class="text-3xl text-[#0c0a09] font-serif mb-6">
                Parece que te has perdido en el armario.
            </h2>
            <p class="text-xl text-stone-600 mb-12">
                La página que buscas no existe o ha sido movida. Pero ya que
                estás aquí, ¿por qué no aprovechas para descubrir tu perfil de
                imagen?
            </p>

            <div class="flex flex-col sm:flex-row justify-center gap-4">
                <a href="/">
                    <Button variant="outline" size="lg">Volver al Inicio</Button
                    >
                </a>
                <a href="/herramientas/test-colorimetria-online">
                    <Button
                        className="bg-[#0c0a09] text-white hover:bg-[#d4af37]"
                        >Hacer Test de Colorimetría</Button
                    >
                </a>
            </div>
        </div>
    </section>
</MainLayout>
