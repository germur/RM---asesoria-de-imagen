---
import MainLayout from "@/layouts/MainLayout.astro";
import { ArrowRight } from "lucide-react";

const seoData = {
    title: "Casos de Éxito · Transformaciones Reales | Roger Murillo Asesoría de Imagen",
    description:
        "Conoce las historias reales de transformación de nuestros clientes. Proceso completo de consultoría de imagen a puerta cerrada en Bogotá.",
};

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Casos de Éxito",
    description: "Historias de transformación de imagen personal y ejecutiva.",
    provider: { "@type": "ProfessionalService", name: "Roger Murillo & Adriana Garzón" },
});

const casos = [
    {
        slug: "carlos-ejecutivo",
        nombre: "Carlos M.",
        cargo: "Director Financiero",
        sector: "Banca & Finanzas",
        resumen: "Llegó sintiéndose invisible en las juntas directivas. Su ropa era cara pero no comunicaba autoridad.",
        desafio: "Carlos ocupaba un cargo de alta dirección, pero su imagen no reflejaba su posición. Usaba trajes de buena marca sin coherencia visual: colores que no correspondían a su paleta, cortes de cabello genéricos y accesorios que restaban en lugar de sumar. En sus propias palabras: 'Sentía que mi presencia no pesaba en la sala'.",
        proceso: "Comenzamos con un diagnóstico integral: análisis de rostro (morfología ovalada con tendencia angular), colorimetría (Invierno Profundo) y evaluación de su armario actual. El 60% de su ropa no correspondía a su paleta de poder. Diseñamos un código visual ejecutivo con énfasis en estructura, contraste y líneas verticales. Roger diseñó un corte que acentuara su mandíbula y Adriana redefinió su paleta de color completa.",
        resultado: "En 3 meses, Carlos reportó un cambio radical en cómo lo percibían. Recibió su primer ascenso en 4 años. Su frase: 'Ahora entro a una sala y la gente me escucha antes de que hable'.",
        duracion: "Consultoría integral + 3 seguimientos",
        imagen: "/images/service-consulting-full.jpg",
    },
    {
        slug: "valentina-emprendedora",
        nombre: "Valentina R.",
        cargo: "CEO & Fundadora",
        sector: "Tecnología",
        resumen: "Quería proyectar liderazgo sin perder su esencia femenina. Se sentía atrapada entre 'verse seria' y 'verse ella'.",
        desafio: "Valentina había fundado su startup 5 años atrás, pero seguía vistiéndose como cuando era empleada. Sentía que debía elegir entre verse 'corporativa' o 'creativa'. Su imagen no transmitía la autoridad que necesitaba en reuniones con inversionistas, y al mismo tiempo temía perder su identidad personal.",
        proceso: "La clave fue entender que la imagen personal no empieza en la ropa — empieza en la identidad. Trabajamos desde quién es Valentina y hacia dónde va. Adriana identificó su estación (Otoño Cálido) y diseñó una paleta que combinara calidez con sofisticación. Roger trabajó un corte que enmarcara su rostro y proyectara determinación sin rigidez. Creamos un sistema de vestuario modular: 15 piezas que generan más de 40 combinaciones estratégicas.",
        resultado: "Valentina cerró su ronda de inversión 2 meses después. Nos dijo: 'Por primera vez siento que mi ropa cuenta la misma historia que yo'. Hoy es clienta recurrente para ajustes estacionales.",
        duracion: "Consultoría integral + guía de estilo + seguimiento trimestral",
        imagen: "/images/roger-adriana-duo.jpg",
    },
    {
        slug: "andres-transicion",
        nombre: "Andrés L.",
        cargo: "Abogado Senior",
        sector: "Legal",
        resumen: "Pasaba por un divorcio y sentía que necesitaba reinventarse. Su imagen era un reflejo de una vida que ya no era la suya.",
        desafio: "Andrés llegó en un momento de transición personal profunda. Había perdido 15 kilos, se había divorciado y sentía que su reflejo en el espejo no correspondía con el hombre que estaba construyendo. Su armario estaba lleno de ropa que le quedaba grande y de un estilo que ya no lo representaba.",
        proceso: "Priorizamos la intimidad del proceso. Esto no era solo un cambio de look — era un acompañamiento. En el estudio a puerta cerrada, Andrés pudo hablar con honestidad sobre quién quería ser. Hicimos diagnóstico completo: rostro cuadrado con líneas fuertes, estación Verano Suave. Roger diseñó un corte que suavizara sus ángulos y Adriana creó una paleta que reflejara calma y renovación. Reestructuramos su armario desde cero.",
        resultado: "Andrés volvió 6 semanas después y nos dijo: 'Me miro al espejo y por fin me reconozco'. Hoy refiere a colegas del bufete y viene cada 6 semanas para mantenimiento de corte.",
        duracion: "Consultoría integral + renovación de armario + mantenimiento mensual",
        imagen: "/images/executive-consulting.webp",
    },
];
---

<MainLayout
    title={seoData.title}
    description={seoData.description}
    schema={schema}
>
    <!-- Hero -->
    <section class="pt-40 pb-32 md:pt-48 md:pb-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl text-center">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Casos de Éxito</p>

            <h1 class="font-serif text-4xl md:text-6xl leading-[1.05] text-brand-black mb-8">
                Historias reales.<br />
                <span class="text-neutral-400">Transformaciones reales.</span>
            </h1>

            <p class="text-lg text-neutral-500 font-light leading-relaxed max-w-2xl mx-auto">
                Cada cliente llega con una historia diferente, pero con un denominador
                común: su imagen no refleja quién es hoy. Aquí contamos cómo los
                recibimos y cómo salieron.
            </p>
        </div>
    </section>

    <!-- Cases -->
    {casos.map((caso, i) => (
        <section class={`py-32 md:py-40 ${i % 2 === 0 ? 'bg-neutral-50' : 'bg-white'}`}>
            <div class="container mx-auto px-6 max-w-6xl">
                <div class="grid md:grid-cols-12 gap-16 md:gap-24 items-start">
                    <div class={`md:col-span-5 ${i % 2 !== 0 ? 'md:order-2' : ''}`}>
                        <img
                            src={caso.imagen}
                            alt={`Caso de éxito: ${caso.nombre}`}
                            class="w-full h-[400px] object-cover grayscale"
                        />
                        <div class="mt-6 flex items-center gap-4">
                            <div class="w-1 h-12 bg-brand-primary"></div>
                            <div>
                                <p class="font-serif text-xl text-brand-black">{caso.nombre}</p>
                                <p class="text-xs tracking-[0.2em] uppercase text-neutral-400">{caso.cargo} · {caso.sector}</p>
                            </div>
                        </div>
                    </div>

                    <div class={`md:col-span-7 ${i % 2 !== 0 ? 'md:order-1' : ''}`}>
                        <p class="text-xs tracking-[0.3em] uppercase text-brand-primary mb-6">
                            Caso #{String(i + 1).padStart(2, '0')}
                        </p>

                        <h2 class="font-serif text-3xl md:text-4xl leading-[1.1] text-brand-black mb-6">
                            {caso.resumen}
                        </h2>

                        <div class="space-y-8 mt-10">
                            <div>
                                <h3 class="text-xs font-medium uppercase tracking-[0.2em] text-brand-black mb-3">El Desafío</h3>
                                <p class="text-sm text-neutral-500 font-light leading-relaxed">{caso.desafio}</p>
                            </div>
                            <div>
                                <h3 class="text-xs font-medium uppercase tracking-[0.2em] text-brand-black mb-3">El Proceso</h3>
                                <p class="text-sm text-neutral-500 font-light leading-relaxed">{caso.proceso}</p>
                            </div>
                            <div>
                                <h3 class="text-xs font-medium uppercase tracking-[0.2em] text-brand-black mb-3">El Resultado</h3>
                                <p class="text-sm text-neutral-500 font-light leading-relaxed">{caso.resultado}</p>
                            </div>
                            <div class="pt-4 border-t border-neutral-200">
                                <p class="text-xs tracking-[0.15em] uppercase text-neutral-400">
                                    Servicio: {caso.duracion}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    ))}

    <!-- CTA -->
    <section class="py-32 md:py-40 bg-brand-black text-white text-center">
        <div class="container mx-auto px-6 max-w-3xl">
            <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] mb-8">
                ¿Quieres ser el próximo <span class="text-neutral-400">caso de éxito?</span>
            </h2>
            <p class="text-lg text-neutral-300 font-light leading-relaxed max-w-xl mx-auto mb-12">
                Tu transformación comienza con una decisión. Agenda tu consultoría
                privada y descubre lo que tu imagen puede hacer por ti.
            </p>
            <div class="flex flex-col sm:flex-row gap-5 justify-center">
                <a
                    href="/contacto"
                    class="bg-brand-primary text-white px-12 py-4 text-xs font-medium uppercase tracking-[0.2em] hover:bg-white hover:text-brand-black transition-colors duration-500"
                >
                    Agendar Consultoría
                </a>
                <a
                    href="/servicios"
                    class="px-12 py-4 text-xs font-medium uppercase tracking-[0.2em] text-white border border-white/20 hover:border-white transition-colors duration-500"
                >
                    Ver Servicios
                </a>
            </div>
        </div>
    </section>
</MainLayout>
