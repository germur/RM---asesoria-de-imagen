---
import MainLayout from "@/layouts/MainLayout.astro";

// 1. Schema Markup Híbrido (Book + Product)
const bookSchema = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "Book",
            name: "Revoluciona tu Imagen",
            author: {
                "@type": "Person",
                name: "Roger Murillo",
            },
            url: "https://rogermurillo.co/libro",
            inLanguage: "es",
            bookFormat: "https://schema.org/EBook",
            numberOfPages: "150",
            description:
                "El manual definitivo de visagismo y estrategia de imagen para ejecutivos.",
        },
        {
            "@type": "Product",
            name: "Ebook: Revoluciona tu Imagen",
            description: "Guía digital de estrategia de imagen personal.",
            image: "https://rogermurillo.co/images/book-mockup-3d.jpg",
            offers: {
                "@type": "Offer",
                price: "19.00",
                priceCurrency: "USD",
                availability: "https://schema.org/InStock",
                url: "https://rogermurillo.co/libro",
            },
            aggregateRating: {
                "@type": "AggregateRating",
                ratingValue: "4.9",
                reviewCount: "128",
            },
        },
    ],
};
---

<MainLayout
    title="Revoluciona tu Imagen · Libro de Imagen Personal · Visagismo y Estilo | Roger Murillo"
    description="El manual definitivo de imagen personal, visagismo y estilo ejecutivo. Aprende a proyectar autoridad, liderazgo y confianza desde la primera página. Descarga inmediata."
    schema={JSON.stringify(bookSchema)}
>
    <section class="pt-40 pb-32 md:pt-48 md:pb-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="flex flex-col md:flex-row items-center gap-16 md:gap-24">
                <div class="w-full md:w-1/2 flex justify-center">
                    <img
                        src="/images/book-cover-3d.png"
                        alt="Libro Revoluciona tu Imagen por Roger Murillo"
                        class="w-3/4 md:w-full max-w-sm"
                        fetchpriority="high"
                    />
                </div>

                <div class="w-full md:w-1/2 text-center md:text-left">
                    <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">
                        Best Seller Digital
                    </p>

                    <h1 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black mb-8">
                        Deja de vestir como un empleado. <br />
                        <span class="text-neutral-400">Proyecta como un CEO.</span>
                    </h1>

                    <p class="text-lg text-neutral-500 font-light leading-relaxed mb-10 max-w-lg mx-auto md:mx-0">
                        El manual definitivo de <strong class="text-brand-black font-medium">visagismo y estrategia de imagen</strong>
                        que no te ensenan en las escuelas de moda. Ciencia aplicada a tu reputacion.
                    </p>

                    <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start items-center">
                        <a
                            href="#comprar"
                            class="bg-brand-primary text-white px-10 py-4 text-xs font-medium uppercase tracking-[0.2em] hover:bg-brand-black transition-colors duration-500 inline-block"
                        >
                            Comprar Ahora &mdash; $19 USD
                        </a>
                        <span class="text-xs text-neutral-400">Garantia de 30 dias</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-32 md:py-40 bg-neutral-50">
        <div class="container mx-auto px-6 max-w-3xl text-center">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">
                Mas de 20 anos de experiencia
            </p>
            <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black mb-8">
                Crees que el estilo es caro?
            </h2>
            <p class="text-lg text-neutral-500 font-light leading-relaxed">
                La realidad es que la <strong class="text-brand-black font-medium">falta de estrategia</strong> es lo que
                te esta costando dinero y oportunidades. Comprar ropa cara que no
                comunica nada es un gasto. Invertir en conocimiento es un activo.
            </p>
        </div>
    </section>

    <section class="py-32 md:py-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-start">
                <div>
                    <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">
                        Contenido
                    </p>
                    <h2 class="font-serif text-4xl leading-[1.1] text-brand-black mb-10">
                        Manipula la percepcion de tu entorno.
                    </h2>

                    <div class="space-y-10">
                        <div>
                            <h4 class="font-serif text-lg text-brand-black mb-2">La Ciencia del Visagismo</h4>
                            <p class="text-neutral-500 font-light leading-relaxed">
                                Entiende la geometria de tu rostro para elegir cortes y accesorios con precision matematica.
                            </p>
                        </div>
                        <div>
                            <h4 class="font-serif text-lg text-brand-black mb-2">Los 5 Errores de Autoridad</h4>
                            <p class="text-neutral-500 font-light leading-relaxed">
                                Descubre que detalles de tu vestimenta estan gritando "inseguridad" en la sala de juntas.
                            </p>
                        </div>
                        <div>
                            <h4 class="font-serif text-lg text-brand-black mb-2">Tu Paleta de Poder</h4>
                            <p class="text-neutral-500 font-light leading-relaxed">
                                Como elegir los colores que te hacen ver saludable y dominante sin ser un experto en moda.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="bg-brand-black p-10 md:p-12 text-white">
                    <p class="text-xs tracking-[0.3em] uppercase text-neutral-500 mb-6">
                        Indice
                    </p>
                    <h3 class="font-serif text-2xl mb-8 text-white">
                        Indice del Manual
                    </h3>
                    <ul class="space-y-4 text-sm text-neutral-300 font-light">
                        <li>01. El mito de la belleza vs. Estilo</li>
                        <li>02. Antropometria Facial Aplicada</li>
                        <li>03. Semiotica del Traje Ejecutivo</li>
                        <li>04. Colorimetria para Negocios</li>
                        <li>05. Construyendo tu Capsula de Poder</li>
                        <li>06. Auditoria de Armario</li>
                        <li class="text-brand-primary pt-2">... y 4 capitulos mas.</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section id="comprar" class="py-32 md:py-40 bg-brand-black text-white text-center">
        <div class="container mx-auto px-6 max-w-3xl">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-500 mb-6">
                Descarga inmediata
            </p>

            <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-white mb-8">
                Tu transformacion comienza con $19.
            </h2>

            <p class="text-lg text-neutral-300 font-light leading-relaxed mb-12">
                Descarga inmediata en PDF. Leelo en tu tablet, movil o
                computadora. Si aplicas una sola tecnica, el libro se habra pagado solo.
            </p>

            <div class="border border-neutral-700 p-8 md:p-10 max-w-lg mx-auto mb-8">
                <div class="flex justify-between items-center mb-8">
                    <div class="text-left">
                        <span class="block text-xs font-medium uppercase tracking-[0.2em] text-white mb-1">
                            Ebook: Revoluciona tu Imagen
                        </span>
                        <span class="text-xs text-neutral-500">Edicion Digital 2026</span>
                    </div>
                    <div class="text-right">
                        <span class="block text-3xl font-serif text-white">$19</span>
                        <span class="text-xs text-neutral-600 line-through">$49.00</span>
                    </div>
                </div>

                <a
                    href="https://hotmart.com/es/marketplace/productos/hagsxd-revoluciona-tu-imagen-p6zmn/Y86932194S?src=rogermurillo_website_pdp"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="block w-full py-4 bg-brand-primary text-white text-xs font-medium uppercase tracking-[0.2em] hover:bg-white hover:text-brand-black transition-colors duration-500 text-center"
                >
                    Descargar Ahora
                </a>

                <p class="text-xs text-neutral-600 mt-4">
                    Pago seguro via Hotmart. Acceso inmediato al correo electronico.
                </p>
            </div>
        </div>
    </section>
</MainLayout>
