---
import MainLayout from "@/layouts/MainLayout.astro";
import AnimatedTitleWords from "@/components/ui/AnimatedTitleWords.astro";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Herramientas de Diagnóstico de Imagen",
    description: "Herramientas gratuitas de diagnóstico de imagen: colorimetría, tipo de rostro y morfología corporal."
});
---

<MainLayout
  title="Herramientas Gratuitas de Imagen Personal | Roger Murillo"
  description="Diagnóstico de colorimetría, tipo de rostro, morfología corporal y más. Herramientas gratuitas desarrolladas por Roger Murillo."
  schema={schema}
>

  <style>
    .reveal{opacity:0;transform:translateY(36px);transition:opacity 1s cubic-bezier(.16,1,.3,1) var(--delay,0s),transform 1s cubic-bezier(.16,1,.3,1) var(--delay,0s)}
    .reveal.is-in{opacity:1;transform:translateY(0)}
    .tool-card{transition:background-color .6s cubic-bezier(.16,1,.3,1), color .6s cubic-bezier(.16,1,.3,1)}
    /* HOVER: fondo negro, TODO el texto blanco legible */
    .tool-card:hover{background:#0a0a0a}
    .tool-card:hover .tool-num{color:var(--color-brand-primary, #C41230)}
    .tool-card:hover .tool-tag{color:var(--color-brand-primary, #C41230) !important}
    .tool-card:hover .tool-title{color:#fff !important}
    .tool-card:hover .tool-desc{color:rgba(255,255,255,0.7) !important}
    .tool-card:hover .tool-cta{color:#fff !important;border-color:rgba(255,255,255,0.35) !important;background:transparent}
    .tool-card:hover .tool-cta:hover{border-color:#fff !important;background:rgba(255,255,255,0.06)}
  </style>

  <!-- HERO -->
  <section class="pt-40 pb-32 md:pt-48 md:pb-40 bg-brand-black text-white relative overflow-hidden">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="flex items-center gap-5 mb-14">
        <span class="w-12 h-px bg-brand-primary"></span>
        <p class="text-[10px] tracking-[0.4em] uppercase text-white/60">Diagnóstico · Gratuito</p>
      </div>
      <h1 class="font-serif leading-[0.85] max-w-4xl">
        <AnimatedTitleWords text="Herramientas" class="block text-6xl md:text-8xl lg:text-9xl text-white" />
        <AnimatedTitleWords text="que miden" class="block text-6xl md:text-8xl lg:text-9xl italic text-neutral-500 pl-[6%]" delay={300} />
        <AnimatedTitleWords text="la verdad." class="block text-6xl md:text-8xl lg:text-9xl text-brand-primary pl-[2%]" delay={500} />
      </h1>
      <div class="mt-14 max-w-xl">
        <p class="text-base text-white/60 font-light leading-relaxed">Diagnósticos de colorimetría, rostro, cuerpo e impacto ejecutivo. Sin registro, sin costo.</p>
      </div>
    </div>
  </section>

  <!-- TOOLS LIST -->
  <section class="bg-white">
    <div class="border-b border-neutral-200">
      <div class="container mx-auto px-6 max-w-6xl py-8 flex items-end justify-between text-[10px] tracking-[0.4em] uppercase text-neutral-400">
        <span>Herramientas</span><span>5 disponibles</span>
      </div>
    </div>

    <!-- Tool 01 -->
    <div class="tool-card border-b border-neutral-200">
      <div class="container mx-auto px-6 max-w-6xl py-16 md:py-20">
        <div class="grid lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-7">
            <div class="flex items-baseline gap-8 mb-8">
              <span class="tool-num font-serif italic text-5xl text-neutral-300 transition-colors">01</span>
              <div>
                <p class="tool-tag text-[10px] tracking-[0.3em] uppercase text-brand-primary mb-2">Más usado · Cambio de look con IA</p>
                <h3 class="tool-title font-serif text-4xl md:text-5xl text-brand-black">Test de Colorimetría</h3>
              </div>
            </div>
            <p class="tool-desc text-lg text-neutral-600 font-light leading-relaxed mb-10 max-w-xl">
              ¿Invierno, Verano, Otoño o Primavera? Descubre los colores que iluminan tu piel y cuáles te apagan. Resultado en 2 minutos, sin registro.
            </p>
            <a href="/herramientas/test-colorimetria-online" class="tool-cta inline-flex items-center gap-4 px-8 py-4 text-[11px] tracking-[0.25em] uppercase border border-brand-black/20 hover:border-brand-black transition-colors duration-500">Hacer el test →</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Tool 02 -->
    <div class="tool-card border-b border-neutral-200">
      <div class="container mx-auto px-6 max-w-6xl py-16 md:py-20">
        <div class="grid lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-7">
            <div class="flex items-baseline gap-8 mb-8">
              <span class="tool-num font-serif italic text-5xl text-neutral-300 transition-colors">02</span>
              <div>
                <p class="tool-tag text-[10px] tracking-[0.3em] uppercase text-neutral-400 mb-2">Visagismo · Geometría facial</p>
                <h3 class="tool-title font-serif text-4xl md:text-5xl text-brand-black">Calculadora de Rostro</h3>
              </div>
            </div>
            <p class="tool-desc text-lg text-neutral-600 font-light leading-relaxed mb-10 max-w-xl">
              La forma de tu cara, decodificada con matemáticas. Descubre tu tipo de rostro y qué corte, barba y gafas equilibran tus facciones.
            </p>
            <a href="/herramientas/calculadora-rostro" class="tool-cta inline-flex items-center gap-4 px-8 py-4 text-[11px] tracking-[0.25em] uppercase border border-brand-black/20 hover:border-brand-black transition-colors duration-500">Analizar mi rostro →</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Tool 03 -->
    <div class="tool-card border-b border-neutral-200">
      <div class="container mx-auto px-6 max-w-6xl py-16 md:py-20">
        <div class="grid lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-7">
            <div class="flex items-baseline gap-8 mb-8">
              <span class="tool-num font-serif italic text-5xl text-neutral-300 transition-colors">03</span>
              <div>
                <p class="tool-tag text-[10px] tracking-[0.3em] uppercase text-neutral-400 mb-2">Morfología · Siluetas estratégicas</p>
                <h3 class="tool-title font-serif text-4xl md:text-5xl text-brand-black">Calculadora de Cuerpo</h3>
              </div>
            </div>
            <p class="tool-desc text-lg text-neutral-600 font-light leading-relaxed mb-10 max-w-xl">
              Triángulo, Reloj de Arena, Rectángulo... Ingresa tus medidas y aprende qué siluetas de ropa equilibran tu figura real.
            </p>
            <a href="/herramientas/calculadora-tipo-cuerpo" class="tool-cta inline-flex items-center gap-4 px-8 py-4 text-[11px] tracking-[0.25em] uppercase border border-brand-black/20 hover:border-brand-black transition-colors duration-500">Calcular ahora →</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Tool 04 -->
    <div class="tool-card border-b border-neutral-200">
      <div class="container mx-auto px-6 max-w-6xl py-16 md:py-20">
        <div class="grid lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-7">
            <div class="flex items-baseline gap-8 mb-8">
              <span class="tool-num font-serif italic text-5xl text-neutral-300 transition-colors">04</span>
              <div>
                <p class="tool-tag text-[10px] tracking-[0.3em] uppercase text-neutral-400 mb-2">Autoridad · Presencia · Coherencia</p>
                <h3 class="tool-title font-serif text-4xl md:text-5xl text-brand-black">Test de Impacto Ejecutivo</h3>
              </div>
            </div>
            <p class="tool-desc text-lg text-neutral-600 font-light leading-relaxed mb-10 max-w-xl">
              Evalúa tu presencia visual como líder: coherencia de marca, autoridad percibida y congruencia entre rol e imagen.
            </p>
            <a href="/herramientas/test-impacto-ejecutivo" class="tool-cta inline-flex items-center gap-4 px-8 py-4 text-[11px] tracking-[0.25em] uppercase border border-brand-black/20 hover:border-brand-black transition-colors duration-500">Hacer evaluación →</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Tool 05 -->
    <div class="tool-card border-b border-neutral-200">
      <div class="container mx-auto px-6 max-w-6xl py-16 md:py-20">
        <div class="grid lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-7">
            <div class="flex items-baseline gap-8 mb-8">
              <span class="tool-num font-serif italic text-5xl text-neutral-300 transition-colors">05</span>
              <div>
                <p class="tool-tag text-[10px] tracking-[0.3em] uppercase text-neutral-400 mb-2">Reto · 7 días</p>
                <h3 class="tool-title font-serif text-4xl md:text-5xl text-brand-black">Revoluciona Tu Imagen</h3>
              </div>
            </div>
            <p class="tool-desc text-lg text-neutral-600 font-light leading-relaxed mb-10 max-w-xl">
              7 días, 7 ejercicios prácticos para transformar tu imagen desde la raíz. Guía paso a paso por email.
            </p>
            <a href="/herramientas/reto-revoluciona-tu-imagen" class="tool-cta inline-flex items-center gap-4 px-8 py-4 text-[11px] tracking-[0.25em] uppercase border border-brand-black/20 hover:border-brand-black transition-colors duration-500">Empezar reto →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-32 md:py-40 bg-neutral-50 border-t border-neutral-200">
    <div class="container mx-auto px-6 max-w-5xl text-center">
      <h2 class="font-serif text-5xl md:text-7xl leading-[0.95] text-brand-black mb-10">
        ¿Listo para la<br/><span class="italic text-brand-primary">consultoría completa?</span>
      </h2>
      <p class="text-lg text-neutral-600 font-light max-w-xl mx-auto mb-12">Las herramientas diagnostican. La consultoría transforma.</p>
      <a href="/servicios/asesoria-integral-imagen" class="inline-flex items-center gap-4 bg-brand-black text-white px-10 py-5 text-[11px] tracking-[0.25em] uppercase hover:bg-brand-primary transition-colors duration-500">Ver consultoría →</a>
    </div>
  </section>

  <script>
    const ro = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-in'); ro.unobserve(e.target) } }), { threshold: .15, rootMargin: '0px 0px -60px 0px' });
    document.querySelectorAll('.reveal').forEach(el => ro.observe(el));
  </script>

</MainLayout>
