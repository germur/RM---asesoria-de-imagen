---
import MainLayout from "@/layouts/MainLayout.astro";
import {
    Check,
    Star,
    ArrowRight,
    BookOpen,
    ShieldCheck,
    Zap,
} from "lucide-react";
import AnimatedTitleWords from "@/components/ui/AnimatedTitleWords.astro";

// 1. Schema SEO para Servicios Profesionales (Google lo ama)
// Define claramente que esto es una consultoría, no una peluquería de barrio.
const servicesSchema = {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "Consultoría de Imagen Ejecutiva",
    provider: {
        "@type": "ProfessionalService",
        name: "Roger Murillo & Adriana Garzón",
        priceRange: "$$$",
        image: "https://rogermurillo.co/images/service-consulting.jpg",
    },
    areaServed: {
        "@type": "City",
        name: "Bogotá",
    },
    hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Servicios de Imagen Estratégica",
        itemListElement: [
            {
                "@type": "Offer",
                itemOffered: {
                    "@type": "Service",
                    name: "Consultoría Integral A Puerta Cerrada",
                },
            },
            {
                "@type": "Offer",
                itemOffered: {
                    "@type": "Service",
                    name: "Diseño de Color y Salud Capilar",
                },
            },
        ],
    },
};
---

<MainLayout
    title="Servicios de Consultoría de Imagen | Roger Murillo"
    description="Servicios de imagen estratégica High-Ticket. Asesoría integral, colorimetría avanzada y visagismo para ejecutivos. Atención exclusiva en Bogotá."
    schema={servicesSchema}
>
    <section class="relative py-32 bg-brand-black text-white overflow-hidden">
        <div
            class="absolute top-0 left-0 w-full h-full opacity-20 pointer-events-none"
        >
            <div
                class="absolute right-0 top-0 w-[500px] h-[500px] bg-brand-primary rounded-full blur-[150px] opacity-20"
            >
            </div>
        </div>

        <div class="container mx-auto px-6 relative z-10 text-center">
            <span
                class="inline-block py-1 px-3 border border-brand-primary text-brand-primary text-xs font-bold tracking-[0.3em] uppercase mb-8 animate-fade-in-up"
            >
                Catálogo de Soluciones
            </span>
            <h1
                class="font-serif text-5xl md:text-7xl lg:text-8xl mb-8 leading-[0.9]"
            >
                <AnimatedTitleWords text="No vendemos cortes." class="block" />
                <div class="text-stone-400 italic">
                    <AnimatedTitleWords
                        text="Diseñamos reputación."
                        delay={400}
                    />
                </div>
            </h1>
            <p
                class="text-xl text-gray-300 font-light max-w-2xl mx-auto leading-relaxed animate-fade-in-up delay-200"
            >
                Elige el nivel de intervención que tu carrera necesita hoy.
                Desde diagnósticos digitales hasta la experiencia inmersiva "A
                Puerta Cerrada".
            </p>
        </div>
    </section>

    <section class="py-24 bg-white border-b border-brand-gray">
        <div class="container mx-auto px-6">
            <div class="flex flex-col lg:flex-row gap-16 items-center">
                <div class="w-full lg:w-1/2 relative group">
                    <div
                        class="absolute top-4 left-4 w-full h-full border-2 border-brand-primary -z-10 transition-transform group-hover:translate-x-2 group-hover:translate-y-2"
                    >
                    </div>
                    <img
                        src="/images/service-consulting-full.jpg"
                        alt="Sesión de consultoría de imagen ejecutiva"
                        class="w-full h-[600px] object-cover grayscale contrast-125 shadow-2xl"
                    />
                </div>

                <div class="w-full lg:w-1/2">
                    <div class="flex items-center gap-4 mb-6">
                        <span
                            class="px-3 py-1 bg-brand-black text-white text-xs font-bold uppercase tracking-widest"
                            >Signature Service</span
                        >
                        <span
                            class="text-brand-primary font-serif italic text-lg"
                            >Roger & Adriana</span
                        >
                    </div>

                    <h2
                        class="font-serif text-5xl text-brand-black mb-6 leading-none"
                    >
                        Consultoría Integral <br /> "A Puerta Cerrada"
                    </h2>

                    <p
                        class="text-slate-600 text-lg mb-8 leading-relaxed font-light"
                    >
                        La experiencia definitiva. Un análisis de 360 grados
                        donde alineamos tu <strong
                            >morfología, colorimetría y objetivos profesionales</strong
                        >. No es una cita de peluquería; es una sesión de
                        estrategia donde definimos tu código visual para los
                        próximos años.
                    </p>

                    <ul
                        class="space-y-4 mb-10 border-l-2 border-brand-gray pl-6"
                    >
                        <li class="flex items-start gap-3">
                            <Check
                                className="text-brand-primary w-5 h-5 shrink-0 mt-1"
                            />
                            <span class="text-slate-800"
                                ><strong>Diagnóstico MAES:</strong> Análisis biométrico
                                de rostro y cuerpo.</span
                            >
                        </li>
                        <li class="flex items-start gap-3">
                            <Check
                                className="text-brand-primary w-5 h-5 shrink-0 mt-1"
                            />
                            <span class="text-slate-800"
                                ><strong>Colorimetría Avanzada:</strong> Test de telas
                                y definición de paleta de poder.</span
                            >
                        </li>
                        <li class="flex items-start gap-3">
                            <Check
                                className="text-brand-primary w-5 h-5 shrink-0 mt-1"
                            />
                            <span class="text-slate-800"
                                ><strong>Diseño Capilar:</strong> Corte y color ejecutado
                                por Roger y Adriana.</span
                            >
                        </li>
                        <li class="flex items-start gap-3">
                            <Check
                                className="text-brand-primary w-5 h-5 shrink-0 mt-1"
                            />
                            <span class="text-slate-800"
                                ><strong>Entrega:</strong> Manual digital personalizado
                                (Dossier).</span
                            >
                        </li>
                    </ul>

                    <div class="flex flex-col sm:flex-row gap-6 items-center">
                        <a
                            href="/contacto"
                            class="bg-brand-primary text-white px-8 py-4 text-center font-bold uppercase tracking-widest hover:bg-brand-secondary transition-colors shadow-xl shadow-brand-primary/20 rounded-sm"
                        >
                            Aplicar para Consultoría
                        </a>
                        <span
                            class="text-xs text-gray-400 font-bold uppercase tracking-widest flex items-center gap-2"
                        >
                            <span
                                class="w-2 h-2 bg-green-500 rounded-full animate-pulse"
                            ></span>
                            Agenda limitada a 4 cupos/mes
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 bg-brand-gray">
        <div class="container mx-auto px-6">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h2 class="font-serif text-4xl text-brand-black mb-4">
                    Especialidades Técnicas
                </h2>
                <p class="text-slate-600 font-light text-lg">
                    Intervenciones focales para mantenimiento y corrección de
                    estilo.
                </p>
            </div>

            <div class="grid md:grid-cols-2 gap-8">
                <div
                    class="bg-white p-10 hover:shadow-2xl transition-all duration-500 group border-t-4 border-transparent hover:border-brand-primary relative overflow-hidden"
                >
                    <div
                        class="absolute top-0 right-0 p-6 opacity-5 group-hover:opacity-10 transition-opacity"
                    >
                        <ShieldCheck size={100} />
                    </div>
                    <h3
                        class="font-serif text-3xl text-brand-black mb-4 group-hover:text-brand-primary transition-colors"
                    >
                        Visagismo & Corte
                    </h3>
                    <p
                        class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-6"
                    >
                        Dirigido por Roger Murillo
                    </p>
                    <p class="text-slate-600 mb-8 leading-relaxed">
                        No cortamos por cortar. Diseñamos líneas geométricas que
                        compensan tus facciones. Incluye diagnóstico de
                        estructura ósea y análisis de perfil.
                    </p>
                    <a
                        href="/servicios/visagismo-corte"
                        class="inline-flex items-center text-brand-black font-bold border-b-2 border-brand-black/20 pb-1 hover:border-brand-primary hover:text-brand-primary transition-all uppercase text-xs tracking-widest"
                    >
                        Ver Detalles <ArrowRight className="ml-2 w-4" />
                    </a>
                </div>

                <div
                    class="bg-white p-10 hover:shadow-2xl transition-all duration-500 group border-t-4 border-transparent hover:border-brand-primary relative overflow-hidden"
                >
                    <div
                        class="absolute top-0 right-0 p-6 opacity-5 group-hover:opacity-10 transition-opacity"
                    >
                        <Star size={100} />
                    </div>
                    <h3
                        class="font-serif text-3xl text-brand-black mb-4 group-hover:text-brand-primary transition-colors"
                    >
                        Color & Salud Capilar
                    </h3>
                    <p
                        class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-6"
                    >
                        Dirigido por Adriana Garzón
                    </p>
                    <p class="text-slate-600 mb-8 leading-relaxed">
                        La química aplicada a la estética. Diseño de color
                        basado en tu paleta estacional (Invierno, Verano...)
                        priorizando la salud integral de la fibra capilar.
                    </p>
                    <a
                        href="/servicios/color-salud-capilar"
                        class="inline-flex items-center text-brand-black font-bold border-b-2 border-brand-black/20 pb-1 hover:border-brand-primary hover:text-brand-primary transition-all uppercase text-xs tracking-widest"
                    >
                        Ver Detalles <ArrowRight className="ml-2 w-4" />
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 bg-white border-t border-brand-gray">
        <div class="container mx-auto px-6">
            <div
                class="flex flex-col md:flex-row justify-between items-end mb-12"
            >
                <div>
                    <span
                        class="text-brand-primary font-bold tracking-widest uppercase text-xs mb-2 block"
                        >Autodidacta</span
                    >
                    <h2 class="font-serif text-4xl text-brand-black">
                        La Academia Digital
                    </h2>
                </div>
                <a
                    href="/academia"
                    class="hidden md:block text-slate-500 hover:text-brand-primary underline decoration-1 underline-offset-4 text-sm font-bold uppercase tracking-wide"
                    >Ver todos los recursos &rarr;</a
                >
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                <a href="/libro" class="block group h-full">
                    <div
                        class="bg-brand-gray h-64 flex items-center justify-center mb-6 overflow-hidden relative rounded-sm"
                    >
                        <div
                            class="absolute inset-0 bg-brand-black/0 group-hover:bg-brand-black/5 transition-colors z-10"
                        >
                        </div>
                        <div
                            class="w-32 h-48 bg-white shadow-xl border border-gray-200 flex items-center justify-center text-center p-2 transform group-hover:scale-105 transition-transform duration-500"
                        >
                            <span class="font-serif font-bold text-brand-black"
                                >Revoluciona<br />tu Imagen</span
                            >
                        </div>
                    </div>
                    <h3
                        class="font-serif text-xl text-brand-black mb-2 group-hover:text-brand-primary transition-colors"
                    >
                        Libro: Revoluciona tu Imagen
                    </h3>
                    <p class="text-sm text-slate-500 mb-4">
                        La guía fundamental del método MAES. Físico y Digital.
                    </p>
                    <span
                        class="text-brand-black font-bold text-sm bg-brand-gray px-3 py-1 inline-block"
                        >$19.00 USD</span
                    >
                </a>

                <a href="/academia" class="block group h-full">
                    <div
                        class="bg-brand-black h-64 flex items-center justify-center mb-6 overflow-hidden relative rounded-sm"
                    >
                        <BookOpen
                            size={48}
                            className="text-white group-hover:text-brand-primary transition-colors"
                        />
                    </div>
                    <h3
                        class="font-serif text-xl text-brand-black mb-2 group-hover:text-brand-primary transition-colors"
                    >
                        Masterclass: Colorimetría
                    </h3>
                    <p class="text-sm text-slate-500 mb-4">
                        Aprende a usar el color a tu favor en 90 minutos.
                    </p>
                    <span
                        class="text-brand-black font-bold text-sm bg-brand-gray px-3 py-1 inline-block"
                        >$47.00 USD</span
                    >
                </a>

                <a
                    href="/herramientas/test-colorimetria-online"
                    class="block group h-full"
                >
                    <div
                        class="bg-brand-primary h-64 flex items-center justify-center mb-6 overflow-hidden border border-brand-primary relative rounded-sm"
                    >
                        <Zap
                            size={48}
                            className="text-white group-hover:scale-110 transition-transform"
                        />
                    </div>
                    <h3
                        class="font-serif text-xl text-brand-black mb-2 group-hover:text-brand-primary transition-colors"
                    >
                        Test de Colorimetría IA
                    </h3>
                    <p class="text-sm text-slate-500 mb-4">
                        Herramienta de diagnóstico automático.
                    </p>
                    <span
                        class="text-brand-primary font-bold text-sm uppercase tracking-widest inline-block border-b border-brand-primary"
                        >Gratis</span
                    >
                </a>
            </div>
        </div>
    </section>

    <section class="py-24 bg-brand-black text-white">
        <div class="container mx-auto px-6 max-w-3xl">
            <h2 class="font-serif text-3xl mb-12 text-center text-white">
                Preguntas Frecuentes
            </h2>

            <div class="space-y-4">
                <details
                    class="group bg-white/5 p-6 rounded-sm cursor-pointer open:bg-white/10 transition-colors border border-white/10"
                >
                    <summary
                        class="font-bold flex justify-between items-center list-none text-lg"
                    >
                        <span>¿Por qué "A Puerta Cerrada"?</span>
                        <span
                            class="text-brand-primary transition-transform group-open:rotate-180"
                            >▼</span
                        >
                    </summary>
                    <p
                        class="text-gray-400 mt-4 text-sm leading-relaxed font-light"
                    >
                        Para garantizar tu privacidad y nuestra concentración. A
                        diferencia de un salón ruidoso, aquí trabajamos tu
                        imagen estratégica sin interrupciones. Es un espacio de
                        consultoría, no de tránsito.
                    </p>
                </details>

                <details
                    class="group bg-white/5 p-6 rounded-sm cursor-pointer open:bg-white/10 transition-colors border border-white/10"
                >
                    <summary
                        class="font-bold flex justify-between items-center list-none text-lg"
                    >
                        <span>¿Cuál es la diferencia con un corte normal?</span>
                        <span
                            class="text-brand-primary transition-transform group-open:rotate-180"
                            >▼</span
                        >
                    </summary>
                    <p
                        class="text-gray-400 mt-4 text-sm leading-relaxed font-light"
                    >
                        El corte normal sigue una tendencia de moda. El Diseño
                        de Corte Roger Murillo se basa en la antropometría de tu
                        cráneo y rostro para corregir proporciones y proyectar
                        la imagen que deseas (autoridad, cercanía, dinamismo).
                    </p>
                </details>

                <details
                    class="group bg-white/5 p-6 rounded-sm cursor-pointer open:bg-white/10 transition-colors border border-white/10"
                >
                    <summary
                        class="font-bold flex justify-between items-center list-none text-lg"
                    >
                        <span>¿Cómo puedo agendar una cita?</span>
                        <span
                            class="text-brand-primary transition-transform group-open:rotate-180"
                            >▼</span
                        >
                    </summary>
                    <p
                        class="text-gray-400 mt-4 text-sm leading-relaxed font-light"
                    >
                        Debido a la alta demanda, trabajamos exclusivamente con
                        cita previa y, para servicios de consultoría, requerimos
                        un depósito de reserva. Puedes iniciar el proceso vía
                        WhatsApp en nuestra página de contacto.
                    </p>
                </details>
            </div>
        </div>
    </section>
</MainLayout>
