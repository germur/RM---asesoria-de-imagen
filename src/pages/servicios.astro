---
import MainLayout from "@/layouts/MainLayout.astro";
import { ArrowRight } from "lucide-react";
import AnimatedTitleWords from "@/components/ui/AnimatedTitleWords.astro";

const servicesSchema = {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "Consultoría de Imagen Ejecutiva",
    provider: {
        "@type": "ProfessionalService",
        name: "Roger Murillo & Adriana Garzón",
        priceRange: "$$$",
        image: "https://rogermurillo.co/images/service-consulting.jpg",
    },
    areaServed: { "@type": "City", name: "Bogotá" },
    hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Servicios de Imagen Estratégica",
        itemListElement: [
            { "@type": "Offer", itemOffered: { "@type": "Service", name: "Consultoría Integral A Puerta Cerrada" } },
            { "@type": "Offer", itemOffered: { "@type": "Service", name: "Diseño de Color y Salud Capilar" } },
            { "@type": "Offer", itemOffered: { "@type": "Service", name: "Peluquería & Corte con Tijera" } },
        ],
    },
};
---

<MainLayout
    title="Consultoría de Imagen · Visagismo · Colorimetría · Peluquería en Bogotá | Roger Murillo"
    description="Consultoría de imagen integral, visagismo profesional, colorimetría avanzada y peluquería de autor en Bogotá. Servicio exclusivo a puerta cerrada para directivos, líderes y figuras públicas."
    schema={servicesSchema}
>
    <!-- HERO -->
    <section class="pt-40 pb-32 md:pt-48 md:pb-40 bg-brand-black text-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="flex items-center gap-4 mb-8">
                <span class="w-8 h-px bg-brand-primary"></span>
                <p class="text-xs tracking-[0.3em] uppercase text-neutral-500">Servicios</p>
            </div>
            <div class="max-w-4xl">
                <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl leading-[0.95] mb-10">
                    <AnimatedTitleWords text="No vendemos cortes." class="block text-white" />
                    <AnimatedTitleWords text="Diseñamos reputación." class="block text-neutral-400" delay={400} />
                </h1>
                <p class="text-lg md:text-xl text-neutral-300 font-light max-w-2xl leading-relaxed">
                    Elige el nivel de intervención que tu momento necesita hoy.
                    Para ejecutivos, para personas en transición y para quienes
                    simplemente quieren vestirse mejor.
                </p>
            </div>
        </div>
    </section>

    <!-- SIGNATURE SERVICE -->
    <section class="py-32 md:py-40 bg-brand-black text-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="grid md:grid-cols-12 gap-16 md:gap-24 items-center">
                <div class="md:col-span-7">
                    <p class="text-xs tracking-[0.3em] uppercase text-neutral-500 mb-6">Signature Service</p>
                    <h2 class="font-serif text-4xl md:text-6xl leading-[1.05] mb-8">
                        Consultoría Integral<br />
                        <span class="text-neutral-400">"A Puerta Cerrada"</span>
                    </h2>
                    <p class="text-lg text-neutral-300 leading-relaxed mb-10 font-light max-w-xl">
                        Un análisis de 360 grados donde alineamos tu morfología,
                        colorimetría y objetivos de vida. No es una cita de
                        peluquería; es una sesión de estrategia donde definimos
                        tu código visual para los próximos años.
                    </p>

                    <div class="space-y-4 mb-12 border-l border-neutral-700 pl-8">
                        <p class="text-sm text-neutral-300">Diagnóstico biométrico: rostro, colorimetría y morfología.</p>
                        <p class="text-sm text-neutral-300">Colorimetría avanzada: test de telas y paleta de poder.</p>
                        <p class="text-sm text-neutral-300">Diseño capilar ejecutado por Roger y Adriana.</p>
                        <p class="text-sm text-neutral-300">Entrega: dossier digital personalizado.</p>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-5 items-start">
                        <a
                            href="/servicios/asesoria-integral-imagen"
                            class="bg-brand-primary text-white px-10 py-4 text-xs font-medium uppercase tracking-[0.2em] hover:bg-white hover:text-brand-black transition-colors duration-500"
                        >
                            Ver Consultoría Completa
                        </a>
                        <span class="text-xs text-neutral-500 tracking-[0.15em] uppercase mt-3">
                            Agenda limitada &mdash; 4 cupos/mes
                        </span>
                    </div>
                </div>

                <div class="md:col-span-5">
                    <img
                        src="/images/roger-portrait-bw.jpg"
                        alt="Sesión de consultoría"
                        class="w-full grayscale"
                    />
                </div>
            </div>
        </div>
    </section>

    <!-- SPECIALTIES — 4 cards incluyendo Peluquería -->
    <section class="py-32 md:py-40 bg-white">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="max-w-xl mb-20">
                <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Especialidades</p>
                <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black">
                    Intervenciones focales.
                </h2>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-px bg-neutral-200">
                <a href="/servicios/visagismo-corte" class="group bg-white p-10 md:p-12 flex flex-col justify-between min-h-[320px]">
                    <div>
                        <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Roger Murillo</p>
                        <h3 class="font-serif text-2xl md:text-3xl text-brand-black mb-5 group-hover:text-brand-primary transition-colors duration-500">
                            Visagismo & Corte
                        </h3>
                        <p class="text-sm text-neutral-500 leading-relaxed">
                            Líneas geométricas que compensan tus facciones.
                            Diagnóstico de estructura ósea y análisis de perfil.
                        </p>
                    </div>
                    <span class="inline-flex items-center gap-3 text-xs tracking-[0.2em] uppercase text-brand-black group-hover:text-brand-primary transition-colors duration-500 mt-8">
                        Ver Detalles <ArrowRight size={14} />
                    </span>
                </a>

                <a href="/servicios/color-salud-capilar" class="group bg-white p-10 md:p-12 flex flex-col justify-between min-h-[320px]">
                    <div>
                        <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Adriana Garzón</p>
                        <h3 class="font-serif text-2xl md:text-3xl text-brand-black mb-5 group-hover:text-brand-primary transition-colors duration-500">
                            Color & Salud Capilar
                        </h3>
                        <p class="text-sm text-neutral-500 leading-relaxed">
                            Diseño de color basado en tu paleta estacional,
                            priorizando la salud integral de la fibra capilar.
                        </p>
                    </div>
                    <span class="inline-flex items-center gap-3 text-xs tracking-[0.2em] uppercase text-brand-black group-hover:text-brand-primary transition-colors duration-500 mt-8">
                        Ver Detalles <ArrowRight size={14} />
                    </span>
                </a>

                <a href="/servicios/peluqueria" class="group bg-white p-10 md:p-12 flex flex-col justify-between min-h-[320px]">
                    <div>
                        <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Roger & Adriana</p>
                        <h3 class="font-serif text-2xl md:text-3xl text-brand-black mb-5 group-hover:text-brand-primary transition-colors duration-500">
                            Peluquería
                        </h3>
                        <p class="text-sm text-neutral-500 leading-relaxed">
                            Corte con tijera como servicio estrella. Tintura,
                            recuperación capilar y colorimetría para hombre y mujer.
                        </p>
                    </div>
                    <span class="inline-flex items-center gap-3 text-xs tracking-[0.2em] uppercase text-brand-black group-hover:text-brand-primary transition-colors duration-500 mt-8">
                        Ver Detalles <ArrowRight size={14} />
                    </span>
                </a>

                <a href="/servicios/imagen-ejecutiva-autoridad" class="group bg-white p-10 md:p-12 flex flex-col justify-between min-h-[320px]">
                    <div>
                        <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Roger & Adriana</p>
                        <h3 class="font-serif text-2xl md:text-3xl text-brand-black mb-5 group-hover:text-brand-primary transition-colors duration-500">
                            Imagen Ejecutiva
                        </h3>
                        <p class="text-sm text-neutral-500 leading-relaxed">
                            Protocolo visual para liderazgo. Proyecta autoridad
                            antes de abrir la boca.
                        </p>
                    </div>
                    <span class="inline-flex items-center gap-3 text-xs tracking-[0.2em] uppercase text-brand-black group-hover:text-brand-primary transition-colors duration-500 mt-8">
                        Ver Detalles <ArrowRight size={14} />
                    </span>
                </a>
            </div>
        </div>
    </section>

    <!-- ACADEMIA + RESOURCES -->
    <section class="py-32 md:py-40 bg-neutral-50">
        <div class="container mx-auto px-6 max-w-6xl">
            <div class="grid md:grid-cols-12 gap-16 md:gap-24 items-start">
                <div class="md:col-span-5">
                    <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Formación</p>
                    <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] text-brand-black mb-8">
                        La Academia Digital
                    </h2>
                    <p class="text-lg text-neutral-500 leading-relaxed font-light mb-10">
                        Cursos, guías y masterclasses para entender las reglas
                        del color, el corte y el estilo. Desde $25 USD.
                    </p>
                    <a
                        href="/academia"
                        class="inline-flex items-center gap-3 text-xs tracking-[0.2em] uppercase text-brand-black hover:text-brand-primary transition-colors duration-500"
                    >
                        Ver Catálogo <ArrowRight size={14} />
                    </a>
                </div>

                <div class="md:col-span-7 space-y-6">
                    <a href="/libro" class="group flex gap-6 items-center p-6 bg-white hover:bg-brand-black transition-colors duration-500">
                        <div class="w-20 h-20 bg-neutral-100 group-hover:bg-neutral-800 flex items-center justify-center shrink-0 transition-colors duration-500">
                            <span class="font-serif text-sm text-brand-black group-hover:text-white transition-colors duration-500">Libro</span>
                        </div>
                        <div>
                            <h3 class="font-serif text-xl text-brand-black group-hover:text-white transition-colors duration-500 mb-1">Revoluciona tu Imagen</h3>
                            <p class="text-sm text-neutral-500 group-hover:text-neutral-400 transition-colors duration-500">La guía definitiva de imagen estratégica.</p>
                        </div>
                    </a>

                    <a href="/herramientas/test-colorimetria-online" class="group flex gap-6 items-center p-6 bg-white hover:bg-brand-black transition-colors duration-500">
                        <div class="w-20 h-20 bg-brand-primary flex items-center justify-center shrink-0">
                            <span class="font-serif text-sm text-white">Test</span>
                        </div>
                        <div>
                            <h3 class="font-serif text-xl text-brand-black group-hover:text-white transition-colors duration-500 mb-1">Test de Colorimetría</h3>
                            <p class="text-sm text-neutral-500 group-hover:text-neutral-400 transition-colors duration-500">Diagnóstico automático con IA. Gratis.</p>
                        </div>
                    </a>

                    <a href="/herramientas" class="group flex gap-6 items-center p-6 bg-white hover:bg-brand-black transition-colors duration-500">
                        <div class="w-20 h-20 bg-neutral-100 group-hover:bg-neutral-800 flex items-center justify-center shrink-0 transition-colors duration-500">
                            <span class="font-serif text-sm text-brand-black group-hover:text-white transition-colors duration-500">Tools</span>
                        </div>
                        <div>
                            <h3 class="font-serif text-xl text-brand-black group-hover:text-white transition-colors duration-500 mb-1">Herramientas Gratuitas</h3>
                            <p class="text-sm text-neutral-500 group-hover:text-neutral-400 transition-colors duration-500">Calculadoras de rostro, cuerpo y más.</p>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="py-32 md:py-40 bg-white">
        <div class="container mx-auto px-6 max-w-3xl">
            <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6 text-center">FAQ</p>
            <h2 class="font-serif text-4xl text-brand-black mb-16 text-center">Preguntas Frecuentes</h2>

            <div class="space-y-0 divide-y divide-neutral-100">
                {[
                    {
                        q: "¿Por qué \"A Puerta Cerrada\"?",
                        a: "Porque priorizamos la intimidad. Tu imagen es un proceso personal que requiere confianza y confort. A diferencia de un salón ruidoso, aquí trabajamos tu imagen estratégica sin interrupciones, en un espacio de consultoría, no de tránsito."
                    },
                    {
                        q: "¿Cuál es la diferencia con un corte normal?",
                        a: "El corte normal sigue una tendencia de moda. El Diseño de Corte Roger Murillo se basa en la antropometría de tu cráneo y rostro para corregir proporciones y proyectar la imagen que deseas."
                    },
                    {
                        q: "¿Cómo puedo agendar una cita?",
                        a: "Trabajamos exclusivamente con cita previa y, para servicios de consultoría, requerimos un depósito de reserva. Puedes iniciar el proceso vía WhatsApp en nuestra página de contacto."
                    },
                ].map(faq => (
                    <details class="group py-6 cursor-pointer">
                        <summary class="flex justify-between items-center list-none text-lg text-brand-black">
                            <span>{faq.q}</span>
                            <span class="text-neutral-300 group-open:rotate-45 transition-transform text-2xl leading-none">+</span>
                        </summary>
                        <p class="text-neutral-500 mt-4 text-sm leading-relaxed font-light max-w-2xl">
                            {faq.a}
                        </p>
                    </details>
                ))}
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-32 md:py-40 bg-brand-black text-white text-center">
        <div class="container mx-auto px-6 max-w-3xl">
            <h2 class="font-serif text-4xl md:text-6xl leading-[1.05] mb-8">
                ¿Listo para el cambio?
            </h2>
            <p class="text-lg text-neutral-300 font-light mb-14 max-w-lg mx-auto leading-relaxed">
                Agenda tu consultoría o empieza con nuestras herramientas gratuitas.
            </p>
            <div class="flex flex-col sm:flex-row gap-5 justify-center">
                <a
                    href="/contacto"
                    class="bg-brand-primary text-white px-12 py-4 text-xs font-medium uppercase tracking-[0.2em] hover:bg-white hover:text-brand-black transition-colors duration-500"
                >
                    Agendar Consultoría
                </a>
                <a
                    href="/servicios/precios"
                    class="px-12 py-4 text-xs font-medium uppercase tracking-[0.2em] text-white border border-white/20 hover:border-white transition-colors duration-500"
                >
                    Ver Inversión
                </a>
            </div>
        </div>
    </section>
</MainLayout>
